
<% 
  // Helper to safely format numbers
  const fmtNum = (num) => (typeof num === 'number' ? num.toFixed(2) : '0.00');
  
  // Determine primary status for the invoice
  let primaryStatus = order.status;
  let statusColor = 'bg-stone-100 text-stone-500';
  let statusBadge = 'PENDING';
  
  if (order.status === 'Delivered') {
    statusColor = 'bg-green-50 text-green-600';
    statusBadge = 'PAID';
  } else if (order.status === 'Cancelled') {
    statusColor = 'bg-red-50 text-red-600';
    statusBadge = 'CANCELLED';
  } else if (returns && returns.length > 0) {
    statusColor = 'bg-orange-50 text-orange-600';
    statusBadge = 'RETURNED';
  }
%>

<div id="invoice-template" class="w-[210mm] bg-white p-8 text-[#111827] font-sans">
    <!-- Header Section -->
    <div class="flex justify-between items-start border-b-2 border-stone-100 pb-6 mb-6">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 bg-brand-dark flex items-center justify-center text-white rounded-lg font-black text-lg">A</div>
          <h1 class="text-2xl font-black uppercase tracking-tighter">AJAX</h1>
        </div>
        <div class="space-y-1">
          <p class="text-[0.6rem] font-black text-stone-400 uppercase tracking-widest">
            Tax Invoice / Bill of Supply
          </p>
        </div>
      </div>
      <div class="text-right">
        <h2 class="text-4xl font-serif italic text-stone-100 mb-4 select-none">Invoice</h2>
        <div class="flex gap-6 justify-end items-start text-right">
          <div>
            <p class="text-[0.55rem] font-black text-stone-300 uppercase tracking-widest mb-0.5">Invoice No.</p>
            <p class="text-xs font-bold tracking-tight">#INV-<%= order._id.toString().slice(-8).toUpperCase() %></p>
          </div>
          <div>
            <p class="text-[0.55rem] font-black text-stone-300 uppercase tracking-widest mb-0.5">Issue Date</p>
            <p class="text-xs font-bold tracking-tight"><%= new Date().toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' }) %></p>
          </div>
          <div class="px-3 py-1 rounded-full <%= statusColor %> text-[0.55rem] font-black uppercase tracking-[0.2em]">
            <%= statusBadge %>
          </div>
        </div>
      </div>
    </div>

    <!-- Info Grid -->
    <div class="grid grid-cols-2 gap-12 mb-10">
      <div class="space-y-6">
        <div>
          <h3 class="text-[0.55rem] font-black text-stone-300 uppercase tracking-[0.2em] mb-3">Billing & Shipping</h3>
          <p class="text-base font-bold mb-1"><%= order.address.name %></p>
          <p class="text-[0.7rem] text-stone-500 leading-relaxed font-medium">
            <%= order.address.street %>, <%= order.address.area %><br>
            <%= order.address.city %>, <%= order.address.state %><br>
            <%= order.address.pincode %> | <span class="text-stone-300">T:</span> <%= order.address.phone %>
          </p>
        </div>
      </div>

      <div class="space-y-6">
        <h3 class="text-[0.55rem] font-black text-stone-300 uppercase tracking-[0.2em] mb-3">Transaction Details</h3>
        <div class="grid grid-cols-2 gap-y-4 gap-x-8">
          <div>
            <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-widest mb-0.5">Order ID</p>
            <p class="text-[0.65rem] font-bold tracking-tight">#<%= order._id.toString().slice(-10).toUpperCase() %></p>
          </div>
          <div>
            <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-widest mb-0.5">Payment</p>
            <p class="text-[0.65rem] font-bold uppercase tracking-widest"><%= order.paymentMethod %></p>
          </div>
          <div>
            <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-widest mb-0.5">Order Date</p>
            <p class="text-[0.65rem] font-bold tracking-tight"><%= new Date(order.createdAt).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
          </div>
          <div>
            <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-widest mb-0.5">Shipment</p>
            <p class="text-[0.65rem] font-bold uppercase tracking-widest">Standard</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Table -->
    <div class="mb-10">
      <table class="w-full">
        <thead>
          <tr class="border-b-2 border-stone-100">
            <th class="py-6 text-left text-[0.65rem] font-black text-stone-300 uppercase tracking-widest">Description</th>
            <th class="py-6 text-center text-[0.65rem] font-black text-stone-300 uppercase tracking-widest">Quantity</th>
            <th class="py-6 text-right text-[0.65rem] font-black text-stone-300 uppercase tracking-widest">Unit Price</th>
            <th class="py-6 text-right text-[0.65rem] font-black text-stone-300 uppercase tracking-widest">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-50 text-xs">
          <% order.items.forEach(item => { %>
            <tr class="group">
              <td class="py-4">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-14 bg-stone-50 rounded-lg overflow-hidden flex-shrink-0 border border-stone-100">
                    <img src="<%= item.image %>" class="w-full h-full object-cover">
                  </div>
                  <div>
                    <p class="font-bold text-stone-800 leading-tight"><%= item.name %></p>
                    <p class="text-[0.6rem] font-bold text-stone-300 uppercase tracking-widest">SZ: <%= item.size %> | <%= item.status %></p>
                  </div>
                </div>
              </td>
              <td class="py-4 text-center font-bold text-stone-400"><%= item.quantity %></td>
              <td class="py-4 text-right font-bold text-stone-400">₹<%= fmtNum(item.price) %></td>
              <td class="py-4 text-right font-bold text-stone-800">₹<%= fmtNum(item.price * item.quantity) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Summary & Totals -->
    <div class="flex justify-between items-start gap-20">
      <div class="flex-grow max-w-sm">
        <h4 class="text-[0.6rem] font-black text-stone-300 uppercase tracking-widest mb-6 border-b border-stone-50 pb-2 inline-block">Order Timeline</h4>
        <div class="space-y-6 relative pl-6">
          <div class="absolute left-[3.5px] top-1 bottom-1 w-[1px] bg-stone-100"></div>
          <% order.statusHistory.slice(-4).forEach(h => { %>
            <div class="relative flex flex-col gap-1">
              <div class="absolute -left-[26px] top-1.5 w-2 h-2 bg-stone-200 rounded-full border-2 border-white shadow-sm"></div>
              <p class="text-[0.6rem] font-black uppercase tracking-widest leading-none"><%= h.status %></p>
              <p class="text-[0.5rem] font-bold text-stone-400 leading-none"><%= new Date(h.updatedAt).toLocaleDateString('en-US', { day: '2-digit', month: 'short' }) %></p>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="w-72 space-y-5 pt-4">
        <div class="flex justify-between items-center text-xs">
          <span class="font-bold text-stone-300 uppercase tracking-widest">Subtotal</span>
          <span class="font-bold text-stone-600">₹<%= fmtNum(subtotal) %></span>
        </div>
        <div class="flex justify-between items-center text-xs">
          <span class="font-bold text-stone-300 uppercase tracking-widest">Shipping Fee</span>
          <span class="font-bold <%= shipping === 0 ? 'text-green-500' : 'text-stone-600' %>">
            <%= shipping === 0 ? 'FREE' : '₹' + fmtNum(shipping) %>
          </span>
        </div>
        
        <% 
          let refundedTotal = 0;
          if (typeof returns !== 'undefined' && returns) {
            refundedTotal = returns.reduce((sum, r) => sum + (r.refundAmount || 0), 0);
          }
        %>
        
        <% if (refundedTotal > 0) { %>
          <div class="flex justify-between items-center text-xs p-4 bg-orange-50/50 rounded-xl border border-orange-100/50">
            <div class="flex items-center gap-2">
              <span class="w-1 h-1 bg-orange-400 rounded-full"></span>
              <span class="font-bold text-orange-600 uppercase tracking-widest">Refunded</span>
            </div>
            <span class="font-bold text-orange-600">- ₹<%= fmtNum(refundedTotal) %></span>
          </div>
        <% } %>

        <div class="pt-4 border-t-2 border-stone-100 flex justify-between items-end">
          <div>
            <p class="text-[0.6rem] font-black uppercase tracking-[0.2em] mb-1">Total Settlement</p>
            <p class="text-[0.45rem] text-stone-300 italic font-medium leading-tight">Price includes GST and relevant taxes</p>
          </div>
          <div class="flex items-baseline gap-1">
            <span class="text-3xl font-serif tracking-tighter text-stone-800">₹<%= fmtNum(finalTotal - refundedTotal) %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer Area -->
    <div class="mt-16 pt-8 border-t border-stone-100 flex justify-between items-end">
      <div class="max-w-md">
        <h4 class="text-[0.55rem] font-black text-stone-400 uppercase tracking-widest mb-4">Important Information</h4>
        <div class="space-y-2 text-[0.55rem] text-stone-300 font-bold uppercase tracking-tighter leading-relaxed">
          <p>1. This invoice is digitally generated and validated. No physical signature is required.</p>
          <p>2. Returns must be initiated within 7 days of delivery.</p>
          <p>3. For billing inquiries, email accounts@ajax.com</p>
        </div>
      </div>
      <div class="text-right">
        <div class="w-40 h-px bg-stone-100 ml-auto mb-2"></div>
        <p class="editorial-title text-xl italic text-stone-200 mb-1 leading-none text-brand-dark not-italic font-bold">AJAX Official</p>
        <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-[0.3em]">Authorized Signatory</p>
      </div>
    </div>
    
    <div class="mt-12 text-center">
      <p class="text-[0.55rem] font-black text-stone-100 uppercase tracking-[0.4em] select-none">Luxury Essentials — Est. 2024</p>
    </div>
</div>
