<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AJAX — Shopping Bag</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Outfit:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Playfair Display', 'serif'],
                        sans: ['Outfit', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <%- include('../partials/navbar-styles') %>
    <style>
        :root {
            --bg-white: #ffffff;
            --dark: #1C1C1C;
            --stone: #7A7A7A;
            --bdr: #EAE5DC;
        }

        body {
            background-color: var(--bg-white);
            color: var(--dark);
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .editorial-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 6vw, 3.5rem);
            font-weight: 500;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .editorial-subtitle {
            font-size: 0.65rem;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            font-weight: 500;
            color: var(--stone);
        }

        /* Item Card Styling */
        .bag-card {
            background: #fff;
            border: 1px solid var(--bdr);
            border-radius: 1.5rem;
            padding: 1.5rem;
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
        }
        .bag-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.03);
        }

        .qty-stepper {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .qty-btn {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 14px;
            transition: background 0.3s;
            color: var(--stone);
        }
        .qty-btn:hover { color: var(--text-main); background: #f0f0f0; }

        /* Summary Sidebar */
        .summary-card {
            background: #fff;
            border-radius: 2rem;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(61, 46, 36, 0.08);
        }
        .summary-header {
            background: var(--dark);
            color: #fff;
            padding: 2rem;
        }
        .btn-checkout {
            background: var(--text-main);
            color: #fff;
            width: 100%;
            padding: 1.25rem;
            border-radius: 0.75rem;
            text-transform: uppercase;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.15em;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
        }
        .btn-checkout:hover {
            opacity: 0.9;
            transform: scale(1.02);
        }

        /* Animations */
        .item-exit {
            opacity: 0 !important;
            transform: translateX(30px) scale(0.9) !important;
            max-height: 0 !important;
            padding: 0 !important;
            margin: 0 !important;
            overflow: hidden !important;
            pointer-events: none;
        }

        .fade-in {
            animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
    <%- include('../partials/footer-styles') %>
</head>
<body>

    <%- include('../partials/navbar') %>

    <main class="max-w-[1440px] mx-auto px-6 md:px-12 pt-16 pb-24">
        
        <!-- Breadcrumbs -->
        <%- include('../partials/breadcrumbs', { 
            breadcrumbs: [
                { name: "Shop", url: "/menProductList" },
                { name: "Your Bag" }
            ] 
        }) %>

        <!-- Header -->
        <div class="text-center mb-24 fade-in">
            <h1 class="editorial-title mb-4">SHOPPING BAG</h1>
            <p class="editorial-subtitle">YOUR CURATED SELECTION FOR RADIANT SKIN</p>
        </div>

        <div class="flex flex-col lg:flex-row gap-12 items-start fade-in" style="animation-delay: 0.1s;">
            
            <!-- Items Column -->
            <div class="flex-grow space-y-6">
                <div class="mb-6">
                    <p class="text-[0.6rem] tracking-[0.2em] font-black uppercase text-stone-400">REVIEW & ADJUST</p>
                    <h2 class="text-2xl font-medium tracking-tight mt-1">Your Items</h2>
                </div>

                <% 
                  // Mock data check (replace with real items if passed from backend)
                  const bagItems = typeof cart !== 'undefined' ? cart.items : [];
                %>

                <% if (bagItems.length > 0) { %>
                    <div class="items-container space-y-6">
                    <% bagItems.forEach(item => { %>
                        <div class="bag-card group flex flex-col sm:flex-row gap-8 transition-all duration-500 ease-in-out" 
                             data-id="<%= item._id %>" 
                             data-price="<%= item.variant.price %>">
                            
                            <!-- Image Container -->
                            <div class="w-full sm:w-40 aspect-square bg-[#fff] rounded-xl overflow-hidden flex-shrink-0">
                                <img src="<%= item.variant.images[0] %>" alt="<%= item.variant.productId.name %>" class="w-full h-full object-cover">
                            </div>

                            <!-- Content -->
                            <div class="flex-grow flex flex-col justify-between py-2">
                                <div class="flex justify-between items-start gap-4">
                                    <div>
                                        <h3 class="text-lg font-medium tracking-tight mb-1"><%= item.variant.productId.name %></h3>
                                        <p class="text-[0.65rem] tracking-[0.1em] font-bold text-stone-400 uppercase"><%= item.variant.size %></p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-lg font-medium item-price" data-raw-price="<%= item.variant.price %>">₹<%= item.variant.price %></p>
                                        <% if (item.variant.oldPrice) { %>
                                            <p class="text-[0.6rem] text-stone-400 line-through">₹<%= item.variant.oldPrice %></p>
                                            <p class="text-[0.6rem] text-green-600 font-bold uppercase mt-1">
                                                <%= Math.round((1 - item.variant.price/item.variant.oldPrice) * 100) %>% OFF
                                            </p>
                                        <% } %>
                                    </div>
                                </div>

                                <div class="flex justify-between items-center mt-6">
                                    <!-- Stepper -->
                                    <div class="qty-stepper bg-[#F9F9F7] px-3 py-2 rounded-full">
                                        <button class="qty-btn" onclick="updateQty('<%= item._id %>', -1)">-</button>
                                        <span class="qty-val text-sm font-bold w-6 text-center"><%= item.quantity %></span>
                                        <button class="qty-btn" onclick="updateQty('<%= item._id %>', 1)">+</button>
                                    </div>

                                    <!-- Actions -->
                                    <button onclick="removeItem('<%= item._id %>')" 
                                            class="flex items-center gap-2 text-[0.6rem] font-black tracking-[0.2em] text-stone-400 hover:text-red-500 transition-colors uppercase">
                                        <i data-lucide="trash-2" size="14"></i>
                                        REMOVE
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                    </div>
                <% } else { %>
                    <!-- Empty State -->
                    <div class="empty-state-container bg-white rounded-[2rem] p-20 text-center border border-stone-100">
                        <div class="w-20 h-20 bg-[var(--bg-beige)] rounded-full flex items-center justify-center mx-auto mb-6">
                            <i data-lucide="shopping-bag" size="32" class="text-stone-400"></i>
                        </div>
                        <h3 class="text-xl font-medium mb-4">Your bag is empty</h3>
                        <p class="text-stone-400 text-sm mb-10 max-w-xs mx-auto">Your curated selection for radiant skin is currently waiting for you.</p>
                        <a href="/menProductList" class="btn-checkout inline-flex w-auto px-10">
                            START SHOPPING
                        </a>
                    </div>
                <% } %>

                <div class="pt-10">
                    <a href="/menProductList" class="text-[0.65rem] tracking-[0.2em] font-black uppercase flex items-center gap-2 group">
                        <i data-lucide="arrow-left" size="14" class="group-hover:-translate-x-1 transition-transform"></i>
                        Continue Shopping
                    </a>
                </div>
            </div>

            <!-- Summary Column -->
            <% if (bagItems.length > 0) { %>
            <div class="w-full lg:w-[420px] shrink-0 sticky top-32">
                <div class="summary-card">
                    <div class="summary-header">
                        <h2 class="text-2xl font-serif italic mb-1">Order Summary</h2>
                        <p class="text-[0.55rem] tracking-[0.2em] font-bold uppercase opacity-60">YOUR SELECTION AT A GLANCE</p>
                    </div>
                    
                    <div class="p-8 md:p-10 bg-white">
                        <div class="space-y-6 mb-12">
                            <div class="flex justify-between items-center text-[0.8rem]">
                                <span class="text-stone-400 font-medium">Subtotal</span>
                                <span class="font-bold subtotal-display">₹<%= typeof cart !== 'undefined' ? cart.totalPrice : 0 %></span>
                            </div>
                            <div class="flex justify-between items-center text-[0.8rem]">
                                <span class="text-green-600 font-medium">Offer Savings</span>
                                <span class="font-bold text-green-600">- ₹0.00</span>
                            </div>
                            <div class="flex justify-between items-center text-[0.8rem]">
                                <div class="flex items-center gap-1">
                                    <span class="text-stone-400 font-medium">Shipping</span>
                                    <i data-lucide="help-circle" size="12" class="text-stone-300"></i>
                                </div>
                                <span class="text-stone-400 font-medium uppercase text-[0.65rem]">TBD at checkout</span>
                            </div>
                        </div>

                        <div class="pt-8 border-t border-stone-100 mb-12 flex justify-between items-end">
                            <div>
                                <p class="text-[0.7rem] font-black uppercase tracking-wider mb-1">TOTAL</p>
                                <p class="text-[0.6rem] text-stone-300 font-medium uppercase">INR</p>
                            </div>
                            <div class="text-right">
                                <p class="text-4xl font-medium tracking-tighter total-display">₹<%= typeof cart !== 'undefined' ? cart.totalPrice : 0 %></p>
                            </div>
                        </div>

                        <button class="btn-checkout mb-8">
                            <i data-lucide="lock" size="14"></i>
                            PROCEED TO CHECKOUT ➔
                        </button>

                        <div class="text-center mb-10">
                            <p class="text-[0.55rem] font-black tracking-[0.2em] text-stone-300 uppercase flex items-center justify-center gap-2">
                                <span class="w-4 h-[1px] bg-stone-100"></span>
                                <%= bagItems.length %> ITEMS IN YOUR BAG
                                <span class="w-4 h-[1px] bg-stone-100"></span>
                            </p>
                        </div>

                        <!-- Trust Badges -->
                        <div class="grid grid-cols-3 gap-4 pt-8 border-t border-stone-50">
                            <div class="text-center">
                                <i data-lucide="shield" size="18" class="mx-auto text-stone-300 mb-2"></i>
                                <p class="text-[0.55rem] font-bold text-stone-400 uppercase tracking-widest">SECURE</p>
                            </div>
                            <div class="text-center">
                                <i data-lucide="truck" size="18" class="mx-auto text-stone-300 mb-2"></i>
                                <p class="text-[0.55rem] font-bold text-stone-400 uppercase tracking-widest">DELIVERY</p>
                            </div>
                            <div class="text-center">
                                <i data-lucide="award" size="18" class="mx-auto text-stone-300 mb-2"></i>
                                <p class="text-[0.55rem] font-bold text-stone-400 uppercase tracking-widest">PURE</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        lucide.createIcons();

        // 🧮 Robust Calculation Engine
        function recalculate() {
            let subtotal = 0;
            const items = document.querySelectorAll('.bag-card:not(.item-exit)');
            
            // If we just removed the last item, reload to show empty state
            if (items.length === 0) {
                // Check if we are ALREADY showing the empty state container
                const emptyState = document.querySelector('.empty-state-container');
                if (!emptyState) {
                    window.location.reload();
                }
                return;
            }

            items.forEach(card => {
                const price = parseFloat(card.dataset.price) || 0;
                const qtyVal = card.querySelector('.qty-val');
                if (qtyVal) {
                    const qty = parseInt(qtyVal.innerText) || 0;
                    subtotal += price * qty;
                }
            });

            const subtotalDisplays = document.querySelectorAll('.subtotal-display');
            const totalDisplays = document.querySelectorAll('.total-display');

            subtotalDisplays.forEach(el => el.innerText = `₹${subtotal.toFixed(2)}`);
            totalDisplays.forEach(el => el.innerText = `₹${subtotal.toFixed(2)}`);

            // If bag is empty after removal, we might want to reload to show empty state
            if (items.length === 0) {
                window.location.reload();
            }
        }

        // 🔄 Update Quantity
        async function updateQty(itemId, delta) {
            const card = document.querySelector(`.bag-card[data-id="${itemId}"]`);
            if (!card) return;

            const qtyEl = card.querySelector('.qty-val');
            const currentQty = parseInt(qtyEl.innerText);
            const newQty = currentQty + delta;

            if (newQty < 1) return;
            if (newQty > 5) {
                return ajaxToast("error", "Maximum 5 items allowed");
            }

            try {
                //Optimistically update UI
                qtyEl.innerText = newQty;
                recalculate();

                const res = await axios.post('/cart/update', { itemId, delta });
                
                if (!res.data.success) {
                    // Revert if failed
                    qtyEl.innerText = currentQty;
                    recalculate();
                    ajaxToast("error", res.data.message);
                }
            } catch (err) {
                console.log(err);
                qtyEl.innerText = currentQty;
                recalculate();
            }
        }

        // 🗑️ Remove Item
        async function removeItem(itemId) {
            const card = document.querySelector(`.bag-card[data-id="${itemId}"]`);
            if (!card) return;

            try {
                const res = await axios.post('/cart/remove', { itemId });

                if (res.data.success) {
                    // Disappearing Animation
                    card.classList.add('item-exit');
                    
                    setTimeout(() => {
                        card.remove();
                        recalculate();
                        ajaxToast("success", "Item removed from bag");
                    }, 500);
                } else {
                    ajaxToast("error", res.data.message);
                }
            } catch (err) {
                console.log(err);
            }
        }

        // Initial check on load
        window.addEventListener('load', recalculate);

    </script>
</body>
</html>
