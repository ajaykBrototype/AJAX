<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AJAX — The Bag</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@200;300;400;500;700;900&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Playfair Display', 'serif'],
                        sans: ['DM Sans', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <%- include('../partials/navbar-styles') %>
    <style>
        :root {
            --dark: #1C1C1C;
            --stone: #7A7A7A;
            --cream: #F9F9F7;
            --bdr: #EAE5DC;
        }

        body {
            background-color: #fff;
            color: var(--dark);
            font-family: 'DM Sans', sans-serif;
            -webkit-font-smoothing: antialiased;
        }

        .editorial-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 6vw, 4rem);
            font-weight: 400;
            letter-spacing: -0.02em;
            line-height: 1.1;
        }

        .bag-item {
            border-bottom: 1px solid var(--bdr);
            padding: 2rem 0;
            transition: all 0.4s ease;
        }

        .bag-item:first-child {
            border-top: 1px solid var(--bdr);
        }

        .qty-stepper {
            display: flex;
            align-items: center;
            border: 1px solid var(--bdr);
            width: fit-content;
        }

        .qty-btn {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: background 0.3s;
        }

        .qty-btn:hover { background: var(--cream); }

        .qty-val {
            width: 40px;
            text-align: center;
            font-size: 12px;
            font-weight: 700;
        }

        .sticky-summary {
            position: sticky;
            top: 120px;
        }

        .btn-checkout {
            background: var(--dark);
            color: #fff;
            width: 100%;
            padding: 1.25rem;
            text-transform: uppercase;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0.2em;
            transition: all 0.3s;
        }

        .btn-checkout:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

        .remove-link {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            text-decoration: underline;
            color: var(--stone);
            transition: color 0.3s;
        }

        .remove-link:hover { color: var(--dark); }

        /* Animations */
        .fade-in {
            animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
    <%- include('../partials/footer-styles') %>
</head>
<body>

    <%- include('../partials/navbar') %>

    <main class="max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-24">
        
        <%- include('../partials/breadcrumbs', { 
            breadcrumbs: [
                { name: "Your Bag" }
            ] 
        }) %>

        <div class="mt-8 mb-16 fade-in">
            <h1 class="editorial-title">THE BAG</h1>
            <p class="text-[0.65rem] tracking-[0.2em] font-bold text-stone-400 mt-4 uppercase">
                <%= typeof cart !== 'undefined' ? cart.items.length : 1 %> ITEM(S) IN YOUR SELECTION
            </p>
        </div>

        <div class="flex flex-col lg:flex-row gap-16 fade-in" style="animation-delay: 0.1s;">
            <!-- Bag Items List -->
            <div class="flex-grow">
                <% 
                  // Mock data for demonstration
                  const displayItems = typeof cart !== 'undefined' ? cart.items : [
                    {
                        _id: '1',
                        product: { name: 'Structured Linen Overshirt', category: { name: 'New Arrival' } },
                        variant: { color: 'Bone White', size: 'L', price: 1200, images: ['https://images.unsplash.com/photo-1598033129183-c4f50c717658?q=80&w=1974&auto=format&fit=crop'] },
                        quantity: 1
                    }
                  ];
                %>

                <% displayItems.forEach(item => { %>
                    <div class="bag-item flex gap-6 md:gap-10">
                        <!-- Image -->
                        <div class="w-32 md:w-48 aspect-[3/4] bg-[var(--cream)] overflow-hidden">
                            <img src="<%= item.variant.images[0] %>" alt="<%= item.variant.name %>" class="w-full h-full object-cover">
                        </div>

                        <!-- Details -->
                        <div class="flex-grow flex flex-col justify-between py-1">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-[0.6rem] tracking-[0.15em] font-black text-stone-400 uppercase mb-2">
                                       <%= item.variant.productId.category?.name || '' %>
                                    </p>
                                    <h3 class="text-lg md:text-xl font-medium tracking-tight mb-2"><%= item.variant.productId.name %></h3>
                                    <div class="flex gap-4 text-[0.7rem] text-stone-500 font-medium">
                                        <p>COLOR: <span class="text-black uppercase"><%= item.variant.color %></span></p>
                                        <p>SIZE: <span class="text-black uppercase"><%= item.variant.size %></span></p>
                                    </div>
                                </div>
                                <p class="text-sm font-bold">₹<%= item.variant.price %></p>
                            </div>

                            <div class="flex justify-between items-end">
                                <div class="qty-stepper">
                                    <button class="qty-btn" onclick="updateQty('<%= item._id %>', -1)">-</button>
                                    <div class="qty-val"><%= item.quantity %></div>
                                    <button class="qty-btn" onclick="updateQty('<%= item._id %>', 1)">+</button>
                                </div>
                                <div class="flex gap-6">
                                    <a href="#" class="remove-link">Wishlist</a>
                                    <a href="#" class="remove-link" onclick="removeItem('<%= item._id %>')">Remove</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>

                <!-- Empty State Link -->
                <div class="mt-12">
                    <a href="/menProductList" class="text-[0.65rem] tracking-[0.2em] font-black uppercase flex items-center gap-2 group">
                        <i data-lucide="arrow-left" size="14" class="group-hover:-translate-x-1 transition-transform"></i>
                        Continue Shopping
                    </a>
                </div>
            </div>

            <!-- Order Summary Sidebar -->
            <div class="w-full lg:w-[400px]">
                <div class="sticky-summary bg-[var(--cream)] p-8 md:p-10">
                    <h2 class="text-[0.65rem] tracking-[0.25em] font-black uppercase mb-8 pb-4 border-b border-[var(--bdr)]">Order Summary</h2>
                    
                    <div class="space-y-4 mb-10">
                        <div class="flex justify-between text-[0.75rem] font-medium">
                            <span class="text-stone-500">Subtotal</span>
                            <span>₹<%= typeof cart !== 'undefined' ? cart.totalPrice : 1200 %></span>
                        </div>
                        <div class="flex justify-between text-[0.75rem] font-medium">
                            <span class="text-stone-500">Estimated Shipping</span>
                            <span class="text-green-600 uppercase">Complimentary</span>
                        </div>
                        <div class="flex justify-between text-[0.75rem] font-medium">
                            <span class="text-stone-500">Taxes</span>
                            <span>₹0.00</span>
                        </div>
                    </div>

                    <div class="flex justify-between items-end pt-6 border-t border-[var(--bdr)] mb-10">
                        <div>
                            <p class="text-[0.65rem] tracking-[0.2em] font-black uppercase mb-1">Total</p>
                            <p class="text-[0.6rem] text-stone-400 font-medium">VAT Included</p>
                        </div>
                        <p class="text-2xl font-medium tracking-tighter">₹<%= typeof cart !== 'undefined' ? cart.totalPrice : 1200 %></p>
                    </div>

                    <button class="btn-checkout flex items-center justify-between">
                        Proceed to Checkout
                        <i data-lucide="arrow-right" size="14"></i>
                    </button>

                    <div class="mt-8 pt-8 border-t border-[var(--bdr)]">
                        <div class="flex items-start gap-4">
                            <i data-lucide="shield-check" size="18" class="text-stone-400"></i>
                            <div>
                                <p class="text-[0.65rem] font-black uppercase tracking-wider mb-1">Secure Checkout</p>
                                <p class="text-[0.6rem] text-stone-400 leading-relaxed">Your data is protected by industry-standard encryption for a safe shopping experience.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script>
        lucide.createIcons();

        async function updateQty(itemId, delta) {
            // Backend integration logic here
            console.log('Update quantity:', itemId, delta);
            // Example: const res = await axios.post('/cart/update', { itemId, delta });
            // window.location.reload();
        }

        async function removeItem(itemId) {
            // Backend integration logic here
            console.log('Remove item:', itemId);
            // Example: const res = await axios.post('/cart/remove', { itemId });
            // window.location.reload();
        }
    </script>
</body>
</html>
