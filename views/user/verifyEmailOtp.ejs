<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Verify Email</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <!-- 1. Load SweetAlert FIRST -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- 2. Then your helper -->
<script src="/js/utils/swal-helper.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>

<body class="min-h-screen flex overflow-hidden">

  <!-- LEFT IMAGE -->
  <div class="hidden md:block w-1/2 h-screen">
    <img 
      src="/images/otp.jpg"
      class="w-full h-full object-cover"
    />
  </div>

  <!-- RIGHT SIDE -->
  <div class="w-full md:w-1/2 flex items-center justify-center bg-[#f5f2ed]">

    <div class="w-full max-w-md p-8">

      <%- include('../partials/breadcrumbs', { 
          breadcrumbs: [
              { name: "My Profile", url: "/profile" },
              { name: "Verify Email" }
          ] 
      }) %>

      <h1 class="text-xl font-semibold mb-6">AJAX</h1>

      <h2 class="text-3xl font-bold mb-2">Verify your email</h2>
      <p class="text-gray-500 mb-6">
        Enter the 6-digit code sent to your email
      </p>

      <!-- OTP BOXES -->
      <div id="otpContainer" class="flex gap-2 mb-6 justify-between">
        <input maxlength="1" class="otp-box" />
        <input maxlength="1" class="otp-box" />
        <input maxlength="1" class="otp-box" />
        <input maxlength="1" class="otp-box" />
        <input maxlength="1" class="otp-box" />
        <input maxlength="1" class="otp-box" />
      </div>

      <p id="otpError" class="text-red-500 text-sm mb-4 hidden"></p>

      <!-- BUTTON -->
      <button id="verifyBtn"
        class="w-full bg-black text-white py-3 rounded-lg hover:opacity-90">
        VERIFY CODE →
      </button>

      <!-- RESEND -->
      <div class="flex justify-between mt-4 text-sm text-gray-400">
        <span id="timer">Resend code in 60s</span>
        <button id="resendBtn" class="text-black font-semibold hidden">
          RESEND
        </button>
      </div>

    </div>
  </div>

<!-- STYLE -->
<style>
.otp-box {
  width: 45px;
  height: 50px;
  text-align: center;
  font-size: 20px;
  border: 1px solid #ccc;
  border-radius: 8px;
}
.otp-box:focus {
  outline: none;
  border-color: black;
}
</style>

<script>
const inputs = document.querySelectorAll(".otp-box");
const otpContainer = document.getElementById("otpContainer");

// 🔥 AUTO FOCUS + VALIDATION
inputs.forEach((input, index) => {

  input.addEventListener("input", () => {
    // allow only numbers
    input.value = input.value.replace(/[^0-9]/g, "");

    if (input.value && index < inputs.length - 1) {
      inputs[index + 1].focus();
    }

    clearOtpError();
  });

  input.addEventListener("keydown", (e) => {
    if (e.key === "Backspace" && !input.value && index > 0) {
      inputs[index - 1].focus();
    }
  });

});

// 🔥 PASTE (GLOBAL FIX)
otpContainer.addEventListener("paste", (e) => {
  e.preventDefault();

  const paste = (e.clipboardData || window.clipboardData)
    .getData("text")
    .replace(/\D/g, "");

  if (!paste) return;

  const digits = paste.split("");

  inputs.forEach((inp, i) => {
    inp.value = digits[i] || "";
  });

  const lastIndex = Math.min(digits.length, inputs.length) - 1;
  if (lastIndex >= 0) inputs[lastIndex].focus();

  clearOtpError();

  if (digits.length === inputs.length) {
    verifyOtp();
  }
});

// 🔥 GET OTP
function getOtp() {
  return Array.from(inputs).map(i => i.value).join("");
}

// 🔥 VERIFY
async function verifyOtp() {
  const otp = getOtp();

  if (otp.length !== 6) {
    showToast("error", "Enter complete OTP");
    return;
  }

  try {
    const res = await axios.post("/profile/email/verify", { otp });

    showToast("success", res.data.message);

    setTimeout(() => {
      window.location.href = "/profile";
    }, 1200);

  } catch (err) {
    showToast("error", err.response?.data?.message || "Invalid OTP");
  }
}

// 🔥 BUTTON CLICK
document.getElementById("verifyBtn").addEventListener("click", verifyOtp);

// 🔁 TIMER
let time = 60;
let timerInterval = null;
const timerEl = document.getElementById("timer");
const resendBtn = document.getElementById("resendBtn");

function startTimer() {
  time = 60;
  resendBtn.classList.add("hidden");
  timerEl.innerText = `Resend code in ${time}s`;

  if (timerInterval) clearInterval(timerInterval);
  
  timerInterval = setInterval(() => {
    time--;
    timerEl.innerText = `Resend code in ${time}s`;

    if (time <= 0) {
      clearInterval(timerInterval);
      resendBtn.classList.remove("hidden");
      timerEl.innerText = "Didn't receive code?";
    }
  }, 1000);
}

// Initial start
startTimer();

// 🔁 RESEND
resendBtn.addEventListener("click", async () => {
  try {
    const res = await axios.post("/profile/email/resend-otp");
    showToast("success", res.data.message || "OTP resent successfully");
    startTimer();
  } catch (err) {
    showToast("error", err.response?.data?.message || "Failed to resend OTP");
  }
});

// 🔹 ERROR UI
function showOtpError(message) {
  const el = document.getElementById("otpError");
  el.textContent = message;
  el.classList.remove("hidden");
}

function clearOtpError() {
  const el = document.getElementById("otpError");
  el.classList.add("hidden");
}

inputs[0].focus();
</script>

<script src="/js/utils/swalToast.js"></script>

</body>
</html>
