
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | AJAX</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif: ['Playfair Display', 'serif'],
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <style>
    body { font-family: 'Inter', sans-serif; background-color: #fcfcfc; }
    .premium-input {
      background: transparent;
      border: none;
      border-bottom: 1px solid #d1d1d1;
      border-radius: 0;
      padding: 12px 0;
      transition: all 0.3s ease;
    }
    .premium-input:focus {
      outline: none;
      border-bottom-color: #000;
      box-shadow: none;
    }
    .stagger-item { opacity: 0; transform: translateY(20px); }
  </style>

  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>

<body class="min-h-screen flex overflow-hidden">

  <!-- LEFT IMAGE -->
  <div class="hidden md:block w-7/12 h-screen overflow-hidden">
    <img 
      id="hero-img"
      src="/images/signup.jpg"
      class="w-full h-full object-cover scale-110"
    />
  </div>

  <!-- RIGHT FORM -->
  <div class="w-full md:w-5/12 flex items-center justify-center bg-white p-8 md:p-12 lg:p-20 relative">
    
    <!-- Back to Home Button -->
    <a href="/home" class="absolute top-8 right-8 text-[0.65rem] tracking-[0.2em] uppercase text-gray-400 hover:text-black transition-colors duration-300 flex items-center gap-2">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to Store
    </a>

    <div class="w-full max-w-sm">
      <!-- Logo -->
      <a href="/home" class="stagger-item inline-block mb-16">
        <h1 class="text-xl font-bold tracking-[0.4em] uppercase">AJAX</h1>
      </a>

      <!-- Header -->
      <div class="mb-10">
        <h2 class="font-serif italic text-4xl mb-3 stagger-item">Welcome Back</h2>
        <p class="text-xs tracking-wider uppercase text-gray-400 stagger-item">Sign in to continue your journey</p>
      </div>

      <!-- FORM -->
      <form id="loginForm" class="space-y-8">
        <div class="stagger-item">
          <label class="text-[0.6rem] uppercase tracking-[0.2em] text-gray-400 mb-1 block">Email Address</label>
          <input type="email" name="email" placeholder="email@example.com"
            class="w-full premium-input text-sm" />
          <p id="emailError" class="text-red-500 text-[0.65rem] mt-1 hidden"></p>
        </div>

        <div class="stagger-item">
          <label class="text-[0.6rem] uppercase tracking-[0.2em] text-gray-400 mb-1 block">Password</label>
          <div class="relative">
            <input type="password" name="password" id="password"
              placeholder="••••••••"
              class="w-full premium-input text-sm" />
            <span 
              class="absolute right-0 top-3 cursor-pointer text-xs"
              onclick="togglePassword('password', this)"
            >SHOW</span>
          </div>
          <div class="flex justify-end mt-2">
            <a href="/forgot-password" class="text-[0.65rem] text-gray-400 hover:text-black transition-colors">
              Forgot your password?
            </a>
          </div>
          <p id="passwordError" class="text-red-500 text-[0.65rem] mt-1 hidden"></p>
        </div>

        <div class="stagger-item pt-4">
          <button class="w-full bg-black text-white py-4 text-[0.7rem] tracking-[0.3em] uppercase hover:bg-gray-900 transition-all duration-300 transform hover:scale-[1.01] active:scale-[0.98]">
            Sign In
          </button>
        </div>
      </form>

      <div class="stagger-item mt-6">
        <div class="relative flex items-center justify-center mb-6">
          <div class="w-full border-t border-gray-100"></div>
          <span class="absolute bg-white px-4 text-[0.6rem] uppercase tracking-[0.2em] text-gray-300">Or</span>
        </div>

        <a href="/auth/google" class="w-full block">
          <div class="w-full border border-gray-100 py-4 text-center text-[0.7rem] tracking-[0.2em] uppercase hover:bg-gray-50 transition-all duration-300 flex items-center justify-center gap-3">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </div>
        </a>
      </div>

      <p class="stagger-item text-[0.7rem] text-gray-400 mt-10 text-center">
        New to AJAX? 
        <a href="/signup" class="text-black font-semibold underline underline-offset-4 hover:opacity-70 transition-opacity">Create an account</a>
      </p>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <% if (isBlocked) { %>
  <script>
  Swal.fire({
    icon: "error",
    title: "Account Blocked",
    text: "Your account has been blocked by admin",
    confirmButtonColor: "#000"
  });
  </script>
  <% } %>

  <script>
    // GSAP ANIMATIONS
    window.addEventListener('DOMContentLoaded', () => {
      const tl = gsap.timeline();

      tl.to('#hero-img', {
        scale: 1,
        duration: 2.5,
        ease: 'power2.out'
      });

      tl.to('.stagger-item', {
        opacity: 1,
        y: 0,
        stagger: 0.1,
        duration: 1,
        ease: 'power3.out'
      }, "-=2");
    });
  </script>
  <script src="/js/user/login.js"></script>
  <script src="/js/utils/swal-helper.js"></script>
</body>
</html>

