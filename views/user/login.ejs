
 <!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Login</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

</head>

<body class="min-h-screen flex overflow-hidden">

  <!-- LEFT IMAGE -->

  <div class="hidden md:block w-1/2 h-screen">
    <img 
      src="/images/signup.jpg"
      class="w-full h-full object-cover"
    />
  </div>

  <!-- RIGHT FORM -->

  <div class="w-full md:w-1/2 flex items-center justify-center bg-[#f5f2ed]">


<div class="w-full max-w-md p-8">

  <%- include('../partials/breadcrumbs', { 
      breadcrumbs: [
          { name: "Login" }
      ] 
  }) %>

  <!-- Logo -->
  <h1 class="text-2xl font-bold mb-6">AJAX</h1>

  <!-- Title -->
  <h2 class="text-3xl font-bold mb-2">Welcome Back</h2>
  <p class="text-gray-500 mb-6">Login to your account</p>

  <!-- FORM -->
  <form id="loginForm" class="space-y-4">

    <!-- EMAIL -->
    <div>
      <input type="email" name="email" placeholder="Email"
        class="w-full p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-black" />
      <p id="emailError" class="text-red-500 text-sm hidden"></p>
    </div>

    <!-- PASSWORD -->
    <div class="relative">
      <input type="password" name="password" id="password"
        placeholder="Password"
        class="w-full p-3 border rounded-lg pr-10 focus:outline-none focus:ring-2 focus:ring-black" />

      <!-- Eye -->
      <span 
        class="absolute right-3 top-3 cursor-pointer"
        onclick="togglePassword('password', this)"
      >👁️</span>

      <p id="passwordError" class="text-red-500 text-sm hidden"></p>
    </div>

    <!-- FORGOT PASSWORD -->
    <div class="flex justify-end text-sm">
      <a href="/forgot-password" class="text-gray-600 hover:text-black">
        Forgot Password?
      </a>
    </div>

    <!-- LOGIN BUTTON -->
    <button class="w-full bg-black text-white py-3 rounded-lg hover:opacity-90 transition">
      LOGIN →
    </button>

  </form>
  <a href="/auth/google" class="w-full block mt-3">
  <div class="w-full border border-gray-300 py-3 text-center rounded-lg hover:bg-gray-100 transition">
    Continue with Google
  </div>
</a>

  <!-- EXTRA -->
  <p class="text-sm text-gray-500 mt-6 text-center">
    Don't have an account? 
    <a href="/signup" class="text-black font-semibold">Sign up</a>
  </p>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<% if (isBlocked) { %>
<script>
Swal.fire({
  icon: "error",
  title: "Account Blocked",
  text: "Your account has been blocked by admin",
});
</script>
<% } %>

<script>
window.history.pushState(null, "", window.location.href);
window.onpopstate = function () {
  window.location.reload();
};
</script>
<script src="/js/user/login.js"></script>

<!-- Global Toast Injection -->
<%- include('../partials/toast') %>
<script src="/js/utils/toast.js"></script>
</body>
</html>

