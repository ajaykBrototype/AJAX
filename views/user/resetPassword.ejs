```
<div class="w-full max-w-md p-8">

  <!-- Logo -->
  <h1 class="text-2xl font-bold mb-6">AJAX</h1>

  <!-- Title -->
  <h2 class="text-3xl font-bold mb-2">Reset Password</h2>
  <p class="text-gray-500 mb-6">
    Enter your new password below
  </p>

  <!-- FORM -->
  <form id="resetForm" class="space-y-4">

    <!-- NEW PASSWORD -->
    <div class="relative">
      <input type="password" name="password" id="password"
        placeholder="New Password"
        class="w-full p-3 border rounded-lg pr-10 focus:ring-2 focus:ring-black" />

      <span 
        class="absolute right-3 top-3 cursor-pointer"
        onclick="togglePassword('password', this)"
      >👁️</span>

      <p id="passwordError" class="text-red-500 text-sm hidden"></p>
    </div>

    <!-- CONFIRM PASSWORD -->
    <div class="relative">
      <input type="password" name="confirmPassword" id="confirmPassword"
        placeholder="Confirm Password"
        class="w-full p-3 border rounded-lg pr-10 focus:ring-2 focus:ring-black" />

      <span 
        class="absolute right-3 top-3 cursor-pointer"
        onclick="togglePassword('confirmPassword', this)"
      >👁️</span>

      <p id="confirmPasswordError" class="text-red-500 text-sm hidden"></p>
    </div>

    <!-- BUTTON -->
    <button class="w-full bg-black text-white py-3 rounded-lg hover:opacity-90 transition">

  </form>

  <!-- BACK TO LOGIN -->
  <p class="text-sm text-gray-500 mt-6 text-center">
    Remember your password? 
    <a href="/login" class="text-black font-semibold">Login</a>
  </p>

</div>
