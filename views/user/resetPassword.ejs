<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Reset Password — AJAX</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- 1. Load SweetAlert FIRST -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- 2. Then your helper -->
<script src="/js/utils/swal-helper.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  
  <style>
    body { background-color: #FAFAF8; font-family: 'DM Sans', sans-serif; }
    .font-serif { font-family: 'Playfair Display', serif; }
    .input-premium {
      border-bottom: 1px solid rgba(28, 28, 28, 0.1);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .input-premium:focus { outline: none; border-bottom-color: #000; }
    .input-premium.error { border-bottom-color: #B04040; }
    
    .strength-seg { height: 2px; flex: 1; background: #EAE5DC; transition: 0.3s; }
    .active-weak { background: #B04040; }
    .active-fair { background: #C47A2A; }
    .active-good { background: #5B8A4A; }
    .active-strong { background: #3A7D44; }
    
    .req-item { display: flex; align-items: center; gap: 6px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; }
    .req-item.met { color: #3A7D44; }
    .req-item.unmet { color: #9B8E83; opacity: 0.6; }
    
    #match-dot { width: 6px; height: 6px; border-radius: 50%; opacity: 0; transition: 0.3s; }
    #match-dot.show { opacity: 1; }
    #match-dot.ok { background: #3A7D44; }
    #match-dot.bad { background: #B04040; }
  </style>
</head>

<body class="min-h-screen flex overflow-hidden">

  <div class="hidden md:block w-1/2 h-screen">
    <img src="/images/signup.jpg" class="w-full h-full object-cover grayscale-[20%]" />
  </div>

  <div class="w-full md:w-1/2 flex items-center justify-center p-8">
    <div class="w-full max-w-sm">
      <%- include('../partials/breadcrumbs', { 
          breadcrumbs: [
              { name: "Login", url: "/login" },
              { name: "Reset Password" }
          ] 
      }) %>
      <h1 class="font-serif text-2xl tracking-[0.3em] mb-12">AJAX</h1>
      <h2 class="font-serif text-4xl mb-2">Reset Password</h2>
      <p class="text-stone-400 text-[10px] tracking-[0.2em] uppercase mb-12">Define your new security credentials</p>

      <form id="reset-password-form" class="space-y-10" novalidate>
        
        <div class="relative">
          <label class="text-[9px] uppercase tracking-[0.2em] text-stone-400">New Password</label>
          <div class="relative">
            <input type="password" id="new-password" placeholder="••••••••" class="input-premium w-full py-3 bg-transparent text-sm pr-10" />
            <button type="button" onclick="togglePassword('new-password', this)" class="absolute right-0 top-1/2 -translate-y-1/2 text-stone-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
          
          <div id="strength-bar" class="flex gap-1 mt-3" style="display: none;">
            <div id="seg1" class="strength-seg"></div>
            <div id="seg2" class="strength-seg"></div>
            <div id="seg3" class="strength-seg"></div>
            <div id="seg4" class="strength-seg"></div>
          </div>
          <p id="strength-label" class="text-[9px] uppercase mt-2 font-medium" style="display: none;"></p>

          <div id="req-list" class="grid grid-cols-2 gap-2 mt-4" style="display: none;">
            <div id="req-length" class="req-item unmet">8+ Characters</div>
            <div id="req-upper" class="req-item unmet">Uppercase</div>
            <div id="req-number" class="req-item unmet">Number</div>
            <div id="req-special" class="req-item unmet">Symbol</div>
          </div>
          <p id="new-error" class="text-[10px] text-red-500 mt-2 hidden uppercase tracking-tighter"></p>
        </div>

        <div class="relative">
          <div class="flex justify-between items-center mb-1">
            <label class="text-[9px] uppercase tracking-[0.2em] text-stone-400">Confirm Password</label>
            <div id="match-dot"></div>
          </div>
          <div class="relative">
            <input type="password" id="confirm-password" placeholder="••••••••" class="input-premium w-full py-3 bg-transparent text-sm pr-10" />
            <button type="button" onclick="togglePassword('confirm-password', this)" class="absolute right-0 top-1/2 -translate-y-1/2 text-stone-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            </button>
          </div>
          <p id="confirm-error" class="text-[10px] text-red-500 mt-2 hidden uppercase tracking-tighter"></p>
        </div>

        <button id="submit-btn" type="submit" class="w-full bg-black text-white py-5 text-[11px] tracking-[0.3em] uppercase hover:bg-stone-800 transition-all">
          Update Password
        </button>
      </form>

      <p class="text-[11px] text-stone-400 mt-12 text-center uppercase tracking-widest">
        Wait, I remember! <a href="/login" class="text-black font-semibold border-b border-black">Login</a>
      </p>
    </div>
  </div>

  <input type="password" id="current-password" class="hidden" value="bypass">
  <div id="current-error" class="hidden"></div>

  <script src="/js/user/changePassword.js"></script>
</body>
</html>
