<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>My Profile — AJAX</title>
<meta name="description" content="Your AJAX account profile — personal details, security status and shopping region."/>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@200;300;400;500&display=swap" rel="stylesheet">
<script>
tailwind.config = {
  theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['DM Sans','system-ui','sans-serif'] } } }
}
</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:#FAFAF8;color:#1C1C1C;overflow-x:hidden}
:root{--dark:#1C1C1C;--cream:#F5F0E8;--warm:#FAFAF8;--stone:#9B8E83;--mist:#EAE5DC;--bdr:rgba(28,28,28,0.1)}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:#ccc}

/* ── NAVBAR ── */
#navbar{position:fixed;top:0;left:0;right:0;z-index:999;padding:.9rem 3rem;background:rgba(250,250,248,.97);backdrop-filter:blur(16px);box-shadow:0 1px 0 var(--bdr)}
@media(max-width:767px){#navbar{padding:.8rem 1.25rem}}
.logo{font-family:'Playfair Display',serif;font-weight:400;font-size:1.45rem;letter-spacing:.42em;text-transform:uppercase;text-decoration:none;color:var(--dark)}
.nav-link{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;color:var(--dark);position:relative;padding-bottom:3px;transition:opacity .25s}
.nav-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--dark);transition:width .4s cubic-bezier(.25,.1,.25,1)}
.nav-link:hover::after{width:100%}.nav-link:hover{opacity:.55}
.nav-icon{cursor:pointer;transition:transform .25s,opacity .25s;display:flex;align-items:center;justify-content:center;background:none;border:none;padding:6px;color:var(--dark);text-decoration:none}
.nav-icon:hover{transform:scale(1.1);opacity:.5}

/* ── MOBILE MENU ── */
#mob-menu{display:none;position:fixed;inset:0;z-index:998;background:var(--warm);flex-direction:column;align-items:center;justify-content:center;gap:2.2rem}
#mob-menu.open{display:flex}
#mob-close{position:absolute;top:1.5rem;right:1.75rem;background:none;border:none;cursor:pointer;font-size:1.3rem;color:var(--dark);opacity:.5;transition:opacity .2s}
#mob-close:hover{opacity:1}
.mob-link{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:400;font-style:italic;color:var(--dark);text-decoration:none;transition:opacity .25s}
.mob-link:hover{opacity:.35}

/* ── PAGE FADE-IN ── */
@keyframes pageIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.page-in{animation:pageIn .7s cubic-bezier(.16,1,.3,1) both}
.d1{animation-delay:.06s}.d2{animation-delay:.14s}.d3{animation-delay:.22s}.d4{animation-delay:.30s}

/* ── SIDEBAR ── */
.sidebar-link{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);text-decoration:none;border-left:2px solid transparent;transition:color .25s,border-color .25s,background .25s}
.sidebar-link:hover{color:var(--dark);background:rgba(28,28,28,.03)}
.sidebar-link.active{color:var(--dark);border-left-color:var(--dark);background:rgba(28,28,28,.04);font-weight:500}

/* ── BUTTONS ── */
.btn-dark{display:inline-flex;align-items:center;gap:.5rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:#fff;background:var(--dark);border:1px solid var(--dark);padding:.82rem 1.8rem;transition:background .3s;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;text-decoration:none}
.btn-dark:hover{background:#333}
.btn-ghost{display:inline-flex;align-items:center;gap:.5rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dark);background:none;border:1px solid var(--bdr);padding:.82rem 1.8rem;transition:border-color .3s;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;text-decoration:none}
.btn-ghost:hover{border-color:var(--dark)}

/* ── BADGE ── */
.badge{display:inline-flex;align-items:center;gap:.35rem;font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;border:1px solid var(--bdr);padding:.3rem .75rem;color:var(--stone)}
.badge-gold{border-color:rgba(180,140,60,.4);color:rgba(150,115,35,1);background:rgba(180,140,60,.06)}

/* ── DETAIL FIELD ── */
.detail-field{padding:1.5rem 0;border-bottom:1px solid var(--bdr)}
.detail-field:last-child{border-bottom:none}
.field-label{font-size:.52rem;letter-spacing:.25em;text-transform:uppercase;color:var(--stone);margin-bottom:.5rem}
.field-value{font-size:.88rem;font-weight:300;color:var(--dark)}

/* ── MOBILE SIDEBAR DRAWER ── */
#sidebar-drawer{display:none;position:fixed;inset:0;z-index:997}
#sidebar-drawer.open{display:block}
.drawer-bg{position:absolute;inset:0;background:rgba(28,28,28,.4);backdrop-filter:blur(4px)}
.drawer-panel{position:absolute;left:0;top:0;bottom:0;width:72vw;max-width:280px;background:#fff;padding:2rem 1.25rem;animation:drawerIn .35s cubic-bezier(.16,1,.3,1) both;border-right:1px solid var(--bdr)}
@keyframes drawerIn{from{transform:translateX(-100%)}to{transform:translateX(0)}}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  .top-grid{grid-template-columns:1fr !important}
}
@media(max-width:640px){
  .details-grid{grid-template-columns:1fr 1fr !important}
  .main-pad{padding:2.5rem 1.25rem !important}
  .header-row{flex-direction:column;align-items:flex-start !important}
}
@media(max-width:400px){
  .details-grid{grid-template-columns:1fr !important}
}

/* ── ACCOUNT DROPDOWN ── */
.dropdown-menu {
  position: absolute;
  top: calc(100% + 20px);
  right: 0;
  width: 240px;
  background: #fff;
  border: 1px solid var(--bdr);
  box-shadow: 0 12px 48px rgba(28,28,28,0.08);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-8px);
  transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1), transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.35s;
  z-index: 50;
  padding: 0.5rem 0;
}
.dropdown-menu.open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.dropdown-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.85rem 1.4rem;
  font-size: 0.72rem;
  font-weight: 300;
  color: var(--dark);
  text-decoration: none;
  transition: background 0.25s cubic-bezier(0.16, 1, 0.3, 1), color 0.25s, transform 0.25s;
}
.dropdown-item:hover {
  background: var(--cream);
  transform: translateX(3px);
}
.dropdown-divider {
  height: 1px;
  background: var(--bdr);
  margin: 0.4rem 0;
}
</style>
</head>
<body>

<!-- ══ MOBILE MENU ══ -->
<div id="mob-menu">
  <button id="mob-close">✕</button>
  <a href="/" class="mob-link">Home</a>
  <a href="#" class="mob-link">Men</a>
  <a href="#" class="mob-link">Women</a>
  <a href="#" class="mob-link">New Arrivals</a>
  <a href="#" class="mob-link">Journal</a>
</div>

<!-- ══ MOBILE SIDEBAR DRAWER ══ -->
<div id="sidebar-drawer">
  <div class="drawer-bg" id="drawer-bg"></div>
  <div class="drawer-panel">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2rem;">
      <span style="font-size:.55rem;letter-spacing:.28em;text-transform:uppercase;color:var(--stone)">Account</span>
      <button id="drawer-close" style="background:none;border:none;cursor:pointer;color:var(--stone);font-size:1.1rem">✕</button>
    </div>
    <a href="/profile" class="sidebar-link active">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Profile
    </a>
    <a href="/address" class="sidebar-link" style="margin-top:.1rem">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      Address
    </a>
    <a href="/orders" class="sidebar-link" style="margin-top:.1rem">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      My Orders
    </a>
    <a href="/wishlist" class="sidebar-link" style="margin-top:.1rem">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      Wishlist
    </a>
    <a href="/wallet" class="sidebar-link" style="margin-top:.1rem">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
      Wallet
    </a>
    <div style="height:1px;background:var(--bdr);margin:1.5rem 0"></div>
    <button id="logoutBtnSidebar" class="sidebar-link" style="color:#B04040">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Logout
    </button>
  </div>
</div>

<!-- ══ NAVBAR ══ -->
<nav id="navbar">
  <div style="max-width:1320px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;">
    <a href="/" class="logo">AJAX</a>

    <div class="hidden md:flex items-center gap-10">
      <a href="#" class="nav-link">MEN</a>
      <a href="#" class="nav-link">WOMEN</a>
      <a href="#" class="nav-link">KIDS</a>
      <a href="#" class="nav-link">BEAUTY</a>
    </div>

    <div class="flex items-center gap-1">
      <button class="nav-icon" title="Search">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <a href="/wishlist" class="nav-icon hidden md:flex" title="Wishlist">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </a>
      <a href="/cart" class="nav-icon hidden md:flex" title="Cart">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </a>
      <div class="relative hidden md:flex items-center">
        <button id="accountBtn" class="nav-icon" title="Account">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </button>
        <div id="accountDropdown" class="dropdown-menu">
          <div style="padding:1rem 1.4rem;border-bottom:1px solid var(--bdr);margin-bottom:0.4rem">
            <p style="font-size:0.52rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--stone);margin-bottom:0.35rem">Quick Access</p>
            <p style="font-family:'Playfair Display',serif;font-size:1.15rem;color:var(--dark);line-height:1.2">My Account</p>
          </div>
          <a href="/profile" class="dropdown-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Overview
          </a>
          <a href="/address" class="dropdown-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Addresses
          </a>
          <a href="/orders" class="dropdown-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            My Orders
          </a>
          <div class="dropdown-divider"></div>
          
        </div>
      </div>
      <button id="ham" class="nav-icon md:hidden">
        <svg width="20" height="14" viewBox="0 0 20 14" fill="none"><line x1="0" y1="1" x2="20" y2="1" stroke="currentColor" stroke-width="1.5"/><line x1="0" y1="7" x2="20" y2="7" stroke="currentColor" stroke-width="1.5"/><line x1="0" y1="13" x2="20" y2="13" stroke="currentColor" stroke-width="1.5"/></svg>
      </button>
      <button id="sidebar-toggle" class="nav-icon md:hidden" title="Account">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </button>
    </div>
  </div>
</nav>

<!-- ══ PAGE BODY ══ -->
<div style="padding-top:65px;min-height:100vh;">
  <div style="max-width:1320px;margin:0 auto;display:flex;align-items:flex-start;">

    <!-- SIDEBAR (desktop) -->
    <aside class="hidden md:block" style="width:220px;min-height:calc(100vh - 65px);border-right:1px solid var(--bdr);padding:3.5rem 0;flex-shrink:0;position:sticky;top:65px;">
      <nav style="display:flex;flex-direction:column;gap:.1rem;">
        <a href="/profile" class="sidebar-link active">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Profile
        </a>
        <a href="/address" class="sidebar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Address
        </a>
        <a href="/orders" class="sidebar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          My Orders
        </a>
        <a href="/wishlist" class="sidebar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Wishlist
        </a>
        <a href="/wallet" class="sidebar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
          Wallet
        </a>
        <div style="height:1px;background:var(--bdr);margin:1.75rem 1rem"></div>
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main-pad page-in" style="flex:1;padding:3.5rem 3rem;min-width:0;">

      <!-- Page Header -->
      <div class="header-row page-in d1" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1.25rem;margin-bottom:3rem;">
        <div>
          <p style="font-size:.54rem;letter-spacing:.35em;text-transform:uppercase;color:var(--stone);margin-bottom:.5rem">Account Overview</p>
          <h1 style="font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(2rem,4vw,3rem);line-height:1.1;color:var(--dark)">My Profile</h1>
        </div>
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
          <a href="/edit-profile" class="btn-dark">
            Edit Profile
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <button type="button" id="logoutBtnHeader" class="btn-ghost">Logout</button>
        </div>
      </div>

      <!-- Profile card + side panels -->
      <div class="top-grid page-in d2" style="display:grid;grid-template-columns:1fr 280px;gap:1.5rem;margin-bottom:2.5rem;align-items:start;">

        <!-- Identity card -->
        <div style="background:#fff;border:1px solid var(--bdr);padding:2.2rem 2.5rem;display:flex;align-items:center;gap:2rem;flex-wrap:wrap;">
          <img
            src="<%= user.profileImage || '/images/default-user.png' %>"
            alt="Profile Photo"
            style="width:96px;height:96px;object-fit:cover;display:block;filter:grayscale(12%);flex-shrink:0;"
          />
          <div style="flex:1;min-width:160px;">
            <h2 style="font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:500;color:var(--dark);line-height:1.15;margin-bottom:.35rem"><%=user.name%></h2>
            <p style="font-size:.72rem;font-weight:300;color:var(--stone);margin-bottom:1rem">
              Member since: <strong style="color:var(--dark);font-weight:500">Joined in <%= new Date(user.createdAt).getFullYear() %></strong>
            </p>
          </div>
        </div>

        <!-- Side panels -->
        <div style="display:flex;flex-direction:column;gap:1rem;">

          <!-- Security Status -->
          <div style="background:#fff;border:1px solid var(--bdr);padding:1.5rem 1.75rem;">
            <p style="font-size:.5rem;letter-spacing:.3em;text-transform:uppercase;color:var(--stone);margin-bottom:.9rem">Security Status</p>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.55rem;">
              <span style="font-size:.9rem;color:var(--dark)">Password</span>
              <a href="/change-password" style="font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--dark);text-decoration:none;border-bottom:1px solid var(--dark);padding-bottom:1px;transition:opacity .2s" onmouseover="this.style.opacity='.5'" onmouseout="this.style.opacity='1'">Change</a>
            </div>
            <p style="font-size:.7rem;font-weight:300;color:var(--stone)">Last updated <%= new Date(user.createdAt) %> ago</p>
          </div>

          <!-- Shopping Region -->
          <div style="background:var(--dark);padding:1.75rem;">
            <p style="font-size:.5rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.38);margin-bottom:.75rem">Shopping Region</p>
            <p style="font-size:1.15rem;font-family:'Playfair Display',serif;font-weight:400;color:#fff"><%=user.nationality%></p>
          </div>

        </div>
      </div>

      <!-- Personal Details -->
      <div class="page-in d3">
        <div style="display:flex;align-items:center;justify-content:space-between;padding-bottom:1rem;border-bottom:1px solid var(--bdr);margin-bottom:0;">
          <h2 style="font-family:'Playfair Display',serif;font-weight:400;font-size:1.4rem;color:var(--dark)">Personal Details</h2>
        </div>

        <div class="details-grid" style="display:grid;grid-template-columns:1fr 1fr 1fr;">

          <div class="detail-field" style="padding-right:2rem;">
            <p class="field-label">Full Name</p>
            <p class="field-value"><%=user.name%></p>
          </div>

          <div class="detail-field" style="padding-right:2rem;">
            <p class="field-label">Email Address</p>
            <p class="field-value"><%=user.email%></p>
          </div>

          <div class="detail-field">
            <p class="field-label">Phone Number</p>
            <p class="field-value"><%= user.phone || 'Not added' %></p>
          </div>

          <div class="detail-field" style="padding-right:2rem;">
            <p class="field-label">Date of Birth</p>
            <p class="field-value"><%= user.dob ? new Date(user.dob).toDateString() : 'Not added' %></p>
          </div>

          <div class="detail-field" style="padding-right:2rem;">
            <p class="field-label">Gender</p>
            <p class="field-value"><%= user.gender || 'Not added' %></p>
          </div>

          <div class="detail-field">
            <p class="field-label">Nationality</p>
            <p class="field-value"><%= user.nationality|| 'Not added' %></p>
          </div>

        </div>
      </div>

    </main>
  </div>
</div>

