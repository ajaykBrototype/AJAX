<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard — AJAX</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Outfit:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Playfair Display', 'serif'],
                        sans: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            dark: '#1C1C1C',
                            cream: '#F5F0E8',
                            warm: '#FAFAF8',
                            stone: '#9B8E83',
                            mist: '#EAE5DC'
                        }
                    }
                }
            }
        }
    </script>
    <%- include('../partials/navbar-styles') %>
    <%- include('../partials/footer-styles') %>
    <style>
        body {
            background-color: #FBF9F6;
            color: #1C1C1C;
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .dashboard-card {
            background: #fff;
            border-radius: 2.5rem;
            border: 1px solid rgba(28,28,28,0.04);
            box-shadow: 0 4px 24px rgba(0,0,0,0.02);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .dashboard-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.04);
            border-color: rgba(28,28,28,0.08);
        }
        .sidebar-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.5rem;
            border-radius: 1.25rem;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.05em;
            color: #9B8E83;
            transition: all 0.3s ease;
        }
        .sidebar-item:hover {
            background: rgba(28,28,28,0.03);
            color: #1C1C1C;
        }
        .sidebar-item.active {
            background: #F5F0E8;
            color: #1C1C1C;
        }
        .hero-banner {
            background: linear-gradient(135deg, #1C1C1C 0%, #2D2D2D 100%);
            border-radius: 2.5rem;
            position: relative;
            overflow: hidden;
        }
        .hero-banner::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 400px;
            height: 400px;
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 50%;
            pointer-events: none;
        }
        .editorial-title {
            font-family: 'Playfair Display', serif;
        }
    </style>
</head>
<body class="bg-[#FBF9F6]">
    <%- include('../partials/navbar') %>

    <main class="max-w-[1440px] mx-auto px-6 md:px-12 pt-32 pb-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
            
            <!-- Left Sidebar -->
            <div class="lg:col-span-3 space-y-8">
                <!-- User Profile Card -->
                <div class="dashboard-card p-8 text-center md:text-left">
                    <div class="flex flex-col items-center md:items-start gap-6">
                        <div class="relative group">
                            <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-brand-warm shadow-inner">
                                <img src="<%= user.profileImage || '/images/default-user.png' %>" alt="Profile" class="w-full h-full object-cover">
                            </div>
                            <a href="/edit-profile" class="absolute bottom-0 right-0 w-8 h-8 bg-brand-dark text-white rounded-full flex items-center justify-center shadow-lg hover:scale-110 transition-transform">
                                <i data-lucide="camera" size="14"></i>
                            </a>
                        </div>
                        <div class="space-y-1">
                            <h2 class="editorial-title text-2xl font-bold"><%= user.name %></h2>
                            <p class="text-[0.65rem] font-bold text-stone-300 uppercase tracking-widest">Member</p>
                        </div>
                        <div class="w-full pt-6 border-t border-brand-mist/20 space-y-4">
                            <div class="flex items-center gap-3 text-stone-400">
                                <i data-lucide="mail" size="14"></i>
                                <span class="text-[0.7rem] font-medium truncate"><%= user.email %></span>
                            </div>
                            <div class="flex items-center gap-3 text-stone-400">
                                <i data-lucide="phone" size="14"></i>
                                <span class="text-[0.7rem] font-medium"><%= user.phone || 'Not provided' %></span>
                            </div>
                        </div>
                        <a href="/edit-profile" class="w-full flex items-center justify-center gap-3 py-4 rounded-2xl border border-brand-mist/40 text-[0.65rem] font-black uppercase tracking-widest hover:bg-brand-warm transition-all group">
                            <i data-lucide="edit-3" size="14" class="group-hover:rotate-12 transition-transform"></i>
                            Edit Profile
                        </a>
                    </div>
                </div>

                <!-- Navigation Sidebar -->
                <div class="dashboard-card p-4">
                    <nav class="space-y-1">
                        <a href="/profile" class="sidebar-item active">
                            <i data-lucide="layout-grid" size="18"></i>
                            Overview
                        </a>
                        <a href="/orders" class="sidebar-item">
                            <i data-lucide="package" size="18"></i>
                            Orders
                        </a>
                        <a href="/wishlist" class="sidebar-item">
                            <i data-lucide="heart" size="18"></i>
                            Wishlist
                        </a>
                        <a href="/address" class="sidebar-item">
                            <i data-lucide="map-pin" size="18"></i>
                            Addresses
                        </a>
                        <a href="/change-password" class="sidebar-item">
                            <i data-lucide="lock" size="18"></i>
                            Password
                        </a>
                        <div class="pt-4 mt-4 border-t border-brand-mist/20">
                            <button onclick="handleLogout()" class="sidebar-item w-full hover:text-red-500 hover:bg-red-50">
                                <i data-lucide="log-out" size="18"></i>
                                Sign Out
                            </button>
                        </div>
                    </nav>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="lg:col-span-9 space-y-10">
                
                <!-- Hero Section -->
                <section class="hero-banner p-10 md:p-16 text-white">
                    <div class="relative z-10 space-y-8">
                        <div class="space-y-2">
                            <p class="text-[0.6rem] font-black tracking-[0.4em] uppercase text-white/50">Welcome Back</p>
                            <h1 class="editorial-title text-4xl md:text-6xl font-medium flex items-center gap-4">
                                <%= user.name.split(' ')[0] %> 
                                <span class="text-3xl md:text-5xl">✨</span>
                            </h1>
                        </div>
                        <p class="text-[0.85rem] md:text-base text-white/60 font-light max-w-md leading-relaxed">
                            Your radiance journey continues. Discover new arrivals curated just for your skin.
                        </p>
                        <a href="/menProductList" class="inline-flex items-center gap-4 bg-white text-brand-dark px-10 py-4 rounded-2xl text-[0.65rem] font-black uppercase tracking-widest hover:scale-105 active:scale-95 transition-all">
                            Explore Arrivals
                            <i data-lucide="arrow-right" size="16"></i>
                        </a>
                    </div>
                </section>

                <!-- Stats Grid -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="dashboard-card p-8 flex items-center gap-6 group">
                        <div class="w-14 h-14 rounded-2xl bg-[#E8F3F1] flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i data-lucide="shopping-bag" class="text-[#2D8A7E]" size="24"></i>
                        </div>
                        <div>
                            <p class="text-[0.55rem] font-black text-stone-300 uppercase tracking-widest mb-1">Orders</p>
                            <p class="text-2xl font-bold"><%= orderCount || 0 %></p>
                        </div>
                    </div>

                    <div class="dashboard-card p-8 flex items-center gap-6 group">
                        <div class="w-14 h-14 rounded-2xl bg-[#FFF0F0] flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i data-lucide="heart" class="text-red-400" size="24"></i>
                        </div>
                        <div>
                            <p class="text-[0.55rem] font-black text-stone-300 uppercase tracking-widest mb-1">Wishlist</p>
                            <p class="text-2xl font-bold"><%= wishlistCount || 0 %></p>
                        </div>
                    </div>

                    <div class="dashboard-card p-8 flex items-center gap-6 bg-[#004236] text-white border-none group">
                        <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                            <i data-lucide="wallet" class="text-white" size="24"></i>
                        </div>
                        <div>
                            <p class="text-[0.55rem] font-black text-white/40 uppercase tracking-widest mb-1">Wallet</p>
                            <p class="text-2xl font-bold font-serif italic tracking-tight">₹<%= wallet ? wallet.balance.toFixed(2) : '0.00' %></p>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <section class="space-y-8">
                    <h3 class="editorial-title text-2xl font-medium tracking-tight">Quick Actions</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Action 1 -->
                        <div class="dashboard-card p-10 flex gap-8 items-start group">
                            <div class="w-12 h-12 rounded-2xl bg-brand-warm flex items-center justify-center flex-shrink-0 group-hover:bg-brand-dark group-hover:text-white transition-all">
                                <i data-lucide="user" size="20"></i>
                            </div>
                            <div class="space-y-4">
                                <div>
                                    <h4 class="text-base font-bold mb-1">Profile Details</h4>
                                    <p class="text-[0.7rem] text-stone-400 leading-relaxed font-medium">Update your personal information, email, and preferences.</p>
                                </div>
                                <a href="/edit-profile" class="inline-flex items-center gap-2 text-[0.65rem] font-black uppercase tracking-widest border-b-2 border-brand-dark pb-1 hover:gap-4 transition-all">
                                    Edit
                                    <i data-lucide="chevron-right" size="14"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Action 2 -->
                        <div class="dashboard-card p-10 flex gap-8 items-start group">
                            <div class="w-12 h-12 rounded-2xl bg-brand-warm flex items-center justify-center flex-shrink-0 group-hover:bg-brand-dark group-hover:text-white transition-all">
                                <i data-lucide="credit-card" size="20"></i>
                            </div>
                            <div class="space-y-4">
                                <div>
                                    <h4 class="text-base font-bold mb-1">Wallet & Payments</h4>
                                    <p class="text-[0.7rem] text-stone-400 leading-relaxed font-medium">Manage your balance, add funds, and view transaction history.</p>
                                </div>
                                <a href="/wallet" class="inline-flex items-center gap-2 text-[0.65rem] font-black uppercase tracking-widest border-b-2 border-[#2D8A7E] text-[#2D8A7E] pb-1 hover:gap-4 transition-all">
                                    ₹<%= wallet ? wallet.balance.toFixed(2) : '0.00' %> available
                                    <i data-lucide="chevron-right" size="14"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Action 3 -->
                        <div class="dashboard-card p-10 flex gap-8 items-start group">
                            <div class="w-12 h-12 rounded-2xl bg-brand-warm flex items-center justify-center flex-shrink-0 group-hover:bg-brand-dark group-hover:text-white transition-all">
                                <i data-lucide="users" size="20"></i>
                            </div>
                            <div class="space-y-4">
                                <div>
                                    <h4 class="text-base font-bold mb-1">Refer & Earn</h4>
                                    <p class="text-[0.7rem] text-stone-400 leading-relaxed font-medium">Invite your friends to AJAX and earn exclusive rewards.</p>
                                </div>
                                <a href="#" class="inline-flex items-center gap-2 text-[0.65rem] font-black uppercase tracking-widest border-b-2 border-brand-dark pb-1 hover:gap-4 transition-all">
                                    Share Link
                                    <i data-lucide="chevron-right" size="14"></i>
                                </a>
                            </div>
                        </div>

                        <!-- Action 4 -->
                        <div class="dashboard-card p-10 flex gap-8 items-start group">
                            <div class="w-12 h-12 rounded-2xl bg-brand-warm flex items-center justify-center flex-shrink-0 group-hover:bg-brand-dark group-hover:text-white transition-all">
                                <i data-lucide="map-pin" size="20"></i>
                            </div>
                            <div class="space-y-4">
                                <div>
                                    <h4 class="text-base font-bold mb-1">My Addresses</h4>
                                    <p class="text-[0.7rem] text-stone-400 leading-relaxed font-medium">Manage your shipping and billing addresses for faster checkout.</p>
                                </div>
                                <a href="/address" class="inline-flex items-center gap-2 text-[0.65rem] font-black uppercase tracking-widest border-b-2 border-brand-dark pb-1 hover:gap-4 transition-all">
                                    Manage
                                    <i data-lucide="chevron-right" size="14"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        lucide.createIcons();

        function handleLogout() {
            Swal.fire({
                title: "Sign Out?",
                text: "Are you sure you want to log out of your session?",
                icon: "question",
                showCancelButton: true,
                confirmButtonColor: "#1C1C1C",
                cancelButtonColor: "#f44336",
                confirmButtonText: "Yes, sign out",
                cancelButtonText: "Cancel",
                background: '#fff',
                color: '#1C1C1C',
                borderRadius: '2rem'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/logout";
                }
            });
        }
    </script>
</body>
</html>
