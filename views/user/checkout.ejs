<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AJAX — Checkout</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Outfit:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Playfair Display', 'serif'],
                        sans: ['Outfit', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            dark: '#1C1C1C',
                            cream: '#F5F0E8',
                            warm: '#FAFAF8',
                            stone: '#9B8E83',
                            mist: '#EAE5DC'
                        }
                    }
                }
            }
        }
    </script>
    <%- include('../partials/navbar-styles') %>
    <%- include('../partials/footer-styles') %>
    <style>
        :root {
            --bg-page: #ffffff; 
        }
        body {
            background-color: var(--bg-page);
            color: var(--dark);
            font-family: 'Outfit', sans-serif;
            -webkit-font-smoothing: antialiased;
        }
        .checkout-card {
            background: #fff;
            border-radius: 2rem;
            border: 1px solid var(--bdr);
            box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        }
        /* Custom Radio Buttons */
        .payment-option input[type="radio"] {
            display: none;
        }
        .payment-option .radio-custom {
            width: 22px;
            height: 22px;
            border: 1.5px solid var(--mist);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: #fff;
        }
        .payment-option input[type="radio"]:checked + .radio-custom {
            border-color: var(--dark);
            background: #fff;
        }
        .payment-option input[type="radio"]:checked + .radio-custom::after {
            content: '';
            width: 10px;
            height: 10px;
            background: var(--dark);
            border-radius: 50%;
            animation: radioScale 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        @keyframes radioScale {
            from { transform: scale(0); }
            to { transform: scale(1); }
        }
        .payment-option.active {
            border-color: var(--dark);
            box-shadow: 0 0 0 1px var(--dark);
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: var(--mist);
            border-radius: 10px;
        }

        .editorial-title {
            font-family: 'Playfair Display', serif;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <main class="max-w-[1440px] mx-auto px-6 md:px-12 pt-28 pb-24">
      
         <%- include('../partials/breadcrumbs', { 
            breadcrumbs: [
                { name: "Shop", url: "/menProductList" },
                { name: "Your Bag" }
            ] 
        }) %>

         <%
        let subtotal = 0;

         cart.items.forEach(item => {
         subtotal += (item.variant?.price || 0) * item.quantity;
          });

          const shipping = subtotal > 1000 ? 0 : 100;
         const total = subtotal + shipping;
           %>
   
    

        <!-- Header -->
        <div class="text-center mb-24">
            <h1 class="editorial-title text-5xl md:text-6xl mb-6">Checkout</h1>
            <p class="text-[0.6rem] tracking-[0.3em] font-bold text-stone-400 uppercase">Complete your purchase and begin your journey</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
            <!-- Left Column: Shipping & Payment -->
            <div class="lg:col-span-7 space-y-20">
                
                <!-- Shipping Address Section -->
                <section>
                    <div class="flex justify-between items-end mb-8">
                        <h2 class="editorial-title text-2xl tracking-widest">Shipping Address</h2>
                        <a href="/address" class="text-[0.6rem] font-black tracking-[0.2em] text-stone-300 hover:text-dark uppercase transition-all">Change</a>
                    </div>
                    
                    <% if (address) { %>
                    <div class="checkout-card p-10 md:p-12">
                        <div class="flex justify-between items-start mb-8">
                            <div>
                                <h3 class="text-2xl font-bold mb-3"><%= address.name%></h3>
                                <span class="inline-block px-4 py-1.5 bg-brand-warm rounded-lg text-[0.55rem] font-black tracking-[0.2em] text-stone-400 uppercase border border-brand-mist/20"><%= address.type || "Home" %></span>
                            </div>
                        </div>
                        <div class="space-y-1.5 text-sm font-medium text-stone-400 leading-relaxed max-w-sm">
                            <p><%= address.street %></p>
                            <p><%= address.city %>, <%= address.state %></p>
                            <p><%= address.state %> — <%= address.pincode %></p>
                            <p><%= address.country || "India" %></p>
                        </div>
                        <div class="mt-10 pt-10 border-t border-brand-mist/30 flex items-center gap-5">
                            <div class="w-12 h-12 rounded-2xl bg-brand-warm flex items-center justify-center border border-brand-mist/20 shadow-sm">
                                <i data-lucide="phone" size="16" class="text-stone-300"></i>
                            </div>
                            <p class="text-base font-bold tracking-widest"> <%= address.phone %></p>
                        </div>
                    </div>
                    <% } else { %>

                <div class="checkout-card p-10 text-center">
              <p class="text-red-500 mb-4">No address found</p>
               <a href="/address" class="text-blue-500 underline">
                 Add Address
                   </a>
                  </div>

                <% } %>

                </section>

                <!-- Payment Methods Section -->
                <section>
                    <h2 class="editorial-title text-2xl tracking-widest mb-10">Payment</h2>
                    <div class="space-y-5">
                        
                        <!-- Wallet Option -->
                        <label class="payment-option checkout-card p-8 flex items-center gap-8 cursor-pointer hover:border-dark/20 transition-all border border-transparent group">
                            <input type="radio" name="payment" value="wallet" disabled>
                            <div class="radio-custom flex-shrink-0"></div>
                            <div class="w-16 h-16 rounded-2xl bg-[#E8F3F1] flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i data-lucide="wallet" class="text-[#2D8A7E]" size="24"></i>
                            </div>
                            <div class="flex-grow">
                                <h4 class="text-lg font-bold">Wallet Balance</h4>
                                <p class="text-xs font-medium text-stone-400 mt-0.5">Available Balance: ₹0.00</p>
                            </div>
                            <span class="px-4 py-1.5 bg-[#FFF0F0] text-[#D14F4F] text-[0.55rem] font-black tracking-[0.2em] uppercase rounded-lg border border-[#FFE0E0]">Insufficient</span>
                        </label>

                        
                        <label class="payment-option checkout-card p-8 flex items-center gap-8 cursor-pointer hover:border-dark/20 transition-all border border-transparent group">
                            <input type="radio" name="payment" value="razorpay">
                            <div class="radio-custom flex-shrink-0"></div>
                            <div class="w-16 h-16 rounded-2xl bg-[#E8F0FE] flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i data-lucide="credit-card" class="text-[#1A73E8]" size="24"></i>
                            </div>
                            <div class="flex-grow">
                                <h4 class="text-lg font-bold">Razorpay</h4>
                                <p class="text-xs font-medium text-stone-400 mt-0.5">UPI, Net Banking, Credit/Debit Cards</p>
                            </div>
                        </label>

                        
                        <label class="payment-option checkout-card p-8 flex items-center gap-8 cursor-pointer hover:border-dark transition-all border border-transparent group active">
                            <input type="radio" name="payment" value="cod" checked>
                            <div class="radio-custom flex-shrink-0"></div>
                            <div class="w-16 h-16 rounded-2xl bg-[#F5F1EB] flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i data-lucide="banknote" class="text-[#8B7355]" size="24"></i>
                            </div>
                            <div class="flex-grow">
                                <h4 class="text-lg font-bold">Cash on Delivery</h4>
                                <p class="text-xs font-medium text-stone-400 mt-0.5">Pay with cash when you receive your order</p>
                            </div>
                        </label>

                    </div>
                </section>

            </div>

            <!-- Right Column: Sidebar -->
            <div class="lg:col-span-5 sticky top-32">
                <div class="checkout-card p-10 md:p-12 overflow-hidden relative">
                    <!-- Subtle Gradient Top -->
                    <div class="absolute top-0 left-0 right-0 h-2 bg-dark"></div>

                    <h2 class="editorial-title text-2xl tracking-widest mb-10">Your Selection</h2>
                    
                    <!-- Item List -->
                    <div class="space-y-8 mb-12 max-h-[300px] overflow-y-auto pr-4 custom-scrollbar">
                        <!-- Sample Item 1 -->
                       <% cart.items.forEach(item => { %>
<div class="flex gap-6 items-center <%= item.variant.stock === 0 ? 'opacity-50' : '' %>">

    <div class="relative w-24 h-24 bg-brand-warm rounded-3xl overflow-hidden">
        <img src="<%= item.variant?.images?.[0] || '/images/default.png' %>"  class="w-full h-full object-cover">

        <% if (item.variant.stock === 0) { %>
            <span class="absolute inset-0 bg-black/50 text-white text-xs flex items-center justify-center">
                OUT OF STOCK
            </span>
        <% } %>

        <span class="absolute top-2 right-2 bg-dark text-white text-xs w-6 h-6 flex items-center justify-center rounded-full">
            <%= item.quantity %>
        </span>
    </div>

    <div class="flex-grow">
        <h4 class="text-[0.75rem] font-bold uppercase">
            <%= item.variant?.productId?.name || "Product" %>
        </h4>
        <p class="text-[0.6rem] text-stone-300 uppercase">
            <%= item.variant?.size || "N/A" %>
        </p>
         <p class="text-[0.6rem] text-stone-300 uppercase">
            <%= item?.quantity || "N/A" %>
        </p>
    </div>

    <p class="font-bold text-base">
        ₹<%= (item.variant?.price || 0) * item.quantity %>
    </p>

</div>
<% }) %>
                    </div>

                    <!-- Coupon -->
                    <div class="mb-12">
                        <div class="flex gap-3">
                            <input type="text" placeholder="Enter coupon code" class="flex-grow bg-brand-warm border border-brand-mist/30 rounded-2xl px-6 py-4 text-[0.7rem] font-bold tracking-widest focus:ring-1 focus:ring-dark focus:border-dark transition-all outline-none">
                            <button class="bg-dark text-white text-[0.65rem] font-black tracking-[0.25em] px-8 py-4 rounded-2xl hover:bg-black hover:shadow-lg hover:shadow-dark/10 transition-all uppercase">Apply</button>
                        </div>
                        <button class="mt-5 flex items-center gap-2.5 text-[0.55rem] font-black tracking-[0.25em] text-stone-300 hover:text-dark uppercase transition-all group">
                            <i data-lucide="tag" size="14" class="group-hover:rotate-12 transition-transform"></i>
                            View all available coupons
                        </button>
                    </div>

                    <!-- Totals -->
                    <div class="space-y-5 pt-10 border-t border-brand-mist/30 mb-12">
                        <div class="flex justify-between items-center text-[0.7rem] font-bold text-stone-400">
                            <span class="uppercase tracking-[0.2em]">Subtotal</span>
                            <span class="text-dark">₹ <%= subtotal%></span>
                        </div>
                        <div class="flex justify-between items-center text-[0.7rem] font-bold text-stone-400">
                            <span class="uppercase tracking-[0.2em]">Shipping</span>
                            <span class="text-green-600 font-black">   <%= shipping === 0 ? "FREE" : `₹ ${shipping}` %></span>
                        </div>
                    </div>

                    <div class="flex justify-between items-end mb-12">
                        <div>
                            <p class="text-[0.65rem] font-black uppercase tracking-[0.3em] mb-1.5 text-stone-300">TOTAL</p>
                            <p class="text-[0.55rem] text-stone-200 font-bold uppercase tracking-widest">INR</p>
                        </div>
                        <p class="text-5xl font-serif tracking-tighter">₹ <%= total%></p>
                    </div>

                    <!-- Action Button -->
                    <div class="space-y-4">
                        <button class="w-full bg-white text-brand-dark border border-brand-dark/10 py-6 rounded-[2rem] text-[0.75rem] font-black tracking-[0.3em] uppercase hover:bg-brand-dark hover:text-white hover:scale-[1.02] active:scale-[0.98] transition-all duration-500 flex items-center justify-center gap-4 shadow-xl shadow-brand-dark/5 relative overflow-hidden group">
                            <span class="relative z-10">Complete Order — ₹<%= total%></span>
                            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-dark/5 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
                        </button>
                        
                        <p class="text-center text-[0.55rem] font-black tracking-[0.3em] text-stone-200 uppercase flex items-center justify-center gap-3">
                            <i data-lucide="lock" size="12" class="opacity-40"></i>
                            Secure Encrypted Checkout
                        </p>
                    </div>

                    <!-- Trust Icons -->
                    <div class="grid grid-cols-3 gap-6 pt-12 mt-12 border-t border-brand-mist/30">
                        <div class="text-center group">
                            <i data-lucide="shield-check" size="20" class="mx-auto text-stone-200 mb-3 group-hover:text-stone-400 transition-colors"></i>
                            <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-[0.25em]">Cruelty Free</p>
                        </div>
                        <div class="text-center group">
                            <i data-lucide="heart" size="20" class="mx-auto text-stone-200 mb-3 group-hover:text-stone-400 transition-colors"></i>
                            <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-[0.25em]">Vegan</p>
                        </div>
                        <div class="text-center group">
                            <i data-lucide="award" size="20" class="mx-auto text-stone-200 mb-3 group-hover:text-stone-400 transition-colors"></i>
                            <p class="text-[0.5rem] font-black text-stone-300 uppercase tracking-[0.25em]">Lab Tested</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        lucide.createIcons();
        
        // UI logic for radio buttons
        const options = document.querySelectorAll('.payment-option');
        options.forEach(option => {
            option.addEventListener('click', () => {
                const radio = option.querySelector('input');
                if (radio.disabled) return;
                
                options.forEach(opt => opt.classList.remove('active'));
                option.classList.add('active');
                radio.checked = true;
            });
        });
    </script>
</body>
</html>
