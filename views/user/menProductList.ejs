<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AJAX — Men's Shirts</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@200;300;400;500;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
tailwind.config = {
  theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['DM Sans','system-ui','sans-serif'] } } }
}
</script>
<%- include('../partials/navbar-styles') %>
<style>

/* PAGE SPECIFIC STYLES */
.page-title {
  font-family: 'DM Sans', sans-serif;
  font-weight: 900;
  font-size: clamp(2rem, 5vw, 3.5rem);
  text-transform: uppercase;
  letter-spacing: -0.02em;
  color: var(--dark);
  margin-top: 6rem;
  margin-bottom: 0.5rem;
  line-height: 1;
}

/* SEARCH & SORT BAR */
.toolbar-link {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--dark);
  transition: opacity 0.3s;
}
.toolbar-link:hover { opacity: 0.6; }

.search-input {
  background: transparent;
  border: none;
  border-bottom: 1px solid transparent;
  outline: none;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  width: 0;
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.search-container:hover .search-input,
.search-input:focus {
  width: 200px;
  opacity: 1;
  border-bottom-color: var(--dark);
  padding-left: 0.5rem;
}

/* PRODUCT CARD ENHANCEMENTS */
.product-card {
  position: relative;
  overflow: hidden;
}
.secondary-img {
  position: absolute !important;
  top: 0;
  left: 0;
  opacity: 0;
  transition: opacity 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) !important;
}
.product-card:hover .secondary-img {
  opacity: 1;
}
.product-card:hover .primary-img {
  opacity: 0.8;
}

.sort-select {
  appearance: none;
  background: transparent;
  border: none;
  outline: none;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
}

/* HORIZONTAL SCROLLBAR FOR CATEGORIES */
.hide-scroll::-webkit-scrollbar {
  display: none;
}
.hide-scroll {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* ANIMATIONS */
.fade-in-up {
  opacity: 0;
  transform: translateY(20px);
  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
@keyframes fadeInUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }

</style>
<%- include('../partials/footer-styles') %>
</head>
<body>

<%- include('../partials/navbar') %>

<!-- MAIN CONTENT -->
<main class="px-6 md:px-12 max-w-[1440px] mx-auto">
  
  <%- include('../partials/breadcrumbs', { 
      breadcrumbs: [
          { name: "Men's Shirts" }
      ] 
  }) %>
  
  <!-- Header Section -->
  <div class="fade-in-up">
    <h1 class="page-title">MEN'S SHIRTS</h1>
  </div>

  <!-- Categories Pills -->
  <div class="flex gap-2 overflow-x-auto hide-scroll mb-8 fade-in-up delay-1">
    <a href="/menProductList"
       class="px-5 py-2 text-[0.6rem] font-bold tracking-[0.1em] border uppercase transition-all
       <%= !selectedSub ? 'bg-black text-white border-black' : 'hover:bg-black hover:text-white border-[var(--bdr)]' %>">
       VIEW ALL
    </a>
    <% subCategories.forEach(sub => { %>
      <a href="/menProductList?sub=<%= sub._id %>"
         class="px-5 py-2 text-[0.6rem] font-bold tracking-[0.1em] border uppercase transition-all
         <%= selectedSub == sub._id.toString() ? 'bg-black text-white border-black' : 'hover:bg-black hover:text-white border-[var(--bdr)]' %>">
        <%= sub.name %>
      </a>
    <% }) %>
  </div>

  <!-- Toolbar: Filter, Search, Sort -->
  <div class="flex flex-wrap items-center justify-between gap-6 py-6 border-y border-[var(--bdr)] mb-12 fade-in-up delay-1">
    
    <!-- Left: Filter -->
    <div class="flex items-center">
      <button class="toolbar-link flex items-center gap-2">
        FILTER <i data-lucide="plus" size="12" stroke-width="3"></i>
      </button>
    </div>

    <!-- Right: Search & Sort -->
    <div class="flex items-center gap-8 md:gap-12 ml-auto">
      <!-- Search -->
      <div class="search-container flex items-center gap-2">
        <input type="text" placeholder="SEARCH..." class="search-input">
        <button class="toolbar-link flex items-center gap-2">
          <i data-lucide="search" size="14" stroke-width="2.5"></i>
        </button>
      </div>

      <!-- Sort -->
      <div class="flex items-center gap-4">
        <span class="text-[0.6rem] tracking-[0.2em] text-[var(--stone)] uppercase">Sort</span>
        <div class="flex items-center gap-1">
          <select class="sort-select">
            <option value="newest">Newest</option>
            <option value="price-low">Price: Low - High</option>
            <option value="price-high">Price: High - Low</option>
            <option value="name-az">A - Z</option>
            <option value="name-za">Z - A</option>
          </select>
          <i data-lucide="chevron-down" size="10" class="text-stone-400"></i>
        </div>
      </div>
    </div>
  </div>

  <!-- Product Grid -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-10 fade-in-up delay-2">

  <% if (products.length > 0) { %>

    <% products.forEach(product => { %>

      <% const variant = product.variants?.[0]; %>
      <a href="/product/<%= product._id %>" class="block">

    <div class="product-card group">
      <div class="product-img-wrap relative bg-[#F9F9F7] aspect-[3/4] overflow-hidden mb-4">
        
        <button class="wishlist-btn absolute top-4 right-4 z-10 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0" onclick="event.preventDefault()">
          <i data-lucide="heart" size="18" stroke-width="1.5"></i>
        </button>

        <!-- Primary Image -->
        <img 
          src="<%= variant?.images?.[0] %>" 
          alt="<%= product.name %>"
          class="primary-img w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
        />

        <!-- Secondary Image (Hover) -->
        <% if (variant?.images?.[1]) { %>
        <img 
          src="<%= variant.images[1] %>" 
          alt="<%= product.name %>"
          class="secondary-img w-full h-full object-cover"
        />
        <% } %>

        <!-- Quick Add Overlay (Aesthetic) -->
        <div class="absolute inset-x-0 bottom-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-500 bg-white/80 backdrop-blur-sm">
           <p class="text-[0.55rem] font-black tracking-[0.2em] text-center uppercase">Quick View</p>
        </div>
      </div>

      <div class="product-info space-y-1">
        <h3 class="text-[0.7rem] font-bold tracking-[0.05em] uppercase text-[#1C1C1C]"><%= product.name %></h3>
        <p class="text-[0.75rem] font-medium text-stone-500">₹<%= variant?.price %></p>
      </div>
    </div>

</a>
    <% }) %>

  <% } else { %>

    <p class="col-span-4 text-center text-gray-500 mt-10">
      No products available
    </p>

  <% } %>

</div>

 <!-- Pagination -->
<div class="mt-20 mb-10 flex flex-col items-center justify-center fade-in-up delay-3">

  <div class="flex items-center gap-3 text-[0.85rem] font-medium text-[#1C1C1C]">

    <!-- 🔙 PREV -->
    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %><%= selectedSub ? '&sub=' + selectedSub : '' %>"
         class="w-8 h-8 flex items-center justify-center hover:bg-[#EAE5DC] transition-colors">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
    <% } %>

    <!-- 🔢 PAGE NUMBERS -->
    <% for (let i = 1; i <= totalPages; i++) { %>

      <a href="?page=<%= i %><%= selectedSub ? '&sub=' + selectedSub : '' %>"
         class="w-8 h-8 flex items-center justify-center transition-colors
         <%= currentPage === i 
            ? 'bg-[#1C1C1C] text-white' 
            : 'hover:bg-[#EAE5DC]' %>">

        <%= i %>

      </a>

    <% } %>

    <!-- 🔜 NEXT -->
    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %><%= selectedSub ? '&sub=' + selectedSub : '' %>"
         class="w-8 h-8 flex items-center justify-center hover:bg-[#EAE5DC] transition-colors">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    <% } %>

  </div>

  <!-- 🔢 PRODUCT COUNT -->
  <p class="text-[0.6rem] tracking-[0.2em] text-[var(--stone)] mt-6 uppercase">
    SHOWING <%= products.length %> OF <%= totalProducts %> PRODUCTS
  </p>

</div>

</main>

<%- include('../partials/footer') %>

<script src="https://unpkg.com/lucide@latest"></script>
<script>
    lucide.createIcons();

    // Sorting Logic (UI and URL Update)
    const sortSelect = document.querySelector('.sort-select');
    if (sortSelect) {
        sortSelect.addEventListener('change', () => {
            const value = sortSelect.value;
            const url = new URL(window.location.href);
            url.searchParams.set('sort', value);
            window.location.href = url.toString();
        });
    }

    // Search Logic (UI and URL Update)
    const searchInput = document.querySelector('.search-input');
    if (searchInput) {
        searchInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                const value = searchInput.value.trim();
                const url = new URL(window.location.href);
                if (value) {
                    url.searchParams.set('search', value);
                } else {
                    url.searchParams.delete('search');
                }
                window.location.href = url.toString();
            }
        });
    }

    // Restore sort/search values from URL
    window.addEventListener('load', () => {
        const url = new URL(window.location.href);
        if (url.searchParams.has('sort') && sortSelect) {
            sortSelect.value = url.searchParams.get('sort');
        }
        if (url.searchParams.has('search') && searchInput) {
            searchInput.value = url.searchParams.get('search');
        }
    });
</script>
</body>
</html>
