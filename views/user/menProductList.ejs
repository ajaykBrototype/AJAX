<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AJAX — Men's Shirts</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@200;300;400;500;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
tailwind.config = {
  theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['DM Sans','system-ui','sans-serif'] } } }
}
</script>
<%- include('../partials/navbar-styles') %>
<style>

/* PAGE SPECIFIC STYLES */
.page-title {
  font-family: 'DM Sans', sans-serif;
  font-weight: 900;
  font-size: clamp(3rem, 6vw, 5rem);
  text-transform: uppercase;
  letter-spacing: -0.02em;
  color: var(--dark);
  margin-top: 8rem; /* Space for navbar */
  margin-bottom: 1.5rem;
}

/* HORIZONTAL SCROLLBAR FOR CATEGORIES */
.hide-scroll::-webkit-scrollbar {
  display: none;
}
.hide-scroll {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* PRODUCT CARD */
.product-card {
  position: relative;
  cursor: pointer;
}
.product-img-wrap {
  position: relative;
  background: var(--cream);
  aspect-ratio: 3/4;
  overflow: hidden;
  margin-bottom: 0.8rem;
}
.product-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
}
.product-card:hover .product-img-wrap img {
  transform: scale(1.05);
}
.wishlist-btn {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: transparent;
  border: none;
  cursor: pointer;
  z-index: 10;
  color: var(--dark);
  opacity: 0.7;
  transition: opacity 0.3s, transform 0.3s;
}
.wishlist-btn:hover {
  opacity: 1;
  transform: scale(1.1);
}
.wishlist-btn svg {
  width: 20px;
  height: 20px;
  stroke-width: 1.5;
}

.product-name {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--dark);
  margin-bottom: 0.2rem;
}
.product-price {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--dark);
  margin-bottom: 0.5rem;
}
.color-swatches {
  display: flex;
  gap: 0.3rem;
  align-items: center;
}
.swatch {
  width: 10px;
  height: 10px;
  display: inline-block;
  border: 1px solid var(--bdr);
}
.color-more {
  font-size: 0.65rem;
  color: var(--stone);
  margin-left: 0.2rem;
}

/* ANIMATIONS */
.fade-in-up {
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}
@keyframes fadeInUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.delay-1 { animation-delay: 0.1s; }
.delay-2 { animation-delay: 0.2s; }
.delay-3 { animation-delay: 0.3s; }
.delay-4 { animation-delay: 0.4s; }

</style>
<%- include('../partials/footer-styles') %>
</head>
<body>

<%- include('../partials/navbar') %>

<!-- MAIN CONTENT -->
<main class="px-6 md:px-12 max-w-[1440px] mx-auto">
  
  <!-- Header Section -->
  <div class="fade-in-up">
    <h1 class="page-title">MEN'S SHIRTS</h1>
  </div>

  <!-- Categories / Filters -->
  <div class="flex flex-col gap-6 mb-10 fade-in-up delay-1">
    <!-- Category Pills -->
    <div class="flex gap-3 overflow-x-auto hide-scroll pb-2 items-center">

  <!-- VIEW ALL -->
  <a href="/menProductList"
     class="px-6 py-2.5 border uppercase
     <%= !selectedSub ? 'bg-black text-white' : '' %>">
     VIEW ALL
  </a>

  <% subCategories.forEach(sub => { %>
    <a href="/menProductList?sub=<%= sub._id %>"
       class="px-6 py-2.5 border uppercase
       <%= selectedSub == sub._id.toString() ? 'bg-black text-white' : '' %>">

      <%= sub.name %>

    </a>
  <% }) %>

</div>

    <!-- Filter Toggle -->
    <div>
      <button class="text-[0.65rem] tracking-[0.15em] font-bold uppercase text-[#1C1C1C] flex items-center gap-1 hover:opacity-70 transition-opacity">
        FILTER <span class="text-xs font-normal ml-1">┼</span>
      </button>
    </div>
  </div>

  <!-- Product Grid -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-10 fade-in-up delay-2">

  <% if (products.length > 0) { %>

    <% products.forEach(product => { %>

      <% const variant = product.variants?.[0]; %>
      <a href="/product/<%= product._id %>" class="block">

  <div class="product-card group">

    <div class="product-img-wrap">

      <button class="wishlist-btn" onclick="event.preventDefault()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </button>

      <img 
        src="<%= variant?.images?.[0] %>" 
        alt="<%= product.name %>"
      />

    </div>

    <div class="product-info">
      <h3 class="product-name"><%= product.name %></h3>
      <p class="product-price">₹<%= variant?.price %></p>
    </div>

  </div>

</a>
    <% }) %>

  <% } else { %>

    <p class="col-span-4 text-center text-gray-500 mt-10">
      No products available
    </p>

  <% } %>

</div>

 <!-- Pagination -->
<div class="mt-20 mb-10 flex flex-col items-center justify-center fade-in-up delay-3">

  <div class="flex items-center gap-3 text-[0.85rem] font-medium text-[#1C1C1C]">

    <!-- 🔙 PREV -->
    <% if (currentPage > 1) { %>
      <a href="?page=<%= currentPage - 1 %><%= selectedSub ? '&sub=' + selectedSub : '' %>"
         class="w-8 h-8 flex items-center justify-center hover:bg-[#EAE5DC] transition-colors">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m15 18-6-6 6-6"/>
        </svg>
      </a>
    <% } %>

    <!-- 🔢 PAGE NUMBERS -->
    <% for (let i = 1; i <= totalPages; i++) { %>

      <a href="?page=<%= i %><%= selectedSub ? '&sub=' + selectedSub : '' %>"
         class="w-8 h-8 flex items-center justify-center transition-colors
         <%= currentPage === i 
            ? 'bg-[#1C1C1C] text-white' 
            : 'hover:bg-[#EAE5DC]' %>">

        <%= i %>

      </a>

    <% } %>

    <!-- 🔜 NEXT -->
    <% if (currentPage < totalPages) { %>
      <a href="?page=<%= currentPage + 1 %><%= selectedSub ? '&sub=' + selectedSub : '' %>"
         class="w-8 h-8 flex items-center justify-center hover:bg-[#EAE5DC] transition-colors">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    <% } %>

  </div>

  <!-- 🔢 PRODUCT COUNT -->
  <p class="text-[0.6rem] tracking-[0.2em] text-[var(--stone)] mt-6 uppercase">
    SHOWING <%= products.length %> OF <%= totalProducts %> PRODUCTS
  </p>

</div>

</main>

<%- include('../partials/footer') %>


</body>
</html>
