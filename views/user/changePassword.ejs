<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Change Password — AJAX</title>
<meta name="description" content="Securely update your AJAX account password."/>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@200;300;400;500&display=swap" rel="stylesheet">
<script>
  tailwind.config = {
    theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['DM Sans','system-ui','sans-serif'] } } }
  }
</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:#FAFAF8;color:#1C1C1C;overflow-x:hidden}
:root{
  --dark:#1C1C1C;
  --cream:#F5F0E8;
  --warm:#FAFAF8;
  --stone:#9B8E83;
  --mist:#EAE5DC;
  --bdr:rgba(28,28,28,0.1);
  --error:#B04040;
  --success:#3A7D44;
}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:#ccc}

/* ── NAVBAR ── */
#navbar{position:fixed;top:0;left:0;right:0;z-index:999;padding:.9rem 3rem;background:rgba(250,250,248,.97);backdrop-filter:blur(16px);box-shadow:0 1px 0 var(--bdr)}
@media(max-width:767px){#navbar{padding:.8rem 1.25rem}}
.logo{font-family:'Playfair Display',serif;font-weight:400;font-size:1.45rem;letter-spacing:.42em;text-transform:uppercase;text-decoration:none;color:var(--dark)}
.nav-link{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;color:var(--dark);position:relative;padding-bottom:3px;transition:opacity .25s}
.nav-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--dark);transition:width .4s cubic-bezier(.25,.1,.25,1)}
.nav-link:hover::after{width:100%}.nav-link:hover{opacity:.55}
.nav-icon{cursor:pointer;transition:transform .25s,opacity .25s;display:flex;align-items:center;justify-content:center;background:none;border:none;padding:6px;color:var(--dark);text-decoration:none}
.nav-icon:hover{transform:scale(1.1);opacity:.5}

/* ── MOBILE MENU ── */
#mob-menu{display:none;position:fixed;inset:0;z-index:998;background:var(--warm);flex-direction:column;align-items:center;justify-content:center;gap:2.2rem}
#mob-menu.open{display:flex}
#mob-close{position:absolute;top:1.5rem;right:1.75rem;background:none;border:none;cursor:pointer;font-size:1.3rem;color:var(--dark);opacity:.5;transition:opacity .2s}
#mob-close:hover{opacity:1}
.mob-link{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:400;font-style:italic;color:var(--dark);text-decoration:none;transition:opacity .25s}
.mob-link:hover{opacity:.35}

/* ── PAGE FADE-IN ── */
@keyframes pageIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes cardIn{from{opacity:0;transform:translateY(28px) scale(.985)}to{opacity:1;transform:translateY(0) scale(1)}}
.page-in{animation:pageIn .7s cubic-bezier(.16,1,.3,1) both}
.card-in{animation:cardIn .65s cubic-bezier(.16,1,.3,1) both;animation-delay:.08s}
.d1{animation-delay:.06s}.d2{animation-delay:.16s}.d3{animation-delay:.26s}

/* ── SIDEBAR ── */
.sidebar-link{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);text-decoration:none;border-left:2px solid transparent;transition:color .25s,border-color .25s,background .25s}
.sidebar-link:hover{color:var(--dark);background:rgba(28,28,28,.03)}
.sidebar-link.active{color:var(--dark);border-left-color:var(--dark);background:rgba(28,28,28,.04);font-weight:500}

/* ── MOBILE SIDEBAR DRAWER ── */
#sidebar-drawer{display:none;position:fixed;inset:0;z-index:997}
#sidebar-drawer.open{display:block}
.drawer-bg{position:absolute;inset:0;background:rgba(28,28,28,.4);backdrop-filter:blur(4px)}
.drawer-panel{position:absolute;left:0;top:0;bottom:0;width:72vw;max-width:280px;background:#fff;padding:2rem 1.25rem;animation:drawerIn .35s cubic-bezier(.16,1,.3,1) both;border-right:1px solid var(--bdr)}
@keyframes drawerIn{from{transform:translateX(-100%)}to{transform:translateX(0)}}

/* ── CENTERED LAYOUT ── */
.content-area{
  padding-top:65px;
  min-height:100vh;
  display:flex;
  align-items:flex-start;
}
.layout-wrapper{
  max-width:1320px;
  margin:0 auto;
  width:100%;
  display:flex;
  align-items:flex-start;
}

/* ── MAIN CONTENT CENTERED ── */
.main-content{
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  padding:4rem 2rem 4rem;
  min-width:0;
}

/* ── BREADCRUMB ── */
.breadcrumb{
  display:flex;
  align-items:center;
  gap:.55rem;
  margin-bottom:.65rem;
  width:100%;
  max-width:520px;
}

/* ── PAGE TITLE BLOCK ── */
.title-block{
  width:100%;
  max-width:520px;
  margin-bottom:2.5rem;
  text-align:center;
}

/* ── MAIN CARD ── */
.password-card{
  background:#fff;
  border:1px solid var(--bdr);
  width:100%;
  max-width:520px;
  padding:2.75rem 3rem;
  position:relative;
}
@media(max-width:600px){
  .password-card{padding:2rem 1.5rem}
}

/* ── CARD HEADER ── */
.card-header{
  display:flex;
  align-items:center;
  gap:.9rem;
  padding-bottom:1.6rem;
  border-bottom:1px solid var(--bdr);
  margin-bottom:2rem;
}
.shield-icon-wrap{
  width:42px;height:42px;
  border:1px solid var(--bdr);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}

/* ── FORM INPUTS ── */
.field-wrap{position:relative;margin-bottom:1.35rem}
.field-label-txt{display:block;font-size:.52rem;letter-spacing:.28em;text-transform:uppercase;color:var(--stone);margin-bottom:.55rem;transition:color .2s}
.field-input{
  width:100%;
  background:#FAFAF8;
  border:1px solid var(--bdr);
  padding:.9rem 3rem .9rem 1rem;
  font-size:.88rem;
  font-weight:300;
  font-family:'DM Sans',sans-serif;
  color:var(--dark);
  outline:none;
  transition:border-color .25s,box-shadow .25s,background .2s;
}
.field-input:focus{border-color:var(--dark);box-shadow:0 0 0 3px rgba(28,28,28,.06);background:#fff}
.field-input.error{border-color:var(--error);background:#fff}
.field-input.success{border-color:var(--success);background:#fff}
.field-input::placeholder{color:rgba(155,142,131,.55);font-size:.82rem}
.eye-btn{
  position:absolute;right:.9rem;top:50%;
  transform:translateY(-50%) translateY(8px);
  background:none;border:none;cursor:pointer;
  color:var(--stone);padding:3px;
  display:flex;align-items:center;
  transition:color .2s;
}
.eye-btn:hover{color:var(--dark)}
.field-error{font-size:.6rem;color:var(--error);letter-spacing:.05em;margin-top:.35rem;display:none;padding-left:1px}
.field-error.show{display:block}

/* ── STATUS DOT ── */
.match-dot{
  position:absolute;right:.9rem;top:50%;
  transform:translateY(-50%) translateY(8px);
  width:7px;height:7px;border-radius:50%;
  display:none;
  transition:background .3s,opacity .3s;
}
.match-dot.show{display:block}
.match-dot.ok{background:var(--success)}
.match-dot.bad{background:var(--error)}

/* ── PASSWORD STRENGTH ── */
.strength-bar-wrap{display:flex;gap:4px;margin-top:.65rem}
.strength-seg{flex:1;height:2px;background:var(--mist);transition:background .4s,transform .3s;border-radius:1px}
.strength-seg.active-weak{background:#B04040}
.strength-seg.active-fair{background:#C47A2A}
.strength-seg.active-good{background:#5B8A4A}
.strength-seg.active-strong{background:#3A7D44}
.strength-label{font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;color:var(--stone);margin-top:.45rem;transition:color .3s}

/* ── REQUIREMENTS ── */
.req-list{display:flex;flex-direction:column;gap:.38rem;margin-top:.7rem}
.req-item{display:flex;align-items:center;gap:.5rem;font-size:.65rem;font-weight:300;color:var(--stone);transition:color .3s}
.req-item svg{flex-shrink:0;transition:stroke .3s}
.req-item.met{color:var(--success)}

/* ── FORGOT LINK ── */
.forgot-link{
  display:inline-block;
  font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;
  color:var(--stone);text-decoration:none;
  border-bottom:1px solid var(--bdr);padding-bottom:1px;
  transition:color .2s,border-color .2s;
}
.forgot-link:hover{color:var(--dark);border-color:var(--dark)}

/* ── BUTTONS ── */
.btn-dark{
  width:100%;display:flex;align-items:center;justify-content:center;gap:.55rem;
  font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;
  color:#fff;background:var(--dark);border:1px solid var(--dark);
  padding:1.05rem 1.8rem;
  transition:background .3s,transform .2s,box-shadow .3s;
  cursor:pointer;font-family:'DM Sans',sans-serif;
  position:relative;overflow:hidden;
}
.btn-dark::after{
  content:'';position:absolute;inset:0;
  background:rgba(255,255,255,0);
  transition:background .25s;
}
.btn-dark:hover{background:#2a2a2a;transform:translateY(-1px);box-shadow:0 6px 20px rgba(28,28,28,.18)}
.btn-dark:active{transform:translateY(0);box-shadow:none}
.btn-ghost{
  width:100%;display:flex;align-items:center;justify-content:center;gap:.55rem;
  font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;
  color:var(--dark);background:none;border:1px solid var(--bdr);
  padding:1.05rem 1.8rem;
  transition:border-color .3s,transform .2s,box-shadow .2s;
  cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;
}
.btn-ghost:hover{border-color:var(--dark);transform:translateY(-1px);box-shadow:0 4px 12px rgba(28,28,28,.06)}

/* ── OR DIVIDER ── */
.or-divider{display:flex;align-items:center;gap:1rem;margin:1.1rem 0}
.or-divider::before,.or-divider::after{content:'';flex:1;height:1px;background:var(--bdr)}
.or-divider span{font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;color:var(--stone)}

/* ── SECTION SEPARATOR ── */
.sep{height:1px;background:var(--bdr);margin:.65rem 0 1.45rem}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  .sidebar-col{display:none !important}
}
@media(max-width:640px){
  .main-content{padding:2.5rem 1.1rem}
  .title-block{text-align:left}
}

/* ── ACCOUNT DROPDOWN ── */
.dropdown-menu {
  position: absolute;
  top: calc(100% + 20px);
  right: 0;
  width: 240px;
  background: #fff;
  border: 1px solid var(--bdr);
  box-shadow: 0 12px 48px rgba(28,28,28,0.08);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-8px);
  transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1), transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.35s;
  z-index: 50;
  padding: 0.5rem 0;
}
.dropdown-menu.open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.dropdown-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.85rem 1.4rem;
  font-size: 0.72rem;
  font-weight: 300;
  color: var(--dark);
  text-decoration: none;
  transition: background 0.25s cubic-bezier(0.16, 1, 0.3, 1), color 0.25s, transform 0.25s;
}
.dropdown-item:hover {
  background: var(--cream);
  transform: translateX(3px);
}
.dropdown-divider {
  height: 1px;
  background: var(--bdr);
  margin: 0.4rem 0;
}
</style>
</head>
