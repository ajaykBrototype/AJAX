<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Change Password — AJAX</title>
<meta name="description" content="Securely update your AJAX account password."/>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@200;300;400;500&display=swap" rel="stylesheet">
<script>
  tailwind.config = {
    theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['DM Sans','system-ui','sans-serif'] } } }
  }
</script>
<%- include('../partials/navbar-styles') %>
<style>

/* ── PAGE FADE-IN ── */
@keyframes pageIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes cardIn{from{opacity:0;transform:translateY(28px) scale(.985)}to{opacity:1;transform:translateY(0) scale(1)}}
.page-in{animation:pageIn .7s cubic-bezier(.16,1,.3,1) both}
.card-in{animation:cardIn .65s cubic-bezier(.16,1,.3,1) both;animation-delay:.08s}
.d1{animation-delay:.06s}.d2{animation-delay:.16s}.d3{animation-delay:.26s}

/* ── SIDEBAR ── */
.sidebar-link{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);text-decoration:none;border-left:2px solid transparent;transition:color .25s,border-color .25s,background .25s}
.sidebar-link:hover{color:var(--dark);background:rgba(28,28,28,.03)}
.sidebar-link.active{color:var(--dark);border-left-color:var(--dark);background:rgba(28,28,28,.04);font-weight:500}


/* ── CENTERED LAYOUT ── */
.content-area{
  padding-top:65px;
  min-height:100vh;
  display:flex;
  align-items:flex-start;
}
.layout-wrapper{
  max-width:1320px;
  margin:0 auto;
  width:100%;
  display:flex;
  align-items:flex-start;
}

/* ── MAIN CONTENT CENTERED ── */
.main-content{
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  padding:4rem 2rem 4rem;
  min-width:0;
}

/* ── BREADCRUMB ── */
.breadcrumb{
  display:flex;
  align-items:center;
  gap:.55rem;
  margin-bottom:.65rem;
  width:100%;
  max-width:520px;
}

/* ── PAGE TITLE BLOCK ── */
.title-block{
  width:100%;
  max-width:520px;
  margin-bottom:2.5rem;
  text-align:center;
}

/* ── MAIN CARD ── */
.password-card{
  background:#fff;
  border:1px solid var(--bdr);
  width:100%;
  max-width:520px;
  padding:2.75rem 3rem;
  position:relative;
}
@media(max-width:600px){
  .password-card{padding:2rem 1.5rem}
}

/* ── CARD HEADER ── */
.card-header{
  display:flex;
  align-items:center;
  gap:.9rem;
  padding-bottom:1.6rem;
  border-bottom:1px solid var(--bdr);
  margin-bottom:2rem;
}
.shield-icon-wrap{
  width:42px;height:42px;
  border:1px solid var(--bdr);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}

/* ── FORM INPUTS ── */
.field-wrap{position:relative;margin-bottom:1.35rem}
.field-label-txt{display:block;font-size:.52rem;letter-spacing:.28em;text-transform:uppercase;color:var(--stone);margin-bottom:.55rem;transition:color .2s}
.field-input{
  width:100%;
  background:#FAFAF8;
  border:1px solid var(--bdr);
  padding:.9rem 3rem .9rem 1rem;
  font-size:.88rem;
  font-weight:300;
  font-family:'DM Sans',sans-serif;
  color:var(--dark);
  outline:none;
  transition:border-color .25s,box-shadow .25s,background .2s;
}
.field-input:focus{border-color:var(--dark);box-shadow:0 0 0 3px rgba(28,28,28,.06);background:#fff}
.field-input.error{border-color:var(--error);background:#fff}
.field-input.success{border-color:var(--success);background:#fff}
.field-input::placeholder{color:rgba(155,142,131,.55);font-size:.82rem}
.eye-btn{
  position:absolute;right:.9rem;top:50%;
  transform:translateY(-50%) translateY(8px);
  background:none;border:none;cursor:pointer;
  color:var(--stone);padding:3px;
  display:flex;align-items:center;
  transition:color .2s;
}
.eye-btn:hover{color:var(--dark)}
.field-error{font-size:.6rem;color:var(--error);letter-spacing:.05em;margin-top:.35rem;display:none;padding-left:1px}
.field-error.show{display:block}

/* ── STATUS DOT ── */
.match-dot{
  position:absolute;right:.9rem;top:50%;
  transform:translateY(-50%) translateY(8px);
  width:7px;height:7px;border-radius:50%;
  display:none;
  transition:background .3s,opacity .3s;
}
.match-dot.show{display:block}
.match-dot.ok{background:var(--success)}
.match-dot.bad{background:var(--error)}

/* ── PASSWORD STRENGTH ── */
.strength-bar-wrap{display:flex;gap:4px;margin-top:.65rem}
.strength-seg{flex:1;height:2px;background:var(--mist);transition:background .4s,transform .3s;border-radius:1px}
.strength-seg.active-weak{background:#B04040}
.strength-seg.active-fair{background:#C47A2A}
.strength-seg.active-good{background:#5B8A4A}
.strength-seg.active-strong{background:#3A7D44}
.strength-label{font-size:.55rem;letter-spacing:.15em;text-transform:uppercase;color:var(--stone);margin-top:.45rem;transition:color .3s}

/* ── REQUIREMENTS ── */
.req-list{display:flex;flex-direction:column;gap:.38rem;margin-top:.7rem}
.req-item{display:flex;align-items:center;gap:.5rem;font-size:.65rem;font-weight:300;color:var(--stone);transition:color .3s}
.req-item svg{flex-shrink:0;transition:stroke .3s}
.req-item.met{color:var(--success)}

/* ── FORGOT LINK ── */
.forgot-link{
  display:inline-block;
  font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;
  color:var(--stone);text-decoration:none;
  border-bottom:1px solid var(--bdr);padding-bottom:1px;
  transition:color .2s,border-color .2s;
}
.forgot-link:hover{color:var(--dark);border-color:var(--dark)}

/* ── BUTTONS ── */
.btn-dark{
  width:100%;display:flex;align-items:center;justify-content:center;gap:.55rem;
  font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;
  color:#fff;background:var(--dark);border:1px solid var(--dark);
  padding:1.05rem 1.8rem;
  transition:background .3s,transform .2s,box-shadow .3s;
  cursor:pointer;font-family:'DM Sans',sans-serif;
  position:relative;overflow:hidden;
}
.btn-dark::after{
  content:'';position:absolute;inset:0;
  background:rgba(255,255,255,0);
  transition:background .25s;
}
.btn-dark:hover{background:#2a2a2a;transform:translateY(-1px);box-shadow:0 6px 20px rgba(28,28,28,.18)}
.btn-dark:active{transform:translateY(0);box-shadow:none}
.btn-ghost{
  width:100%;display:flex;align-items:center;justify-content:center;gap:.55rem;
  font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;
  color:var(--dark);background:none;border:1px solid var(--bdr);
  padding:1.05rem 1.8rem;
  transition:border-color .3s,transform .2s,box-shadow .2s;
  cursor:pointer;font-family:'DM Sans',sans-serif;text-decoration:none;
}
.btn-ghost:hover{border-color:var(--dark);transform:translateY(-1px);box-shadow:0 4px 12px rgba(28,28,28,.06)}

/* ── OR DIVIDER ── */
.or-divider{display:flex;align-items:center;gap:1rem;margin:1.1rem 0}
.or-divider::before,.or-divider::after{content:'';flex:1;height:1px;background:var(--bdr)}
.or-divider span{font-size:.52rem;letter-spacing:.2em;text-transform:uppercase;color:var(--stone)}

/* ── SECTION SEPARATOR ── */
.sep{height:1px;background:var(--bdr);margin:.65rem 0 1.45rem}

/* ── RESPONSIVE ── */
@media(max-width:960px){
  .sidebar-col{display:none !important}
}
@media(max-width:640px){
  .main-content{padding:2.5rem 1.1rem}
  .title-block{text-align:left}
}

</style>
<%- include('../partials/footer-styles') %>
</head>
<body>

<%- include('../partials/navbar', { hasSidebarToggle: true }) %>
<%- include('../partials/sidebar-drawer', { activePage: 'profile' }) %>

<!-- ══ PAGE BODY ══ -->
<div class="content-area">
  <div class="layout-wrapper">

    <%- include('../partials/sidebar', { activePage: 'profile' }) %>

    <!-- MAIN CONTENT -->
    <main class="main-content page-in">

      <%- include('../partials/breadcrumbs', { 
          breadcrumbs: [
              { name: "My Profile", url: "/profile" },
              { name: "Change Password" }
          ] 
      }) %>

      <!-- Title block -->
      <div class="title-block page-in d1">
        <p style="font-size:.5rem;letter-spacing:.35em;text-transform:uppercase;color:var(--stone);margin-bottom:.4rem">Account Security</p>
        <h1 style="font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(1.85rem,4vw,2.55rem);line-height:1.1;color:var(--dark)">Change Password</h1>
      </div>

      <!-- ── PASSWORD CARD ── -->
      <div class="password-card card-in">

        <!-- Card header -->
        <div class="card-header">
          <div class="shield-icon-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--dark)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <p style="font-size:.82rem;font-weight:400;color:var(--dark);margin-bottom:.15rem">Update your password</p>
            <p style="font-size:.7rem;font-weight:300;color:var(--stone)">Choose a strong, unique password to keep your account secure.</p>
          </div>
        </div>



        <form id="change-password-form" novalidate>

          <!-- ── Current Password ── -->
          <div class="field-wrap">
            <label class="field-label-txt" for="current-password">Current Password</label>
            <input
              class="field-input"
              type="password"
              id="current-password"
              name="currentPassword"
              autocomplete="current-password"
              placeholder="Enter your current password"
            />
            <button type="button" class="eye-btn" id="eye-current" aria-label="Toggle current password visibility">
              <svg id="eye-icon-current" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <p class="field-error" id="current-error">Please enter your current password.</p>
          </div>

          <!-- Separator -->
          <div class="sep"></div>

          <!-- ── New Password ── -->
          <div class="field-wrap">
            <label class="field-label-txt" for="new-password">New Password</label>
            <input
              class="field-input"
              type="password"
              id="new-password"
              name="newPassword"
              autocomplete="new-password"
              placeholder="Create a new password"
            />
            <button type="button" class="eye-btn" id="eye-new" aria-label="Toggle new password visibility">
              <svg id="eye-icon-new" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <p class="field-error" id="new-error">Password must be at least 8 characters.</p>

            <!-- Strength bar -->
            <div class="strength-bar-wrap" id="strength-bar" style="display:none;">
              <div class="strength-seg" id="seg1"></div>
              <div class="strength-seg" id="seg2"></div>
              <div class="strength-seg" id="seg3"></div>
              <div class="strength-seg" id="seg4"></div>
            </div>
            <p class="strength-label" id="strength-label" style="display:none;"></p>

            <!-- Requirements -->
            <div class="req-list" id="req-list" style="display:none;">
              <div class="req-item unmet" id="req-length">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                At least 8 characters
              </div>
              <div class="req-item unmet" id="req-upper">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                One uppercase letter
              </div>
              <div class="req-item unmet" id="req-number">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                One number
              </div>
              <div class="req-item unmet" id="req-special">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                One special character
              </div>
            </div>
          </div>

          <!-- ── Confirm New Password ── -->
          <div class="field-wrap">
            <label class="field-label-txt" for="confirm-password">Confirm New Password</label>
            <input
              class="field-input"
              type="password"
              id="confirm-password"
              name="confirmPassword"
              autocomplete="new-password"
              placeholder="Re-enter your new password"
            />
            <button type="button" class="eye-btn" id="eye-confirm" aria-label="Toggle confirm password visibility" style="right:2.4rem;">
              <svg id="eye-icon-confirm" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <div class="match-dot" id="match-dot"></div>
            <p class="field-error" id="confirm-error">Passwords do not match.</p>
          </div>

          <!-- Forgot password -->
          <div style="text-align:right;margin-top:-.3rem;margin-bottom:1.65rem;">
            <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-dark" id="submit-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Save Changes
          </button>

          <div class="or-divider"><span>or</span></div>

          <a href="/profile" class="btn-ghost">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Back to Profile
          </a>

        </form>
      </div>
      <!-- End card -->

      <!-- ── Security info strip ── -->
      <div class="card-in" style="width:100%;max-width:520px;margin-top:1rem;animation-delay:.18s;">
        <div style="background:var(--dark);padding:1.6rem 2rem;display:flex;align-items:flex-start;gap:2rem;flex-wrap:wrap;">
          <div style="flex:1;min-width:160px;">
            <p style="font-size:.46rem;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.38);margin-bottom:.7rem">Security Tips</p>
            <ul style="display:flex;flex-direction:column;gap:.55rem;">
              <li style="display:flex;align-items:flex-start;gap:.6rem;">
                <svg style="flex-shrink:0;margin-top:1px" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.5)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span style="font-size:.65rem;font-weight:300;color:rgba(255,255,255,.6);line-height:1.7">Never reuse passwords from other accounts</span>
              </li>
              <li style="display:flex;align-items:flex-start;gap:.6rem;">
                <svg style="flex-shrink:0;margin-top:1px" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.5)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span style="font-size:.65rem;font-weight:300;color:rgba(255,255,255,.6);line-height:1.7">Mix letters, numbers &amp; symbols for strength</span>
              </li>
            </ul>
          </div>
          <div style="display:flex;align-items:flex-start;gap:.55rem;padding-top:.15rem;">
            <div style="width:6px;height:6px;border-radius:50%;background:#3A7D44;flex-shrink:0;margin-top:4px;"></div>
            <div>
              <p style="font-size:.75rem;color:#fff;margin-bottom:.12rem">Active &amp; Secure</p>
              <p style="font-size:.65rem;font-weight:300;color:rgba(255,255,255,.45)">Last changed <strong style="color:rgba(255,255,255,.7);font-weight:400">3 months ago</strong></p>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<!-- ══ FOOTER ══ -->
<%- include('../partials/footer') %>

<script>

/* ─── EYE TOGGLE ─── */
function setupEye(btnId, inputId, iconId) {
  const btn   = document.getElementById(btnId);
  const input = document.getElementById(inputId);
  if(!btn || !input) return;
  btn.addEventListener('click', () => {
    const show = input.type === 'password';
    input.type = show ? 'text' : 'password';
    document.getElementById(iconId).innerHTML = show
      ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`
      : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
  });
}
setupEye('eye-current', 'current-password', 'eye-icon-current');
setupEye('eye-new',     'new-password',      'eye-icon-new');
setupEye('eye-confirm', 'confirm-password',  'eye-icon-confirm');

const style = document.createElement('style');
style.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
document.head.appendChild(style);
</script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/user/resetPassword.js"></script>
</body>
</html>
