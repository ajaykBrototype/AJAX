          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Wishlist
        </a>
        <a href="/wallet" class="sidebar-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
          Wallet
        </a>
        <div style="height:1px;background:var(--bdr);margin:1.75rem 1rem"></div>
        <a href="/logout" class="sidebar-link" style="color:#B04040">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Logout
        </a>
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main-content page-in">

      <!-- Breadcrumb -->
      <div class="breadcrumb page-in d1">
        <a href="/profile" style="font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:var(--stone);text-decoration:none;transition:color .2s" onmouseover="this.style.color='var(--dark)'" onmouseout="this.style.color='var(--stone)'">Profile</a>
        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="var(--stone)" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
        <span style="font-size:.52rem;letter-spacing:.22em;text-transform:uppercase;color:var(--dark)">Security</span>
      </div>

      <!-- Title block -->
      <div class="title-block page-in d1">
        <p style="font-size:.5rem;letter-spacing:.35em;text-transform:uppercase;color:var(--stone);margin-bottom:.4rem">Account Security</p>
        <h1 style="font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(1.85rem,4vw,2.55rem);line-height:1.1;color:var(--dark)">Change Password</h1>
      </div>

      <!-- ── PASSWORD CARD ── -->
      <div class="password-card card-in">

        <!-- Card header -->
        <div class="card-header">
          <div class="shield-icon-wrap">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--dark)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div>
            <p style="font-size:.82rem;font-weight:400;color:var(--dark);margin-bottom:.15rem">Update your password</p>
            <p style="font-size:.7rem;font-weight:300;color:var(--stone)">Choose a strong, unique password to keep your account secure.</p>
          </div>
        </div>



        <form id="change-password-form" novalidate>

          <!-- ── Current Password ── -->
          <div class="field-wrap">
            <label class="field-label-txt" for="current-password">Current Password</label>
            <input
              class="field-input"
              type="password"
              id="current-password"
              name="currentPassword"
              autocomplete="current-password"
              placeholder="Enter your current password"
            />
            <button type="button" class="eye-btn" id="eye-current" aria-label="Toggle current password visibility">
              <svg id="eye-icon-current" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <p class="field-error" id="current-error">Please enter your current password.</p>
          </div>

          <!-- Separator -->
          <div class="sep"></div>

          <!-- ── New Password ── -->
          <div class="field-wrap">
            <label class="field-label-txt" for="new-password">New Password</label>
            <input
              class="field-input"
              type="password"
              id="new-password"
              name="newPassword"
              autocomplete="new-password"
              placeholder="Create a new password"
            />
            <button type="button" class="eye-btn" id="eye-new" aria-label="Toggle new password visibility">
              <svg id="eye-icon-new" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <p class="field-error" id="new-error">Password must be at least 8 characters.</p>

            <!-- Strength bar -->
            <div class="strength-bar-wrap" id="strength-bar" style="display:none;">
              <div class="strength-seg" id="seg1"></div>
              <div class="strength-seg" id="seg2"></div>
              <div class="strength-seg" id="seg3"></div>
              <div class="strength-seg" id="seg4"></div>
            </div>
            <p class="strength-label" id="strength-label" style="display:none;"></p>

            <!-- Requirements -->
            <div class="req-list" id="req-list" style="display:none;">
              <div class="req-item unmet" id="req-length">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                At least 8 characters
              </div>
              <div class="req-item unmet" id="req-upper">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                One uppercase letter
              </div>
              <div class="req-item unmet" id="req-number">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                One number
              </div>
              <div class="req-item unmet" id="req-special">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                One special character
              </div>
            </div>
          </div>

          <!-- ── Confirm New Password ── -->
          <div class="field-wrap">
            <label class="field-label-txt" for="confirm-password">Confirm New Password</label>
            <input
              class="field-input"
              type="password"
              id="confirm-password"
              name="confirmPassword"
              autocomplete="new-password"
              placeholder="Re-enter your new password"
            />
            <button type="button" class="eye-btn" id="eye-confirm" aria-label="Toggle confirm password visibility" style="right:2.4rem;">
              <svg id="eye-icon-confirm" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <div class="match-dot" id="match-dot"></div>
            <p class="field-error" id="confirm-error">Passwords do not match.</p>
          </div>

          <!-- Forgot password -->
          <div style="text-align:right;margin-top:-.3rem;margin-bottom:1.65rem;">
            <a href="/forgot-password" class="forgot-link">Forgot Password?</a>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-dark" id="submit-btn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Save Changes
          </button>

          <div class="or-divider"><span>or</span></div>

          <a href="/profile" class="btn-ghost">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Back to Profile
          </a>

        </form>
      </div>
      <!-- End card -->

      <!-- ── Security info strip ── -->
      <div class="card-in" style="width:100%;max-width:520px;margin-top:1rem;animation-delay:.18s;">
        <div style="background:var(--dark);padding:1.6rem 2rem;display:flex;align-items:flex-start;gap:2rem;flex-wrap:wrap;">
          <div style="flex:1;min-width:160px;">
            <p style="font-size:.46rem;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.38);margin-bottom:.7rem">Security Tips</p>
            <ul style="display:flex;flex-direction:column;gap:.55rem;">
              <li style="display:flex;align-items:flex-start;gap:.6rem;">
                <svg style="flex-shrink:0;margin-top:1px" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.5)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span style="font-size:.65rem;font-weight:300;color:rgba(255,255,255,.6);line-height:1.7">Never reuse passwords from other accounts</span>
              </li>
              <li style="display:flex;align-items:flex-start;gap:.6rem;">
                <svg style="flex-shrink:0;margin-top:1px" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.5)" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                <span style="font-size:.65rem;font-weight:300;color:rgba(255,255,255,.6);line-height:1.7">Mix letters, numbers &amp; symbols for strength</span>
              </li>
            </ul>
          </div>
          <div style="display:flex;align-items:flex-start;gap:.55rem;padding-top:.15rem;">
            <div style="width:6px;height:6px;border-radius:50%;background:#3A7D44;flex-shrink:0;margin-top:4px;"></div>
            <div>
              <p style="font-size:.75rem;color:#fff;margin-bottom:.12rem">Active &amp; Secure</p>
              <p style="font-size:.65rem;font-weight:300;color:rgba(255,255,255,.45)">Last changed <strong style="color:rgba(255,255,255,.7);font-weight:400">3 months ago</strong></p>
            </div>
          </div>
        </div>
      </div>

    </main>
  </div>
</div>

<!-- ══ FOOTER ══ -->
