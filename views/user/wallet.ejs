<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>My Wallet — AJAX</title>
<meta name="description" content="Manage your AJAX digital wallet, check balance and view transaction history."/>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
<script>
tailwind.config = {
  theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['Plus Jakarta Sans','system-ui','sans-serif'] } } }
}
</script>
<%- include('../partials/navbar-styles') %>
<style>
:root {
    --brand-dark: #1C1C1C;
    --brand-stone: #8E8E8E;
    --brand-cream: #F9F9F7;
    --brand-bdr: #EEEEEE;
}

body { background-color: #FFFFFF; font-family: 'Plus Jakarta Sans', sans-serif; color: var(--brand-dark); }

/* ── PAGE FADE-IN ── */
@keyframes pageIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.page-in{animation:pageIn .7s cubic-bezier(.16,1,.3,1) both}
.d1{animation-delay:.06s}.d2{animation-delay:.14s}.d3{animation-delay:.22s}.d4{animation-delay:.30s}

/* ── SIDEBAR OVERRIDE (for consistency) ── */
.sidebar-link{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--brand-stone);text-decoration:none;border-left:2px solid transparent;transition:all .25s}
.sidebar-link:hover{color:var(--brand-dark);background:rgba(28,28,28,.03)}
.sidebar-link.active{color:var(--brand-dark);border-left-color:var(--brand-dark);background:rgba(28,28,28,.04);font-weight:600}

/* ── WALLET CARD ── */
.wallet-card { background: var(--brand-dark); color: #fff; border-radius: 28px; padding: 2.5rem; position: relative; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.12); }
.wallet-card::after { content: ''; position: absolute; top: -50%; right: -20%; width: 300px; height: 300px; background: rgba(255,255,255,0.03); border-radius: 50%; }

.balance-label { font-size: 0.55rem; letter-spacing: 0.35em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 0.75rem; font-weight: 700; }
.balance-amount { font-family: 'Playfair Display', serif; font-size: 3.2rem; line-height: 1; margin-bottom: 2rem; }
.card-holder-label { font-size: 0.5rem; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 0.35rem; }
.card-holder-name { font-size: 0.85rem; letter-spacing: 0.05em; font-weight: 500; }

.btn-add { background: #fff; color: var(--brand-dark); padding: 0.9rem 1.8rem; border-radius: 16px; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; transition: all 0.3s; width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
.btn-add:hover { background: var(--brand-cream); transform: translateY(-2px); }

/* ── TABLE ── */
.trans-table th { padding: 1.25rem 1rem; font-size: 0.55rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--brand-stone); font-weight: 800; border-bottom: 1px solid var(--brand-bdr); text-align: left; }
.trans-table td { padding: 1.5rem 1rem; font-size: 0.75rem; color: var(--brand-dark); border-bottom: 1px solid var(--brand-bdr); vertical-align: middle; }
.status-tag { padding: 0.35rem 0.8rem; border-radius: 100px; font-size: 0.55rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; }
.status-credit { background: #E8F5E9; color: #2E7D32; }
.status-debit { background: #FEE2E2; color: #DC2626; }

.empty-state { text-align: center; padding: 5rem 2rem; border: 1px dashed var(--brand-bdr); border-radius: 24px; margin-top: 1rem; }

/* ── ADD FUNDS MODAL (MODERN UI) ── */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.3); backdrop-filter: blur(12px); z-index: 1000; display: none; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s; }
.modal-overlay.open { display: flex; opacity: 1; }
.modal-content { background: #FFFFFF; width: 92%; max-width: 440px; padding: 3rem 2.5rem; border-radius: 32px; position: relative; transform: translateY(30px); transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 40px 100px rgba(0,0,0,0.15); border: 1px solid rgba(0,0,0,0.05); }
.modal-overlay.open .modal-content { transform: translateY(0); }

.modal-title { font-family: 'Playfair Display', serif; font-size: 2.4rem; font-weight: 500; margin-bottom: 2rem; text-align: center; color: var(--brand-dark); }
.modal-close { position: absolute; top: 1.75rem; right: 1.75rem; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; background: #F8F8F8; border-radius: 50%; cursor: pointer; transition: all 0.2s; border: none; }
.modal-close:hover { background: #EEE; transform: rotate(90deg); }

.preset-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 2.5rem; }
.preset-btn { background: #F9F9F9; border: 1px solid transparent; padding: 1rem 0.5rem; font-size: 0.75rem; font-weight: 700; border-radius: 16px; transition: all 0.3s; cursor: pointer; color: var(--brand-dark); }
.preset-btn:hover { background: #EEE; }
.preset-btn.active { background: var(--brand-dark); color: #fff; border-color: var(--brand-dark); box-shadow: 0 8px 16px rgba(0,0,0,0.15); }

.custom-label { font-size: 0.55rem; letter-spacing: 0.25em; text-transform: uppercase; font-weight: 800; color: var(--brand-stone); margin-bottom: 1rem; text-align: center; }
.amount-input-wrapper { background: #F9F9F9; padding: 1.75rem; border-radius: 20px; display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 2.5rem; border: 1px solid transparent; transition: all 0.3s; }
.amount-input-wrapper:focus-within { background: #FFF; border-color: var(--brand-dark); box-shadow: 0 10px 25px rgba(0,0,0,0.04); }
.amount-prefix { font-size: 1.4rem; font-weight: 700; color: var(--brand-dark); }
.amount-input { background: none; border: none; font-size: 2.2rem; font-weight: 800; width: 140px; outline: none; text-align: center; font-family: 'Plus Jakarta Sans', sans-serif; color: var(--brand-dark); }

.summary-card { background: #F9F9F9; padding: 1.5rem 2rem; border-radius: 20px; margin-bottom: 2rem; display: flex; align-items: center; justify-content: space-between; }
.summary-label { font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; font-weight: 700; color: var(--brand-stone); }
.summary-value { font-size: 1.6rem; font-weight: 800; color: var(--brand-dark); }

.btn-secure { background: var(--brand-dark); color: #fff; width: 100%; padding: 1.4rem; border-radius: 20px; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; transition: all 0.3s; box-shadow: 0 15px 35px rgba(0,0,0,0.15); }
.btn-secure:hover { background: #333; transform: translateY(-3px); box-shadow: 0 20px 45px rgba(0,0,0,0.2); }


</style>
<%- include('../partials/footer-styles') %>
</head>
<body>

<%- include('../partials/navbar', { hasSidebarToggle: true }) %>

<div style="padding-top:65px; min-height:100vh;">
  <div style="max-width:1320px; margin:0 auto; display:flex; align-items:flex-start;">

    <%- include('../partials/sidebar', { activePage: 'wallet' }) %>

    <main class="page-in" style="flex:1; padding:3.5rem 3rem; min-width:0;">
      
      <!-- Breadcrumbs -->
      <%- include('../partials/breadcrumbs', { 
          breadcrumbs: [
              { name: "Profile", url: "/profile" },
              { name: "Wallet" }
          ] 
      }) %>


      <header style="margin-bottom: 3.5rem;" class="page-in d2">
        <h1 style="font-family:'Playfair Display',serif; font-size: 3rem; font-weight: 400; line-height: 1.1; margin-bottom: 0.75rem;">My Wallet</h1>
        <p style="font-size: 0.65rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--brand-stone); font-weight: 600;">Manage your balance and track your transactions</p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Left Column: Balance Card -->
        <div class="lg:col-span-4 page-in d3">
          <div class="wallet-card">
            <div class="balance-label">Available Balance</div>
            <div class="balance-amount">₹<%= wallet ? wallet.balance.toFixed(2) : '0.00' %></div>
            
            <div style="margin-bottom: 2.5rem;">
              <div class="card-holder-label">Card Holder</div>
              <div class="card-holder-name"><%= user.name || 'Valued Customer' %></div>
            </div>

            <button onclick="openAddMoneyModal()" class="btn-add">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Money
            </button>
          </div>

          <div style="margin-top: 2rem; padding: 1.5rem; border: 1px solid var(--brand-bdr); border-radius: 20px;" class="bg-stone-50/50">
              <p style="font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--brand-stone); font-weight: 700; margin-bottom: 0.5rem;">Quick Tip</p>
              <p style="font-size: 0.7rem; line-height: 1.6; color: var(--brand-stone);">You can use your wallet balance for instant checkouts and hassle-free returns.</p>
          </div>
        </div>

        <!-- Right Column: Transaction History -->
        <div class="lg:col-span-8 page-in d4">
          <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem;">
            <h2 style="font-family:'Playfair Display',serif; font-size: 1.4rem; font-weight: 400;">Recent Transactions</h2>
            <p style="font-size: 0.55rem; letter-spacing: 0.1em; font-weight: 700; color: var(--brand-stone); text-transform: uppercase;">Total: <%= (wallet && wallet.transactions) ? wallet.transactions.length : 0 %></p>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full trans-table">
              <thead>
                <tr>
                  <th>Date & Time</th>
                  <th>Transaction ID</th>
                  <th>Order ID</th>
                  <th>Description</th>
                  <th>Status</th>
                  <th>Amount</th>
                </tr>
              </thead>
              <tbody>
                <% if (wallet && wallet.transactions && wallet.transactions.length > 0) { %>
                  <% wallet.transactions.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(trans => { %>
                    <tr>
                      <td>
                        <div class="flex flex-col">
                          <span class="font-bold"><%= new Date(trans.date).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
                          <span class="text-[10px] text-stone-400 font-medium"><%= new Date(trans.date).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
                        </div>
                      </td>
                      <td class="font-mono text-[10px] text-stone-400">#<%= trans.transactionId || 'N/A' %></td>
                      <td class="font-bold"><%= trans.orderId || '—' %></td>
                      <td class="text-stone-500"><%= trans.description %></td>
                      <td>
                        <span class="status-tag <%= trans.type === 'credit' ? 'status-credit' : 'status-debit' %>">
                          <%= trans.type %>
                        </span>
                      </td>
                      <td class="font-bold <%= trans.type === 'credit' ? 'text-green-600' : 'text-red-600' %>">
                        <%= trans.type === 'credit' ? '+' : '-' %>₹<%= trans.amount.toFixed(2) %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="6">
                      <div class="empty-state">
                        <div style="width: 48px; height: 48px; background: var(--brand-cream); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand-stone)" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
                        </div>
                        <h3 style="font-family:'Playfair Display',serif; font-size: 1.2rem; margin-bottom: 0.5rem;">No Transactions Yet</h3>
                        <p style="font-size: 0.75rem; color: var(--brand-stone); max-width: 280px; margin: 0 auto;">When you add funds or make purchases using your wallet, they will appear here.</p>
                      </div>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

    </main>
  </div>
</div>

<%- include('../partials/footer') %>

<!-- ══ ADD FUNDS MODAL ══ -->
<div id="addFundsModal" class="modal-overlay">
  <div class="modal-content page-in">
    <button onclick="closeAddMoneyModal()" class="modal-close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    
    <h2 class="modal-title">Add Funds</h2>
    
    <div class="preset-grid">
      <button onclick="setPreset(100)" class="preset-btn">₹100</button>
      <button onclick="setPreset(500)" class="preset-btn">₹500</button>
      <button onclick="setPreset(1000)" class="preset-btn active">₹1000</button>
    </div>
    
    <div class="custom-amount-sec">
      <p class="custom-label">Custom Amount</p>
      <div class="amount-input-wrapper">
        <span class="amount-prefix">₹</span>
        <input type="number" id="walletAmountInput" class="amount-input" value="1000" oninput="updateSummary()">
      </div>
    </div>
    
    <div class="summary-card">
      <span class="summary-label">Total Payment</span>
      <span class="summary-value">₹<span id="summaryAmount">1000</span></span>
    </div>
    
    <button onclick="initiateAddMoney()" class="btn-secure">Secure Top Up</button>
  </div>
</div>


<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="/js/user/wallet.js"></script>

</body>
</html>
