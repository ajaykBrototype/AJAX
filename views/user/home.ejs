  </div>
</section>

<!-- TICKER -->
<div class="ticker">
  <div class="ticker-t">
    <span class="t-item">Free Shipping on Orders Over ₹5,000</span>
    <span class="t-item" style="opacity:.4">✦</span>
    <span class="t-item">New Collection — Autumn / Winter 2026</span>
    <span class="t-item" style="opacity:.4">✦</span>
    <span class="t-item">Sustainably Crafted · Endlessly Refined</span>
    <span class="t-item" style="opacity:.4">✦</span>
    <span class="t-item">Complimentary Returns Within 30 Days</span>
    <span class="t-item" style="opacity:.4">✦</span>
    <span class="t-item">Free Shipping on Orders Over ₹5,000</span>
    <span class="t-item" style="opacity:.4">✦</span>
    <span class="t-item">New Collection — Autumn / Winter 2026</span>
    <span class="t-item" style="opacity:.4">✦</span>
    <span class="t-item">Sustainably Crafted · Endlessly Refined</span>
    <span class="t-item" style="opacity:.4">✦</span>
    <span class="t-item">Complimentary Returns Within 30 Days</span>
    <span class="t-item" style="opacity:.4">✦</span>
  </div>
</div>

<!-- CATEGORY GRID -->
<div class="sec">
  <div class="sec-hdr sr">
    <div>
      <p class="sec-eye">Shop by Category</p>
