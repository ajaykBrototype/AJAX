    </div>
    <div class="p-card sr d4">
      <div class="p-thumb">
        <span class="p-tag">Essential</span>
        <img src="https://images.unsplash.com/photo-1539109136881-3be0616acf4b?w=600&q=80&auto=format&fit=crop" alt="Linen Shirt" loading="lazy"/>
        <div class="p-ov"><button class="p-qa">Quick Add</button></div>
      </div>
      <div class="p-info"><p class="p-name">Oversized Linen Shirt</p><p class="p-price">₹4,900</p></div>
    </div>
