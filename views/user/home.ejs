      <div class="cat-ov"></div>
      <div class="cat-txt">
        <span class="cat-lbl">Explore Collection</span>
        <div class="cat-name">Men</div>
        <div class="cat-arr">Shop Now <svg width="16" height="8" viewBox="0 0 16 8" fill="none"><path d="M0 4h14M10 1l4 3-4 3" stroke="currentColor" stroke-width="1"/></svg></div>
      </div>
    </a>
    <!-- WOMEN -->
    <a href="#" class="cat-tile cat-rt">
      <img src="https://images.unsplash.com/photo-1581338834647-b0fb40704e21?w=700&q=80&auto=format&fit=crop" alt="Women" loading="lazy"/>
      <div class="cat-ov"></div>
      <div class="cat-txt">
        <span class="cat-lbl">Explore Collection</span>
        <div class="cat-name">Women</div>
        <div class="cat-arr">Shop Now <svg width="16" height="8" viewBox="0 0 16 8" fill="none"><path d="M0 4h14M10 1l4 3-4 3" stroke="currentColor" stroke-width="1"/></svg></div>
      </div>
    </a>
    <!-- NEW ARRIVALS -->
    <a href="#" class="cat-tile cat-rb">
