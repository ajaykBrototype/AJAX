<script>
/* Navbar scroll */
const nb=document.getElementById('navbar'),lg=document.getElementById('logo');
const navs=document.querySelectorAll('[data-nav]'),svgs=document.querySelectorAll('.ns'),hls=document.querySelectorAll('.hl');
function setNav(dark){
  const c=dark?'#1C1C1C':'#fff';
  lg.style.color=c;
  navs.forEach(e=>e.style.color=c);
  svgs.forEach(s=>s.setAttribute('stroke',c));
  hls.forEach(l=>l.setAttribute('stroke',c));
  if(dark){nb.classList.add('scrolled')}else{nb.classList.remove('scrolled')}
}
window.addEventListener('scroll',()=>setNav(window.scrollY>70),{passive:true});
setNav(false);

/* Mobile menu */
document.getElementById('ham').addEventListener('click',()=>document.getElementById('mob-menu').classList.add('open'));
document.getElementById('mob-close').addEventListener('click',()=>document.getElementById('mob-menu').classList.remove('open'));

/* Scroll reveal */
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');obs.unobserve(e.target)}})},{threshold:0.07,rootMargin:'0px 0px -30px 0px'});
document.querySelectorAll('.sr').forEach(el=>obs.observe(el));

/* Account Dropdown */
const accBtn=document.getElementById('accountBtn'),accDrop=document.getElementById('accountDropdown');
if(accBtn&&accDrop){
  accBtn.addEventListener('click',e=>{
    e.stopPropagation();
    accDrop.classList.toggle('opacity-0');
    accDrop.classList.toggle('invisible');
    accDrop.classList.toggle('translate-y-[-8px]');
  });
  document.addEventListener('click',e=>{
    if(!accDrop.contains(e.target)&&!accBtn.contains(e.target)){
      accDrop.classList.add('opacity-0','invisible','translate-y-[-8px]');
    }
  });
}
</script>

