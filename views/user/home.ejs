<!-- EDITORIAL SPLIT -->
<section style="margin:1rem 0">
  <div class="ed-split">
    <div class="ed-img sr">
      <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=900&q=85&auto=format&fit=crop" alt="Modern Essentials" loading="lazy"/>
