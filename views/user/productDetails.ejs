    const currentProductId = '<%= product._id %>';
    let wishlistedVariants = <%- JSON.stringify(wishlistedVariants || []) %>;
</script>
<script src="/js/user/productDetail.js"></script>
<script src="/js/user/wishlist.js"></script>
</body>
</html>
