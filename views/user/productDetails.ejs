    <%- include('../partials/footer') %>

    <script>
        // Initialize Icons
        lucide.createIcons();

        // Luxury Image Load Animations
        window.addEventListener('load', () => {
            // Main Image Zoom Out effect
            if (document.querySelector('.main-image')) {
                gsap.from('.main-image', {
                    scale: 1.1,
                    duration: 1.5,
                    ease: "power2.out"
                });
            }

            // Simple reveal for elements that might still have the class
            gsap.to('.reveal', {
                opacity: 1,
                y: 0,
                duration: 0.8,
                stagger: 0.1,
                ease: "power2.out"
            });
        });

        // Image Switching Logic
        function switchImage(src, thumb) {
            const mainImg = document.getElementById('mainImage');
            
            // Add fade-out/in effect
            gsap.to(mainImg, {
                opacity: 0,
                duration: 0.2,
                onComplete: () => {
                    mainImg.src = src;
                    gsap.to(mainImg, { opacity: 1, duration: 0.4 });
                }
            });

            // Update active thumbnail
            document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active-thumb'));
            thumb.classList.add('active-thumb');
        }

        // Simple Quantity Stepper Logic
        const qtyVal = document.querySelector('.qty-val');
        document.querySelectorAll('.qty-btn').forEach((btn, idx) => {
            btn.addEventListener('click', () => {
                let current = parseInt(qtyVal.innerText);
                if (idx === 0 && current > 1) qtyVal.innerText = current - 1;
                if (idx === 1) qtyVal.innerText = current + 1;
            });
        });

        // Size Button Toggle
        document.querySelectorAll('.size-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
            });
        });

        // Swatch Toggle
        document.querySelectorAll('.swatch').forEach(swatch => {
            swatch.addEventListener('click', () => {
                document.querySelectorAll('.swatch').forEach(s => s.classList.remove('active'));
                swatch.classList.add('active');
            });
        });

        // Image Zoom Logic
        const imageContainer = document.querySelector('.main-image-container');
        const mainImage = document.getElementById('mainImage');

        imageContainer.addEventListener('mousemove', (e) => {
            const rect = imageContainer.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;

            const xPercent = (x / rect.width) * 100;
            const yPercent = (y / rect.height) * 100;

            mainImage.style.transformOrigin = `${xPercent}% ${yPercent}%`;
            mainImage.style.transform = "scale(2)";
        });

        imageContainer.addEventListener('mouseleave', () => {
            mainImage.style.transform = "scale(1)";
            mainImage.style.transformOrigin = "center center";
        });
    </script>
