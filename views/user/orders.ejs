<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Order History — AJAX</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Outfit:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script>
tailwind.config = {
  theme: { 
    extend: { 
      fontFamily: { 
        serif: ['Playfair Display', 'serif'], 
        sans: ['Outfit', 'sans-serif'] 
      },
      colors: {
        brand: {
          dark: '#1C1C1C',
          cream: '#F5F0E8',
          warm: '#FAFAF8',
          stone: '#9B8E83',
          mist: '#EAE5DC'
        }
      }
    } 
  }
}
</script>
<%- include('../partials/navbar-styles') %>
<%- include('../partials/footer-styles') %>
<style>
:root {
  --brand-dark: #1C1C1C;
  --brand-cream: #F5F0E8;
  --brand-warm: #FAFAF8;
  --brand-stone: #9B8E83;
  --brand-mist: #EAE5DC;
}

body {
  background-color: var(--brand-warm);
  font-family: 'Outfit', sans-serif;
  color: var(--brand-dark);
}

.editorial-title {
  font-family: 'Playfair Display', serif;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.order-card {
  background: #fff;
  border: 1px solid rgba(28, 28, 28, 0.04);
  border-radius: 1.5rem;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 10px 30px rgba(0,0,0,0.02);
}

.order-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 50px rgba(0,0,0,0.04);
}

.card-header {
  background: #FCFCFB;
  padding: 1.5rem 2rem;
  border-bottom: 1px solid rgba(28, 28, 28, 0.04);
}

.status-badge {
  font-size: 0.55rem;
  font-weight: 900;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  padding: 0.4rem 1rem;
  border-radius: 2rem;
}

.status-delivered { background: #EAF4EE; color: #5C8C6A; }
.status-cancelled { background: #FEF2F2; color: #B04040; }
.status-confirmed { background: #FFF9EB; color: #B48C3C; }

.btn-premium {
  font-size: 0.6rem;
  font-weight: 900;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 0.75rem 1.5rem;
  border-radius: 0.75rem;
  transition: all 0.3s ease;
}

/* Custom Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--brand-warm); }
::-webkit-scrollbar-thumb { background: var(--brand-mist); border-radius: 10px; }

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in-up { animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both; }

/* Custom Dropdown */
.dropdown-menu {
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 200px;
  z-index: 100;
  background: white;
  visibility: hidden;
  opacity: 0;
  transform: translateY(15px);
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);
  border: 1px solid rgba(28, 28, 28, 0.05);
  border-radius: 28px;
  padding: 10px;
}
.dropdown-menu.show {
  visibility: visible;
  opacity: 1;
  transform: translateY(8px);
}
.dropdown-item {
  padding: 12px 20px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #1c1c1c;
  cursor: pointer;
  border-radius: 18px;
  transition: all 0.2s ease;
  margin-bottom: 4px;
}
.dropdown-item:last-child { margin-bottom: 0; }
.dropdown-item:hover {
  background-color: #F9F9F7;
}
.dropdown-item.active {
  background-color: #111827;
  color: white;
}
</style>
</head>
<body>
<%- include('../partials/navbar', { hasSidebarToggle: false }) %>

<div style="padding-top:65px; min-height:100vh;">
    <main class="page-in max-w-[1440px] mx-auto px-6 md:px-12 pt-10 pb-24" style="flex:1; min-width:0;">
      
      <%- include('../partials/breadcrumbs', { 
          breadcrumbs: [
              { name: "MenProduct", url: "/menProductList" },
              { name: "Order History" }
          ] 
      }) %>

      <!-- Header Section -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-8 mb-12 fade-in-up relative z-50">
        <div>
          <h1 class="editorial-title text-4xl md:text-5xl font-medium mb-3">Order History</h1>
          <p class="text-[0.6rem] tracking-[0.3em] font-bold text-stone-400 uppercase">Manage your recent orders & tracking information</p>
        </div>
        
        <div class="flex items-center gap-4 w-full md:w-auto">
          <div class="relative flex-grow md:w-64">
            <input id="searchInput" type="text" placeholder="Search orders..." class="w-full bg-white border border-brand-mist/30 rounded-2xl px-6 py-3.5 text-[0.7rem] font-medium focus:ring-1 focus:ring-brand-dark focus:border-brand-dark transition-all outline-none pl-12">
            <svg class="absolute left-5 top-1/2 -translate-y-1/2 text-stone-300" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </div>
          <div class="relative w-full md:w-56" id="customSort">
            <button type="button" class="w-full bg-white border border-brand-mist/30 rounded-2xl px-6 py-3.5 flex items-center justify-between text-[0.65rem] font-black uppercase tracking-widest outline-none hover:border-brand-dark transition-all" id="dropdownTrigger">
              <span id="sortValueLabel">All Time</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="transition-transform duration-300" id="dropdownArrow">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            
            <div class="dropdown-menu mt-2 rounded-2xl py-2" id="dropdownList">
              <div class="dropdown-item px-6 py-3.5 text-[0.65rem] font-black uppercase tracking-widest cursor-pointer transition-all active text-brand-dark" data-value="all">All Time</div>
              <div class="dropdown-item px-6 py-3.5 text-[0.65rem] font-black uppercase tracking-widest cursor-pointer transition-all text-brand-dark" data-value="30days">Last 30 Days</div>
              <div class="dropdown-item px-6 py-3.5 text-[0.65rem] font-black uppercase tracking-widest cursor-pointer transition-all text-brand-dark" data-value="6months">Last 6 Months</div>
              <div class="dropdown-item px-6 py-3.5 text-[0.65rem] font-black uppercase tracking-widest cursor-pointer transition-all text-brand-dark" data-value="2025">2025 Orders</div>
            </div>
            <input type="hidden" id="sortSelect" value="all">
          </div>
        </div>
      </div>

      <!-- Orders List -->
      <div id="ordersContainer" class="space-y-8">
        
        <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
          <% orders.forEach(order => { %>
            <div class="order-card fade-in-up">
              <!-- Card Header -->
              <div class="card-header flex flex-wrap justify-between items-center gap-6">
                <div class="flex gap-10">
                  <div>
                    <p class="text-[0.5rem] font-black tracking-[0.2em] text-stone-300 uppercase mb-1">Order Placed</p>
                    <p class="text-xs font-bold text-brand-dark"><%= new Date(order.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
                  </div>
                  <div>
                    <p class="text-[0.5rem] font-black tracking-[0.2em] text-stone-300 uppercase mb-1">Total</p>
                    <p class="text-xs font-bold text-brand-dark">₹<%= order.totalAmount %></p>
                  </div>
                  <div>
                    <p class="text-[0.5rem] font-black tracking-[0.2em] text-stone-300 uppercase mb-1">Order #</p>
                    <p class="text-xs font-bold text-brand-dark">#ORD-<%= order._id.toString().slice(-8).toUpperCase() %></p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <span class="status-badge <%= order.status === 'Delivered' ? 'status-delivered' : (order.status === 'Cancelled' ? 'status-cancelled' : 'status-confirmed') %>">
                    <%= order.status %>
                  </span>
                  <a href="/orders/<%= order._id %>" class="btn-premium bg-white text-brand-dark border border-brand-dark/10 hover:bg-brand-warm flex items-center gap-2">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                    Order Details
                  </a>
                </div>
              </div>

              <!-- Card Body -->
              <div class="p-8">
                <% order.items.forEach(item => { %>
                  <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 py-4 first:pt-0 last:pb-0">
                    <div class="flex items-center gap-6">
                      <div class="w-20 h-24 bg-brand-warm rounded-xl overflow-hidden flex-shrink-0">
                        <img src="<%= item.image || '/images/default-product.png' %>" class="w-full h-full object-cover" alt="<%= item.name %>">
                      </div>
                      <div>
                        <h4 class="font-serif text-lg text-brand-dark mb-1"><%= item.name %></h4>
                        <p class="text-[0.65rem] text-stone-400 uppercase tracking-widest font-bold mb-3">SIZE: <%= item.size || 'N/A' %></p>
                        <div class="flex items-center gap-2 text-[0.6rem] font-bold text-stone-300 uppercase tracking-widest">
                          <% if (order.status === 'Delivered') { %>
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-5l-4-4h-3v10"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
                            Delivered successfully
                          <% } else if (order.status === 'Cancelled') { %>
                             <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                            Order cancelled
                          <% } else { %>
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
                            Processing order
                          <% } %>
                        </div>
                      </div>
                    </div>
                    
                    <div class="flex gap-3 w-full md:w-auto">
                      <% if (order.status === 'Delivered') { %>
                        <a href="/product/<%= item.productId %>" class="flex-1 md:flex-none btn-premium bg-brand-dark text-white hover:bg-black flex items-center gap-2">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2.5 2v3h3"/><path d="M2.5 5a10 10 0 1 1 2.36 5.58"/></svg>
                          Buy Again
                        </a>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <!-- Empty State -->
          <div class="text-center py-32 fade-in-up">
            <div class="w-20 h-20 bg-brand-warm rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="text-stone-300" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </div>
            <h3 class="font-serif text-2xl text-brand-dark mb-2">No orders found</h3>
            <p class="text-stone-400 text-sm mb-8">You haven't placed any orders yet.</p>
            <a href="/menProductList" class="inline-block btn-premium bg-brand-dark text-white hover:bg-black">Start Shopping</a>
          </div>
        <% } %>

      </div>
    </main>

  </div>
</div>

<%- include('../partials/footer') %>



<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>

const searchInput = document.getElementById("searchInput");

const sortSelect = document.getElementById("sortSelect");

const ordersContainer =
document.getElementById("ordersContainer");

let debounceTimer;


async function fetchOrders() {

    const search = searchInput.value;

    const sort = sortSelect.value;

    try {

        const response = await axios.get(
            `/orders?search=${search}&sort=${sort}`
        );

        const parser = new DOMParser();

        const doc = parser.parseFromString(
            response.data,
            "text/html"
        );

      
        const newOrders =
        doc.getElementById("ordersContainer");

        ordersContainer.innerHTML =
        newOrders.innerHTML;

    } catch (error) {

        console.log(error);

    }

}

searchInput.addEventListener("input", () => {

    clearTimeout(debounceTimer);

    debounceTimer = setTimeout(() => {

        fetchOrders();

    }, 500);

});


const dropdownTrigger = document.getElementById("dropdownTrigger");
const dropdownList = document.getElementById("dropdownList");
const dropdownArrow = document.getElementById("dropdownArrow");
const sortValueLabel = document.getElementById("sortValueLabel");
const dropdownItems = document.querySelectorAll(".dropdown-item");

dropdownTrigger.addEventListener("click", (e) => {
    e.stopPropagation();
    dropdownList.classList.toggle("show");
    dropdownArrow.classList.toggle("rotate-180");
});

document.addEventListener("click", () => {
    dropdownList.classList.remove("show");
    dropdownArrow.classList.remove("rotate-180");
});

dropdownItems.forEach(item => {
    item.addEventListener("click", (e) => {
        const value = item.getAttribute("data-value");
        const label = item.innerText;
        
        // Update Label and Input
        sortValueLabel.innerText = label;
        sortSelect.value = value;
        
        // Update active state
        dropdownItems.forEach(i => i.classList.remove("active"));
        item.classList.add("active");
        
        // Fetch Orders
        fetchOrders();
    });
});

</script>

</body>
</html>
