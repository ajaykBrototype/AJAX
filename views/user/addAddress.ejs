<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Add New Address — AJAX</title>
<meta name="description" content="Add a new delivery address to your AJAX account."/>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@200;300;400;500&display=swap" rel="stylesheet">
<script>
tailwind.config = {
  theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['DM Sans','system-ui','sans-serif'] } } }
}
</script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:#FAFAF8;color:#1C1C1C;overflow-x:hidden}
:root{--dark:#1C1C1C;--cream:#F5F0E8;--warm:#FAFAF8;--stone:#9B8E83;--mist:#EAE5DC;--bdr:rgba(28,28,28,0.1);--accent:#C9A96E}
::-webkit-scrollbar{width:3px}::-webkit-scrollbar-thumb{background:#ccc}

/* ── NAVBAR ── */
#navbar{position:fixed;top:0;left:0;right:0;z-index:999;padding:.9rem 3rem;background:rgba(250,250,248,.97);backdrop-filter:blur(16px);box-shadow:0 1px 0 var(--bdr)}
@media(max-width:767px){#navbar{padding:.8rem 1.25rem}}
.logo{font-family:'Playfair Display',serif;font-weight:400;font-size:1.45rem;letter-spacing:.42em;text-transform:uppercase;text-decoration:none;color:var(--dark)}
.nav-link{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;text-decoration:none;color:var(--dark);position:relative;padding-bottom:3px;transition:opacity .25s}
.nav-link::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:var(--dark);transition:width .4s cubic-bezier(.25,.1,.25,1)}
.nav-link:hover::after{width:100%}.nav-link:hover{opacity:.55}
.nav-icon{cursor:pointer;transition:transform .25s,opacity .25s;display:flex;align-items:center;justify-content:center;background:none;border:none;padding:6px;color:var(--dark);text-decoration:none}
.nav-icon:hover{transform:scale(1.1);opacity:.5}

/* ── MOBILE MENU ── */
#mob-menu{display:none;position:fixed;inset:0;z-index:998;background:var(--warm);flex-direction:column;align-items:center;justify-content:center;gap:2.2rem}
#mob-menu.open{display:flex}
#mob-close{position:absolute;top:1.5rem;right:1.75rem;background:none;border:none;cursor:pointer;font-size:1.3rem;color:var(--dark);opacity:.5;transition:opacity .2s}
#mob-close:hover{opacity:1}
.mob-link{font-family:'Playfair Display',serif;font-size:2.5rem;font-weight:400;font-style:italic;color:var(--dark);text-decoration:none;transition:opacity .25s}
.mob-link:hover{opacity:.35}

/* ── PAGE FADE-IN ── */
@keyframes pageIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.page-in{animation:pageIn .7s cubic-bezier(.16,1,.3,1) both}
.d1{animation-delay:.06s}.d2{animation-delay:.14s}.d3{animation-delay:.22s}.d4{animation-delay:.30s}.d5{animation-delay:.38s}

/* ── SIDEBAR ── */
.sidebar-link{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);text-decoration:none;border-left:2px solid transparent;transition:color .25s,border-color .25s,background .25s}
.sidebar-link:hover{color:var(--dark);background:rgba(28,28,28,.03)}
.sidebar-link.active{color:var(--dark);border-left-color:var(--dark);background:rgba(28,28,28,.04);font-weight:500}

/* ── BUTTONS ── */
.btn-dark{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:#fff;background:var(--dark);border:1px solid var(--dark);padding:.85rem 2rem;transition:background .3s,transform .2s;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;text-decoration:none}
.btn-dark:hover{background:#333;transform:translateY(-1px)}
.btn-dark:active{transform:translateY(0)}
.btn-ghost{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dark);background:none;border:1px solid var(--bdr);padding:.85rem 2rem;transition:border-color .3s,transform .2s;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;text-decoration:none}
.btn-ghost:hover{border-color:var(--dark);transform:translateY(-1px)}
.btn-ghost:active{transform:translateY(0)}

/* ── MOBILE SIDEBAR DRAWER ── */
#sidebar-drawer{display:none;position:fixed;inset:0;z-index:997}
#sidebar-drawer.open{display:block}
.drawer-bg{position:absolute;inset:0;background:rgba(28,28,28,.4);backdrop-filter:blur(4px)}
.drawer-panel{position:absolute;left:0;top:0;bottom:0;width:72vw;max-width:280px;background:#fff;padding:2rem 1.25rem;animation:drawerIn .35s cubic-bezier(.16,1,.3,1) both;border-right:1px solid var(--bdr)}
@keyframes drawerIn{from{transform:translateX(-100%)}to{transform:translateX(0)}}

/* ── FORM FIELDS ── */
.form-group{display:flex;flex-direction:column;gap:.45rem}
.form-label{font-size:.54rem;letter-spacing:.22em;text-transform:uppercase;color:var(--stone);font-weight:500;display:flex;align-items:center;gap:.4rem}
.form-label .req{color:#B04040;font-size:.65rem}
.form-input{width:100%;padding:.78rem 1rem;background:#fff;border:1px solid var(--bdr);color:var(--dark);font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:300;outline:none;transition:border-color .25s,box-shadow .25s;-webkit-appearance:none;appearance:none}
.form-input::placeholder{color:#C5BFBA}
.form-input:focus{border-color:var(--dark);box-shadow:0 0 0 3px rgba(28,28,28,.05)}
.form-input:hover:not(:focus){border-color:rgba(28,28,28,.25)}
.form-textarea{resize:vertical;min-height:110px;line-height:1.7}

/* ── ADDRESS TYPE BUTTONS ── */
.type-btn{display:inline-flex;align-items:center;gap:.5rem;font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;padding:.65rem 1.4rem;border:1px solid var(--bdr);background:#fff;color:var(--stone);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .25s;white-space:nowrap}
.type-btn:hover{border-color:var(--dark);color:var(--dark)}
.type-btn.selected{background:var(--dark);border-color:var(--dark);color:#fff}

/* ── TOGGLE SWITCH ── */
.toggle-wrap{display:flex;align-items:center;gap:.85rem;cursor:pointer}
.toggle{position:relative;width:42px;height:24px;flex-shrink:0}
.toggle input{opacity:0;width:0;height:0;position:absolute}
.toggle-slider{position:absolute;inset:0;background:#D8D3CE;border-radius:999px;transition:background .3s}
.toggle-slider::before{content:'';position:absolute;width:18px;height:18px;left:3px;top:3px;background:#fff;border-radius:50%;transition:transform .3s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.toggle input:checked + .toggle-slider{background:var(--dark)}
.toggle input:checked + .toggle-slider::before{transform:translateX(18px)}
.toggle-label{font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone)}

/* ── FORM CARD ── */
.form-card{background:#fff;border:1px solid var(--bdr);padding:2.5rem 2.5rem 2.8rem}
@media(max-width:640px){.form-card{padding:1.75rem 1.25rem 2rem}}

/* ── BREADCRUMB ── */
.breadcrumb{display:flex;align-items:center;gap:.5rem;font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);margin-bottom:1.6rem}
.breadcrumb a{color:var(--stone);text-decoration:none;transition:color .2s}
.breadcrumb a:hover{color:var(--dark)}
.breadcrumb span{font-weight:500;color:var(--dark)}

/* ── SECTION DIVIDER ── */
.section-label{font-size:.52rem;letter-spacing:.32em;text-transform:uppercase;color:var(--stone);margin-bottom:1.5rem;padding-bottom:.75rem;border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:.65rem}
.section-label::before{content:'';width:18px;height:1px;background:var(--stone)}

/* ── GRID ── */
.field-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.field-grid-4{display:grid;grid-template-columns:1fr 1.1fr 1fr 1.2fr;gap:1.25rem}
@media(max-width:820px){.field-grid-4{grid-template-columns:1fr 1fr;gap:1rem}}
@media(max-width:540px){.field-grid-2,.field-grid-4{grid-template-columns:1fr}}

/* ── VALIDATION ── */
.field-error{font-size:.62rem;color:#B04040;letter-spacing:.04em;margin-top:.2rem;display:none}
.form-input.error{border-color:#B04040;box-shadow:0 0 0 3px rgba(176,64,64,.06)}
.form-input.success{border-color:#5C8C6A}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  .main-pad{padding:2rem 1.25rem !important}
  .page-title{font-size:1.9rem !important}
  .btn-row{flex-direction:column-reverse !important}
  .btn-row .btn-dark,.btn-row .btn-ghost{width:100%;justify-content:center}
}

/* ── FLOATING LABEL FX ── */
.input-wrap{position:relative}
.input-suffix{position:absolute;right:.9rem;top:50%;transform:translateY(-50%);color:var(--stone);pointer-events:none;font-size:.75rem}

/* ── ACCOUNT DROPDOWN ── */
.dropdown-menu {
  position: absolute;
  top: calc(100% + 20px);
  right: 0;
  width: 240px;
  background: #fff;
  border: 1px solid var(--bdr);
  box-shadow: 0 12px 48px rgba(28,28,28,0.08);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-8px);
  transition: opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1), transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.35s;
  z-index: 50;
  padding: 0.5rem 0;
}
.dropdown-menu.open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.dropdown-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.85rem 1.4rem;
  font-size: 0.72rem;
  font-weight: 300;
  color: var(--dark);
  text-decoration: none;
  transition: background 0.25s cubic-bezier(0.16, 1, 0.3, 1), color 0.25s, transform 0.25s;
}
.dropdown-item:hover {
  background: var(--cream);
  transform: translateX(3px);
}
.dropdown-divider {
  height: 1px;
  background: var(--bdr);
  margin: 0.4rem 0;
}
</style>
</head>
<body>

<!-- ══ MOBILE MENU ══ -->
<div id="mob-menu">
  <button id="mob-close">✕</button>
  <a href="/" class="mob-link">Home</a>
