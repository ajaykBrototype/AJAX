<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Add New Address — AJAX</title>
<meta name="description" content="Add a new delivery address to your AJAX account."/>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=DM+Sans:wght@200;300;400;500&display=swap" rel="stylesheet">
<script>
tailwind.config = {
  theme: { extend: { fontFamily: { serif: ['Playfair Display','Georgia','serif'], sans: ['DM Sans','system-ui','sans-serif'] } } }
}
</script>
<%- include('../partials/navbar-styles') %>
<style>

/* ── PAGE FADE-IN ── */
@keyframes pageIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.page-in{animation:pageIn .7s cubic-bezier(.16,1,.3,1) both}
.d1{animation-delay:.06s}.d2{animation-delay:.14s}.d3{animation-delay:.22s}.d4{animation-delay:.30s}.d5{animation-delay:.38s}

/* ── SIDEBAR ── */
.sidebar-link{display:flex;align-items:center;gap:.75rem;padding:.65rem 1rem;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);text-decoration:none;border-left:2px solid transparent;transition:color .25s,border-color .25s,background .25s}
.sidebar-link:hover{color:var(--dark);background:rgba(28,28,28,.03)}
.sidebar-link.active{color:var(--dark);border-left-color:var(--dark);background:rgba(28,28,28,.04);font-weight:500}

/* ── BUTTONS ── */
.btn-dark{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:#fff;background:var(--dark);border:1px solid var(--dark);padding:.85rem 2rem;transition:background .3s,transform .2s;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;text-decoration:none}
.btn-dark:hover{background:#333;transform:translateY(-1px)}
.btn-dark:active{transform:translateY(0)}
.btn-ghost{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--dark);background:none;border:1px solid var(--bdr);padding:.85rem 2rem;transition:border-color .3s,transform .2s;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;text-decoration:none}
.btn-ghost:hover{border-color:var(--dark);transform:translateY(-1px)}
.btn-ghost:active{transform:translateY(0)}


/* ── FORM FIELDS ── */
.form-group{display:flex;flex-direction:column;gap:.45rem}
.form-label{font-size:.54rem;letter-spacing:.22em;text-transform:uppercase;color:var(--stone);font-weight:500;display:flex;align-items:center;gap:.4rem}
.form-label .req{color:#B04040;font-size:.65rem}
.form-input{width:100%;padding:.78rem 1rem;background:#fff;border:1px solid var(--bdr);color:var(--dark);font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:300;outline:none;transition:border-color .25s,box-shadow .25s;-webkit-appearance:none;appearance:none}
.form-input::placeholder{color:#C5BFBA}
.form-input:focus{border-color:var(--dark);box-shadow:0 0 0 3px rgba(28,28,28,.05)}
.form-input:hover:not(:focus){border-color:rgba(28,28,28,.25)}
.form-textarea{resize:vertical;min-height:110px;line-height:1.7}

/* ── ADDRESS TYPE BUTTONS ── */
.type-btn{display:inline-flex;align-items:center;gap:.5rem;font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;padding:.65rem 1.4rem;border:1px solid var(--bdr);background:#fff;color:var(--stone);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all .25s;white-space:nowrap}
.type-btn:hover{border-color:var(--dark);color:var(--dark)}
.type-btn.selected{background:var(--dark);border-color:var(--dark);color:#fff}

/* ── TOGGLE SWITCH ── */
.toggle-wrap{display:flex;align-items:center;gap:.85rem;cursor:pointer}
.toggle{position:relative;width:42px;height:24px;flex-shrink:0}
.toggle input{opacity:0;width:0;height:0;position:absolute}
.toggle-slider{position:absolute;inset:0;background:#D8D3CE;border-radius:999px;transition:background .3s}
.toggle-slider::before{content:'';position:absolute;width:18px;height:18px;left:3px;top:3px;background:#fff;border-radius:50%;transition:transform .3s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.toggle input:checked + .toggle-slider{background:var(--dark)}
.toggle input:checked + .toggle-slider::before{transform:translateX(18px)}
.toggle-label{font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone)}

/* ── FORM CARD ── */
.form-card{background:#fff;border:1px solid var(--bdr);padding:2.5rem 2.5rem 2.8rem}
@media(max-width:640px){.form-card{padding:1.75rem 1.25rem 2rem}}

/* ── BREADCRUMB ── */
.breadcrumb{display:flex;align-items:center;gap:.5rem;font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);margin-bottom:1.6rem}
.breadcrumb a{color:var(--stone);text-decoration:none;transition:color .2s}
.breadcrumb a:hover{color:var(--dark)}
.breadcrumb span{font-weight:500;color:var(--dark)}

/* ── SECTION DIVIDER ── */
.section-label{font-size:.52rem;letter-spacing:.32em;text-transform:uppercase;color:var(--stone);margin-bottom:1.5rem;padding-bottom:.75rem;border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:.65rem}
.section-label::before{content:'';width:18px;height:1px;background:var(--stone)}

/* ── GRID ── */
.field-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem}
.field-grid-4{display:grid;grid-template-columns:1fr 1.1fr 1fr 1.2fr;gap:1.25rem}
@media(max-width:820px){.field-grid-4{grid-template-columns:1fr 1fr;gap:1rem}}
@media(max-width:540px){.field-grid-2,.field-grid-4{grid-template-columns:1fr}}

/* ── VALIDATION ── */
.field-error{font-size:.62rem;color:#B04040;letter-spacing:.04em;margin-top:.2rem;display:none}
.form-input.error{border-color:#B04040;box-shadow:0 0 0 3px rgba(176,64,64,.06)}
.form-input.success{border-color:#5C8C6A}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  .main-pad{padding:2rem 1.25rem !important}
  .page-title{font-size:1.9rem !important}
  .btn-row{flex-direction:column-reverse !important}
  .btn-row .btn-dark,.btn-row .btn-ghost{width:100%;justify-content:center}
}

/* ── FLOATING LABEL FX ── */
.input-wrap{position:relative}
.input-suffix{position:absolute;right:.9rem;top:50%;transform:translateY(-50%);color:var(--stone);pointer-events:none;font-size:.75rem}

</style>
<%- include('../partials/footer-styles') %>
</head>
<body>

<%- include('../partials/navbar', { hasSidebarToggle: true }) %>
<!-- <%- include('../partials/sidebar-drawer', { activePage: 'address' }) %> -->

<!-- ══ PAGE BODY ══ -->
<div style="padding-top:65px;min-height:100vh;">
  <div style="max-width:1320px;margin:0 auto;display:flex;align-items:flex-start;">

    <%- include('../partials/sidebar', { activePage: 'address' }) %>

    <!-- MAIN CONTENT -->
    <main class="main-pad" style="flex:1;padding:3.5rem 3rem;min-width:0;">

      <%- include('../partials/breadcrumbs', { 
          breadcrumbs: [
              { name: "My Profile", url: "/profile" },
              { name: "My Addresses", url: "/address" },
              { name: "Add New Address" }
          ] 
      }) %>

      <!-- Page Header -->
      <div class="page-in d2" style="margin-bottom:2.5rem;">
        <p style="font-size:.54rem;letter-spacing:.35em;text-transform:uppercase;color:var(--stone);margin-bottom:.5rem">Account Overview</p>
        <h1 class="page-title" style="font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(2rem,4vw,3rem);line-height:1.1;color:var(--dark)">Add New Address</h1>
      </div>

      <!-- ── FORM CARD ── -->
      <form id="addAddressForm"  novalidate>

        <div class="form-card page-in d3">

          <!-- Section: Shipping Information -->
          <p class="section-label">Shipping Information</p>

          <!-- Row 1: Full Name + Mobile -->
          <div class="field-grid-2" style="margin-bottom:1.25rem;">
            <div class="form-group">
              <label for="fullName" class="form-label">
                Full Name <span class="req">*</span>
              </label>
              <div class="input-wrap">
                <input
                  type="text"
                  id="fullName"
                  name="name"
                  class="form-input"
                  placeholder="Johnathan Doe"
                  autocomplete="name"
                  maxlength="60"
                />
              </div>
              <span class="field-error" id="err-fullName">Please enter your full name.</span>
            </div>

            <div class="form-group">
              <label for="phone" class="form-label">
                Mobile Number <span class="req">*</span>
              </label>
              <div class="input-wrap">
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="form-input"
                  placeholder="+91 98765 43210"
                  autocomplete="tel"
                  maxlength="10",
                  minlength="10"
                />
              </div>
              <span class="field-error" id="err-phone">Enter a valid mobile number.</span>
            </div>
          </div>

          <!-- Row 2: Pincode / City / State / Country -->
          <div class="field-grid-4" style="margin-bottom:1.25rem;">
            <div class="form-group">
              <label for="pincode" class="form-label">
                Pincode <span class="req">*</span>
              </label>
              <input
                type="text"
                id="pincode"
                name="pincode"
                class="form-input"
                placeholder="10001"
                autocomplete="postal-code"
                maxlength="6"
                minlength="6"
                inputmode="numeric"
              />
              <span class="field-error" id="err-pincode">Enter a valid pincode.</span>
            </div>

            <div class="form-group">
              <label for="city" class="form-label">
                City <span class="req">*</span>
              </label>
              <input
                type="text"
                id="city"
                name="city"
                class="form-input"
                placeholder="New York"
                autocomplete="address-level2"
                maxlength="50"
              />
              <span class="field-error" id="err-city">Enter your city.</span>
            </div>

            <div class="form-group">
              <label for="state" class="form-label">
                State <span class="req">*</span>
              </label>
              <input
                type="text"
                id="state"
                name="state"
                class="form-input"
                placeholder="NY"
                autocomplete="address-level1"
                maxlength="50"
              />
              <span class="field-error" id="err-state">Enter your state.</span>
            </div>

            <div class="form-group">
              <label for="country" class="form-label">
                Country <span class="req">*</span>
              </label>
              <input
                type="text"
                id="country"
                name="country"
                class="form-input"
                placeholder="India"
                value="India"
                autocomplete="country-name"
                maxlength="50"
              />
              <span class="field-error" id="err-country">Enter your country.</span>
            </div>
          </div>

          <!-- Row 3: Street + Area (two rows, full width) -->
          <div class="form-group" style="margin-bottom:1.25rem;">
            <label for="street" class="form-label">
              Street / Road <span class="req">*</span>
            </label>
            <input
              type="text"
              id="street"
              name="street"
              class="form-input"
              placeholder="e.g. MG Road, Connaught Place"
              autocomplete="address-line1"
              maxlength="150"
            />
            <span class="field-error" id="err-street">Please enter your street / road.</span>
          </div>

          <div class="form-group" style="margin-bottom:2rem;">
            <label for="area" class="form-label">
              House No., Building, Area &amp; Landmark <span class="req">*</span>
            </label>
            <textarea
              id="area"
              name="area"
              class="form-input form-textarea"
              placeholder="e.g. Flat 4B, Sunrise Apartments, Near City Mall..."
              autocomplete="address-line2"
              maxlength="250"
            ></textarea>
            <span class="field-error" id="err-area">Please enter your building / area details.</span>
          </div>

          <!-- ── SECTION: Address Type + Default ── -->
          <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;">

            <!-- Address Type -->
            <div>
              <p class="form-label" style="margin-bottom:.85rem;">Address Type</p>
              <div style="display:flex;gap:.65rem;flex-wrap:wrap;" role="group" aria-label="Address type">
                <button type="button" class="type-btn selected" id="type-home" data-type="home" aria-pressed="true">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  Home
                </button>
                <button type="button" class="type-btn" id="type-work" data-type="work" aria-pressed="false">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
                  Work
                </button>
                <button type="button" class="type-btn" id="type-other" data-type="other" aria-pressed="false">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  Other
                </button>
                <input type="hidden" id="addressType" name="addressType" value="home"/>
              </div>
            </div>

            <!-- Set as Default toggle -->
            <div style="display:flex;flex-direction:column;gap:.5rem;align-items:flex-end;">
              <p class="form-label" style="margin-bottom:.35rem;">Set as Default Address</p>
              <label class="toggle-wrap" for="isDefault">
                <div class="toggle">
                  <input type="checkbox" id="isDefault" name="isDefault" value="true"/>
                  <span class="toggle-slider"></span>
                </div>
                <span class="toggle-label" id="toggle-status">Off</span>
              </label>
            </div>

          </div>

        </div><!-- /form-card -->

        <!-- ── ACTION BUTTONS ── -->
        <div class="btn-row page-in d5" style="display:flex;align-items:center;justify-content:flex-end;gap:1rem;margin-top:2rem;flex-wrap:wrap;">
          <a href="/address" class="btn-ghost">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Cancel
          </a>
          <button type="submit" class="btn-dark" id="submitBtn">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Save Address
          </button>
        </div>

      </form>
    </main>
  </div>
</div>

<!-- ══ FOOTER ══ -->
<%- include('../partials/footer') %>


<script>

/* ── Address Type buttons ── */
const typeBtns = document.querySelectorAll('.type-btn');
const addressTypeInput = document.getElementById('addressType');
typeBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    typeBtns.forEach(b => { b.classList.remove('selected'); b.setAttribute('aria-pressed','false'); });
    btn.classList.add('selected');
    btn.setAttribute('aria-pressed','true');
    addressTypeInput.value = btn.dataset.type;
  });
});

/* ── Default toggle label ── */
const toggleInput = document.getElementById('isDefault');
const toggleStatus = document.getElementById('toggle-status');
toggleInput.addEventListener('change', () => {
  toggleStatus.textContent = toggleInput.checked ? 'On' : 'Off';
});

const rules = {
  fullName: { required:true, minLen:2, label:'full name' },


  phone: { 
    required:true, 
    pattern:/^\d{10}$/, 
    label:'mobile number (10 digits)' 
  },

  street: { required:true, minLen:3, label:'street / road' },
  area: { required:true, minLen:5, label:'house / area details' },

  pincode: { 
    required:true, 
    pattern:/^\d{6}$/, 
    label:'pincode (6 digits)' 
  },

  city: { required:true, minLen:2, label:'city' },
  state: { required:true, minLen:2, label:'state' },
  country: { required:true, minLen:2, label:'country' },
};

function showError(id, msg) {
  const el = document.getElementById(id);
  const err = document.getElementById('err-' + id);
  el.classList.add('error');
  if (err) { err.textContent = msg; err.style.display = 'block'; }
}
function clearError(id) {
  const el = document.getElementById(id);
  const err = document.getElementById('err-' + id);
  el.classList.remove('error');
  if (err) err.style.display = 'none';
}
function validateField(id) {
  const rule = rules[id];
  if (!rule) return true;
  const el = document.getElementById(id);
  const val = el.value.trim();
  if (rule.required && !val) {
    showError(id, `Please enter your ${rule.label}.`);
    return false;
  }
  if (val && rule.minLen && val.length < rule.minLen) {
    showError(id, `${rule.label.charAt(0).toUpperCase()+rule.label.slice(1)} is too short.`);
    return false;
  }
  if (val && rule.pattern && !rule.pattern.test(val)) {
    showError(id, `Enter a valid ${rule.label}.`);
    return false;
  }
  clearError(id);
  return true;
}

/* Inline validation on blur */
Object.keys(rules).forEach(id => {
  const el = document.getElementById(id);
  if (!el) return;
  el.addEventListener('blur', () => validateField(id));
  el.addEventListener('input', () => {
    if (el.classList.contains('error')) validateField(id);
  });
});

/* Form submit */
document.getElementById('addAddressForm').addEventListener('submit', function(e) {
  e.preventDefault();
  let valid = true;
  Object.keys(rules).forEach(id => {
    if (!validateField(id)) valid = false;
  });
  if (!valid) {
    /* Scroll to first error */
    const firstErr = document.querySelector('.form-input.error');
    if (firstErr) firstErr.scrollIntoView({ behavior:'smooth', block:'center' });
  } else {
    /* Show loading state */
    const btn = document.getElementById('submitBtn');
    btn.innerHTML = `
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin .8s linear infinite">
        <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
      </svg>
      Saving...
    `;
    btn.disabled = true;
    btn.style.opacity = '.7';

    /* Simulate API Save and Toast display */
    setTimeout(() => {
      btn.innerHTML = `Saved`;
      if(typeof showToast === 'function') {
        showToast('success', 'Address saved successfully.');
      }
      setTimeout(() => {
        window.location.href = '/address';
      }, 1500);
    }, 1000);
  }
});

/* Spin keyframe */
const style = document.createElement('style');
style.textContent = '@keyframes spin{to{transform:rotate(360deg)}}';
document.head.appendChild(style);
</script>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="/js/user/address.js"></script>
</body>
</html>
