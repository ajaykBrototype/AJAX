<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title><%= (typeof product !== 'undefined' && product) ? product.name + ' — AJAX' : 'Sky Linen Shirt — AJAX' %></title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600;700&family=Noto+Serif:wght@300;400;600;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <!-- Animation Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <style>
        :root {
            --bg-color: #F9F9F8;
            --surface-color: #F4F4F3;
            --text-primary: #1A1C1C;
            --text-secondary: #474747;
            --text-muted: #A1A1AA;
            --border-color: #E4E4E7;
            --accent-color: #000000;
            --font-main: 'Inter', sans-serif;
            --font-serif: 'Noto Serif', serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            font-family: var(--font-main);
            overflow-x: hidden;
            line-height: 1.5;
        }

        /* --- Header --- */
        header {
            position: fixed;
            top: 0;
            width: 100%;
            height: 80px;
            background: rgba(249, 249, 248, 0.8);
            backdrop-filter: blur(12px);
            z-index: 1000;
            display: flex;
            align-items: center;
            padding: 0 48px;
            border-bottom: 1px solid rgba(228, 228, 231, 0.1);
        }

        .nav-container {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-family: var(--font-serif);
            font-size: 24px;
            font-weight: 900;
            letter-spacing: 7.2px;
            text-transform: uppercase;
            text-decoration: none;
            color: var(--text-primary);
        }

        .nav-links {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-link {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            text-decoration: none;
            color: var(--text-primary);
            transition: opacity 0.3s;
        }

        .nav-link.secondary {
            font-weight: 400;
            color: var(--text-secondary);
        }

        .nav-link:hover {
            opacity: 0.6;
        }

        .nav-icons {
            display: flex;
            gap: 24px;
            align-items: center;
        }

        .nav-icon-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-primary);
            display: flex;
            align-items: center;
        }

        /* --- Main Layout --- */
        main {
            padding-top: 176px; /* 80px header + 96px padding as per Figma */
            max-width: 1280px;
            margin: 0 auto;
            display: flex;
            gap: 48px;
            min-height: 1024px;
        }

        /* --- Product Images Section --- */
        .product-images {
            display: flex;
            gap: 16px;
            flex: 1;
        }

        .thumbnail-strip {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 96px;
        }

        .thumbnail {
            width: 96px;
            height: 128px;
            background: var(--surface-color);
            cursor: pointer;
            overflow: hidden;
            transition: transform 0.3s;
        }

        .thumbnail:hover {
            transform: scale(1.02);
        }

        .thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .main-image-container {
            position: relative;
            width: 545.33px;
            height: 727.11px;
            background: var(--surface-color);
            overflow: hidden;
        }

        .main-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .wishlist-toggle {
            position: absolute;
            top: 16px;
            right: 16px;
            width: 43px;
            height: 41.18px;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(4px);
            border: none;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            transition: background 0.3s;
        }

        .wishlist-toggle:hover {
            background: #ffffff;
        }

        /* --- Product Details Right Panel --- */
        .product-details {
            flex: 0 0 446.67px;
            display: flex;
            flex-direction: column;
        }

        .editorial-label {
            font-size: 10px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 16px;
        }

        .product-title {
            font-family: var(--font-serif);
            font-size: 60px;
            font-weight: 700;
            line-height: 1;
            letter-spacing: -1.5px;
            margin-bottom: 16px;
        }

        .product-price {
            font-size: 24px;
            font-weight: 300;
            color: rgba(26, 28, 28, 0.8);
            margin-bottom: 40px;
        }

        .short-desc {
            font-size: 14px;
            color: var(--text-secondary);
            margin-bottom: 24px;
        }

        .long-desc {
            font-size: 16px;
            line-height: 1.6;
            color: rgba(26, 28, 28, 0.7);
            margin-bottom: 48px;
        }

        /* Option Selectors */
        .option-group {
            margin-bottom: 40px;
        }

        .option-label {
            font-size: 11px;
            letter-spacing: 1.1px;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .swatches {
            display: flex;
            gap: 16px;
        }

        .swatch {
            width: 32px;
            height: 32px;
            cursor: pointer;
            position: relative;
        }

        .swatch.active::after {
            content: '';
            position: absolute;
            top: -4px;
            left: -4px;
            right: -4px;
            bottom: -4px;
            border: 1px solid var(--accent-color);
            padding: 4px;
        }

        .size-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
        }

        .size-btn {
            height: 46px;
            border: 1px solid var(--border-color);
            background: none;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .size-btn:hover {
            border-color: var(--accent-color);
        }

        .size-btn.active {
            background: var(--accent-color);
            color: #ffffff;
            border-color: var(--accent-color);
        }

        .size-guide-link {
            font-size: 10px;
            text-decoration: underline;
            color: var(--text-muted);
            text-transform: uppercase;
            cursor: pointer;
        }

        /* Quantity Stepper */
        .quantity-stepper {
            display: flex;
            align-items: center;
            border: 1px solid var(--border-color);
            width: 128px;
            height: 42px;
            margin-bottom: 32px;
        }

        .qty-btn {
            flex: 1;
            height: 100%;
            border: none;
            background: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .qty-val {
            width: 48px;
            text-align: center;
            font-size: 14px;
        }

        /* Action Buttons */
        .action-btns {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 32px;
        }

        .btn-primary {
            height: 57px;
            background: var(--accent-color);
            color: #ffffff;
            border: none;
            font-size: 11px;
            letter-spacing: 2.2px;
            text-transform: uppercase;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: opacity 0.3s;
        }

        .btn-secondary {
            height: 59px;
            background: none;
            border: 1px solid var(--accent-color);
            color: var(--accent-color);
            font-size: 11px;
            letter-spacing: 2.2px;
            text-transform: uppercase;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }

        .btn-secondary:hover {
            background: var(--accent-color);
            color: #ffffff;
        }

        /* Accordions */
        .accordions {
            margin-top: 64px;
        }

        .accordion-item {
            border-top: 1px solid #F4F4F5;
            padding: 32px 0;
        }

        .accordion-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            margin-bottom: 16px;
        }

        .accordion-title {
            font-size: 11px;
            letter-spacing: 1.1px;
            text-transform: uppercase;
            font-weight: 400;
        }

        .accordion-content {
            font-size: 14px;
            line-height: 1.6;
            color: rgba(26, 28, 28, 0.7);
        }

        .accordion-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .accordion-list li {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .bullet {
            width: 6px;
            height: 6px;
            background: #D4D4D8;
        }

        /* --- Related Products Section --- */
        .related-section {
            background: var(--surface-color);
            padding: 96px 48px;
            margin-top: 96px;
        }

        .related-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 64px;
        }

        .related-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 40px;
        }

        .product-card {
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }

        .card-img {
            aspect-ratio: 266/354;
            background: #ffffff;
            margin-bottom: 24px;
            overflow: hidden;
        }

        .card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .product-card:hover .card-img img {
            transform: scale(1.05);
        }

        .card-category {
            font-size: 10px;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .card-title {
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 8px;
        }

        .card-price {
            font-size: 14px;
            color: #71717A;
        }

        /* --- Customer Reviews Section --- */
        .reviews-section {
            padding: 48px 48px 96px;
            background: #ffffff;
            border-top: 1px solid #F4F4F5;
            display: grid;
            grid-template-columns: 341px 1fr;
            gap: 80px;
        }

        .reviews-summary h2 {
            font-size: 10px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--text-secondary);
            margin-bottom: 16px;
        }

        .reviews-summary h3 {
            font-family: var(--font-serif);
            font-size: 36px;
            margin-bottom: 16px;
        }

        .rating-hero {
            display: flex;
            align-items: center;
            gap: 24px;
            margin-bottom: 32px;
        }

        .rating-val {
            font-family: var(--font-serif);
            font-size: 48px;
            font-weight: 300;
        }

        .stars-row {
            display: flex;
            gap: 4px;
            margin-bottom: 4px;
        }

        .rating-count {
            font-size: 10px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .filter-row {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 16px;
        }

        .filter-label {
            width: 64px;
            font-size: 11px;
            letter-spacing: 1.1px;
            text-transform: uppercase;
        }

        .filter-bar-bg {
            flex: 1;
            height: 2px;
            background: #F4F4F5;
            position: relative;
        }

        .filter-bar-fill {
            position: absolute;
            height: 100%;
            background: var(--accent-color);
        }

        .filter-percent {
            font-size: 11px;
            color: var(--text-muted);
        }

        .review-list {
            display: flex;
            flex-direction: column;
            gap: 64px;
        }

        .review-card {
            border-bottom: 1px solid #F4F4F5;
            padding-bottom: 48px;
        }

        .review-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 24px;
        }

        .review-stars {
            margin-bottom: 8px;
        }

        .review-title {
            font-family: var(--font-serif);
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .review-author {
            font-size: 10px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .verified-badge {
            background: #FAFAFA;
            padding: 4px 8px;
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 9px;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .review-text {
            font-size: 14px;
            line-height: 1.6;
            color: rgba(26, 28, 28, 0.7);
            max-width: 672px;
        }

        /* --- Footer --- */
        footer {
            padding: 48px 48px 96px;
            background: var(--bg-color);
            border-top: 1px solid rgba(228, 228, 231, 0.2);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1.5fr;
            gap: 48px;
            margin-bottom: 96px;
        }

        .footer-brand h2 {
            font-family: var(--font-serif);
            font-size: 24px;
            font-weight: 900;
            margin-bottom: 22px;
        }

        .footer-brand p {
            font-size: 14px;
            color: var(--text-secondary);
            max-width: 384px;
            margin-bottom: 24px;
        }

        .footer-links h4 {
            font-size: 11px;
            letter-spacing: 1.1px;
            text-transform: uppercase;
            margin-bottom: 24px;
        }

        .footer-nav {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .footer-nav a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 14px;
        }

        .newsletter-input {
            border: none;
            border-bottom: 1px solid var(--accent-color);
            padding: 8px 0;
            width: 100%;
            background: none;
            font-family: var(--font-main);
            font-size: 14px;
            margin-top: 16px;
            outline: none;
        }

        .footer-bottom {
            border-top: 1px solid #F4F4F5;
            padding-top: 32px;
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        /* --- Animations --- */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
        }
    </style>
</head>
<body>

    <header>
        <div class="nav-container">
            <a href="/" class="logo">AJAX</a>
            <nav class="nav-links">
                <a href="/men" class="nav-link">Men</a>
                <a href="/women" class="nav-link secondary">Women</a>
                <a href="/editorial" class="nav-link secondary">Editorial</a>
            </nav>
            <div class="nav-icons">
                <button class="nav-icon-btn"><i data-lucide="search" size="18"></i></button>
                <button class="nav-icon-btn"><i data-lucide="user" size="18"></i></button>
                <button class="nav-icon-btn"><i data-lucide="shopping-bag" size="18"></i></button>
            </div>
        </div>
    </header>

    <main>
        <section class="product-images">
            <div class="thumbnail-strip reveal">
                <div class="thumbnail"><img src="/linen_fabric_texture_1776954165604.png" alt="Detail"></div>
                <div class="thumbnail"><img src="/premium_sky_blue_linen_shirt_1776953916501.png" alt="Back View"></div>
                <div class="thumbnail"><img src="/linen_shirt_hanger_1776954277351.png" alt="Lifestyle"></div>
            </div>
            <div class="main-image-container reveal" style="transition-delay: 0.1s;">
                <img src="/premium_sky_blue_linen_shirt_1776953916501.png" alt="Sky Linen Shirt" class="main-image">
                <button class="wishlist-toggle">
                    <i data-lucide="heart" size="19"></i>
                </button>
            </div>
        </section>

        <section class="product-details">
            <div class="reveal" style="transition-delay: 0.2s;">
                <p class="editorial-label">Summer Editorial 24'</p>
                <h1 class="product-title"><%= (typeof product !== 'undefined' && product) ? product.name : 'Sky Linen Shirt' %></h1>
                <p class="product-price">$<%= (typeof product !== 'undefined' && product) ? product.price : '89.00' %></p>
            </div>

            <div class="reveal" style="transition-delay: 0.3s;">
                <p class="short-desc">"Lightweight comfort meets effortless style"</p>
                <p class="long-desc">
                    Our signature Sky Linen Shirt is crafted from the finest European flax. 
                    Designed for a relaxed, breathable fit that transitions seamlessly from seaside lunches to sunset soirées.
                </p>
            </div>

            <div class="option-group reveal" style="transition-delay: 0.4s;">
                <div class="option-label">Color — Sky Blue</div>
                <div class="swatches">
                    <div class="swatch active" style="background: #BED4E7;"></div>
                    <div class="swatch" style="background: #FFFFFF; border: 1px solid #eee;"></div>
                    <div class="swatch" style="background: #556B2F;"></div>
                </div>
            </div>

            <div class="option-group reveal" style="transition-delay: 0.5s;">
                <div class="option-label">
                    <span>Size</span>
                    <span class="size-guide-link">Size Guide</span>
                </div>
                <div class="size-grid">
                    <button class="size-btn">S</button>
                    <button class="size-btn active">M</button>
                    <button class="size-btn">L</button>
                    <button class="size-btn">XL</button>
                </div>
            </div>

            <div class="reveal" style="transition-delay: 0.6s;">
                <div class="option-label">Quantity</div>
                <div class="quantity-stepper">
                    <button class="qty-btn"><i data-lucide="minus" size="14"></i></button>
                    <div class="qty-val">1</div>
                    <button class="qty-btn"><i data-lucide="plus" size="14"></i></button>
                </div>

                <div class="action-btns">
                    <button class="btn-primary">Add to Bag <i data-lucide="arrow-right" size="14"></i></button>
                    <button class="btn-secondary">Wishlist</button>
                </div>

                <div style="background: #F4F4F3; padding: 16px; display: flex; align-items: center; gap: 12px; margin-bottom: 32px;">
                    <i data-lucide="truck" size="16" color="#A1A1AA"></i>
                    <span style="font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #52525B;">Complimentary standard shipping on all orders</span>
                </div>
            </div>

            <div class="accordions reveal" style="transition-delay: 0.7s;">
                <div class="accordion-item">
                    <div class="accordion-header">
                        <span class="accordion-title">Material</span>
                        <i data-lucide="plus" size="14"></i>
                    </div>
                    <div class="accordion-content">
                        <ul class="accordion-list">
                            <li><div class="bullet"></div> 100% European Flax Linen</li>
                            <li><div class="bullet"></div> Pre-washed for extra softness</li>
                        </ul>
                    </div>
                </div>
                <div class="accordion-item">
                    <div class="accordion-header">
                        <span class="accordion-title">Care guide</span>
                        <i data-lucide="plus" size="14"></i>
                    </div>
                    <div class="accordion-content">
                        To maintain the integrity of the linen fibers, machine wash cold with like colors. Do not bleach. 
                        Hang to dry or tumble dry low.
                    </div>
                </div>
            </div>
        </section>
    </main>

    <section class="related-section">
        <div class="related-header reveal">
            <div>
                <p class="editorial-label" style="margin-bottom: 8px;">Recommendation</p>
                <h3 style="font-family: var(--font-serif); font-size: 36px; letter-spacing: -0.9px;">Completing the Look</h3>
            </div>
            <a href="#" class="nav-link" style="text-decoration: underline;">View All</a>
        </div>
        <div class="related-grid">
            <div class="product-card reveal" style="transition-delay: 0.1s;">
                <div class="card-img"><img src="/related_minimalist_white_shirt_1776954058211.png" alt="Item"></div>
                <p class="card-category">Editorial 24'</p>
                <h4 class="card-title">Classic White Linen</h4>
                <p class="card-price">$89.00</p>
            </div>
            <div class="product-card reveal" style="transition-delay: 0.2s;">
                <div class="card-img"><img src="/related_olive_linen_shirt_1776954098434.png" alt="Item"></div>
                <p class="card-category">Summer Drop</p>
                <h4 class="card-title">Olive Field Shirt</h4>
                <p class="card-price">$95.00</p>
            </div>
            <div class="product-card reveal" style="transition-delay: 0.3s;">
                <div class="card-img"><img src="/related_minimalist_white_shirt_1776954058211.png" alt="Item"></div>
                <p class="card-category">New Arrival</p>
                <h4 class="card-title">Sand Linen Trousers</h4>
                <p class="card-price">$120.00</p>
            </div>
            <div class="product-card reveal" style="transition-delay: 0.4s;">
                <div class="card-img" style="position: relative;">
                    <img src="/related_olive_linen_shirt_1776954098434.png" alt="Item">
                    <div style="position: absolute; top: 16px; left: 16px; background: #000; color: #fff; padding: 4px 8px; font-size: 9px; letter-spacing: 0.9px; text-transform: uppercase;">Sold Out</div>
                </div>
                <p class="card-category">Essential</p>
                <h4 class="card-title">Striped Resort Shirt</h4>
                <p class="card-price">$89.00</p>
            </div>
        </div>
    </section>

    <section class="reviews-section">
        <div class="reviews-summary reveal">
            <h2>Feedback</h2>
            <h3>Customer Reviews</h3>
            <div class="rating-hero">
                <div class="rating-val">4.8</div>
                <div>
                    <div class="stars-row">
                        <i data-lucide="star" size="16" fill="#000"></i>
