<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password — AJAX</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif: ['Playfair Display', 'serif'],
            sans: ['DM Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>

  <style>
    body { background-color: #FAFAF8; color: #1C1C1C; }
    .input-premium {
      border-bottom: 1px solid rgba(28, 28, 28, 0.2);
      background: transparent;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .input-premium:focus {
      outline: none;
      border-bottom-color: #1C1C1C;
      padding-left: 8px;
    }
    .fade-in { animation: fadeIn 0.8s ease forwards; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>

<body class="min-h-screen flex font-sans antialiased overflow-hidden">

  <div class="hidden md:block w-7/12 h-screen relative">
    <div class="absolute inset-0 bg-black/10 z-10"></div>
    <img 
      src="/images/signup.jpg" 
      class="w-full h-full object-cover grayscale-[20%]"
      alt="Luxury Aesthetic"
    />
    <div class="absolute bottom-12 left-12 z-20 text-white">
      <p class="text-[10px] tracking-[0.4em] uppercase mb-2">Security & Identity</p>
      <h3 class="font-serif italic text-3xl">Refining the essentials.</h3>
    </div>
  </div>

  <div class="w-full md:w-5/12 flex items-center justify-center p-8 md:p-16">
    <div class="w-full max-w-sm fade-in">
    
      
      <div class="mb-12">
        <h1 class="font-serif text-2xl tracking-[0.3em] mb-16">AJAX</h1>
        <h2 class="font-serif text-4xl mb-4">Reset Access</h2>
        <p class="text-stone-400 text-xs tracking-widest uppercase leading-relaxed">
          Enter your email. If an account exists, we will send a verification code.
        </p>
      </div>

      <form id="forgotForm" class="space-y-10" novalidate>
        <div class="relative">
          <label class="text-[10px] tracking-[0.2em] uppercase text-stone-400 block mb-2">Email Address</label>
          <input 
            type="email" 
            name="email" 
            placeholder="email@example.com"
            class="input-premium w-full py-3 text-sm placeholder:text-stone-300"
          />
          <span id="emailError" class="text-[10px] text-red-500 uppercase tracking-tighter mt-2 block opacity-0 transition-opacity">
            Please enter a valid email address
          </span>
        </div>

        <div class="pt-4">
          <button 
            type="submit"
            id="submitBtn"
            class="w-full bg-black text-white py-5 text-[11px] tracking-[0.3em] uppercase hover:bg-stone-800 transition-all flex items-center justify-center gap-3"
          >
            Send OTP <span class="text-lg">→</span>
          </button>
        </div>
      </form>

      <div class="mt-12 pt-8 border-t border-stone-100 text-center">
        <p class="text-[11px] text-stone-400 tracking-widest uppercase">
          Remembered? 
          <a href="/login" class="text-black font-medium ml-2 border-b border-black pb-0.5">Back to Login</a>
        </p>
      </div>

    </div>
  </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- 2. Then your helper -->
<script src="/js/utils/swal-helper.js"></script>
 

  <script>
    const form = document.getElementById("forgotForm");
    const emailInput = form.email;
    const emailError = document.getElementById("emailError");
    const submitBtn = document.getElementById("submitBtn");

    // Email Regex Validation
    const isValidEmail = (email) => {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      
      const email = emailInput.value.trim();

      // 1. Client-side Validation
      if (!email) {
        emailError.textContent = "Email is required";
        emailError.style.opacity = "1";
        if(typeof showToast === 'function') showToast('error', 'Please enter your email.');
        return;
      }

      if (!isValidEmail(email)) {
        emailError.textContent = "Enter a valid email address";
        emailError.style.opacity = "1";
        if(typeof showToast === 'function') showToast('error', 'Invalid email format.');
        return;
      }

      // Clear errors if valid
      emailError.style.opacity = "0";

      // 2. UI Loading State
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.style.opacity = "0.7";
      submitBtn.innerHTML = "Processing...";

      try {
        const res = await axios.post("/forgot-password", { email });

        if (res.data.success) {
          if(typeof ajaxToast === 'function') {
            ajaxToast('success', 'OTP sent to your email.');
          }
          setTimeout(() => {
            window.location.href = "/otp";
          }, 1500);
        }
      } catch (err) {
        // 3. Error handling with Toast
        const errorMessage = err.response?.data?.message || 'Verification failed. Try again.';
        if(typeof ajaxToast === 'function') {
          ajaxToast('error', errorMessage);
        }
        
        // Reset button
        submitBtn.disabled = false;
        submitBtn.style.opacity = "1";
        submitBtn.innerHTML = originalText;
      }
    });

    // Remove error message when user starts typing again
    emailInput.addEventListener('input', () => {
      emailError.style.opacity = "0";
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
 <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/utils/swal-helper.js"></script>

</body>
</html>
