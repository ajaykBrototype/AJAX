        type="email" 
        name="email" 
        placeholder="Enter your email"
        class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-black"
        required
      />
      <p id="emailError" class="text-red-500 text-sm hidden"></p>
    </div>

    <!-- BUTTON -->
    <button class="w-full bg-black text-white py-3 rounded-lg hover:opacity-90 transition">
      SEND OTP →
    </button>

  </form>

  <!-- BACK TO LOGIN -->
  <p class="text-sm text-gray-500 mt-6 text-center">
    Remember your password?
    <a href="/login" class="text-black font-semibold">Login</a>
  </p>

</div>
