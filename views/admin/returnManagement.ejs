

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Return Management — AJAX Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { background: #f8fafc; color: #111827; font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; }
    
    .card { background: #ffffff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    
    .lbl { font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #64748b; }
    
    .badge { 
      display: inline-flex; 
      align-items: center; 
      padding: 4px 12px; 
      border-radius: 6px; 
      font-size: 11px; 
      font-weight: 600; 
      line-height: 1;
    }
    .b-pending { background: #fff7ed; color: #c2410c; }
    .b-approved { background: #f0fdf4; color: #15803d; }
    .b-pickup { background: #eff6ff; color: #1d4ed8; }
    .b-completed { background: #f1f5f9; color: #475569; }
    .b-rejected { background: #fef2f2; color: #b91c1c; }

    /* Custom Table Styling */
    th { text-align: left; padding: 16px 24px; }
    td { padding: 16px 24px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; }
    tr:last-child td { border-bottom: none; }
    
    /* Stats Icon styling */
    .stats-icon { 
      width: 40px; 
      height: 40px; 
      border-radius: 50%; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
    }

    #sidebar { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    @media(max-width:1024px) {
      #sidebar { position: fixed; left: 0; top: 0; bottom: 0; transform: translateX(-100%); z-index: 1001; width: 280px; }
      #sidebar.open { transform: translateX(0); }
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: fadeIn 0.5s ease-out both; }

    /* Custom Admin Dropdown Styles */
    .custom-admin-dropdown {
      position: relative;
      min-width: 160px;
    }
    .admin-dropdown-trigger {
      background: #ffffff;
      border: 1px solid #e2e8f0;
      border-radius: 9999px;
      padding: 8px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.75rem;
      font-weight: 600;
      color: #111827;
      cursor: pointer;
      transition: all 0.2s ease;
      width: 100%;
      box-shadow: 0 1px 2px rgba(0,0,0,0.05);
    }
    .admin-dropdown-trigger:hover { background: #f9fafb; border-color: #d1d5db; }

    .admin-dropdown-menu {
      position: absolute;
      top: 100%;
      left: 0;
      margin-top: 12px;
      background: white;
      border: 1px solid #e2e8f0;
      border-radius: 28px;
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);
      padding: 10px;
      z-index: 100;
      visibility: hidden;
      opacity: 0;
      transform: translateY(15px);
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      min-width: 220px;
    }
    .admin-dropdown-menu.show {
      visibility: visible;
      opacity: 1;
      transform: translateY(6px);
    }
    .admin-dropdown-item {
      padding: 12px 20px;
      font-size: 0.85rem;
      font-weight: 600;
      color: #4b5563;
      cursor: pointer;
      border-radius: 18px;
      transition: all 0.2s ease;
      margin-bottom: 4px;
    }
    .admin-dropdown-item:last-child { margin-bottom: 0; }
    .admin-dropdown-item:hover { background: #f3f4f6; color: #000; }
    .admin-dropdown-item.active { background: #111827; color: #fff; }
  </style>
</head>
<body class="flex min-h-screen">

  <%- include('partials/sidebar', { currentPath: '/admin/returns' }) %>

  <main class="flex-1 flex flex-col min-w-0 overflow-y-auto max-h-screen">
    
    <!-- Header -->
    <header class="p-6 md:p-8 flex flex-col gap-1">
      <div class="flex items-center gap-3">
        <button id="sidebarToggle" class="lg:hidden p-2 hover:bg-white rounded-lg border border-gray-200">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <h1 class="text-2xl font-bold tracking-tight">Return Management</h1>
      </div>
      <p class="text-sm text-gray-500">Review and manage customer return requests</p>
    </header>

    <div class="px-6 md:px-8 pb-8 space-y-8 animate-up">
      
      <!-- Stats Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Pending -->
        <div class="card p-5 flex items-center justify-between">
          <div>
            <p class="lbl mb-1">Pending Requests</p>
            <h3 class="text-2xl font-bold"><%= pendingReturns %></h3>
          </div>
          <div class="stats-icon bg-yellow-50 text-yellow-500">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          </div>
        </div>
        <!-- Approved -->
        <div class="card p-5 flex items-center justify-between">
          <div>
            <p class="lbl mb-1">Approved Today</p>
            <h3 class="text-2xl font-bold"><%= approvedReturns %></h3>
          </div>
          <div class="stats-icon bg-green-50 text-green-500">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
        </div>
        <!-- Rejected -->
        <div class="card p-5 flex items-center justify-between">
          <div>
            <p class="lbl mb-1">Rejected Today</p>
            <h3 class="text-2xl font-bold"><%= rejectedReturns %></h3>
          </div>
          <div class="stats-icon bg-red-50 text-red-500">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </div>
        </div>
        <!-- Total -->
        <div class="card p-5 flex items-center justify-between">
          <div>
            <p class="lbl mb-1">Total Returns</p>
            <h3 class="text-2xl font-bold"><%= totalReturns %></h3>
          </div>
          <div class="stats-icon bg-blue-50 text-blue-500">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          </div>
        </div>
      </div>

      <!-- Filters & Search -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="custom-admin-dropdown" id="statusDropdown">
          <button type="button" class="admin-dropdown-trigger" id="statusTrigger">
            <span id="currentStatusLabel">
              <% 
                const statusLabels = {
                  'all': 'All Status',
                  'pending': 'Pending Requests',
                  'approved': 'Approved Requests',
                  'rejected': 'Rejected Requests',
                  'pickup-scheduled': 'Pickup Scheduled',
                  'picked-up': 'Picked Up',
                  'refunded': 'Refunded'
                };
              %>
              <%= statusLabels[currentStatus] || 'All Status' %>
            </span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="transition-transform duration-300" id="statusArrow">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          
          <div class="admin-dropdown-menu" id="statusMenu">
            <div class="admin-dropdown-item <%= !currentStatus || currentStatus === 'all' ? 'active' : '' %>" data-value="all">All Status</div>
            <div class="admin-dropdown-item <%= currentStatus === 'pending' ? 'active' : '' %>" data-value="pending">Pending Requests</div>
            <div class="admin-dropdown-item <%= currentStatus === 'approved' ? 'active' : '' %>" data-value="approved">Approved Requests</div>
            <div class="admin-dropdown-item <%= currentStatus === 'rejected' ? 'active' : '' %>" data-value="rejected">Rejected Requests</div>
            <div class="admin-dropdown-item <%= currentStatus === 'pickup-scheduled' ? 'active' : '' %>" data-value="pickup-scheduled">Pickup Scheduled</div>
            <div class="admin-dropdown-item <%= currentStatus === 'picked-up' ? 'active' : '' %>" data-value="picked-up">Picked Up</div>
            <div class="admin-dropdown-item <%= currentStatus === 'refunded' ? 'active' : '' %>" data-value="refunded">Refunded</div>
          </div>
        </div>
        <div class="flex items-center gap-2 w-full sm:w-auto">
          <div class="relative w-full sm:w-64">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input id="searchInput" value="<%= search || '' %>" type="text" placeholder="Search returns..." class="w-full pl-10 pr-4 py-2 bg-white border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-gray-900/5 transition-all">
          </div>
          <button class="px-5 py-2 bg-[#1a2e23] text-white text-xs font-bold uppercase tracking-widest rounded-lg hover:bg-black transition-colors">Search</button>
        </div>
      </div>

      <!-- Table Section -->
      <div class="card overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="bg-gray-50/50">
                <th class="lbl">Request ID</th>
                <th class="lbl">Customer</th>
                <th class="lbl">Product</th>
                <th class="lbl">Reason</th>
                <th class="lbl">Status</th>
                <th class="lbl">Date</th>
                <th class="lbl">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (returns && returns.length > 0) { %>
                <% returns.forEach(returnItem => { 
                  const orderItem = returnItem.orderId?.items?.find(i => i._id.toString() === returnItem.itemId.toString());
                %>
                  <tr class="hover:bg-gray-50/50 transition-colors">
                    <td class="text-sm font-bold text-gray-900">
                      #RET-<%= returnItem._id.toString().toUpperCase().slice(-5) %>
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-green-500 flex items-center justify-center text-[10px] font-bold text-white uppercase">
                          <%= (returnItem.userId?.name || 'U').split(' ').map(n => n[0]).join('').slice(0, 2) %>
                        </div>
                        <span class="text-sm font-medium"><%= returnItem.userId?.name || 'Unknown' %></span>
                      </div>
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg overflow-hidden border border-gray-100 bg-gray-50 flex-shrink-0">
                          <% 
                            let imgPath = orderItem?.image || '';
                            if (imgPath && !imgPath.startsWith('/') && !imgPath.startsWith('http')) imgPath = '/' + imgPath;
                          %>
                          <img src="<%= imgPath || 'https://via.placeholder.com/40' %>" 
                               onerror="this.src='https://via.placeholder.com/40'"
                               class="w-full h-full object-cover">
                        </div>
                        <span class="text-xs font-semibold truncate max-w-[150px]"><%= orderItem?.name || 'Product' %></span>
                        <% if(returnItem.itemCount > 1) { %>
                          <span class="ml-auto px-2 py-0.5 bg-gray-100 text-[9px] font-bold rounded-md text-gray-500">+<%= returnItem.itemCount - 1 %> more</span>
                        <% } %>
                      </div>
                    </td>
                    <td class="text-xs text-gray-500 max-w-[200px] truncate">
                      <%= returnItem.reason %>
                    </td>
                    <td>
                      <% if(returnItem.status === 'Requested') { %>
                        <span class="badge b-pending">Requested</span>
                      <% } else if(returnItem.status === 'Approved') { %>
                        <span class="badge b-approved">Approved</span>
                      <% } else if(returnItem.status === 'Rejected') { %>
                        <span class="badge b-rejected">Rejected</span>
                      <% } else if(returnItem.status === 'Pickup Scheduled') { %>
                        <span class="badge b-pickup">Pickup Scheduled</span>
                      <% } else if(returnItem.status === 'Picked Up') { %>
                        <span class="badge b-pickup">Picked Up</span>
                      <% } else if(returnItem.status === 'Refund Processed') { %>
                        <span class="badge b-completed">Completed</span>
                      <% } else { %>
                        <span class="badge b-completed"><%= returnItem.status %></span>
                      <% } %>
                    </td>
                    <td class="text-xs font-medium text-gray-500">
                      <%= new Date(returnItem.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                    </td>
                    <td>
                      <div class="flex items-center gap-3">
                        <% if(returnItem.status === 'Requested') { %>
                          <button title="Approve" class="text-gray-300 hover:text-green-500 transition-colors">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                          </button>
                          <button title="Reject" class="text-gray-300 hover:text-red-500 transition-colors">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                          </button>
                        <% } %>
                        <a href="/admin/returns/<%= returnItem._id %>" title="View Details" class="text-gray-300 hover:text-gray-900 transition-colors">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="px-6 py-12 text-center text-sm text-gray-400 font-medium italic">No return requests found.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination Footer -->
        <div class="px-6 py-4 border-t border-gray-100 flex items-center justify-between gap-4">
          <p class="text-xs text-gray-500 font-medium">
            Showing <span class="font-bold text-gray-900"><%= (currentPage - 1) * 8 + 1 %></span> to 
            <span class="font-bold text-gray-900"><%= Math.min(currentPage * 8, totalFilteredReturns) %></span> 
            of <span class="font-bold text-gray-900"><%= totalFilteredReturns %></span> results
          </p>

          <div class="flex items-center gap-2">
            <% if (currentPage > 1) { %>
              <a href="/admin/returns?page=<%= currentPage - 1 %>&status=<%= currentStatus %>&search=<%= searchQuery %>" 
                 class="p-2 text-gray-400 hover:text-gray-900 transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </a>
            <% } %>

            <% for(let i = 1; i <= totalPages; i++) { %>
              <% if (i === currentPage) { %>
                <span class="w-8 h-8 flex items-center justify-center bg-black text-white text-xs font-bold rounded-lg shadow-lg shadow-black/10">
                  <%= i %>
                </span>
              <% } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
                <a href="/admin/returns?page=<%= i %>&status=<%= currentStatus %>&search=<%= searchQuery %>" 
                   class="w-8 h-8 flex items-center justify-center text-gray-500 text-xs font-bold hover:bg-gray-50 rounded-lg transition-colors">
                  <%= i %>
                </a>
              <% } else if (i === currentPage - 2 || i === currentPage + 2) { %>
                <span class="text-gray-400">...</span>
              <% } %>
            <% } %>

            <% if (currentPage < totalPages) { %>
              <a href="/admin/returns?page=<%= currentPage + 1 %>&status=<%= currentStatus %>&search=<%= searchQuery %>" 
                 class="p-2 text-gray-400 hover:text-gray-900 transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <div id="sidebarOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[1000] hidden"></div>





  <script>

const searchInput =
document.getElementById("searchInput");

let debounceTimer;

if(searchInput){

searchInput.addEventListener("input",(e)=>{

clearTimeout(
   debounceTimer
);

debounceTimer =
setTimeout(()=>{

   const query =e.target.value.trim();

   const params =
   new URLSearchParams(
      window.location.search
   );



   if(query){

      params.set(
         "search",
         query
      );

   } else {

      params.delete(
         "search"
      );

   }
   window.location.href =
   `/admin/returns?${
      params.toString()
   }`;

},500);

});
}

</script>

  <script>
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebarToggle');
    const overlay = document.getElementById('sidebarOverlay');

    if(toggle) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        sidebar.classList.toggle('open');
        overlay.classList.toggle('hidden');
      });
    }

    if(overlay) {
      overlay.addEventListener('click', () => {
        sidebar.classList.add('-translate-x-full');
        sidebar.classList.remove('open');
        overlay.classList.add('hidden');
      });
    }

    // Status Filter Logic
    const statusTrigger = document.getElementById('statusTrigger');
    const statusMenu = document.getElementById('statusMenu');
    const statusArrow = document.getElementById('statusArrow');
    const statusItems = document.querySelectorAll('.admin-dropdown-item');

    statusTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      statusMenu.classList.toggle('show');
      statusArrow.classList.toggle('rotate-180');
    });

    document.addEventListener('click', () => {
      statusMenu.classList.remove('show');
      statusArrow.classList.remove('rotate-180');
    });

    statusItems.forEach(item => {
      item.addEventListener('click', () => {
        const value = item.getAttribute('data-value');
        window.location.href = `/admin/returns?status=${value}`;
      });
    });
  </script>


</body>
</html>

