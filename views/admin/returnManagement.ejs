<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Return Management — AJAX Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=DM+Sans:wght@200;300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --admin-bg: #f8fafc;
      --admin-card: #ffffff;
      --admin-border: #e5e7eb;
      --admin-text-dark: #111827;
      --admin-text-muted: #6b7280;
      --luxury-accent: #1C1C1C;
      --luxury-muted: #888888;
    }

    body { background: var(--admin-bg); color: var(--admin-text-dark); font-family: 'DM Sans', sans-serif; }
    .font-serif { font-family: 'Playfair Display', serif; }

    #sidebar { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    @media(max-width:1024px) {
      #sidebar { position: fixed; left: 0; top: 0; bottom: 0; transform: translateX(-100%); z-index: 1001; width: 280px; }
      #sidebar.open { transform: translateX(0); }
    }

    .status-badge {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.025em;
      text-transform: uppercase;
      padding: 0.35rem 0.75rem;
      border-radius: 2rem;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    .status-pending { background: #fff7ed; color: #c2410c; }
    .status-approved { background: #f0fdf4; color: #15803d; }
    .status-rejected { background: #fef2f2; color: #b91c1c; }

    /* Drawer Animation */
    .drawer-overlay { background-color: rgba(0, 0, 0, 0.4); backdrop-filter: blur(4px); transition: all 0.3s ease; }
    .drawer-content { transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); transform: translateX(100%); }
    .drawer-active .drawer-content { transform: translateX(0); }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    .animate-fade { animation: fadeIn 0.4s ease-out both; }
  </style>
</head>
<body class="flex min-h-screen">

  <%- include('partials/sidebar', { currentPath: '/admin/returns' }) %>

  <main class="flex-1 flex flex-col min-w-0 overflow-y-auto max-h-screen">
    <!-- Top Nav -->
    <header class="p-4 md:p-8 pb-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 sticky top-0 bg-[var(--admin-bg)] z-40">
      <div class="flex items-center gap-4">
        <button id="sidebarToggle" class="lg:hidden p-2 hover:bg-stone-100 rounded-lg">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <div>
          <h1 class="text-2xl md:text-3xl font-serif font-bold text-[var(--admin-text-dark)]">Return Management</h1>
          <p class="text-sm text-[var(--admin-text-muted)] mt-1">Manage customer return requests and refund processing.</p>
        </div>
      </div>
    </header>

    <div class="px-4 md:px-8 py-4 animate-fade">
      <!-- Stats -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-xl border border-[var(--admin-border)] shadow-sm">
          <p class="text-[10px] font-bold text-[var(--admin-text-muted)] uppercase tracking-widest mb-1">Total Returns</p>
          <h3 class="text-2xl font-bold"><%= totalReturns %></h3>
        </div>
        <div class="bg-white p-6 rounded-xl border border-[var(--admin-border)] shadow-sm">
          <p class="text-[10px] font-bold text-orange-500 uppercase tracking-widest mb-1">Pending Action</p>
          <h3 class="text-2xl font-bold"><%= pendingReturns %></h3>
        </div>
        <div class="bg-white p-6 rounded-xl border border-[var(--admin-border)] shadow-sm">
          <p class="text-[10px] font-bold text-green-600 uppercase tracking-widest mb-1">Approved</p>
          <h3 class="text-2xl font-bold"><%= approvedReturns %></h3>
        </div>
        <div class="bg-white p-6 rounded-xl border border-[var(--admin-border)] shadow-sm">
          <p class="text-[10px] font-bold text-red-500 uppercase tracking-widest mb-1">Rejected</p>
          <h3 class="text-2xl font-bold"><%= rejectedReturns %></h3>
        </div>
      </div>

      <!-- Table -->
      <div class="bg-white rounded-xl border border-[var(--admin-border)] overflow-hidden shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-stone-50/50 border-b border-[var(--admin-border)]">
                <th class="px-6 py-4 text-[10px] font-bold text-[var(--admin-text-muted)] uppercase tracking-widest">Return ID</th>
                <th class="px-6 py-4 text-[10px] font-bold text-[var(--admin-text-muted)] uppercase tracking-widest">Customer</th>
                <th class="px-6 py-4 text-[10px] font-bold text-[var(--admin-text-muted)] uppercase tracking-widest">Date</th>
                <th class="px-6 py-4 text-[10px] font-bold text-[var(--admin-text-muted)] uppercase tracking-widest">Reason</th>
                <th class="px-6 py-4 text-[10px] font-bold text-[var(--admin-text-muted)] uppercase tracking-widest">Status</th>
                <th class="px-6 py-4 text-[10px] font-bold text-[var(--admin-text-muted)] uppercase tracking-widest text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--admin-border)]">
              <% if (returns && returns.length > 0) { %>
                <% returns.forEach(returnItem => { %>
                  <tr class="hover:bg-stone-50/30 transition-colors">
                    <td class="px-6 py-5 text-sm font-bold text-blue-600">
                      #RET-<%= returnItem._id.toString().toUpperCase().slice(-5) %>
                    </td>
                    <td class="px-6 py-5 text-sm font-medium"><%= returnItem.userId?.name || 'Unknown' %></td>
                    <td class="px-6 py-5 text-xs text-[var(--admin-text-muted)]">
                      <%= new Date(returnItem.createdAt).toLocaleDateString() %>
                    </td>
                    <td class="px-6 py-5 text-xs font-medium"><%= returnItem.reason %></td>
                    <td class="px-6 py-5">
                      <span class="status-badge <%= returnItem.status === 'Requested' ? 'status-pending' : returnItem.status === 'Approved' ? 'status-approved' : 'status-rejected' %>">
                        <%= returnItem.status %>
                      </span>
                    </td>
                    <td class="px-6 py-5 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <a href="/admin/returns/<%= returnItem._id %>" class="p-2 hover:bg-stone-100 rounded-full transition-all">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </a>
                        <% if(returnItem.status === 'Requested') { %>
                          <button class="px-3 py-1.5 text-[9px] font-black uppercase tracking-widest text-green-600 bg-green-50 hover:bg-green-100 rounded-full border border-green-200 transition-all">Approve</button>
                          <button class="px-3 py-1.5 text-[9px] font-black uppercase tracking-widest text-red-600 bg-red-50 hover:bg-red-100 rounded-full border border-red-200 transition-all">Reject</button>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="px-6 py-12 text-center text-sm text-[var(--admin-text-muted)]">No returns found.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <!-- Side Drawer -->
  <div id="drawerOverlay" class="fixed inset-0 z-[1002] drawer-overlay opacity-0 invisible" onclick="toggleDrawer(false)"></div>
  <div id="drawer" class="fixed top-0 right-0 bottom-0 w-full max-w-lg bg-white z-[1003] drawer-content shadow-2xl flex flex-col translate-x-full">
    <div class="px-8 py-6 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-xl font-serif font-bold">Return Request Details</h2>
      <button onclick="toggleDrawer(false)" class="p-2 hover:bg-gray-100 rounded-full"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div id="drawerContent" class="flex-1 overflow-y-auto p-8 space-y-8">
      <!-- Content populated by JS -->
    </div>
  </div>

  <!-- OVERLAY (Mobile Sidebar) -->
  <div id="sidebarOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[1000] hidden"></div>

  <script>
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    const sidebarOverlay = document.getElementById('sidebarOverlay');

    if (sidebarToggle) {
      sidebarToggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        sidebar.classList.toggle('open');
        sidebarOverlay.classList.toggle('hidden');
      });
    }

    if (sidebarOverlay) {
      sidebarOverlay.addEventListener('click', () => {
        sidebar.classList.add('-translate-x-full');
        sidebar.classList.remove('open');
        sidebarOverlay.classList.add('hidden');
      });
    }

    function toggleDrawer(open, dataStr) {
      const drawer = document.getElementById('drawer');
      const overlay = document.getElementById('drawerOverlay');
      const content = document.getElementById('drawerContent');
      
      if (open && dataStr) {
        const item = JSON.parse(dataStr);
        content.innerHTML = `
          <div class="space-y-6">
            <div class="pb-6 border-b border-gray-100">
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Request Information</p>
              <h3 class="text-lg font-bold text-gray-900">Return ID: #RET-${item._id.toUpperCase().slice(-5)}</h3>
              <p class="text-sm text-gray-500 mt-1">Submitted on ${new Date(item.createdAt).toLocaleString()}</p>
            </div>
            
            <div>
              <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Customer Message</p>
              <div class="p-5 bg-stone-50 rounded-2xl border border-gray-100">
                <p class="text-sm italic text-gray-700">"${item.reason}"</p>
              </div>
            </div>

            <div class="pt-6">
               <a href="/admin/orders/${item.orderId?._id || item.orderId}" class="inline-flex items-center gap-2 text-xs font-bold text-blue-600 hover:underline">
                  View Full Order Details
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
               </a>
            </div>
          </div>
        `;
        drawer.classList.remove('translate-x-full');
        overlay.classList.remove('invisible');
        overlay.classList.add('opacity-100');
      } else {
        drawer.classList.add('translate-x-full');
        overlay.classList.add('invisible');
        overlay.classList.remove('opacity-100');
      }
    }
  </script>
</body>
</html>
