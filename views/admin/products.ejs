<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Product Management — AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/utils/swal-helper.js"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Plus Jakarta Sans', 'sans-serif']
        },
        colors: {
          'luxury-bg': '#F3F2EE',
          'luxury-accent': '#C1272D', /* Red accent from Figma */
          'luxury-text': '#1C1C1C',
          'luxury-muted': '#8E8E8E'
        }
      }
    }
  }
</script>

<style>
  body { background-color: theme('colors.luxury-bg'); color: theme('colors.luxury-text'); font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }
  
  /* Sidebar styles */
  .sidebar-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 0px; transition: all 0.2s ease; position: relative; color: theme('colors.luxury-muted'); font-size: 14px; font-weight: 500; }
  .sidebar-item:hover { color: theme('colors.luxury-text'); }
  .sidebar-item.active { background-color: #EBEAE4; color: theme('colors.luxury-text'); }
  .sidebar-item.active::after { content: ''; position: absolute; right: 0; top: 0; bottom: 0; width: 3px; background-color: theme('colors.luxury-accent'); }

  /* Table styles */
  .table-card { background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); overflow: hidden; }
  .status-pill { padding: 4px 12px; border-radius: 100px; font-size: 11px; font-weight: 600; text-transform: capitalize; }
  .status-active { background: #E8F5E9; color: #2E7D32; }
  .status-inactive { background: #FFEBEE; color: #C62828; }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #D1D1D1; border-radius: 10px; }

  /* Toggle Switch Styles */
  .switch { position: relative; display: inline-block; width: 38px; height: 20px; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .slider { position: absolute; cursor: pointer; inset: 0; background-color: #E2E2E2; border-radius: 34px; transition: .4s; }
  .slider:before { position: absolute; content: ""; height: 14px; width: 14px; left: 3px; bottom: 3px; background-color: white; border-radius: 50%; transition: .4s; }
  input:checked + .slider { background-color: theme('colors.luxury-text'); }
  input:checked + .slider:before { transform: translateX(18px); }
  
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeIn 0.5s ease out forwards; }
</style>
</head>
<body class="flex min-h-screen">

  <!-- SIDEBAR -->
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-white border-r border-stone-200 transition-transform lg:translate-x-0 lg:static lg:inset-0 -translate-x-full">
    <div class="h-full flex flex-col p-6">
      <!-- Logo -->
      <div class="mb-10">
        <h1 class="text-3xl font-serif font-bold tracking-tighter">AJAX</h1>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 space-y-1">
        <p class="text-[10px] font-bold text-stone-400 tracking-[0.2em] mb-4 uppercase">Management</p>
        
        <a href="/admin/dashboard" class="sidebar-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
        <a href="/admin/orders" class="sidebar-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Orders
        </a>
        <a href="/admin/products" class="sidebar-item active">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
          Products
        </a>
        <a href="/admin/categories" class="sidebar-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Categories
        </a>
        <a href="/admin/coupons" class="sidebar-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 12a10 10 0 1 0 20 0 10 10 0 1 0-20 0Z"/><path d="m7 7 10 10"/><path d="m17 7-10 10"/></svg>
          Coupons
        </a>
        <a href="/admin/offers" class="sidebar-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Offers
        </a>
        <a href="/admin/users" class="sidebar-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Customers
        </a>
        <a href="/admin/reviews" class="sidebar-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Reviews
        </a>
      </nav>

      <!-- Profile Section -->
      <div class="mt-auto pt-6 border-t border-stone-100 flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-stone-100 flex items-center justify-center overflow-hidden">
            <img src="https://ui-avatars.com/api/?name=Abdulla+Safwan&background=F3F2EE&color=1C1C1C" alt="Admin" class="w-full h-full object-cover">
        </div>
        <div class="flex-1 overflow-hidden">
          <p class="text-sm font-bold truncate">Abdulla Safwan</p>
          <p class="text-[10px] text-stone-400 truncate tracking-tight">admin@noco.luxury</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="flex-1 min-w-0 flex flex-col p-4 lg:p-8">
    
    <!-- Header -->
    <header class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-4">
        <button id="sidebarToggle" class="lg:hidden p-2 hover:bg-white rounded-lg transition-colors">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <h2 class="text-3xl font-serif font-bold">Product Management</h2>
      </div>
      
      <div class="flex items-center gap-3">
        <button class="p-2.5 rounded-full hover:bg-white transition-colors relative">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
          <span class="absolute top-2.5 right-2.5 w-2 h-2 bg-luxury-accent rounded-full border-2 border-luxury-bg"></span>
        </button>
        <a href="/admin/products/add" class="bg-luxury-text text-white px-5 py-2.5 rounded-lg flex items-center gap-2 text-sm font-semibold hover:bg-stone-800 transition-all shadow-sm">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Product
        </a>
        <button class="p-2.5 rounded-full hover:bg-white transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
      </div>
    </header>

    <!-- CONTENT CARD -->
    <div class="table-card animate-fade-in">
        <!-- Card Header with Filters -->
        <div class="p-6">
          <form method="GET" action="/admin/products">
            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-8">
                <h3 class="text-xl font-bold">Product Catalog</h3>
                
                <div class="flex flex-wrap items-center gap-3">
                    <!-- Search Bar -->
                    <div class="relative w-full lg:w-72">
                        <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-stone-400" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <input type="text" placeholder="Search by name or SKU..." name="search" value="<%= search %>" class="w-full pl-11 pr-4 py-2.5 bg-stone-50 border border-stone-200 rounded-xl text-sm focus:outline-none focus:border-luxury-text focus:ring-1 focus:ring-luxury-text/10 transition-all">
                    </div>
                    
                    <!-- Filter Dropdowns -->
                    <select name="category" onchange="this.form.submit()" class="bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-luxury-text cursor-pointer min-w-[160px] hover:bg-white transition-all shadow-sm">
                        <option value="">All Categories</option>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat._id %>" <%= selectedCategory == cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                        <% }) %>
                    </select>

                    <select name="subcategory" onchange="this.form.submit()" class="bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-luxury-text cursor-pointer min-w-[160px] hover:bg-white transition-all shadow-sm">
                        <option value="">All Subcategories</option>
                        <% subCategories.forEach(sub => { %>
                            <option value="<%= sub._id %>" <%= selectedSubCategory == sub._id.toString() ? 'selected' : '' %>><%= sub.name %></option>
                        <% }) %>
                    </select>

                    <select name="status" onchange="this.form.submit()" class="bg-stone-50 border border-stone-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:border-luxury-text cursor-pointer min-w-[140px] hover:bg-white transition-all shadow-sm">
                        <option value="">All Status</option>
                        <option value="active" <%= selectedStatus === 'active' ? 'selected' : '' %>>Active</option>
                        <option value="inactive" <%= selectedStatus === 'inactive' ? 'selected' : '' %>>Inactive</option>
                    </select>

                    <% if (search || selectedCategory || selectedSubCategory || selectedStatus) { %>
                        <a href="/admin/products" class="text-xs font-bold text-luxury-accent hover:underline px-2 transition-all">Clear All</a>
                    <% } %>
                </div>
            </div>
           </form>
            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="text-left text-[11px] font-bold text-stone-400 uppercase tracking-widest border-b border-stone-100">
                            <th class="pb-4 pr-4">SL NO</th>
                            <th class="pb-4 pr-4">PDT IMAGE</th>
                            <th class="pb-4 pr-4">PDT NAME & SKU</th>
                            <th class="pb-4 pr-4">CATEGORY</th>
                            <th class="pb-4 pr-4">SUBCATEGORY</th>
                            <th class="pb-4 pr-4">PRICE</th>
                            <th class="pb-4 pr-4 text-center">STOCK</th>
                            <th class="pb-4 pr-4 text-center">STATUS</th>
                            <th class="pb-4 text-right">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-stone-50">
                        <% products.forEach((product, index) => { %>
                        <tr class="group hover:bg-stone-50/50 transition-colors">
                            <td class="py-5 text-sm text-stone-400"><%= (index + 1).toString().padStart(2, '0') %></td>
                            <td class="py-5 pr-4">
                                <div class="w-14 h-14 rounded-lg bg-stone-100 overflow-hidden">
                                   <img src="<%= product.variant?.images?.[0] || '/images/no-image.png' %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                                </div>
                            </td>
                            <td class="py-5 pr-4">
                                <p class="text-sm font-bold text-luxury-text mb-0.5"><%= product.name %></p>
                                <p class="text-[10px] text-stone-400 font-medium tracking-tight uppercase"><%= product.sku %></p>
                            </td>
                            <td class="py-5 pr-4 text-sm font-medium text-stone-600"><%= product.category?.name || '—' %></td>
                            <td class="py-5 pr-4 text-sm font-medium text-stone-500"><%= product.subcategory?.name || '—' %></td>
                            <td class="py-5 pr-4 font-bold text-sm">₹<%= product.variant?.price || 0 %></td>
                            <td class="py-5 pr-4 text-center">
                                <span class="text-sm font-bold <%= product.stock === 0 ? 'text-luxury-accent' : '' %>"> <%= product.variant?.stock || 0 %></span>
                            </td>
                            <td class="py-5 pr-4 text-center">
                                <div class="flex flex-col items-center gap-2">
                                    <span class="status-pill <%= product.isActive ? 'status-active' : 'status-inactive' %>">
                                        <%= product.isActive ? 'Active' : 'Inactive' %>
                                    </span>
                                    <label class="switch">
                                        <input type="checkbox" <%= product.isActive ? 'checked' : '' %> onchange="toggleProductStatus('<%= product._id %>', this)">
                                        <span class="slider"></span>
                                    </label>
                                </div>
                            </td>
                            <td class="py-5 text-right">
                                <div class="flex items-center justify-end gap-2">
                                   <a href="/admin/products/<%= product._id %>" 
                                                title="View"class="p-2 text-stone-400 hover:text-luxury-text hover:bg-white rounded-lg transition-all border border-transparent shadow-none hover:shadow-sm">  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></a>
                                   <a href="/admin/products/edit/<%= product._id %>" title="Edit" class="p-2 text-stone-400 hover:text-luxury-text hover:bg-white rounded-lg transition-all">Edit</a>
                                    <button onclick="deleteProduct('<%= product._id %>')"  title="Delete" class="p-2 text-stone-400 hover:text-luxury-accent hover:bg-white rounded-lg transition-all border border-transparent shadow-none hover:shadow-sm">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        <div class="px-6 py-5 border-t border-stone-50 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-sm text-stone-400 font-medium">
                Showing <%= totalMatchingProducts > 0 ? ((currentPage - 1) * limit + 1) : 0 %>-<%= Math.min(currentPage * limit, totalMatchingProducts) %> of <%= totalMatchingProducts %> luxury pieces
            </p>
            
            <% if (totalPages > 1) { %>
            <div class="flex items-center gap-2">
                <!-- Previous Button -->
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= selectedCategory %>&subcategory=<%= selectedSubCategory %>&status=<%= selectedStatus %>" 
                       class="px-4 py-2 text-xs font-bold uppercase tracking-widest text-stone-600 hover:text-luxury-text border border-stone-200 rounded-lg hover:border-luxury-text transition-all">
                        Previous
                    </a>
                <% } else { %>
                    <span class="px-4 py-2 text-xs font-bold uppercase tracking-widest text-stone-300 border border-stone-100 rounded-lg cursor-not-allowed">
                        Previous
                    </span>
                <% } %>

                <!-- Page Numbers -->
                <div class="flex items-center gap-1">
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <a href="?page=<%= i %>&search=<%= search %>&category=<%= selectedCategory %>&subcategory=<%= selectedSubCategory %>&status=<%= selectedStatus %>" 
                           class="w-8 h-8 flex items-center justify-center rounded-lg text-[10px] font-bold transition-all
                                  <%= i === currentPage ? 'bg-luxury-text text-white shadow-md' : 'hover:bg-stone-50 text-stone-600 hover:text-luxury-text border border-transparent hover:border-stone-200' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>

                <!-- Next Button -->
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= selectedCategory %>&subcategory=<%= selectedSubCategory %>&status=<%= selectedStatus %>" 
                       class="px-4 py-2 text-xs font-bold uppercase tracking-widest text-stone-600 hover:text-luxury-text border border-stone-200 rounded-lg hover:border-luxury-text transition-all">
                        Next
                    </a>
                <% } else { %>
                    <span class="px-4 py-2 text-xs font-bold uppercase tracking-widest text-stone-300 border border-stone-100 rounded-lg cursor-not-allowed">
                        Next
                    </span>
                <% } %>
            </div>
            <% } %>
        </div>
    </div>
  </main>

  <script>
    // Sidebar toggle for mobile
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebarToggle');
    
    if(sidebarToggle) {
        sidebarToggle.addEventListener('click', () => {
            sidebar.classList.toggle('-translate-x-full');
        });
    }

    // Close sidebar when clicking outside on mobile
    document.addEventListener('click', (e) => {
        if (window.innerWidth < 1024 && !sidebar.contains(e.target) && !sidebarToggle.contains(e.target)) {
            sidebar.classList.add('-translate-x-full');
        }
    });

    window.addEventListener('resize', () => {
        if (window.innerWidth >= 1024) {
            sidebar.classList.remove('-translate-x-full');
        }
    });
  </script>
   <script src="/js/admin/product.js"></script>
</body>
</html>
