
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Return Details — AJAX Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <style>
    body { background: #f9fafb; color: #111; font-family: 'Inter', sans-serif; -webkit-font-smoothing: antialiased; }
    .font-serif { font-family: 'Playfair Display', serif; }
    
    .banner { 
      background: #2a4034; /* Dark Forest Green */
      color: #fff; 
      border-radius: 20px; 
      padding: 32px 40px; 
      position: relative; 
      overflow: hidden;
      margin: 24px;
      box-shadow: 0 10px 30px -10px rgba(42, 64, 52, 0.3);
    }
    .banner::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: url('https://www.transparenttextures.com/patterns/cubes.png');
      opacity: 0.05;
    }

    .card { background: #fff; border: 1px solid #f1f5f9; border-radius: 16px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02); }
    .card-header { padding: 20px 24px; border-bottom: 1px solid #f8fafc; display: flex; align-items: center; gap: 10px; }
    
    .lbl-title { font-size: 11px; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
    .data-label { font-size: 13px; color: #94a3b8; font-weight: 500; }
    .data-value { font-size: 13px; color: #1e293b; font-weight: 700; }

    .status-pill {
      background: rgba(255, 255, 255, 0.1);
      color: #dcfce7;
      padding: 6px 14px;
      border-radius: 99px;
      font-size: 12px;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: #fbbf24; }

    .btn-approve { background: #3d6b4a; color: #fff; transition: all 0.2s; }
    .btn-approve:hover { background: #2f5239; transform: translateY(-1px); }
    
    .btn-reject { background: #fff; color: #ef4444; border: 1px solid #fee2e2; transition: all 0.2s; }
    .btn-reject:hover { background: #fef2f2; border-color: #fca5a5; }

    .icon-box { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }

    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }

    .product-img { width: 80px; height: 80px; border-radius: 12px; object-fit: cover; background: #f8fafc; }
  </style>
</head>
<%
  const st = returnItem.status;
  const addr = returnItem.orderId?.address;
  const fmt = d => d ? new Date(d).toLocaleDateString('en-US', { day: '2-digit', month: 'short', year: 'numeric' }) : '—';
  const totalRefund = allReturnsInOrder.reduce((acc, r) => acc + (r.refundAmount || 0), 0);
%>
<body class="flex min-h-screen">

  <%- include('partials/sidebar', { currentPath: '/admin/returns' }) %>

  <main class="flex-1 flex flex-col min-w-0 overflow-y-auto max-h-screen pb-12">
    
    <!-- Header Banner -->
    <header class="animate-up">
      <div class="banner">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 relative z-10">
          <div>
            <nav class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-white/40 mb-3">
              <span>Orders</span>
              <span>/</span>
              <span class="text-white/60">#<%= returnItem.orderId?._id?.toString().toUpperCase().slice(-10) %></span>
              <span>/</span>
              <span class="text-white">RET-<%= returnItem._id.toString().toUpperCase().slice(-2) %></span>
            </nav>
            <h1 class="text-3xl font-serif font-bold text-white mb-1">Return Details</h1>
            <p class="text-white/60 text-sm">Manage and review return request</p>
          </div>
          
          <div class="status-pill">
            <div class="status-dot"></div>
            <%= st === 'Requested' ? 'Pending Review' : st %>
          </div>
        </div>
      </div>
    </header>

    <div class="px-6 md:px-10 grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
      
      <!-- Left Column: Order & Customer -->
      <div class="lg:col-span-8 space-y-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Order Info -->
          <div class="card animate-up" style="animation-delay: 0.1s">
            <div class="card-header">
              <div class="icon-box bg-green-50 text-green-600">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 8V21H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
              </div>
              <span class="lbl-title">Order Info</span>
            </div>
            <div class="p-6 space-y-4">
              <div class="flex justify-between items-center"><span class="data-label">Return ID</span><span class="data-value">#RET-<%= returnItem._id.toString().toUpperCase().slice(-5) %></span></div>
              <div class="flex justify-between items-center"><span class="data-label">Order ID</span><span class="px-2 py-1 bg-green-50 text-green-600 text-[10px] font-bold rounded-md tracking-tighter">#<%= returnItem.orderId?._id?.toString().toUpperCase().slice(-10) %></span></div>
              <div class="flex justify-between items-center"><span class="data-label">Requested On</span><span class="data-value"><%= fmt(returnItem.requestedAt || returnItem.createdAt) %></span></div>
              <div class="p-4 bg-green-50/30 rounded-xl mt-4 flex justify-between items-center">
                <span class="text-sm font-semibold text-green-800">Refund Amount</span>
                <span class="text-lg font-bold text-green-700">₹<%= totalRefund.toLocaleString('en-IN') %></span>
              </div>
            </div>
          </div>

          <!-- Customer Info -->
          <div class="card animate-up" style="animation-delay: 0.2s">
            <div class="card-header">
              <div class="icon-box bg-blue-50 text-blue-600">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <span class="lbl-title">Customer Info</span>
            </div>
            <div class="p-6 flex flex-col items-center justify-center py-10">
              <div class="w-16 h-16 rounded-full bg-stone-100 flex items-center justify-center text-xl font-bold text-gray-400 mb-4 border-4 border-white shadow-sm uppercase">
                <%= (returnItem.userId?.name || 'U')[0] %>
              </div>
              <h3 class="text-base font-bold text-slate-800"><%= returnItem.userId?.name || 'Unknown' %></h3>
              <p class="text-xs text-slate-400 mb-4"><%= returnItem.userId?.email || '—' %></p>
              <div class="w-full h-px bg-slate-50 mb-4"></div>
              <div class="w-full text-center">
                <p class="text-[10px] font-bold text-slate-300 uppercase tracking-widest mb-1">Shipping From</p>
                <p class="text-[11px] text-slate-500 italic"><%= addr ? addr.city + ', ' + addr.state : 'No address' %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Product Details -->
        <div class="card animate-up" style="animation-delay: 0.3s">
          <div class="card-header">
            <div class="icon-box bg-slate-50 text-slate-600">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </div>
            <span class="lbl-title">Product Details</span>
          </div>
          <div class="p-8 space-y-6">
            <% allReturnsInOrder.forEach((ret, idx) => { 
                const orderItem = ret.orderId?.items?.find(i => i._id.toString() === ret.itemId.toString());
                const imgPath = orderItem?.image && !orderItem.image.startsWith('/') && !orderItem.image.startsWith('http') ? '/' + orderItem.image : orderItem?.image;
            %>
            <div class="flex items-center gap-6">
              <img src="<%= imgPath || 'https://via.placeholder.com/150' %>" class="product-img shadow-sm">
              <div class="flex-1">
                <h4 class="text-lg font-bold text-slate-800 leading-tight mb-2 font-serif"><%= orderItem?.name || 'Product' %></h4>
                <div class="inline-flex items-center px-2 py-1 bg-slate-100 rounded text-[9px] font-black uppercase text-slate-500 tracking-wider">
                  Quantity Returned: <%= orderItem?.quantity || 1 %>
                </div>
              </div>
            </div>
            <% if(idx < allReturnsInOrder.length - 1) { %><div class="h-px bg-slate-50"></div><% } %>
            <% }) %>
          </div>
        </div>

        <!-- Reason & Condition -->
        <div class="card animate-up" style="animation-delay: 0.4s">
          <div class="card-header">
            <div class="icon-box bg-orange-50 text-orange-600">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            </div>
            <span class="lbl-title">Reason & Condition</span>
          </div>
          <div class="p-8 space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="p-6 bg-slate-50 rounded-xl border border-slate-100">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Reason</p>
                <p class="text-sm font-bold text-slate-800"><%= returnItem.reason %></p>
              </div>
              <div class="p-6 bg-slate-50 rounded-xl border border-slate-100">
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Condition</p>
                <p class="text-sm font-bold text-slate-800"><%= returnItem.condition %></p>
              </div>
            </div>
            <% if(returnItem.comment) { %>
            <div class="mt-4">
              <p class="text-[10px] font-bold text-slate-300 uppercase tracking-widest mb-3">Customer Description</p>
              <div class="flex gap-4 p-6 bg-slate-50 rounded-xl border border-slate-100">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e2e8f0" stroke-width="3" class="flex-shrink-0"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.75-2-2-2H5c-1.25 0-2 .75-2 2v3c0 1.25.75 2 2 2h3c0 4-2 5-5 5v5zm11 0c3 0 7-1 7-8V5c0-1.25-.75-2-2-2h-3c-1.25 0-2 .75-2 2v3c0 1.25.75 2 2 2h3c0 4-2 5-5 5v5z"/></svg>
                <p class="text-xs font-bold text-slate-600 leading-relaxed"><%= returnItem.comment %></p>
              </div>
            </div>
            <% } %>
          </div>
        </div>

      </div>

      <!-- Right Column: Admin Actions -->
      <div class="lg:col-span-4 animate-up" style="animation-delay: 0.5s">
        <div class="card overflow-hidden border-none shadow-xl">
          <div class="bg-[#2a4034] p-6 flex items-center gap-4">
            <div class="icon-box bg-white/10 text-white">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            </div>
            <span class="text-xs font-black uppercase tracking-widest text-white/90">Admin Actions</span>
          </div>
          <div class="p-8 space-y-6">
            <% if(st === 'Requested') { %>
            <div class="space-y-4">
                <button  id="approveBtn" data-id="<%= returnItem._id %>" class="w-full py-4 btn-approve text-xs font-black uppercase tracking-widest rounded-xl shadow-lg shadow-green-900/10 flex items-center justify-center gap-3">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  Approve Return
                </button>
                <button id="rejectBtn" data-id="<%= returnItem._id %>"  class="w-full py-4 btn-reject text-xs font-black uppercase tracking-widest rounded-xl shadow-sm flex items-center justify-center gap-3">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  Reject
                </button>
            </div>
            <% } %>
            
           <% if(st === 'Approved') { %>

         <div class="pt-2">

        <p class="text-[10px] font-bold text-slate-300 uppercase tracking-widest mb-4">
         Pickup Logistics
  </p>

  <div class="space-y-4">

    <div class="space-y-1.5">

      <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">
        Pickup Date
      </label>

      <input
        id="pickupDate"
        type="date"
        class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm font-bold outline-none focus:ring-2 focus:ring-green-100 transition-all"
      >

    </div>



    <div class="space-y-1.5">

      <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">
        Pickup Time
      </label>

      <input
        id="pickupTime"
        type="time"
        class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl text-sm font-bold outline-none focus:ring-2 focus:ring-green-100 transition-all"
      >

    </div>



    <button
      id="schedulePickupBtn"
      data-id="<%= returnItem._id %>"
      class="w-full py-3 bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest rounded-xl hover:bg-black transition-all"
    >

      Schedule Pickup

    </button>

  </div>

        </div>

        <% } %>


        <% if(returnItem.pickupStatus === 'Scheduled') { %>

<div class="space-y-5">

    <div class="p-5 rounded-2xl bg-amber-50 border border-amber-100">

        <p class="text-[10px] font-black uppercase tracking-widest text-amber-500 mb-3">
            Pickup Scheduled
        </p>

        <div class="space-y-2">

            <div class="flex justify-between">

                <span class="text-xs text-slate-500">
                    Date
                </span>

                <span class="text-xs font-bold text-slate-800">
                    <%= fmt(returnItem.pickupDate) %>
                </span>

            </div>

            <div class="flex justify-between">

                <span class="text-xs text-slate-500">
                    Time
                </span>

                <span class="text-xs font-bold text-slate-800">
                    <%= returnItem.pickupTime %>
                </span>

            </div>

        </div>

    </div>



    <button
        id="pickedUpBtn"
        data-id="<%= returnItem._id %>"
        class="w-full py-4 bg-[#2a4034] text-white rounded-xl text-[10px] font-black uppercase tracking-widest"
    >

        Mark As Picked Up

    </button>

</div>

<% } %>


<% if(returnItem.pickupStatus === 'Picked Up') { %>

<div class="p-6 rounded-2xl bg-green-50 border border-green-100 text-center">

    <div class="w-14 h-14 rounded-full bg-green-100 mx-auto mb-4 flex items-center justify-center">

        <svg width="24"
             height="24"
             viewBox="0 0 24 24"
             fill="none"
             stroke="#15803d"
             stroke-width="3">

            <polyline points="20 6 9 17 4 12"/>

        </svg>

    </div>

    <p class="text-[10px] font-black uppercase tracking-widest text-green-500 mb-2">
        Pickup Completed
    </p>

    <p class="text-sm font-bold text-slate-700">
        Product successfully collected
    </p>

</div>

<% } %>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script>
    // Sidebar logic
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebarToggle');
    if(toggle) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        sidebar.classList.toggle('open');
      });
    }
  </script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/js/admin/returnDetails.js"></script>
</body>
</html>


