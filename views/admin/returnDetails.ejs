<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Return Details — AJAX Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Inter:wght@300;400;500;600;700&family=DM+Sans:wght@200;300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --admin-bg: #f8fafc;
      --admin-card: #ffffff;
      --admin-border: #e5e7eb;
      --admin-text-dark: #111827;
      --admin-text-muted: #6b7280;
      --success-green: #22c55e;
      --danger-red: #ef4444;
      --warning-orange: #f97316;
      --neutral-gray: #64748b;
    }

    body { background: var(--admin-bg); color: var(--admin-text-dark); font-family: 'Inter', 'DM Sans', sans-serif; }
    .font-serif { font-family: 'Playfair Display', serif; }

    .luxury-card { background: #ffffff; border: 1px solid var(--admin-border); border-radius: 18px; box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.05); transition: all 0.3s ease; }
    .luxury-card:hover { box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.04); }

    .timeline-line { position: absolute; left: 11px; top: 24px; bottom: 0; width: 2px; background: #f1f5f9; }
    .timeline-dot { width: 24px; height: 24px; border-radius: 50%; border: 4px solid #fff; position: relative; z-index: 10; box-shadow: 0 0 0 2px #f1f5f9; }
    .timeline-active { box-shadow: 0 0 0 2px var(--warning-orange) !important; background: var(--warning-orange); }
    .timeline-complete { box-shadow: 0 0 0 2px var(--success-green) !important; background: var(--success-green); }

    .sticky-footer { position: sticky; bottom: 0; background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border-top: 1px solid var(--admin-border); z-index: 50; }

    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-up { animation: slideUp 0.5s ease-out both; }
  </style>
</head>
<body class="flex min-h-screen">

  <%- include('partials/sidebar', { currentPath: '/admin/returns' }) %>

  <main class="flex-1 flex flex-col min-w-0 overflow-y-auto max-h-screen">
    <!-- Header Section -->
    <header class="p-6 md:p-10 pb-0 sticky top-0 bg-[var(--admin-bg)] z-40">
      <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6 mb-8 animate-up">
        <div class="flex items-center gap-5">
          <a href="/admin/returns" class="w-10 h-10 luxury-card flex items-center justify-center hover:bg-gray-50 transition-all">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </a>
          <div>
            <div class="flex items-center gap-3">
              <h1 class="text-2xl md:text-3xl font-serif font-bold text-[var(--admin-text-dark)]">#RET-4821</h1>
              <span class="px-3 py-1 bg-orange-50 text-orange-600 text-[10px] font-black uppercase tracking-widest rounded-full border border-orange-100">Requested</span>
            </div>
            <p class="text-sm text-[var(--admin-text-muted)] mt-1 flex items-center gap-2">
              <span class="font-bold text-gray-900">Ajay K</span> • Submitted on May 7, 2024
            </p>
          </div>
        </div>
        
        <div class="flex items-center gap-3 w-full lg:w-auto">
          <button class="flex-1 lg:flex-none px-6 py-3 bg-red-50 text-red-600 text-xs font-black uppercase tracking-widest rounded-xl hover:bg-red-100 transition-all border border-red-100">Reject Return</button>
          <button class="flex-1 lg:flex-none px-8 py-3 bg-green-500 text-white text-xs font-black uppercase tracking-widest rounded-xl hover:bg-green-600 shadow-lg shadow-green-100 transition-all">Approve Return</button>
        </div>
      </div>
    </header>

    <div class="px-6 md:px-10 pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- LEFT SIDE: Main Content -->
        <div class="lg:col-span-8 space-y-8">
          
          <!-- SECTION 1 — PRODUCT INFORMATION -->
          <section class="luxury-card p-6 md:p-8 animate-up" style="animation-delay: 0.1s;">
            <div class="flex items-center gap-2 mb-8">
              <span class="w-1.5 h-6 bg-black rounded-full"></span>
              <h2 class="text-sm font-black uppercase tracking-[0.2em] text-gray-400">Product Information</h2>
            </div>
            <div class="flex flex-col md:flex-row gap-8">
              <div class="w-32 md:w-40 h-48 luxury-card overflow-hidden bg-gray-50 flex-shrink-0">
                <img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400" class="w-full h-full object-cover hover:scale-110 transition-transform duration-500">
              </div>
              <div class="flex-1 grid grid-cols-2 gap-y-6 gap-x-8">
                <div class="col-span-2">
                  <h3 class="text-lg font-bold text-gray-900">Premium Cotton Tee</h3>
                  <p class="text-xs text-[var(--admin-text-muted)] mt-1 uppercase tracking-widest font-medium">SKU: AJAX-COT-001</p>
                </div>
                <div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Variant</p>
                  <p class="text-sm font-bold text-gray-900 italic">Midnight Black</p>
                </div>
                <div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Size</p>
                  <p class="text-sm font-bold text-gray-900">Extra Large (XL)</p>
                </div>
                <div class="pt-4 border-t border-gray-50">
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Quantity</p>
                  <p class="text-sm font-bold text-gray-900">01 Unit</p>
                </div>
                <div class="pt-4 border-t border-gray-50">
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Refund Amount</p>
                  <p class="text-sm font-bold text-gray-900">₹1,499.00</p>
                </div>
              </div>
            </div>
          </section>

          <!-- SECTION 2 — CUSTOMER INFORMATION -->
          <section class="luxury-card p-6 md:p-8 animate-up" style="animation-delay: 0.2s;">
            <div class="flex items-center gap-2 mb-8">
              <span class="w-1.5 h-6 bg-black rounded-full"></span>
              <h2 class="text-sm font-black uppercase tracking-[0.2em] text-gray-400">Customer Details</h2>
            </div>
            <div class="flex flex-col md:flex-row gap-8">
              <div class="w-20 h-20 rounded-2xl luxury-card bg-stone-50 flex items-center justify-center overflow-hidden border-2 border-white shadow-sm flex-shrink-0">
                <img src="https://ui-avatars.com/api/?name=Ajay+K&background=F3F2EE&color=1C1C1C&bold=true" class="w-full h-full object-cover">
              </div>
              <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-6">
                  <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Primary Contact</p>
                    <div class="flex items-center gap-3 group">
                      <div class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center text-gray-400 group-hover:bg-blue-50 group-hover:text-blue-600 transition-colors">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                      </div>
                      <span class="text-sm font-bold">+91 98765 43210</span>
                      <button class="p-1.5 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-gray-100 rounded-md"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg></button>
                    </div>
                  </div>
                  <div>
                    <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Email Address</p>
                    <div class="flex items-center gap-3 group">
                      <div class="w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center text-gray-400 group-hover:bg-purple-50 group-hover:text-purple-600 transition-colors">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                      </div>
                      <span class="text-sm font-bold">ajayk@example.com</span>
                      <button class="p-1.5 opacity-0 group-hover:opacity-100 transition-opacity hover:bg-gray-100 rounded-md"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg></button>
                    </div>
                  </div>
                </div>
                <div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">Shipping Address</p>
                  <div class="p-4 bg-gray-50/50 rounded-xl border border-gray-100 italic text-sm text-gray-600 leading-relaxed">
                    123, Luxury Heights, Jubilee Hills,<br>
                    Hyderabad, Telangana - 500033
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- SECTION 4 — RETURN INFORMATION -->
          <section class="luxury-card p-6 md:p-8 animate-up" style="animation-delay: 0.3s;">
            <div class="flex items-center gap-2 mb-8">
              <span class="w-1.5 h-6 bg-black rounded-full"></span>
              <h2 class="text-sm font-black uppercase tracking-[0.2em] text-gray-400">Return Specifics</h2>
            </div>
            <div class="space-y-8">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Return Reason</p>
                  <div class="inline-flex items-center gap-2 px-4 py-2 bg-stone-100 text-stone-700 rounded-full text-xs font-bold border border-stone-200">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                    Wrong Size Sent
                  </div>
                </div>
                <div>
                  <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Product Condition</p>
                  <div class="inline-flex items-center gap-2 px-4 py-2 bg-green-50 text-green-700 rounded-full text-xs font-bold border border-green-100">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    Brand New / Tags Intact
                  </div>
                </div>
              </div>
              
              <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3">Customer Message</p>
                <div class="p-6 bg-stone-50 rounded-2xl border border-gray-100 shadow-inner">
                  <p class="text-sm text-gray-700 leading-relaxed italic">
                    "I ordered an XL but the fit feels more like a Large. The fabric quality is excellent but I unfortunately cannot wear this. I've kept all the original tags and the packaging is unopened."
                  </p>
                </div>
              </div>

              <div>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Inspection Gallery</p>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                  <div class="aspect-square luxury-card overflow-hidden group cursor-zoom-in">
                    <img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                  </div>
                  <div class="aspect-square luxury-card overflow-hidden group cursor-zoom-in">
                    <img src="https://images.unsplash.com/photo-1576566588028-4147f3842f27?w=400" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- SECTION 6 — PICKUP & SCHEDULING -->
          <section class="luxury-card p-6 md:p-8 animate-up" style="animation-delay: 0.4s;">
            <div class="flex items-center gap-2 mb-8">
              <span class="w-1.5 h-6 bg-black rounded-full"></span>
              <h2 class="text-sm font-black uppercase tracking-[0.2em] text-gray-400">Pickup Logistics</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
              <div class="space-y-2">
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Courier Partner</label>
                <select class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl text-sm font-bold outline-none focus:ring-2 focus:ring-stone-100">
                  <option>Delhivery Express</option>
                  <option>BlueDart</option>
                  <option>Ecom Express</option>
                </select>
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Scheduled Date</label>
                <input type="date" class="w-full px-4 py-3 bg-gray-50 border border-gray-100 rounded-xl text-sm font-bold outline-none focus:ring-2 focus:ring-stone-100" value="2024-05-10">
              </div>
              <div class="flex items-end">
                <button class="w-full py-3 bg-black text-white text-xs font-black uppercase tracking-widest rounded-xl hover:bg-stone-900 shadow-xl shadow-stone-100 transition-all">Schedule Pickup</button>
              </div>
            </div>
          </section>

        </div>

        <!-- RIGHT SIDE: Timeline & Sticky -->
        <div class="lg:col-span-4 space-y-8 sticky top-32">
          
          <!-- SECTION 5 — RETURN TIMELINE -->
          <section class="luxury-card p-8 animate-up" style="animation-delay: 0.5s;">
            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 mb-10">Request Timeline</h3>
            <div class="relative space-y-12">
              <div class="timeline-line"></div>
              
              <!-- Step 1 -->
              <div class="relative flex gap-6">
                <div class="timeline-dot timeline-complete flex items-center justify-center">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="4"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <div>
                  <h4 class="text-sm font-bold text-gray-900">Return Requested</h4>
                  <p class="text-xs text-[var(--admin-text-muted)] mt-1">May 07, 10:42 AM</p>
                  <p class="text-[11px] text-gray-400 mt-2 leading-relaxed">Customer initiated the request via User Dashboard.</p>
                </div>
              </div>

              <!-- Step 2 -->
              <div class="relative flex gap-6">
                <div class="timeline-dot timeline-active border-orange-50"></div>
                <div>
                  <h4 class="text-sm font-bold text-gray-900">Pending Review</h4>
                  <p class="text-xs text-orange-600 font-bold mt-1">Awaiting Approval</p>
                  <p class="text-[11px] text-gray-400 mt-2 leading-relaxed">Admin needs to verify product condition and reason.</p>
                </div>
              </div>

              <!-- Step 3 -->
              <div class="relative flex gap-6">
                <div class="timeline-dot bg-gray-100 shadow-none border-gray-50"></div>
                <div>
                  <h4 class="text-sm font-bold text-gray-300">Pickup Scheduled</h4>
                  <p class="text-xs text-gray-200 mt-1">Next Step</p>
                </div>
              </div>
              
              <!-- Step 4 -->
              <div class="relative flex gap-6">
                <div class="timeline-dot bg-gray-100 shadow-none border-gray-50"></div>
                <div>
                  <h4 class="text-sm font-bold text-gray-300">Refund Processed</h4>
                  <p class="text-xs text-gray-200 mt-1">Final Step</p>
                </div>
              </div>
            </div>
          </section>

          <!-- SECTION 7 — ADMIN NOTES -->
          <section class="luxury-card p-8 animate-up" style="animation-delay: 0.6s;">
            <h3 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 mb-6">Internal Notes</h3>
            <textarea class="w-full h-32 p-4 bg-stone-50 border border-stone-100 rounded-2xl text-sm italic text-gray-600 outline-none focus:ring-2 focus:ring-stone-100 transition-all resize-none" placeholder="Add a private note for other admins..."></textarea>
            <button class="w-full mt-4 py-3 border border-gray-200 text-gray-500 text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-gray-50 transition-all">Save Internal Note</button>
          </section>

        </div>

      </div>
    </div>

    <!-- SECTION 8 — ACTION FOOTER -->
    <footer class="sticky-footer px-6 md:px-10 py-6">
      <div class="max-w-[1600px] mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-4">
          <button class="p-3 luxury-card hover:bg-gray-50 transition-all" title="Download Invoice">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
          </button>
          <button class="p-3 luxury-card hover:bg-gray-50 transition-all" title="Print Details">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
          </button>
        </div>
        
        <div class="flex items-center gap-3 w-full md:w-auto">
          <button class="flex-1 md:flex-none px-6 py-3 bg-red-50 text-red-600 text-xs font-black uppercase tracking-widest rounded-xl border border-red-100">Reject</button>
          <button class="flex-1 md:flex-none px-8 py-3 bg-black text-white text-xs font-black uppercase tracking-widest rounded-xl shadow-xl shadow-stone-200">Approve & Schedule</button>
          <button class="flex-1 md:flex-none px-8 py-3 bg-green-500 text-white text-xs font-black uppercase tracking-widest rounded-xl shadow-xl shadow-green-100">Refund Now</button>
        </div>
      </div>
    </footer>
  </main>

  <script>
    // Smooth transitions for timeline and other elements
    document.querySelectorAll('.luxury-card').forEach(card => {
      card.addEventListener('mouseenter', () => {
        card.style.transform = 'translateY(-2px)';
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = 'translateY(0)';
      });
    });
  </script>
</body>
</html>
