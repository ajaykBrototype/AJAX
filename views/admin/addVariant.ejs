<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Add Product Variant — AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- TAILWIND & LIBRARIES -->
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Plus Jakarta Sans', 'sans-serif']
        },
        colors: {
          'luxury-bg': '#F4F2EE',
          'luxury-accent': '#C1272D',
          'luxury-text': '#1C1C1C',
          'luxury-muted': '#8E8E8E'
        }
      }
    }
  }
</script>

<style>
  body { background-color: theme('colors.luxury-bg'); color: theme('colors.luxury-text'); font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }
  
  /* Sidebar styles */
  .sidebar-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 0px; transition: all 0.2s ease; position: relative; color: theme('colors.luxury-muted'); font-size: 14px; font-weight: 500; }
  .sidebar-item:hover { color: theme('colors.luxury-text'); }
  .sidebar-item.active { background-color: #fff; color: theme('colors.luxury-text'); }
  .sidebar-item.active::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background-color: theme('colors.luxury-accent'); }

  /* Input styles */
  .fl { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: theme('colors.luxury-muted'); margin-bottom: 8px; }
  .fin { width: 100%; padding: 14px 18px; background: white; border: 1.5px solid #E5E7EB; border-radius: 12px; font-size: 14px; outline: none; transition: all 0.2s; }
  .fin:focus { border-color: #1C1C1C; box-shadow: 0 0 0 4px rgba(28, 28, 28, 0.05); }

  /* Card styles */
  .section-card { background: white; border-radius: 0px; padding: 40px; border: 1px solid #E5E7EB; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }

  /* Upload zone */
  .upload-zone { border: 2px dashed #D1D5DB; border-radius: 16px; padding: 48px 24px; text-align: center; cursor: pointer; transition: all 0.2s; background: #F9FAFB; }
  .upload-zone:hover { border-color: #1C1C1C; background: white; }

  /* Sticky footer */
  .sticky-footer { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); border-top: 1px solid #E5E7EB; padding: 16px 40px; z-index: 100; display: flex; justify-content: space-between; align-items: center; }

  /* Animations */
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }

  #cropModal { position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; padding: 20px; }
  #cropModal.open { display: flex; }
  #cropModalBox { background: white; border-radius: 24px; width: 100%; max-width: 700px; overflow: hidden; display: flex; flex-direction: column; }
  #cropperWrapper { width: 100%; height: 450px; background: #F3F4F6; position: relative; overflow: hidden; }
</style>
</head>
<body class="flex min-h-screen">

  <!-- SIDEBAR (Consistent with others) -->
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-white border-r border-stone-200 transition-transform lg:translate-x-0 lg:static lg:inset-0 -translate-x-full">
    <div class="h-full flex flex-col pt-8 pb-6">
      <div class="px-8 mb-12"><h1 class="text-2xl font-serif font-bold tracking-tighter uppercase text-luxury-text">AJAX</h1></div>
      <nav class="flex-1 px-4 space-y-1">
        <p class="text-[10px] font-bold text-stone-400 tracking-[0.2em] mb-4 px-4 uppercase">Management</p>
        <a href="/admin/dashboard" class="sidebar-item">Dashboard</a>
        <a href="/admin/orders" class="sidebar-item">Orders</a>
        <a href="/admin/products" class="sidebar-item active">Products</a>
        <a href="/admin/categories" class="sidebar-item">Categories</a>
      </nav>
      <div class="px-8 mt-auto pt-6 border-t border-stone-100 flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-stone-100 flex items-center justify-center overflow-hidden border border-stone-200">
            <img src="https://ui-avatars.com/api/?name=Sebastian+Vane&background=F3F2EE&color=1C1C1C" class="w-full h-full object-cover">
        </div>
        <div class="flex-1 overflow-hidden">
          <p class="text-xs font-bold truncate">Sebastian Vane</p>
          <p class="text-[10px] text-stone-400 truncate tracking-tight uppercase">Head Curator</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="flex-1 min-w-0 p-6 lg:p-12 pb-32">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-[10px] font-bold tracking-widest text-stone-400 uppercase mb-8 animate-fade-in">
        <a href="/admin/products" class="hover:text-stone-700 transition-colors">Catalog</a>
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/admin/variants" class="hover:text-stone-700 transition-colors">Variants</a>
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-luxury-text">Add Variant</span>
    </nav>

    <header class="mb-12 animate-fade-in">
        <h2 class="text-5xl font-serif font-bold leading-tight">Add Product Variant</h2>
        <p class="text-stone-400 text-sm mt-3">Define SKU specifics for your luxury product</p>
    </header>

    <!-- PARENT PRODUCT CONTEXT -->
    <section class="mb-10 bg-white p-5 border border-stone-200 flex items-center gap-5 animate-fade-in" style="animation-delay: 0.1s;">
        <div class="w-14 h-18 bg-stone-100 overflow-hidden border border-stone-200">
            <img src="https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=200&q=80" class="w-full h-full object-cover">
        </div>
        <div>
            <p class="text-[9px] font-bold text-stone-300 uppercase tracking-widest">Selected Product</p>
            <h3 class="text-lg font-serif font-medium">Silk Evening Gown — Black</h3>
        </div>
    </section>

    <!-- FORM GRID -->
    <form id="variantForm" class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <!-- LEFT: Media Upload -->
        <div class="lg:col-span-5 space-y-8 animate-fade-in" style="animation-delay: 0.2s;">
            <div class="section-card">
                <h3 class="text-xl font-serif font-bold mb-8">Variant Media</h3>
                
                <div class="upload-zone" id="uploadTrigger">
                    <svg class="mx-auto mb-4 text-stone-300" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p class="text-xs font-bold text-stone-900 mb-1 leading-none uppercase tracking-widest">Upload Main Image</p>
                    <p class="text-[10px] text-stone-400">Resolution should be min 1200x1600px</p>
                    <input type="file" id="imageInput" class="hidden" accept="image/*">
                </div>

                <div id="imagePreview" class="mt-6 hidden">
                    <div class="relative w-full aspect-[3/4] rounded-2xl overflow-hidden border border-stone-200">
                        <img id="previewImg" class="w-full h-full object-cover">
                        <button type="button" id="removeImg" class="absolute top-4 right-4 w-10 h-10 bg-white shadow-lg rounded-full flex items-center justify-center text-luxury-accent">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- RIGHT: Configuration -->
        <div class="lg:col-span-7 space-y-8 animate-fade-in" style="animation-delay: 0.3s;">
            <div class="section-card space-y-10">
                <!-- Attributes -->
                <div>
                    <h3 class="text-xl font-serif font-bold mb-8 underline decoration-stone-100 underline-offset-8">Attributes</h3>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="fl">Primary Color</label>
                            <input type="text" class="fin" placeholder="e.g. Midnight Black">
                        </div>
                        <div>
                            <label class="fl">Size</label>
                            <input type="text" class="fin" placeholder="e.g. M, L, 42">
                        </div>
                    </div>
                </div>

                <!-- Inventory -->
                <div>
                    <h3 class="text-xl font-serif font-bold mb-8 underline decoration-stone-100 underline-offset-8">Inventory</h3>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="fl">SKU Identifier</label>
                            <input type="text" class="fin" placeholder="AJAX-SILK-M-BLK">
                        </div>
                        <div>
                            <label class="fl">Stock Quantity</label>
                            <input type="number" class="fin" placeholder="0">
                        </div>
                    </div>
                </div>

                <!-- Financials -->
                <div>
                    <h3 class="text-xl font-serif font-bold mb-8 underline decoration-stone-100 underline-offset-8">Financials</h3>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <label class="fl">Base Price (₹)</label>
                            <input type="number" class="fin" placeholder="45000">
                        </div>
                        <div>
                            <label class="fl">Active Discount (%)</label>
                            <input type="number" class="fin" value="0">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
  </main>

  <!-- STICKY FOOTER -->
  <div class="sticky-footer">
      <p class="text-[10px] font-bold text-stone-400 tracking-widest uppercase">Variant Status: <span class="text-stone-900">Configuring</span></p>
      <div class="flex items-center gap-4">
          <a href="/admin/variants" class="px-8 py-3 text-[11px] font-bold uppercase tracking-widest text-stone-400 hover:text-luxury-accent transition-colors">Discard</a>
          <button type="button" class="px-10 py-3 bg-stone-900 text-white text-[11px] font-bold uppercase tracking-widest hover:bg-stone-800 transition-all shadow-xl">Save Variant</button>
      </div>
  </div>

  <!-- CROP MODAL -->
  <div id="cropModal">
    <div id="cropModalBox">
        <div class="p-6 border-b border-stone-100 flex items-center justify-between">
            <h4 class="text-lg font-serif font-bold">Refine Variant Image</h4>
            <button id="closeCrop" class="p-2 text-stone-400 hover:text-stone-900 transition-colors">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </button>
        </div>
        <div id="cropperWrapper"><img id="cropImage"></div>
        <div class="p-6 bg-stone-50 flex justify-end gap-3">
            <button id="applyCrop" class="px-10 py-3 bg-stone-900 text-white text-[11px] font-bold uppercase tracking-widest hover:bg-stone-800 transition-all">Apply Crop</button>
        </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
  <script>
    // Placeholder interaction logic
    const uploadTrigger = document.getElementById('uploadTrigger');
    const imageInput = document.getElementById('imageInput');
    const cropModal = document.getElementById('cropModal');
    const cropImage = document.getElementById('cropImage');
    const applyCrop = document.getElementById('applyCrop');
    const previewImg = document.getElementById('previewImg');
    const imagePreview = document.getElementById('imagePreview');
    let cropper;

    uploadTrigger.addEventListener('click', () => imageInput.click());

    imageInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (event) => {
                cropImage.src = event.target.result;
                cropModal.classList.add('open');
                if (cropper) cropper.destroy();
                cropper = new Cropper(cropImage, { aspectRatio: 3/4, viewMode: 2 });
            };
            reader.readAsDataURL(file);
        }
    });

    applyCrop.addEventListener('click', () => {
        const canvas = cropper.getCroppedCanvas();
        previewImg.src = canvas.toDataURL();
        imagePreview.classList.remove('hidden');
        uploadTrigger.classList.add('hidden');
        cropModal.classList.remove('open');
    });

    document.getElementById('removeImg').addEventListener('click', () => {
        imagePreview.classList.add('hidden');
        uploadTrigger.classList.remove('hidden');
        imageInput.value = '';
    });

    document.getElementById('closeCrop').addEventListener('click', () => cropModal.classList.remove('open'));
  </script>
</body>
</html>
