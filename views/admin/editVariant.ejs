<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Edit Variant — AJAX Admin</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Plus Jakarta Sans', 'sans-serif']
        },
        colors: {
          'luxury-bg': '#F4F2EE',
          'luxury-accent': '#C1272D',
          'luxury-text': '#1C1C1C',
          'luxury-muted': '#8E8E8E'
        }
      }
    }
  }
</script>

<style>
  body { background-color: theme('colors.luxury-bg'); color: theme('colors.luxury-text'); font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }
  .sidebar-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 0px; transition: all 0.2s ease; position: relative; color: theme('colors.luxury-muted'); font-size: 14px; font-weight: 500; }
  .sidebar-item:hover { color: theme('colors.luxury-text'); }
  .sidebar-item.active { background-color: #fff; color: theme('colors.luxury-text'); }
  .sidebar-item.active::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background-color: theme('colors.luxury-accent'); }
  .fl { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: theme('colors.luxury-muted'); margin-bottom: 8px; }
  .fin { width: 100%; padding: 14px 18px; background: white; border: 1.5px solid #E5E7EB; border-radius: 12px; font-size: 14px; outline: none; transition: all 0.2s; }
  .fin:focus { border-color: #1C1C1C; box-shadow: 0 0 0 4px rgba(28, 28, 28, 0.05); }
  .section-card { background: white; border-radius: 0px; padding: 40px; border: 1px solid #E5E7EB; box-shadow: 0 4px 20px rgba(0,0,0,0.02); }
  .upload-zone { border: 2px dashed #D1D5DB; border-radius: 16px; padding: 32px 24px; text-align: center; cursor: pointer; transition: all 0.2s; background: #F9FAFB; }
  .upload-zone:hover { border-color: #1C1C1C; background: white; }
  .sticky-footer { position: fixed; bottom: 0; left: 0; right: 0; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); border-top: 1px solid #E5E7EB; padding: 16px 40px; z-index: 100; display: flex; justify-content: space-between; align-items: center; }
  .size-btn { border: 1.5px solid #E5E7EB; background: white; padding: 10px 16px; border-radius: 12px; font-size: 12px; font-weight: 700; text-transform: uppercase; transition: all 0.2s; color: #8E8E8E; }
  .size-btn.active { background: #1C1C1C; border-color: #1C1C1C; color: white; }
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }
  #cropModal { position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; padding: 20px; }
  #cropModal.open { display: flex; }
  #cropModalBox { background: white; border-radius: 24px; width: 100%; max-width: 700px; overflow: hidden; display: flex; flex-direction: column; }
  #cropperWrapper { width: 100%; height: 450px; background: #F3F4F6; position: relative; overflow: hidden; }
  .thumb-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr)); gap: 12px; margin-top: 24px; }
  .thumb-item { aspect-ratio: 3/4; border-radius: 12px; overflow: hidden; border: 1.5px solid #E5E7EB; position: relative; background: #F9FAFB; }
  .thumb-item img { width: 100%; height: 100%; object-fit: cover; }
  .thumb-remove { position: absolute; top: 4px; right: 4px; width: 20px; height: 20px; background: rgba(255,255,255,0.9); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #C1272D; shadow-sm; cursor: pointer; }
</style>
</head>
<body class="flex min-h-screen">

  <!-- ── SIDEBAR (PARTIAL) ── -->
  <%- include('partials/sidebar', { currentPath: '/admin/variants' }) %>

  <main class="flex-1 min-w-0 p-6 lg:p-12 pb-32">
    <nav class="flex items-center gap-2 text-[10px] font-bold tracking-widest text-stone-400 uppercase mb-8 animate-fade-in">
        <a href="/admin/products" class="hover:text-stone-700">Catalog</a>
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/admin/products/<%= product._id %>/variants" class="hover:text-stone-700">Variants</a>
        <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-luxury-text">Edit Variant</span>
    </nav>

    <header class="mb-12 animate-fade-in">
        <h2 class="text-5xl font-serif font-bold leading-tight">Edit Variant</h2>
        <p class="text-stone-400 text-sm mt-3">Modify SKU details and update media gallery for <%= variant.sku %>.</p>
    </header>

    <section class="mb-10 bg-white p-5 border border-stone-200 flex items-center gap-5 animate-fade-in">
        <div class="w-14 h-18 bg-stone-100 overflow-hidden border border-stone-200" style="width:56px; height:72px; flex-shrink:0;">
            <img src="<%= variant.images[0] || '/images/no-image.png' %>" class="w-full h-full object-cover">
        </div>
        <div>
            <p class="text-[9px] font-bold text-stone-300 uppercase tracking-widest">Parent Product</p>
            <h3 class="text-lg font-serif font-medium"><%= product.name %></h3>
        </div>
    </section>

    <form id="variantForm" action="/admin/products/variants/edit/<%= variant._id %>" class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <input type="hidden" name="productId" value="<%= product._id %>">
        <input type="hidden" name="size" id="sizeInput" value="<%= variant.size %>">

        <div class="lg:col-span-5 space-y-8 animate-fade-in" style="animation-delay: 0.1s;">
            <div class="section-card">
                <h3 class="text-xl font-serif font-bold mb-8">Variant Media</h3>
                <div class="upload-zone" id="uploadTrigger">
                    <svg class="mx-auto mb-4 text-stone-300" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p class="text-[10px] font-bold text-stone-900 mb-1 uppercase tracking-widest">Add New Image</p>
                    <input type="file" id="imageInput" class="hidden" accept="image/*">
                </div>

                <div id="imageGallery" class="thumb-container">
                    <% variant.images.forEach((img, index) => { %>
                      <div class="thumb-item" data-existing="true" data-url="<%= img %>">
                          <img src="<%= img %>">
                          <div class="thumb-remove" onclick="removeExistingImage(this, '<%= index %>')">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6L6 18M6 6l12 12"/></svg>
                          </div>
                      </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="lg:col-span-7 space-y-8 animate-fade-in" style="animation-delay: 0.2s;">
            <div class="section-card space-y-10">
                <div>
                    <h3 class="text-xl font-serif font-bold mb-8 underline decoration-stone-100 underline-offset-8">Attributes</h3>
                    <div class="grid grid-cols-1 gap-8">
                        <div>
                            <label class="fl">Primary Color</label>
                            <input type="text" name="color" class="fin" value="<%= variant.color %>" required>
                        </div>
                        <div>
                            <label class="fl">Select Size</label>
                            <div class="flex flex-wrap gap-3">
                                <% ['S', 'M', 'L', 'XL', 'XXL', '3XL'].forEach(s => { %>
                                  <button type="button" class="size-btn <%= variant.size === s ? 'active' : '' %>" data-size="<%= s %>"><%= s %></button>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                </div>

                <div>
                    <h3 class="text-xl font-serif font-bold mb-8 underline decoration-stone-100 underline-offset-8">Inventory & Pricing</h3>
                    <div class="grid grid-cols-2 gap-6">
                        <div class="col-span-2 sm:col-span-1">
                            <label class="fl">SKU Identifier</label>
                            <input type="text" name="sku" class="fin" value="<%= variant.sku %>" required>
                        </div>
                        <div class="col-span-2 sm:col-span-1">
                            <label class="fl">Stock Quantity</label>
                            <input type="number" name="stock" class="fin" value="<%= variant.stock %>" required min="0">
                        </div>
                        <div class="col-span-2 sm:col-span-1">
                            <label class="fl">Base Price (₹)</label>
                            <input type="number" name="price" class="fin" value="<%= variant.price %>" required min="0">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
  </main>

  <div class="sticky-footer">
      <p class="text-[10px] font-bold text-stone-400 tracking-widest uppercase" id="imgCountText">Gallery Management</p>
      <div class="flex items-center gap-4">
          <a href="/admin/products/<%= product._id %>/variants" class="px-8 py-3 text-[11px] font-bold uppercase tracking-widest text-stone-400">Back</a>
          <button type="button" id="updateVariantBtn" class="px-10 py-3 bg-stone-900 text-white text-[11px] font-bold uppercase tracking-widest hover:bg-stone-800 transition-all shadow-xl">Update Variant</button>
      </div>
  </div>

  <div id="cropModal">
    <div id="cropModalBox">
        <div class="p-6 border-b border-stone-100 flex items-center justify-between">
            <h4 class="text-lg font-serif font-bold">Refine New Image</h4>
            <button id="closeCrop" class="p-2 text-stone-400"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
        </div>
        <div id="cropperWrapper"><img id="cropImage"></div>
        <div class="p-6 bg-stone-50 flex justify-end">
            <button id="applyCrop" class="px-10 py-3 bg-stone-900 text-white text-[11px] font-bold uppercase tracking-widest">Apply Crop</button>
        </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
  <script>
    const imageInput = document.getElementById('imageInput');
    const imageGallery = document.getElementById('imageGallery');
    const cropModal = document.getElementById('cropModal');
    const cropImage = document.getElementById('cropImage');
    const applyCrop = document.getElementById('applyCrop');
    const updateVariantBtn = document.getElementById('updateVariantBtn');
    const variantForm = document.getElementById('variantForm');
    const sizeInput = document.getElementById('sizeInput');
    
    let cropper;
   window.newFiles = []; 
window.existingImages = Array.from(document.querySelectorAll('.thumb-item[data-existing="true"]')).map(el => el.dataset.url);

    // Size Selection
    document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            sizeInput.value = btn.dataset.size;
        });
    });

    document.getElementById('uploadTrigger').addEventListener('click', () => imageInput.click());

    imageInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (event) => {
                cropImage.src = event.target.result;
                cropModal.classList.add('open');
                if (cropper) cropper.destroy();
                cropper = new Cropper(cropImage, { aspectRatio: 3/4, viewMode: 2 });
            };
            reader.readAsDataURL(file);
        }
    });

    applyCrop.addEventListener('click', () => {
        const canvas = cropper.getCroppedCanvas({ width: 1200, height: 1600 });
        canvas.toBlob((blob) => {
            newFiles.push(blob);
            renderGallery();
            cropModal.classList.remove('open');
            imageInput.value = '';
        }, 'image/jpeg', 0.9);
    });

    function renderGallery() {
        // Keep existing images UI and append new ones
        const newImgsContainer = document.getElementById('newImagesContainer') || document.createElement('div');
        newImgsContainer.id = 'newImagesContainer';
        newImgsContainer.className = 'contents';
        
        // Clear only new images part of gallery if you want to be precise, or re-render all:
        // For simplicity, let's just handle new ones separately or rebuild the whole gallery:
        imageGallery.innerHTML = '';
        
        existingImages.forEach((url, index) => {
            const div = createThumb(url, () => {
                existingImages.splice(index, 1);
                renderGallery();
            }, true);
            imageGallery.appendChild(div);
        });

        // Re-render new
        newFiles.forEach((blob, index) => {
            const url = URL.createObjectURL(blob);
            const div = createThumb(url, () => {
                newFiles.splice(index, 1);
                renderGallery();
            }, false);
            imageGallery.appendChild(div);
        });
    }

    function createThumb(url, removeFn, isExisting) {
        const div = document.createElement('div');
        div.className = 'thumb-item animate-fade-in';
        div.innerHTML = `
            <img src="${url}">
            <div class="thumb-remove"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6L6 18M6 6l12 12"/></svg></div>
            ${isExisting ? '<div class="absolute top-0 left-0 bg-stone-900 text-white text-[7px] px-1">SAVED</div>' : ''}
        `;
        div.querySelector('.thumb-remove').onclick = removeFn;
        return div;
    }

    window.removeExistingImage = (el, index) => {
        // This is called by the initial HTML
        existingImages.splice(index, 1);
        renderGallery();
    };


    document.getElementById('closeCrop').addEventListener('click', () => cropModal.classList.remove('open'));
  </script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  <script src="/js/utils/swal-helper.js"></script>
  <script src="/js/admin/variant.js"></script>
</body>
</html>