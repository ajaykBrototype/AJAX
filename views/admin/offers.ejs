<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Offers Management — AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Plus Jakarta Sans', 'sans-serif']
        },
        colors: {
          brand: {
            black: '#111111',
            gray: '#6B7280',
            lightGray: '#F3F4F6',
            blue: '#4F46E5',
            yellow: '#F59E0B',
            green: '#10B981',
            red: '#EF4444'
          }
        }
      }
    }
  }
</script>

<style>
  :root {
    --bg-white: #FFFFFF;
    --card-bg: #FFFFFF;
    --border-color: #F1F1F1;
    --text-main: #111111;
    --text-muted: #888888;
  }

  body { 
    background-color: var(--bg-white); 
    color: var(--text-main); 
    font-family: 'Plus Jakarta Sans', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #E5E7EB; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #D1D5DB; }

  /* Premium Card & Table Styles */
  .premium-table-container {
    background: white;
    border-radius: 24px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    border: 1px solid var(--border-color);
  }

  .table-row {
    transition: all 0.2s ease;
  }
  .table-row:hover {
    background-color: #FAFAFA;
  }

  /* Badge Styles */
  .badge {
    padding: 4px 12px;
    border-radius: 8px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge-category { background-color: #EEF2FF; color: #4F46E5; }
  .badge-product { background-color: #FFFBEB; color: #D97706; }
  .badge-status-active { background-color: #ECFDF5; color: #059669; }
  .badge-status-expired { background-color: #F9FAFB; color: #6B7280; }

  /* Toggle Switch */
  .switch {
    position: relative;
    display: inline-block;
    width: 36px;
    height: 20px;
  }
  .switch input { opacity: 0; width: 0; height: 0; }
  .slider {
    position: absolute;
    cursor: pointer;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #E5E7EB;
    transition: .4s;
    border-radius: 34px;
  }
  .slider:before {
    position: absolute;
    content: "";
    height: 14px; width: 14px;
    left: 3px; bottom: 3px;
    background-color: white;
    transition: .4s;
    border-radius: 50%;
  }
  input:checked + .slider { background-color: #111111; }
  input:checked + .slider:before { transform: translateX(16px); }

  /* Animation */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-up { animation: fadeInUp 0.5s ease forwards; }

  /* Modal Styles */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(8px);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .modal-overlay.show {
    display: flex;
    opacity: 1;
  }
  .modal-content {
    background: white;
    width: 100%;
    max-width: 640px;
    border-radius: 40px;
    padding: 40px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.2);
    transform: translateY(20px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    max-height: 95vh;
    overflow-y: auto;
  }
  .modal-overlay.show .modal-content {
    transform: translateY(0);
  }

  .field-label {
    font-size: 10px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #1a2b4b;
    margin-bottom: 12px;
    display: block;
  }

  .input-field {
    width: 100%;
    background: #F9FAFB;
    border: none;
    border-radius: 20px;
    padding: 16px 24px;
    font-size: 14px;
    font-weight: 600;
    color: #1a2b4b;
    outline: none;
    transition: all 0.2s ease;
  }
  .input-field:focus {
    background: white;
    box-shadow: 0 0 0 2px #111111;
  }
  .input-field::placeholder { color: #CBD5E1; }

  .toggle-group {
    display: flex;
    background: #F9FAFB;
    padding: 6px;
    border-radius: 20px;
    width: 100%;
  }
  .toggle-item {
    flex: 1;
    text-align: center;
    padding: 10px;
    font-size: 13px;
    font-weight: 700;
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.3s;
    color: #94A3B8;
  }
  .toggle-item.active {
    background: white;
    color: #064E3B;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }


  .input-error {
  border: 1.5px solid #EF4444 !important;
  background: #FEF2F2 !important;
}

.error-text {
  color: #EF4444;
  font-size: 12px;
  font-weight: 600;
  margin-top: 6px;
  padding-left: 4px;
}
</style>
</head>
<body class="flex min-h-screen">

  <!-- ── SIDEBAR (PARTIAL) ── -->
  <%- include('partials/sidebar', { currentPath: '/admin/offers' }) %>

  <!-- ── MAIN CONTENT ── -->
  <main class="flex-1 p-8 lg:p-12 max-h-screen overflow-y-auto">
    
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-10 animate-up" style="animation-delay: 0.1s;">
      <div>
        <h1 class="text-4xl font-serif font-bold tracking-tight text-brand-black mb-2">Offers</h1>
        <p class="text-brand-gray font-medium">Manage discounts, coupons, and seasonal promotions.</p>
      </div>
      <button onclick="openCreateOfferModal()" class="bg-brand-black text-white px-6 py-3 rounded-xl font-semibold flex items-center gap-2 hover:bg-stone-800 transition-all shadow-lg hover:shadow-xl active:scale-95">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create New Offer
      </button>
    </header>

    <!-- Filters & Search Bar -->
    <div class="bg-white rounded-3xl p-4 border border-[#F1F1F1] mb-8 flex flex-col md:flex-row items-center justify-between gap-4 animate-up shadow-sm" style="animation-delay: 0.2s;">
      <div class="flex flex-col md:flex-row items-center gap-4 w-full md:w-auto">
        <!-- Search -->
        <div class="relative w-full md:w-80">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-brand-gray" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" id="searchInput" placeholder="Search by offer name..." class="w-full pl-12 pr-4 py-3 custom-input rounded-2xl text-sm outline-none">
        </div>

        <!-- Filter Dropdowns -->
        <div class="flex items-center gap-3 w-full md:w-auto">
          <select id="typeFilter" class="px-5 py-3 custom-input rounded-2xl text-sm font-semibold outline-none cursor-pointer appearance-none pr-10 relative">
            <option value="all">All Types</option>
            <option value="percentage">Percentage</option>
            <option value="flat">Flat Discount</option>
          </select>
          <select id="statusFilter" class="px-5 py-3 custom-input rounded-2xl text-sm font-semibold outline-none cursor-pointer appearance-none pr-10 relative">
            <option value="all">All Status</option>
            <option value="active">Active</option>
            <option value="expired">Expired</option>
          </select>
        </div>
      </div>

      <div class="text-sm font-medium text-brand-gray pr-4">
        Total Results: <span id="totalResultsCount" class="text-brand-black font-bold"><%= offers ? offers.length : 0 %></span>
      </div>
    </div>

    <!-- Table Container -->
    <div class="premium-table-container animate-up overflow-hidden" style="animation-delay: 0.3s;">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-[#F9F9F9]">
              <th class="px-8 py-6 text-[11px] font-bold text-brand-gray uppercase tracking-widest">Offer Details</th>
              <th class="px-8 py-6 text-[11px] font-bold text-brand-gray uppercase tracking-widest">Scope</th>
              <th class="px-8 py-6 text-[11px] font-bold text-brand-gray uppercase tracking-widest">Discount</th>
              <th class="px-8 py-6 text-[11px] font-bold text-brand-gray uppercase tracking-widest">Min Purchase</th>
              <th class="px-8 py-6 text-[11px] font-bold text-brand-gray uppercase tracking-widest">Timeline</th>
              <th class="px-8 py-6 text-[11px] font-bold text-brand-gray uppercase tracking-widest">Status</th>
              <th class="px-8 py-6 text-[11px] font-bold text-brand-gray uppercase tracking-widest text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#F9F9F9]">
            <% if(offers && offers.length > 0) { %>
              <% offers.forEach(offer => { %>
                <% 
                  const now = new Date();
                  const isExpired = new Date(offer.endDate) < now;
                  const status = (isExpired || !offer.isActive) ? 'expired' : 'active';
                %>
                <tr class="table-row group offer-row" data-name="<%= offer.offerLabel.toLowerCase() %>" data-type="<%= offer.discountMode %>" data-status="<%= status %>">
                  <td class="px-8 py-7">
                    <div class="flex flex-col">
                      <span class="text-sm font-bold text-brand-black mb-1"><%= offer.offerLabel %></span>
                      <span class="text-xs text-brand-gray font-medium italic">Applied to: <%= offer.applicableTo === 'product' ? (offer.targetProduct?.name || 'Unknown Product') : (offer.targetCategory?.name || 'Unknown Category') %></span>
                    </div>
                  </td>
                  <td class="px-8 py-7">
                    <% if (offer.applicableTo === 'category') { %>
                      <span class="badge badge-category">Category</span>
                    <% } else { %>
                      <span class="badge badge-product">Product</span>
                    <% } %>
                  </td>
                  <td class="px-8 py-7">
                    <div class="flex flex-col">
                      <span class="text-sm font-bold text-brand-black">
                        <%= offer.discountMode === 'percentage' ? offer.discountValue + '% Off' : '₹' + offer.discountValue + ' Off' %>
                      </span>
                      <span class="text-[10px] font-bold text-brand-gray uppercase tracking-tighter"><%= offer.discountMode %></span>
                    </div>
                  </td>
                  <td class="px-8 py-7 text-brand-gray">
                    <%= offer.minOrderValue > 0 ? '₹' + offer.minOrderValue : '—' %>
                  </td>
                  <td class="px-8 py-7">
                    <div class="flex flex-col">
                      <% 
                        const sDate = new Date(offer.startDate);
                        const eDate = new Date(offer.endDate);
                      %>
                      <span class="text-xs font-bold text-brand-black"><%= sDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) %> — <%= eDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) %>,</span>
                      <span class="text-xs font-bold text-brand-black"><%= eDate.getFullYear() %></span>
                    </div>
                  </td>
                  <td class="px-8 py-7">
                    <% if (status === 'expired') { %>
                      <span class="badge badge-status-expired"><%= isExpired ? 'Expired' : 'Inactive' %></span>
                    <% } else { %>
                      <span class="badge badge-status-active">Active</span>
                    <% } %>
                  </td>
                  <td class="px-8 py-7">
                    <div class="flex items-center justify-end gap-3">
                      <button  onclick='openEditOfferModal(<%- JSON.stringify(offer) %>)'  class="p-2.5 rounded-xl hover:bg-stone-100 text-brand-gray hover:text-brand-black transition-all">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      </button>
                      <button onclick="deleteOffer('<%= offer._id %>')" class="p-2.5 rounded-xl hover:bg-rose-50 text-brand-gray hover:text-brand-red transition-all">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                      </button>
                      <div class="h-6 w-[1px] bg-stone-100 mx-1"></div>
                      <label class="switch">
                          <input type="checkbox" <%= offer.isActive ? 'checked' : '' %> onchange="toggleOfferStatus('<%= offer._id %>')">                        <span class="slider"></span>
                      </label>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="px-8 py-7 text-center text-brand-gray font-medium">No offers found.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination Placeholder -->
      <div class="px-8 py-6 border-t border-[#F9F9F9] flex justify-between items-center">
        <p class="text-xs font-medium text-brand-gray">Showing <span id="visibleResultsCount" class="text-brand-black"><%= offers && offers.length > 0 ? '1-' + offers.length : '0' %></span> of <span id="totalPaginationCount" class="text-brand-black"><%= offers ? offers.length : 0 %></span> results</p>
           <div class="flex gap-2">

  <button
    class="p-2 rounded-lg border border-[#F1F1F1] text-brand-gray opacity-30 cursor-not-allowed"
    disabled
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  </button>

  <button
    class="w-8 h-8 rounded-lg bg-brand-black text-white text-xs font-bold"
  >
    1
  </button>

  <button
    class="p-2 rounded-lg border border-[#F1F1F1] text-brand-gray opacity-30 cursor-not-allowed"
    disabled
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>

</div>
      </div>
    </div>
  </main>


      <!-- Create Offer Modal -->
<div id="createOfferModal" class="modal-overlay" onclick="closeCreateOfferModal(event)">

  <div class="modal-content animate-up" onclick="event.stopPropagation()">

    <div class="flex justify-between items-start mb-8">

      <div>
        <h2 class="text-3xl font-serif font-bold text-[#1a2b4b] mb-1">
          Create Offer
        </h2>

        <p class="text-brand-gray text-sm font-medium">
          Set up a new discount promotion.
        </p>
      </div>

      <button
        onclick="closeCreateOfferModal()"
        class="p-2 hover:bg-stone-50 rounded-full text-brand-gray transition-colors"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

    </div>

    <form id="createOfferForm" class="space-y-8">

      <!-- OFFER LABEL -->
      <div>

        <label class="field-label">
          Offer Label
        </label>

        <input
          type="text"
          id="offerLabel"
          name="offerLabel"
          placeholder="e.g. Seasonal Sale"
          class="input-field"
        >

        <p class="error-text hidden"></p>

      </div>

      <!-- APPLICABLE TO -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div>

          <label class="field-label">
            Applicable To
          </label>

          <div class="toggle-group" id="applicableToToggle">

            <div
              class="toggle-item active"
              data-value="product"
            >
              Product
            </div>

            <div
              class="toggle-item"
              data-value="category"
            >
              Category
            </div>

            <input
              type="hidden"
              id="applicableTo"
              name="applicableTo"
              value="product"
            >

          </div>

        </div>

        <!-- TARGET -->
        <div>

          <label
            class="field-label"
            id="targetLabel"
          >
            Target Product
          </label>

          <div class="relative">

            <select
              class="input-field appearance-none pr-12 cursor-pointer"
              id="targetSelect"
              name="targetProduct"
            >

              <option
                selected
                disabled
                value=""
              >
                Select a product...
              </option>

             <% products.forEach(p => { %>

              <option  value="<%= p._id %>" data-type="product">
                        <%= p.name %>
               </option>

              <% }) %>

                <% categories.forEach(c => { %>

             <option value="<%= c._id %>" data-type="category" hidden>
                 <%= c.name %>
            </option>

              <% }) %>

            </select>

            <svg
              class="absolute right-6 top-1/2 -translate-y-1/2 text-brand-gray pointer-events-none"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>

          </div>

          <p class="error-text hidden"></p>

        </div>

      </div>

      <!-- DISCOUNT -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div>

          <label class="field-label">
            Discount Mode
          </label>

          <div class="toggle-group" id="discountModeToggle">

            <div
              class="toggle-item active"
              data-value="percentage"
            >
              Percentage
            </div>

            <div
              class="toggle-item"
              data-value="flat"
            >
              Flat
            </div>

            <input
              type="hidden"
              id="discountMode"
              name="discountMode"
              value="percentage"
            >

          </div>

        </div>

        <div>

          <label class="field-label">
            Discount Amount
          </label>

          <div class="relative">

            <input
              type="number"
              name="discountValue"
              placeholder="0.00"
              class="input-field pr-12"
            >

            <span
              class="absolute right-6 top-1/2 -translate-y-1/2 font-bold text-slate-300"
              id="discountUnit"
            >
              %
            </span>

          </div>

          <p class="error-text hidden"></p>

        </div>

      </div>

      <!-- MAX CAP + MIN ORDER -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div>

          <label class="field-label text-slate-400">
            Max Cap
            <span class="normal-case">
              (optional)
            </span>
          </label>

          <div class="relative">

            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-bold text-slate-400">
              ₹
            </span>

            <input
              type="number"
              name="maxDiscountCap"
              placeholder="0.00"
              class="input-field pl-12"
            >

          </div>

          <p class="error-text hidden"></p>

        </div>

        <div>

          <label class="field-label text-slate-400">
            Min Order
            <span class="normal-case">
              (optional)
            </span>
          </label>

          <div class="relative">

            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-bold text-slate-400">
              ₹
            </span>

            <input
              type="number"
              name="minOrderValue"
              placeholder="0.00"
              class="input-field pl-12"
            >

          </div>

          <p class="error-text hidden"></p>

        </div>

      </div>

      <!-- DATES -->
      <div>

        <label class="field-label">
          Promotion Window
        </label>

        <div class="flex items-center gap-4">

          <input
            type="date"
            id="startDate"
            name="startDate"
            placeholder="START DATE"
            class="input-field text-center"
          >

          <span class="text-brand-gray">
            —
          </span>

          <input
            type="date"
            id="endDate"
            name="endDate"
            placeholder="END DATE"
            class="input-field text-center"
          >

        </div>

        <p class="error-text hidden"></p>

      </div>

      <!-- BUTTON -->
      <div class="pt-4">

        <button
          type="submit"
          class="w-full bg-brand-black text-white py-5 rounded-3xl font-bold text-lg hover:bg-stone-800 transition-all shadow-xl active:scale-[0.98]"
        >

          Create Offer

        </button>

      </div>

    </form>

  </div>

</div>

<!-- Edit Offer Modal -->
<div
  id="editOfferModal"
  class="modal-overlay"
  onclick="closeEditOfferModal(event)"
>

  <div
    class="modal-content animate-up"
    onclick="event.stopPropagation()"
  >

    <!-- HEADER -->
    <div class="flex justify-between items-start mb-8">

      <div>

        <h2 class="text-3xl font-serif font-bold text-[#1a2b4b] mb-1">
          Edit Offer
        </h2>

        <p class="text-brand-gray text-sm font-medium">
          Update your discount promotion.
        </p>

      </div>

      <button
        onclick="closeEditOfferModal()"
        class="p-2 hover:bg-stone-50 rounded-full text-brand-gray transition-colors"
      >

        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>

      </button>

    </div>

    <!-- FORM -->
    <form
      id="editOfferForm"
      class="space-y-8"
    >

      <!-- OFFER ID -->
      <input
        type="hidden"
        id="editOfferId"
        name="offerId"
      >

      <!-- OFFER LABEL -->
      <div>

        <label class="field-label">
          Offer Label
        </label>

        <input
          type="text"
          id="editOfferLabel"
          name="offerLabel"
          placeholder="e.g. Seasonal Sale"
          class="input-field"
        >

        <p class="error-text hidden"></p>

      </div>

      <!-- DISCOUNT -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- MODE -->
        <div>

          <label class="field-label">
            Discount Mode
          </label>

          <div
            class="toggle-group"
            id="editDiscountModeToggle"
          >

            <div
              class="toggle-item active"
              data-value="percentage"
            >
              Percentage
            </div>

            <div
              class="toggle-item"
              data-value="flat"
            >
              Flat
            </div>

            <input
              type="hidden"
              id="editDiscountMode"
              name="discountMode"
              value="percentage"
            >

          </div>

        </div>

        <!-- VALUE -->
        <div>

          <label class="field-label">
            Discount Amount
          </label>

          <div class="relative">

            <input
              type="number"
              name="discountValue"
              placeholder="0.00"
              class="input-field pr-12"
            >

            <span
              class="absolute right-6 top-1/2 -translate-y-1/2 font-bold text-slate-300"
              id="editDiscountUnit"
            >
              %
            </span>

          </div>

          <p class="error-text hidden"></p>

        </div>

      </div>

      <!-- OPTIONAL -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <!-- MAX CAP -->
        <div>

          <label class="field-label text-slate-400">
            Max Cap
            <span class="normal-case">
              (optional)
            </span>
          </label>

          <div class="relative">

            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-bold text-slate-400">
              ₹
            </span>

            <input
              type="number"
              name="maxDiscountCap"
              placeholder="0.00"
              class="input-field pl-12"
            >

          </div>

          <p class="error-text hidden"></p>

        </div>

        <!-- MIN ORDER -->
        <div>

          <label class="field-label text-slate-400">
            Min Order
            <span class="normal-case">
              (optional)
            </span>
          </label>

          <div class="relative">

            <span class="absolute left-6 top-1/2 -translate-y-1/2 font-bold text-slate-400">
              ₹
            </span>

            <input
              type="number"
              name="minOrderValue"
              placeholder="0.00"
              class="input-field pl-12"
            >

          </div>

          <p class="error-text hidden"></p>

        </div>

      </div>

      <!-- DATES -->
      <div>

        <label class="field-label">
          Promotion Window
        </label>

        <div class="flex items-center gap-4">

          <input
            type="date"
            id="editStartDate"
            name="startDate"
            class="input-field text-center"
          >

          <span class="text-brand-gray">
            —
          </span>

          <input
            type="date"
            id="editEndDate"
            name="endDate"
            class="input-field text-center"
          >

        </div>

        <p class="error-text hidden"></p>

      </div>

      <!-- BUTTON -->
      <div class="pt-4">

        <button
          type="submit"
          class="w-full bg-brand-black text-white py-5 rounded-3xl font-bold text-lg hover:bg-stone-800 transition-all shadow-xl active:scale-[0.98]"
        >

          Update Offer

        </button>

      </div>

    </form>

  </div>

</div>
    </div>
  </div>

  <script>
    function openCreateOfferModal() {
      const modal = document.getElementById('createOfferModal');
      modal.style.display = 'flex';
      setTimeout(() => modal.classList.add('show'), 10);
      document.body.style.overflow = 'hidden';
    }

    function closeCreateOfferModal(event) {
      const modal = document.getElementById('createOfferModal');
      modal.classList.remove('show');
      setTimeout(() => {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      }, 300);
    }

    // Toggle Logic
    function setupToggle(containerId, hiddenInputId, onSwitch) {
      const container = document.getElementById(containerId);
      const items = container.querySelectorAll('.toggle-item');
      const input = document.getElementById(hiddenInputId);

      items.forEach(item => {
        item.addEventListener('click', () => {
          items.forEach(i => i.classList.remove('active'));
          item.classList.add('active');
          input.value = item.dataset.value;
          if (onSwitch) onSwitch(item.dataset.value);
        });
      });
    }

    setupToggle('discountModeToggle', 'discountMode', (value) => {
      const unit = document.getElementById('discountUnit');
      unit.textContent = value === 'percentage' ? '%' : '₹';
    });

    // Calendar Initialization
    flatpickr("#startDate", {
      dateFormat: "Y-m-d",
      minDate: "today",
      onChange: function(selectedDates, dateStr, instance) {
        endDatePicker.set('minDate', dateStr);
      }
    });

    const endDatePicker = flatpickr("#endDate", {
      dateFormat: "Y-m-d",
      minDate: "today"
    });

    // Filter Logic
    const searchInput = document.getElementById('searchInput');
    const typeFilter = document.getElementById('typeFilter');
    const statusFilter = document.getElementById('statusFilter');
    const offerRows = document.querySelectorAll('.offer-row');
    const totalResultsCount = document.getElementById('totalResultsCount');
    const visibleResultsCount = document.getElementById('visibleResultsCount');
    const totalPaginationCount = document.getElementById('totalPaginationCount');

    function filterOffers() {
      const searchTerm = searchInput.value.toLowerCase().trim();
      const typeValue = typeFilter.value;
      const statusValue = statusFilter.value;

      let visibleCount = 0;

      offerRows.forEach(row => {
        const name = row.dataset.name || '';
        const type = row.dataset.type || '';
        const status = row.dataset.status || '';

        const matchSearch = name.includes(searchTerm);
        const matchType = typeValue === 'all' || type === typeValue;
        const matchStatus = statusValue === 'all' || status === statusValue;

        if (matchSearch && matchType && matchStatus) {
          row.style.display = '';
          visibleCount++;
        } else {
          row.style.display = 'none';
        }
      });

      totalResultsCount.textContent = visibleCount;
      visibleResultsCount.textContent = visibleCount > 0 ? `1-${visibleCount}` : '0';
      totalPaginationCount.textContent = visibleCount;
    }

    let debounceTimer;
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(filterOffers, 300);
    });

    typeFilter.addEventListener('change', filterOffers);
    statusFilter.addEventListener('change', filterOffers);





    const applicableToInput =
    document.getElementById(
        "applicableTo"
    );

const applicableToggleItems =
    document.querySelectorAll(
        "#applicableToToggle .toggle-item"
    );

const targetSelect =
    document.getElementById(
        "targetSelect"
    );

const targetLabel =
    document.getElementById(
        "targetLabel"
    );


// TOGGLE SWITCHING
applicableToggleItems.forEach(item => {

    item.addEventListener(
        "click",
        () => {

        // ACTIVE UI
        applicableToggleItems
        .forEach(i =>
            i.classList.remove(
                "active"
            )
        );

        item.classList.add(
            "active"
        );

        // VALUE
        const value =
            item.dataset.value;

        applicableToInput.value =
            value;

        // LABEL
        targetLabel.textContent =
            value === "product"
            ?
            "Target Product"
            :
            "Target Category";

        // RESET SELECT
        targetSelect.value = "";

        // SWITCH OPTIONS
        const options =
            targetSelect.querySelectorAll(
                "option"
            );

        options.forEach(option => {

            if (
                option.value === ""
            ) {
                option.textContent = value === "product" ? "Select a product..." : "Select a category...";
                return;
            }

            const type =
                option.dataset.type;

            option.hidden =
                type !== value;
        });
    });
});
  </script>
