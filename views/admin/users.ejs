<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>User Management — AJAX Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=DM+Sans:wght@200;300;400;500;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Playfair Display', 'Georgia', 'serif'],
                        sans: ['DM Sans', 'system-ui', 'sans-serif']
                    },
                    colors: {
                        brand: {
                            bg: '#F5F2ED',
                            sidebar: '#ECE9E1',
                            card: '#FFFFFF',
                            text: '#1C1C1C',
                            muted: '#9B8E83',
                            border: 'rgba(28, 28, 28, 0.08)'
                        }
                    }
                }
            }
        }
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'DM Sans', sans-serif; background: #F5F2ED; color: #1C1C1C; min-height: 100vh; overflow-x: hidden; }
        
        /* Sidebar Styling */
        .sidebar-item { transition: all 0.2s ease; border-radius: 8px; margin: 0 12px; }
        .sidebar-item.active { background: #1C1C1C; color: #FFFFFF; }
        .sidebar-item:hover:not(.active) { background: rgba(28, 28, 28, 0.04); }
        .nav-section-title { font-size: 0.65rem; font-weight: 700; color: #9B8E83; text-transform: uppercase; letter-spacing: 0.15em; padding: 0 28px; margin-bottom: 12px; }

        /* Header Styling */
        .header-title-underline { position: relative; display: inline-block; padding-bottom: 8px; }
        .header-title-underline::after { content: ''; position: absolute; left: 0; bottom: 0; width: 40px; height: 2px; background: #1c1c1c; }

        /* Input & Controls */
        .search-input { background: #F3F1ED !important; border: none !important; transition: all 0.2s ease; border-radius: 12px !important; }
        .search-input:focus { background: #EAE8E4 !important; box-shadow: none !important; }

        /* Table Styling */
        .user-table-container { border-radius: 16px; overflow: hidden; background: #FFFFFF; border: 1px solid rgba(28, 28, 28, 0.05); }
        .table-row { transition: background 0.2s ease; border-bottom: 1px solid rgba(28, 28, 28, 0.03); }
        .table-row:hover { background: #FAFAFA; }

        /* Badges */
        .badge { font-size: 0.65rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em; }
        .badge-active { background: #E5E7EB; color: #1C1C1C; }
        .badge-blocked { background: #FFEAEA; color: #B04040; }

        /* Action Icons */
        .action-icon { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; cursor: pointer; }
        .action-icon:hover { background: #F5F2ED; }

        /* Pagination */
        .pagination-btn { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; border-radius: 8px; border: 1px solid rgba(28, 28, 28, 0.08); transition: all 0.2s; background: #FFFFFF; }
        .pagination-btn.active { background: #1C1C1C; color: #FFFFFF; border-color: #1C1C1C; }
        .pagination-btn:hover:not(.active) { background: #F5F2ED; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: #DDD6CC; border-radius: 10px; }
    </style>
</head>
<body class="flex">

    <aside class="w-72 h-screen bg-brand-sidebar flex flex-col sticky top-0 z-50">
        <div class="pt-12 pb-12 px-10">
            <h2 class="text-3xl font-serif tracking-tight font-bold">AJAX</h2>
        </div>

        <div class="nav-section-title mt-4">Management</div>
        
        <nav class="flex-1 space-y-1">
            <a href="/admin/dashboard" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                <span class="text-[0.9rem] font-medium">Dashboard</span>
            </a>
            <a href="/admin/orders" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                <span class="text-[0.9rem] font-medium">Orders</span>
            </a>
            <a href="/admin/products" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21 16-2-2.73a2 2 0 0 0-3.23 0l-2 2.73"></path><path d="m11 16-2-2.73a2 2 0 0 0-3.23 0l-2 2.73"></path><path d="M17 12V3"></path><path d="M7 12V3"></path><path d="M3 12h18"></path><path d="M21 3h-18"></path></svg>
                <span class="text-[0.9rem] font-medium">Products</span>
            </a>
            <a href="/admin/categories" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                <span class="text-[0.9rem] font-medium">Categories</span>
            </a>
              <a href="/admin/coupons" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 5H4v14h11l4-7-4-7z"></path><circle cx="9" cy="12" r="1"></circle></svg>
                <span class="text-[0.9rem] font-medium">Coupons</span>
            </a>
            <a href="/admin/offers" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 3h12l3 6-9 12L3 9z"></path></svg>
                <span class="text-[0.9rem] font-medium">Offers</span>
            </a>
            <a href="/admin/users" class="sidebar-item active flex items-center gap-4 px-6 py-3.5">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                <span class="text-[0.9rem] font-medium">Customers</span>
            </a>
            <a href="/admin/home-manager" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                <span class="text-[0.9rem] font-medium">Home Manager</span>
            </a>
        </nav>

        <div class="p-8 border-t border-brand-border">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full overflow-hidden bg-white border border-brand-border">
                    <img src="https://i.pravatar.cc/100?u=sebastian" alt="Admin" class="w-full h-full object-cover">
                </div>
                <div class="flex-1 overflow-hidden">
                    <h5 class="text-sm font-bold truncate">Sebastian Vielle</h5>
                    <p id="logoutAdmin" class="text-[0.7rem] text-brand-muted cursor-pointer hover:text-brand-text transition-colors">Logout Account</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 p-12 overflow-y-auto max-h-screen">
        
        <header class="flex justify-between items-end mb-12">
            <div>
                <h1 class="text-5xl font-serif header-title-underline">User Management</h1>
            </div>
        </header>

        <div class="user-table-container">
            <div class="p-8 flex flex-col md:flex-row justify-between items-center gap-6 border-b border-brand-border">
                <h3 class="text-xl font-bold">Customer Directory</h3>
                
                <div class="flex flex-1 md:justify-end items-center gap-4 w-full md:w-auto">
                    <div class="relative flex-1 md:max-w-[340px]">
                        <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-brand-muted" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input 
                            type="text" 
                            id="searchInput"
                            value="<%= searchQuery || '' %>"
                            placeholder="Search by name or email..." 
                            class="search-input w-full pl-11 pr-4 py-3 text-sm outline-none placeholder:text-brand-muted/60"
                        >
                    </div>
                    
                    <select id="statusFilter" class="search-input py-3 px-4 text-sm font-medium min-w-[140px] cursor-pointer">
                        <option value="all" <%= status === "all" ? "selected" : "" %>>All Status</option>
                        <option value="active" <%= status === "active" ? "selected" : "" %>>Active</option>
                        <option value="blocked" <%= status === "blocked" ? "selected" : "" %>>Blocked</option>
                    </select>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="text-[0.62rem] text-brand-muted font-bold uppercase tracking-[0.2em] border-b border-brand-border bg-[#FCFCFC]">
                            <th class="px-8 py-5">#</th>
                            <th class="px-8 py-5">Profile</th>
                            <th class="px-8 py-5">Status</th>
                            <th class="px-8 py-5">Registration</th>
                            <th class="px-8 py-5 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-brand-border">
                        <% users.forEach((user, index) => { %>
                            <tr class="table-row">
                                <td class="px-8 py-6 text-sm text-brand-muted">
                                    <%= (currentPage - 1) * 5 + index + 1 %>
                                </td>
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-full bg-brand-bg overflow-hidden border border-brand-border">
                                            <img src="<%= user.profileImage || 'https://ui-avatars.com/api/?background=random&name=' + encodeURIComponent(user.name) %>" class="w-full h-full object-cover">
                                        </div>
                                        <div>
                                            <h5 class="text-[0.85rem] font-bold text-brand-text leading-tight"><%= user.name %></h5>
                                            <p class="text-[0.65rem] text-brand-muted mt-0.5"><%= user.email %></p>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="badge <%= user.isBlocked ? 'badge-blocked' : 'badge-active' %>">
                                        <%= user.isBlocked ? 'Blocked' : 'Active' %>
                                    </span>
                                </td>
                                <td class="px-8 py-6">
                                    <h5 class="text-[0.8rem] font-medium text-brand-text"><%= new Date(user.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></h5>
                                    <p class="text-[0.65rem] text-brand-muted uppercase tracking-wider"><%= new Date(user.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></p>
                                </td>
                                <td class="px-8 py-6">
                                    <div class="flex items-center justify-end gap-3">
                                        <div class="action-icon <%= user.isBlocked ? 'text-green-600' : 'text-red-500' %>" 
                                             title="<%= user.isBlocked ? 'Unblock' : 'Block' %> User"
                                             onclick="toggleBlockUser('<%=user._id %>','<%=user.isBlocked %>')">
                                            <% if(user.isBlocked) { %>
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"></path></svg>
                                            <% } else { %>
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
                                            <% } %>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <div class="p-8 flex flex-col md:flex-row justify-between items-center gap-6 bg-[#FCFCFC]">
                <p class="text-xs text-brand-muted">
                    Showing <span class="text-brand-text font-bold"><%= (currentPage - 1) * 5 + 1 %></span> 
                    - <span class="text-brand-text font-bold"><%= Math.min(currentPage * 5, totalUsers) %></span> 
                    of <span class="text-brand-text font-bold"><%= totalUsers %></span>
                </p>
                
                <div class="flex items-center gap-2">
                    <% if(currentPage > 1) { %>
                        <a href="/admin/users?page=<%= currentPage - 1 %>&search=<%= searchQuery %>&status=<%= status %>" class="pagination-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                        </a>
                    <% } %>

                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <a href="/admin/users?page=<%= i %>&search=<%= searchQuery %>&status=<%= status %>" 
                           class="pagination-btn <%= currentPage === i ? 'active' : '' %>">
                           <%= i %>
                        </a>
                    <% } %>

                    <% if(currentPage < totalPages) { %>
                        <a href="/admin/users?page=<%= currentPage + 1 %>&search=<%= searchQuery %>&status=<%= status %>" class="pagination-btn">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function toggleBlockUser(userId, isBlocked) {
            const action = isBlocked === 'true' ? 'unblock' : 'block';
            const result = await Swal.fire({
                title: `<span style="font-family: 'Playfair Display', serif;">${action.toUpperCase()} USER?</span>`,
                text: `Confirm to ${action} this user's access.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#1C1C1C',
                cancelButtonColor: '#d33',
                confirmButtonText: `Yes, ${action}`,
                background: '#F5F2ED'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/toggleblockuser/${userId}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const data = await response.json();
                    if (data.success) window.location.reload();
                    else Swal.fire('Error', data.message, 'error');
                } catch (error) {
                    Swal.fire('Error', 'Connection failed', 'error');
                }
            }
        }

        // Search & Filter Logic
        let debounceTimer;
        const input = document.getElementById("searchInput");
        const statusFilter = document.getElementById("statusFilter");

        const updateFilters = () => {
            const query = input.value.trim();
            const status = statusFilter.value;
            window.location.href = `/admin/users?page=1&search=${query}&status=${status}`;
        };

        input.addEventListener("input", () => {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(updateFilters, 500);
        });

        statusFilter.addEventListener("change", updateFilters);

        document.getElementById("logoutAdmin")?.addEventListener("click", function () {
            Swal.fire({
                title: "Logout?",
                icon: "question",
                showCancelButton: true,
                confirmButtonColor: "#1C1C1C",
                confirmButtonText: "Logout"
            }).then((result) => {
                if (result.isConfirmed) window.location.href = "/admin/logout";
            });
        });
    </script>
</body>
</html>