<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Subcategory Management — AJAX Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=DM+Sans:wght@200;300;400;500;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        serif: ['Playfair Display', 'Georgia', 'serif'],
                        sans: ['DM Sans', 'system-ui', 'sans-serif']
                    },
                    colors: {
                        brand: {
                            bg: '#F5F2ED',
                            sidebar: '#ECE9E1',
                            card: '#FFFFFF',
                            text: '#1C1C1C',
                            muted: '#9B8E83',
                            border: 'rgba(28, 28, 28, 0.08)'
                        }
                    }
                }
            }
        }
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'DM Sans', sans-serif; background: #F5F2ED; color: #1C1C1C; min-height: 100vh; }
        
        .sidebar-item { transition: all 0.2s ease; border-radius: 8px; margin: 0 12px; }
        .sidebar-item.active { background: #1C1C1C; color: #FFFFFF; }
        .sidebar-item:hover:not(.active) { background: rgba(28, 28, 28, 0.04); }

        .header-title-underline { position: relative; display: inline-block; padding-bottom: 8px; }
        .header-title-underline::after { content: ''; position: absolute; left: 0; bottom: 0; width: 40px; height: 2px; background: #1c1c1c; }

        .search-input { background: #F3F1ED !important; border: none !important; border-radius: 12px !important; }
        .stat-card { background: #FFFFFF; border-radius: 16px; border: 1px solid rgba(28, 28, 28, 0.08); transition: transform 0.2s ease; }
        .stat-card:hover { transform: translateY(-2px); }

        .table-row { transition: background 0.2s ease; border-bottom: 1px solid rgba(28, 28, 28, 0.03); }
        .table-row:hover { background: #FAFAFA; }

        .status-pill { font-size: 0.65rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em; }
        .status-active { background: #E5E7EB; color: #1C1C1C; }
        .status-inactive { background: #E5E7EB; color: #9B8E83; opacity: 0.7; }

        .toggle-switch { width: 44px; height: 24px; background: #E5E7EB; border-radius: 12px; position: relative; cursor: pointer; transition: background 0.3s; }
        .toggle-switch.active { background: #1C1C1C; }
        .toggle-circle { width: 20px; height: 20px; background: #FFFFFF; border-radius: 50%; position: absolute; top: 2px; left: 2px; transition: transform 0.3s; }
        .toggle-switch.active .toggle-circle { transform: translateX(20px); }

        .pagination-btn { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 8px; border: 1px solid rgba(28, 28, 28, 0.08); background: #FFFFFF; }
        .pagination-btn.active { background: #1C1C1C; color: #FFFFFF; }
        
        .nav-section-title { font-size: 0.65rem; font-weight: 700; color: #9B8E83; text-transform: uppercase; letter-spacing: 0.15em; padding: 0 28px; margin-bottom: 12px; }
    </style>
</head>
<body class="flex">

    <aside class="w-72 h-screen bg-brand-sidebar flex flex-col sticky top-0 z-50">
        <div class="pt-12 pb-12 px-10">
            <h2 class="text-3xl font-serif tracking-tight font-bold">AJAX</h2>
        </div>
        <div class="nav-section-title mt-4">Management</div>
        <nav class="flex-1 space-y-1">
            <a href="/admin/dashboard" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                <span class="text-[0.9rem] font-medium">Dashboard</span>
            </a>
            <a href="/admin/products" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
                <span class="text-[0.9rem] font-medium">Products</span>
            </a>
            <a href="/admin/categories" class="sidebar-item flex items-center gap-4 px-6 py-3.5 text-brand-muted">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
                <span class="text-[0.9rem] font-medium">Categories</span>
            </a>
            <a href="/admin/subcategories" class="sidebar-item active flex items-center gap-4 px-6 py-3.5">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h6v6H3zM15 15h6v6h-6zM9 6h6v9"/></svg>
                <span class="text-[0.9rem] font-medium">Subcategories</span>
            </a>
        </nav>
        <div class="p-8 border-t border-brand-border">
            <div class="flex items-center gap-3">
                <img src="https://i.pravatar.cc/100?u=sebastian" class="w-10 h-10 rounded-full object-cover">
                <div class="flex-1 overflow-hidden">
                    <h5 class="text-sm font-bold truncate">Sebastian Vielle</h5>
                    <p class="text-[0.7rem] text-brand-muted truncate">vielle.admin@noco.com</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 p-14 overflow-y-auto max-h-screen">
        <header class="flex justify-between items-center mb-10">
            <h1 class="text-4xl font-serif font-bold header-title-underline">Subcategories</h1>
            <button onclick="openSubModal()" class="bg-[#1C1C1C] text-white px-6 py-3.5 text-[0.8rem] rounded-xl font-bold flex items-center gap-2 hover:bg-stone-800 transition-all shadow-lg">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Add Subcategory
            </button>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="stat-card p-6 flex justify-between items-start">
                <div>
                    <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-widest mb-3">Total Subcategories</p>
                    <h3 class="text-4xl font-serif font-bold">142</h3>
                </div>
                <div class="p-3 bg-brand-bg rounded-xl">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9B8E83" stroke-width="1.5"><path d="M9 3H4v6h5V3zM20 15h-5v6h5v-6zM9 6h6v9"/></svg>
                </div>
            </div>
            <div class="stat-card p-6 flex justify-between items-start">
                <div>
                    <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-widest mb-3">Active</p>
                    <h3 class="text-4xl font-serif font-bold">136</h3>
                </div>
                <div class="p-3 bg-brand-bg rounded-xl">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9B8E83" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                </div>
            </div>
            <div class="stat-card p-6 flex justify-between items-start">
                <div>
                    <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-widest mb-3">Inactive</p>
                    <h3 class="text-4xl font-serif font-bold">06</h3>
                </div>
                <div class="p-3 bg-brand-bg rounded-xl">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9B8E83" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-[24px] border border-brand-border overflow-hidden shadow-sm">
            <div class="px-8 py-8 flex flex-col md:flex-row justify-between items-center gap-6">
                <h3 class="text-xl font-bold">All Subcategories</h3>
                <div class="flex gap-4 w-full md:w-auto">
                    <select class="search-input px-4 py-4 text-[0.9rem] outline-none text-brand-muted min-w-[160px]">
                        <option>All Categories</option>
                        <option>Men</option>
                        <option>Women</option>
                    </select>
                    <div class="relative flex-1 md:w-[300px]">
                        <svg class="absolute left-5 top-1/2 -translate-y-1/2 text-brand-muted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="text" id="searchInput" value="<%= search %>" placeholder="Search subcategories..." class="search-input w-full pl-14 pr-6 py-4 text-[0.9rem] outline-none">
                    </div>
                </div>
            </div>

            <table class="w-full text-left">
                <thead>
                    <tr class="text-[0.7rem] text-brand-muted font-bold uppercase tracking-[0.15em] bg-[#FAFAFA] border-b border-brand-border">
                        <th class="px-10 py-5">Sl.No</th>
                        <th class="px-10 py-5">Subcategory Name</th>
                        <th class="px-10 py-5">Parent Category</th>
                        <th class="px-10 py-5">Products</th>
                        <th class="px-10 py-5">Status</th>
                        <th class="px-10 py-5 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-brand-border/10">
                    <% subCategories.forEach((sub,index)=>{ %>
                    <tr class="table-row">
                        <td class="px-10 py-6 text-[0.9rem] font-medium text-brand-muted"><%= index+1 %></td>
                        <td class="px-10 py-6 font-bold"><%= sub.name %></td>
                        <td class="px-10 py-6 text-[0.9rem]"><%= sub.category?.name %></td>
                        <td class="px-10 py-6 text-[0.9rem]">42</td>
                        <td class="px-10 py-6">
                            <% if(sub.isActive){ %>
                        <span class="status-pill status-active">Active</span>
                                <% } else { %>
                                <span class="status-pill status-inactive">Inactive</span>
                                <% } %></td>
                        <td class="px-10 py-6">
                            <div class="flex items-center justify-center gap-6">
                                <button class="text-brand-muted hover:text-brand-text"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
                                <button class="text-brand-muted hover:text-brand-text"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                                <button class="text-brand-muted hover:text-red-600"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
                                <div class="toggle-switch active"><div class="toggle-circle"></div></div>
                            </div>
                        </td>
                    </tr>
                    <%  }) %>
                </tbody>
            </table>

            <div class="px-10 py-8 flex justify-between items-center bg-[#FAFAFA] border-t border-brand-border">
                <p class="text-[0.85rem] text-brand-muted">Showing 1-4 of 142 subcategories</p>
                <div class="flex items-center gap-2">
                    <button class="pagination-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg></button>
                    <button class="pagination-btn active">1</button>
                    <button class="pagination-btn">2</button>
                    <button class="pagination-btn">3</button>
                    <button class="pagination-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></button>
                </div>
            </div>
        </div>
    </main>

      <div id="subCategoryModal"
     class="fixed inset-0 z-[999] bg-black/40 backdrop-blur-sm hidden items-center justify-center">

  <div id="subModalContent"
       class="bg-white w-[420px] rounded-2xl p-6 relative scale-95 opacity-0 transition-all duration-200">

    <button onclick="closeSubModal()" 
      class="absolute top-4 right-4 text-gray-500 text-xl">✕</button>

    <h2 id="subModalTitle" class="text-2xl font-semibold mb-4">
      Add Subcategory
    </h2>

    <input type="hidden" id="subCategoryId" />

    <label class="text-sm text-gray-600">Select Parent Category</label>
    <select id="parentCategory"
      class="w-full border rounded-lg px-3 py-2 mt-1 mb-4">

      <option value="">Choose a category</option>

      <% categories.forEach(cat => { %>
        <option value="<%= cat._id %>">
          <%= cat.name %>
        </option>
      <% }) %>

    </select>

    <label class="text-sm text-gray-600">Subcategory Name</label>
    <input id="subCategoryName"
      class="w-full border rounded-lg px-3 py-2 mt-1 mb-4"
      placeholder="e.g. Shirts" />

    <div class="flex items-center justify-between mb-6">
      <div>
        <p class="font-medium">Status</p>
        <p class="text-xs text-gray-500">
          Set subcategory as visible
        </p>
      </div>

      <input type="checkbox" id="subCategoryStatus" checked />
    </div>

    <div class="flex justify-end gap-3">
      <button onclick="closeSubModal()" 
        class="px-4 py-2 bg-gray-200 rounded-lg">
        Cancel
      </button>

      <button onclick="saveSubCategory()" 
        class="px-4 py-2 bg-black text-white rounded-lg">
        Save Subcategory
      </button>
    </div>
  </div>
</div>
     <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/js/admin/subCategory.js"></script>
</body>
</html>