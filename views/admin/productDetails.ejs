<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Product Details AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- TAILWIND -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Plus Jakarta Sans', 'sans-serif']
        },
        colors: {
          'luxury-bg': '#F4F2EE', /* Beige from Figma */
          'luxury-accent': '#C1272D', /* Red accent */
          'luxury-text': '#1C1C1C',
          'luxury-muted': '#8E8E8E'
        }
      }
    }
  }
</script>

<style>
  body { background-color: theme('colors.luxury-bg'); color: theme('colors.luxury-text'); font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }
  
  /* Sidebar styles */
  .sidebar-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 0px; transition: all 0.2s ease; position: relative; color: theme('colors.luxury-muted'); font-size: 14px; font-weight: 500; }
  .sidebar-item:hover { color: theme('colors.luxury-text'); }
  .sidebar-item.active { background-color: #fff; color: theme('colors.luxury-text'); }
  .sidebar-item.active::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background-color: theme('colors.luxury-accent'); }

  /* Card Styles */
  .detail-card { background: white; border-radius: 0px; box-shadow: 0 4px 20px rgba(0,0,0,0.02); border: 1px solid #E5E7EB; border-color: rgba(229, 231, 235, 0.5); }
  
  .status-badge { padding: 4px 10px; border-radius: 100px; font-size: 9px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; border: 1.5px solid #1C1C1C; }
  
  .category-pill { background: #1C1C1C; color: white; padding: 4px 10px; font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }

  /* Animations */
  @keyframes fadeInUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeInUp 0.5s ease-out forwards; }
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }
  .delay-300 { animation-delay: 0.3s; }

  /* Media Gallery */
  .thumbnail-box { aspect-ratio: 1; width: 100%; border: 1px solid #E5E7EB; cursor: pointer; transition: all 0.2s; background: #F9FAFB; }
  .thumbnail-box:hover { border-color: #1C1C1C; }
  .thumbnail-box.active { border-color: #1C1C1C; box-shadow: 0 0 0 1px #1C1C1C; }

  /* Progress Bar */
  .avail-progress { height: 6px; background: #E5E7EB; width: 100%; border-radius: 10px; overflow: hidden; }
  .avail-progress-inner { height: 100%; background: #1C1C1C; border-radius: 10px; transition: width 1s ease-in-out; }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #D1D1D1; border-radius: 10px; }
</style>
</head>
<body class="flex min-h-screen">

  <!-- SIDEBAR -->
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-60 bg-white border-r border-stone-200 transition-transform lg:translate-x-0 lg:static lg:inset-0 -translate-x-full">
    <div class="h-full flex flex-col pt-8 pb-6">
      <!-- Logo -->
      <div class="px-8 mb-12">
        <h1 class="text-2xl font-serif font-bold tracking-tighter uppercase">AJAX</h1>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 px-4 space-y-1">
        <p class="text-[10px] font-bold text-stone-400 tracking-[0.2em] mb-4 px-4 uppercase">Management</p>
        
        <a href="/admin/dashboard" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
        <a href="/admin/orders" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Orders
        </a>
        <a href="/admin/products" class="sidebar-item active">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
          Products
        </a>
        <a href="/admin/categories" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Categories
        </a>
        <a href="/admin/coupons" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/><path d="M12 7v5l3 3"/></svg>
          Coupons
        </a>
        <a href="/admin/offers" class="sidebar-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Offers
        </a>
        <a href="/admin/users" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Customers
        </a>
        <a href="/admin/reviews" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Reviews
        </a>
      </nav>

      <!-- Profile Section -->
      <div class="px-8 mt-auto pt-6 border-t border-stone-100 flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-stone-100 flex items-center justify-center overflow-hidden border border-stone-200">
            <img src="https://ui-avatars.com/api/?name=Sebastian+Vane&background=F3F2EE&color=1C1C1C" alt="Admin" class="w-full h-full object-cover">
        </div>
        <div class="flex-1 overflow-hidden">
          <p class="text-[11px] font-bold truncate uppercase tracking-tighter">Sebastian Vane</p>
          <p class="text-[9px] text-stone-400 font-bold truncate tracking-widest uppercase">Head Curator</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="flex-1 min-w-0 flex flex-col p-6 lg:p-10">
    
    <!-- Header Section -->
    <header class="flex flex-col md:flex-row md:items-start justify-between gap-6 mb-10 animate-fade-in">
        <div class="flex-1">
            <div class="flex items-center gap-3">
                <h2 class="text-5xl font-serif font-bold leading-none tracking-tight"><%= product.name %></h2>
                <span class="status-badge bg-white">  <%= product.isActive ? "Active" : "Inactive" %></span>
            </div>
            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mt-3">Product ID: <%= product._id %></p>
        </div>
        
        <div class="flex flex-wrap items-center gap-3">
           <a href="/admin/products/<%= product._id %>/variants"
                class="px-6 py-3 border border-stone-900 text-[11px] font-bold uppercase tracking-widest">
               View All Variants
                 </a>
            <button class="px-6 py-3 border border-red-200 text-red-600 hover:bg-red-50 text-[11px] font-bold uppercase tracking-widest flex items-center gap-2 transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                Delete
            </button>
            <button class="px-6 py-3 bg-stone-900 text-white text-[11px] font-bold uppercase tracking-widest flex items-center gap-2 hover:bg-stone-800 transition-all shadow-md">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Edit Product
            </button>
        </div>
    </header>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
        
        <!-- MAIN LEFT COLUMN (8/12) -->
        <div class="lg:col-span-8 space-y-8">
            
            <!-- Product Media Card -->
            <div class="detail-card p-8 animate-fade-in delay-100">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-xl font-serif font-bold">Product Media</h3>
                    <span class="text-[10px] font-bold text-stone-400 uppercase tracking-widest">5 Images Total</span>
                </div>
                
                <div class="space-y-6">
                    <!-- Main Image Window -->
                    <div class="w-full aspect-[4/3] bg-stone-50 border border-stone-100 flex items-center justify-center overflow-hidden">
                        <img src="<%= product.images?.[0] || '/images/no-image.png' %>"alt="Main Product Image" class="w-full h-full object-cover">
                    </div>
                    
                    <!-- Thumbnails -->
                    <div class="grid grid-cols-4 sm:grid-cols-4 gap-4">
                        <div class="thumbnail-box active overflow-hidden">
                            <img src=<img src="<%= product.images?.[0] || '/images/no-image.png' %>" alt="Thumb 1" class="w-full h-full object-cover">
                        </div>
                        <div class="thumbnail-box overflow-hidden grayscale opacity-70">
                            <img src="<%= product.images?.[1] || '/images/no-image.png' %>" class="w-full h-full object-cover">
                        </div>
                        <div class="thumbnail-box overflow-hidden grayscale opacity-70">
                           <img src="<%= product.images?.[2] || '/images/no-image.png' %>" alt="Thumb 3" class="w-full h-full object-cover">
                        </div>
                        <div class="thumbnail-box overflow-hidden grayscale opacity-70">
                           <img src="<%= product.images?.[0] || '/images/no-image.png' %>" alt="Thumb 4" class="w-full h-full object-cover">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Basic Information Card -->
            <div class="detail-card p-8 animate-fade-in delay-200">
                <h3 class="text-xl font-serif font-bold mb-10">Basic Information</h3>
                
                <div class="space-y-12">
                    <div>
                        <p class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-4">Full Product Name</p>
                        <p class="text-2xl font-serif font-medium leading-tight"><%= product.name %></p>
                    </div>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-10 gap-x-12">
                        <div>
                            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-4">Category</p>
                            <span class="category-pill"> <%= product.category ? product.category.name : "N/A" %></span>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-4">SKU Identifier</p>
                            <p class="text-sm font-bold tracking-tight">Product ID: <%= product._id %></p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-4">Subcategory</p>
                            <p class="text-sm font-bold tracking-tight">  <%= product.subcategory ? product.subcategory.name : "N/A" %></p>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-4">Display Status</p>
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-2 rounded-full bg-green-500"></div>
                                <p class="text-[10px] font-bold uppercase tracking-widest"><%= product.isActive ? "Active" : "Inactive" %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Description Card -->
            <div class="detail-card p-8 animate-fade-in delay-300">
                <h3 class="text-xl font-serif font-bold mb-10">Description</h3>
                
                <div class="space-y-8">
                    <div>
                        <p class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em] mb-4">Detailed Description</p>
                        <div class="text-[13px] leading-relaxed text-stone-600 font-medium space-y-4">
                            <p><%= product.description %></p>
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- SIDEBAR RIGHT COLUMN (4/12) -->
        <div class="lg:col-span-4 space-y-8 animate-fade-in delay-200">
            
            <!-- Pricing Strategy Card -->
            <div class="detail-card p-8">
                <div class="flex items-center gap-3 mb-10">
                    <svg class="text-stone-400" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                    <h3 class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em]">Pricing Strategy</h3>
                </div>
                
                <div class="space-y-6">
                    <div class="flex items-center justify-between pb-6 border-b border-stone-50">
                        <p class="text-[11px] font-bold text-stone-400 uppercase tracking-widest">Market Base Price</p>
                        <p class="text-sm font-bold font-serif">$450.00</p>
                    </div>
                    
                    <div class="flex items-center justify-between">
                        <p class="text-[11px] font-bold text-stone-400 uppercase tracking-widest">Active Discount</p>
                        <p class="text-xs font-bold text-luxury-accent">10% OFF</p>
                    </div>
                    
                    <div class="pt-8">
                        <p class="text-[9px] font-bold text-stone-300 uppercase tracking-[0.2em] mb-2 leading-none">Retail Final Price</p>
                        <p class="text-5xl font-serif font-bold tracking-tighter">$405.00</p>
                    </div>
                </div>
            </div>

            <!-- Inventory Control Card -->
            <div class="detail-card p-8">
                <div class="flex items-center gap-3 mb-10">
                    <svg class="text-stone-400" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <h3 class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em]">Inventory Control</h3>
                </div>
                
                <div class="space-y-10">
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <p class="text-[10px] font-bold text-stone-900 uppercase tracking-widest">Availability</p>
                            <p class="text-[9px] font-bold text-stone-300 uppercase">45% Remaining</p>
                        </div>
                        <div class="avail-progress">
                            <div class="avail-progress-inner" style="width: 45%;"></div>
                        </div>
                    </div>
                    
                    <div class="flex items-center justify-between pt-4">
                        <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest">On-Hand Stock</p>
                        <p class="text-xl font-serif font-bold italic underline underline-offset-4 decoration-stone-200">15 Units</p>
                    </div>
                </div>
            </div>

            <!-- SEO Settings Card -->
            <div class="detail-card p-8">
                <div class="flex items-center gap-3 mb-10">
                    <svg class="text-stone-400" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <h3 class="text-[10px] font-bold text-stone-400 uppercase tracking-[0.2em]">SEO Settings</h3>
                </div>
                
                <div class="space-y-8">
                    <div>
                        <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-4">Material</p>
                        <div class="bg-stone-50 border border-stone-100 p-4 text-[11px] font-medium text-stone-600 tracking-tight">
                           <%= product.material || "Not specified" %>
                        </div>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-4">Care Guide</p>
                        <div class="bg-stone-50 border border-stone-100 p-4 text-[11px] font-medium text-stone-600 tracking-tight leading-relaxed">
                            <%= product.careGuide || "No care guide" %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Floating Settings Button (Matching Cog icon from Figma) -->
    <button class="fixed bottom-10 right-10 w-12 h-12 bg-luxury-text text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 transition-transform z-50">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
    </button>
  </main>

  <script>
    // Sidebar toggle for mobile (placeholder logic)
    const sidebar = document.getElementById('sidebar');
    // Mobile toggle logic can be added here
  </script>
</body>
</html>
