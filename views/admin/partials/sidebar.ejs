<!-- ── SIDEBAR ── -->
<aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-64 bg-white border-r border-stone-200 transition-transform lg:translate-x-0 lg:static lg:inset-0 -translate-x-full">
  <div class="h-full flex flex-col p-6">
    <!-- Logo -->
    <div class="mb-10">
      <h1 class="text-3xl font-serif font-bold tracking-tighter">AJAX</h1>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 space-y-1">
      <p class="text-[10px] font-bold text-stone-400 tracking-[0.2em] mb-4 uppercase">Management</p>
      
      <a href="/admin/dashboard" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        Dashboard
      </a>
      <a href="/admin/orders" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/orders' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        Orders
      </a>
      <a href="/admin/products" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/products' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
        Products
      </a>

      <a href="/admin/categories" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/categories' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Categories
      </a>
      <a href="/admin/subcategories" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/subcategories' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        Subcategories
      </a>
      <a href="/admin/coupons" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/coupons' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 12a10 10 0 1 0 20 0 10 10 0 1 0-20 0Z"/><path d="m7 7 10 10"/><path d="m17 7-10 10"/></svg>
        Coupons
      </a>
      <a href="/admin/offers" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/offers' ? 'active' : '' %>">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
        Offers
      </a>
      <a href="/admin/users" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/users' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Users
      </a>
      <a href="/admin/reviews" class="sidebar-item <%= typeof currentPath !== 'undefined' && currentPath === '/admin/reviews' ? 'active' : '' %>">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Reviews
      </a>
    </nav>

    <!-- Profile & Logout Section -->
    <div class="mt-auto pt-6 border-t border-stone-100 flex flex-col gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-stone-100 flex items-center justify-center overflow-hidden">
            <img src="https://ui-avatars.com/api/?name=Admin&background=F3F2EE&color=1C1C1C" alt="Admin" class="w-full h-full object-cover">
        </div>
        <div class="flex-1 overflow-hidden">
          <p class="text-sm font-bold truncate">Administrator</p>
          <p class="text-[10px] text-stone-400 truncate tracking-tight">admin@ajax.com</p>
        </div>
      </div>
      
      <!-- Logout Button (Danger/Red Style) -->
      <a href="#" onclick="confirmAdminLogout(event)" class="flex items-center justify-center gap-2 w-full py-2.5 rounded-lg bg-rose-50 text-rose-600 hover:bg-rose-100 hover:text-rose-700 transition-colors text-sm font-bold tracking-wide uppercase">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Logout
      </a>
    </div>
  </div>
</aside>

<script>
  function confirmAdminLogout(e) {
    e.preventDefault();
    if (typeof ajaxConfirm === 'function') {
      ajaxConfirm({
        title: 'Sign Out?',
        text: 'You are about to securely log out of the admin portal.',
        confirmText: 'YES, LOGOUT',
        cancelText: 'CANCEL',
        icon: 'warning'
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = '/admin/logout';
        }
      });
    } else {
      // Fallback if swal-helper.js isn't loaded
      if (confirm('Are you sure you want to log out?')) {
        window.location.href = '/admin/logout';
      }
    }
  }
</script>
