<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Dashboard — AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Outfit:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Outfit', 'sans-serif']
        },
        colors: {
          brand: {
            dark: '#1C1C1C',
            muted: '#888888',
            border: 'rgba(0,0,0,0.06)',
            bg: '#FAFAF8'
          }
        }
      }
    }
  }
</script>

<style>
  body { 
    background: #FAFAF8; 
    color: #1C1C1C; 
    font-family: 'Outfit', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .editorial-title { font-family: 'Playfair Display', serif; }
  
  .glass-card {
    background: #FFFFFF;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 30px rgba(0,0,0,0.02);
    border-radius: 24px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .glass-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.08);
  }

  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1C1C1C;
    color: white;
  }

  .chart-container {
    position: relative;
    height: 350px;
    width: 100%;
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #E5E5E5; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #D1D1D1; }

  @keyframes slideInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-slide-up { animation: slideInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both; }

  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }
</style>
</head>
<body class="flex min-h-screen overflow-x-hidden">

  <!-- SIDEBAR (PARTIAL) -->
  <%- include('partials/sidebar', { currentPath: '/admin/dashboard' }) %>

  <!-- MAIN CONTENT -->
  <main class="flex-1 flex flex-col min-w-0">
    
    <!-- Top Nav -->
    <header class="h-24 bg-white/80 backdrop-blur-md border-b border-brand-border flex items-center justify-between px-10 sticky top-0 z-50">
      <div class="flex items-center gap-6">
        <h1 class="editorial-title text-3xl italic tracking-tight">Executive <span class="not-italic font-bold text-brand-dark">Overview</span></h1>
      </div>
      
        <!-- Time Period Selector -->
        <div class="relative hidden md:block">
          <select id="timePeriod" class="appearance-none pl-12 pr-10 py-3 bg-brand-bg border border-brand-border rounded-full text-[0.7rem] font-black uppercase tracking-widest text-brand-muted hover:text-brand-dark transition-all cursor-pointer focus:outline-none focus:ring-2 focus:ring-brand-dark/10">
            <option value="today">Today</option>
            <option value="week">Week</option>
            <option value="month" selected>Month</option>
            <option value="year">Year</option>
            <option value="custom">Custom</option>
          </select>
          <div class="absolute left-5 top-1/2 -translate-y-1/2 pointer-events-none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          </div>
          <div class="absolute right-5 top-1/2 -translate-y-1/2 pointer-events-none">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
        </div>
      </div>
    </header>

    <div class="p-10 space-y-10">
      
      <!-- Quick Stats -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Revenue -->
        <div class="glass-card p-6 animate-slide-up">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            </div>
            <span class="text-[0.65rem] font-black text-brand-dark bg-brand-bg px-3 py-1 rounded-full uppercase tracking-tighter">+12.5%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Total Revenue</p>
          <h3 class="text-3xl font-bold tracking-tighter">₹<%= (stats && stats.totalRevenue) ? stats.totalRevenue.toLocaleString() : '0' %></h3>
        </div>

        <!-- Orders -->
        <div class="glass-card p-6 animate-slide-up delay-1">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            </div>
            <span class="text-[0.65rem] font-black text-brand-dark bg-brand-bg px-3 py-1 rounded-full uppercase tracking-tighter">+8.2%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Total Orders</p>
          <h3 class="text-3xl font-bold tracking-tighter"><%= (stats && stats.totalOrders) ? stats.totalOrders : '0' %></h3>
        </div>

        <!-- Customers -->
        <div class="glass-card p-6 animate-slide-up delay-2">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <span class="text-[0.65rem] font-black text-brand-dark bg-brand-bg px-3 py-1 rounded-full uppercase tracking-tighter">+4.1%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Active Users</p>
          <h3 class="text-3xl font-bold tracking-tighter"><%= (stats && stats.totalUsers) ? stats.totalUsers : '0' %></h3>
        </div>

        <!-- Conversion -->
        <div class="glass-card p-6 animate-slide-up delay-3">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
            </div>
            <span class="text-[0.65rem] font-black text-brand-dark bg-brand-bg px-3 py-1 rounded-full uppercase tracking-tighter">-2.4%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Conversion Rate</p>
          <h3 class="text-3xl font-bold tracking-tighter">3.2%</h3>
        </div>
      </div>

      <!-- Row 1: Sales Activity & Order Status -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">
        <!-- Sales Activity Chart -->
        <div class="lg:col-span-2 glass-card p-6 animate-slide-up delay-4 flex flex-col h-full">
          <div class="flex items-center justify-between mb-8">
            <div>
              <div class="flex items-center gap-3 mb-1">
                <div class="w-3 h-3 rounded-full bg-brand-dark shadow-[0_0_12px_rgba(28,28,28,0.3)]"></div>
                <h4 class="text-lg font-bold tracking-tight">Sales Activity</h4>
              </div>
              <p class="text-[0.65rem] text-brand-muted font-medium">Last 7 days performance</p>
            </div>
            <div class="px-3 py-1.5 bg-brand-bg text-brand-dark text-[0.55rem] font-black uppercase tracking-widest rounded-lg border border-brand-border">7 Days</div>
          </div>
          <div class="flex-1 min-h-[300px]">
            <canvas id="salesChart"></canvas>
          </div>
        </div>

        <!-- Order Status Distribution -->
        <div class="lg:col-span-1 glass-card p-6 bg-[#1A202C] border-none shadow-2xl animate-slide-up delay-4 text-white overflow-hidden flex flex-col h-full">
          <h4 class="text-lg font-bold tracking-tight mb-1">Order Status</h4>
          <p class="text-[0.65rem] text-slate-400 font-medium mb-8">Distribution breakdown</p>
          
          <div class="relative flex-1 flex flex-col items-center justify-center">
            <div class="w-40 h-40 mb-8 relative">
              <canvas id="statusDonut"></canvas>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-2xl font-bold tracking-tighter"><%= stats.totalOrders %></span>
                <span class="text-[0.45rem] font-black uppercase tracking-widest text-slate-400">Orders</span>
              </div>
            </div>

            <div class="w-full space-y-3">
              <% const statuses = ['Delivered', 'Pending', 'Cancelled', 'Returned']; 
                 const statusColors = ['bg-white', 'bg-slate-300', 'bg-slate-500', 'bg-slate-700'];
              %>
              <% statuses.forEach((status, i) => { %>
                <div class="flex items-center gap-4">
                  <span class="text-[0.6rem] font-bold text-slate-300 w-16"><%= status %></span>
                  <div class="flex-1 h-1 bg-slate-700/50 rounded-full overflow-hidden">
                    <div class="h-full <%= statusColors[i] %>" style="width: <%= (orderStatusCounts[status] / stats.totalOrders * 100) || 0 %>%"></div>
                  </div>
                  <span class="text-[0.6rem] font-bold text-slate-300"><%= orderStatusCounts[status] || 0 %></span>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <!-- Row 2: Best Categories & Inventory Alerts -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
        <!-- Best Categories -->
        <div class="glass-card p-6 animate-slide-up delay-4 flex flex-col h-full">
          <div class="flex items-center justify-between mb-8">
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 rounded-full bg-brand-dark shadow-[0_0_12px_rgba(28,28,28,0.3)]"></div>
              <h4 class="text-xl font-bold tracking-tight">Best Categories</h4>
            </div>
            <a href="/admin/subcategories" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-brand-bg text-brand-dark hover:bg-brand-dark hover:text-white transition-all text-[0.6rem] font-black uppercase tracking-widest">
              View All
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </a>
          </div>
          
          <div class="space-y-6 flex-1">
            <% if(typeof subcategorySales !== 'undefined' && subcategorySales.length > 0) { %>
              <% subcategorySales.forEach((sub, index) => { %>
                <div class="space-y-2">
                  <div class="flex justify-between items-end">
                    <span class="text-[0.7rem] font-bold uppercase tracking-widest text-brand-dark"><%= sub.name %></span>
                    <span class="text-[0.6rem] font-black text-brand-muted"><%= sub.totalSold %> sold</span>
                  </div>
                  <div class="h-2 bg-brand-bg rounded-full overflow-hidden">
                    <div class="h-full bg-brand-dark rounded-full" style="width: <%= (sub.totalSold / subcategorySales[0].totalSold * 100) %>%"></div>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <p class="text-[0.7rem] text-brand-muted italic">No category data yet.</p>
            <% } %>
          </div>
        </div>

        <!-- Inventory Alerts -->
        <div class="glass-card p-6 animate-slide-up delay-4 flex flex-col h-full">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-3 h-3 rounded-full bg-rose-500 shadow-[0_0_12px_rgba(244,63,94,0.5)]"></div>
            <h4 class="text-xl font-bold tracking-tight">Inventory Alerts</h4>
          </div>

          <div class="grid grid-cols-2 gap-4 flex-1">
            <!-- Out of Stock -->
            <div class="p-4 rounded-[24px] bg-rose-50/50 border border-rose-100 flex flex-col items-center text-center justify-center">
              <p class="text-[0.45rem] font-black uppercase tracking-[0.2em] text-rose-400 mb-2">Out of Stock</p>
              <h2 class="text-3xl font-bold tracking-tighter text-rose-600 mb-1">
                <%= inventoryStats.outOfStock %>
              </h2>
              <p class="text-[0.5rem] font-bold text-rose-400/80 mb-4 uppercase tracking-tighter">need restock</p>
              <a href="/admin/products" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white text-rose-600 shadow-sm transition-all text-[0.5rem] font-black uppercase tracking-widest hover:bg-rose-600 hover:text-white">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                View
              </a>
            </div>

            <!-- Low Stock -->
            <div class="p-4 rounded-[24px] bg-amber-50/50 border border-amber-100 flex flex-col items-center text-center justify-center">
              <p class="text-[0.45rem] font-black uppercase tracking-[0.2em] text-amber-500 mb-2">Low Stock</p>
              <h2 class="text-3xl font-bold tracking-tighter text-amber-600 mb-1">
                <%= inventoryStats.lowStock %>
              </h2>
              <p class="text-[0.5rem] font-bold text-amber-500/80 mb-4 uppercase tracking-tighter">running low</p>
              <a href="/admin/products" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl bg-white text-amber-600 shadow-sm transition-all text-[0.5rem] font-black uppercase tracking-widest hover:bg-amber-600 hover:text-white">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                View
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Orders & Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 pb-10 items-stretch">
        <!-- Recent Acquisitions -->
        <div class="glass-card p-6 overflow-hidden flex flex-col h-full">
          <div class="pb-6 border-b border-brand-border flex items-center justify-between mb-4">
            <h4 class="text-xl font-bold tracking-tight">Recent Acquisitions</h4>
            <a href="/admin/orders" class="text-[0.6rem] font-black uppercase tracking-widest text-brand-muted hover:text-brand-dark transition-colors underline underline-offset-4">View All Registry</a>
          </div>
          <div class="overflow-x-auto flex-1">
            <table class="w-full text-left">
              <thead>
                <tr class="bg-brand-bg/50">
                  <th class="px-6 py-4 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Order ID</th>
                  <th class="px-6 py-4 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Client</th>
                  <th class="px-6 py-4 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted text-right">Activity</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-border">
                <% if(recentOrders && recentOrders.length > 0) { %>
                  <% recentOrders.forEach(order => { %>
                    <tr class="hover:bg-brand-bg/30 transition-colors">
                      <td class="px-6 py-4 text-[0.7rem] font-bold">#ORD-<%= order._id.toString().slice(-6).toUpperCase() %></td>
                      <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-full bg-brand-bg flex items-center justify-center text-[0.6rem] font-bold">
                            <%= order.address.name.charAt(0) %>
                          </div>
                          <span class="text-[0.7rem] font-bold text-brand-dark"><%= order.address.name %></span>
                        </div>
                      </td>
                      <td class="px-6 py-4 text-right">
                        <a href="/admin/orders/<%= order._id %>" class="inline-flex items-center justify-center w-8 h-8 rounded-lg border border-brand-border hover:bg-brand-dark hover:text-white transition-all">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="3" class="px-6 py-12 text-[0.7rem] text-brand-muted italic text-center">No recent acquisitions found.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Most Popular -->
        <div class="glass-card p-6 overflow-hidden flex flex-col h-full">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-3 h-3 rounded-full bg-brand-dark shadow-[0_0_12px_rgba(28,28,28,0.3)]"></div>
            <h4 class="text-xl font-bold tracking-tight">Most Popular</h4>
          </div>
          
          <div class="flex-1 overflow-y-auto pr-2 custom-scrollbar">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-brand-border">
                  <th class="pb-3 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Product</th>
                  <th class="pb-3 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted text-center">Sold</th>
                  <th class="pb-3 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted text-right">Link</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-border/50">
                <% if(typeof popularProducts !== 'undefined' && popularProducts.length > 0) { %>
                  <% popularProducts.forEach(prod => { %>
                    <tr class="group hover:bg-brand-bg/30 transition-colors">
                      <td class="py-3">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-lg bg-brand-bg border border-brand-border overflow-hidden flex-shrink-0">
                            <img src="<%= prod.image %>" class="w-full h-full object-cover">
                          </div>
                          <span class="text-[0.7rem] font-bold text-brand-dark truncate max-w-[120px]"><%= prod.name %></span>
                        </div>
                      </td>
                      <td class="py-3 text-center text-[0.7rem] font-bold text-brand-dark"><%= prod.totalSold %></td>
                      <td class="py-3 text-right">
                        <a href="/admin/products/<%= prod._id %>" class="w-6 h-6 rounded-lg bg-brand-bg border border-brand-border hover:bg-brand-dark hover:text-white transition-all flex items-center justify-center">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="3" class="px-6 py-12 text-[0.7rem] text-brand-muted italic text-center">No popular products found.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script>
    // Sales Activity Chart (Line)
    const salesCtx = document.getElementById('salesChart').getContext('2d');
    const salesGradient = salesCtx.createLinearGradient(0, 0, 0, 400);
    salesGradient.addColorStop(0, 'rgba(28, 28, 28, 0.12)');
    salesGradient.addColorStop(1, 'rgba(28, 28, 28, 0)');

    const salesChart = new Chart(salesCtx, {
      type: 'line',
      data: {
        labels: [<% chartData.month.forEach(function(p, index) { %>'<%= p.label %>'<%= index < chartData.month.length - 1 ? ',' : '' %><% }) %>],
        datasets: [{
          label: 'Revenue',
          data: [<% chartData.month.forEach(function(p, index) { %><%= p.value %><%= index < chartData.month.length - 1 ? ',' : '' %><% }) %>],
          borderColor: '#1C1C1C',
          borderWidth: 4,
          pointBackgroundColor: '#FFFFFF',
          pointBorderColor: '#1C1C1C',
          pointBorderWidth: 3,
          pointRadius: 6,
          pointHoverRadius: 8,
          fill: true,
          backgroundColor: salesGradient,
          tension: 0.5
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1C1C1C',
            titleFont: { family: 'Outfit', size: 12 },
            bodyFont: { family: 'Outfit', size: 14, weight: 'bold' },
            padding: 12,
            cornerRadius: 12,
            displayColors: false,
            callbacks: {
              label: function(context) { return '₹' + context.parsed.y.toLocaleString(); }
            }
          }
        },
        scales: {
          y: {
            grid: { color: 'rgba(0,0,0,0.04)', drawBorder: false },
            ticks: {
              color: '#888888',
              font: { family: 'Outfit', size: 10, weight: 600 },
              callback: function(value) { 
                if (value >= 1000) return '₹' + value/1000 + 'k';
                return '₹' + value;
              }
            }
          },
          x: {
            grid: { display: false },
            ticks: {
              color: '#888888',
              font: { family: 'Outfit', size: 10, weight: 600 }
            }
          }
        }
      }
    });

    // Dynamic Period Switching
    const periodData = {
      today: { 
        labels: [<% chartData.today.forEach(function(p, index) { %>'<%= p.label %>'<%= index < chartData.today.length - 1 ? ',' : '' %><% }) %>], 
        data: [<% chartData.today.forEach(function(p, index) { %><%= p.value %><%= index < chartData.today.length - 1 ? ',' : '' %><% }) %>] 
      },
      week: { 
        labels: [<% chartData.week.forEach(function(p, index) { %>'<%= p.label %>'<%= index < chartData.week.length - 1 ? ',' : '' %><% }) %>], 
        data: [<% chartData.week.forEach(function(p, index) { %><%= p.value %><%= index < chartData.week.length - 1 ? ',' : '' %><% }) %>] 
      },
      month: { 
        labels: [<% chartData.month.forEach(function(p, index) { %>'<%= p.label %>'<%= index < chartData.month.length - 1 ? ',' : '' %><% }) %>], 
        data: [<% chartData.month.forEach(function(p, index) { %><%= p.value %><%= index < chartData.month.length - 1 ? ',' : '' %><% }) %>] 
      },
      year: { 
        labels: [<% chartData.year.forEach(function(p, index) { %>'<%= p.label %>'<%= index < chartData.year.length - 1 ? ',' : '' %><% }) %>], 
        data: [<% chartData.year.forEach(function(p, index) { %><%= p.value %><%= index < chartData.year.length - 1 ? ',' : '' %><% }) %>] 
      },
      custom: { labels: ['Nov 1', 'Nov 10', 'Nov 20', 'Nov 30'], data: [3200, 4500, 2800, 5100] }
    };

    document.getElementById('timePeriod').addEventListener('change', (e) => {
      const period = e.target.value;
      if (periodData[period]) {
        salesChart.data.labels = periodData[period].labels;
        salesChart.data.datasets[0].data = periodData[period].data;
        salesChart.update({
          duration: 800,
          easing: 'easeOutQuart'
        });
      }
    });

    // Order Status Donut Chart
    const statusCtx = document.getElementById('statusDonut').getContext('2d');
    new Chart(statusCtx, {
      type: 'doughnut',
      data: {
        labels: ['Delivered', 'Pending', 'Cancelled', 'Returned'],
        datasets: [{
          data: [
            <%= orderStatusCounts.Delivered %>,
            <%= orderStatusCounts.Pending %>,
            <%= orderStatusCounts.Cancelled %>,
            <%= orderStatusCounts.Returned %>
          ],
          backgroundColor: ['#FFFFFF', '#CBD5E0', '#718096', '#2D3748'],
          borderWidth: 0,
          hoverOffset: 10
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '85%',
        plugins: {
          legend: { display: false },
          tooltip: { enabled: false }
        }
      }
    });
  </script>
</body>
</html>
