<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Dashboard — AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Outfit:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Outfit', 'sans-serif']
        },
        colors: {
          brand: {
            dark: '#1C1C1C',
            muted: '#888888',
            border: 'rgba(0,0,0,0.06)',
            bg: '#FAFAF8'
          }
        }
      }
    }
  }
</script>

<style>
  body { 
    background: #FAFAF8; 
    color: #1C1C1C; 
    font-family: 'Outfit', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  .editorial-title { font-family: 'Playfair Display', serif; }
  
  .glass-card {
    background: #FFFFFF;
    border: 1px solid rgba(0,0,0,0.04);
    box-shadow: 0 4px 30px rgba(0,0,0,0.02);
    border-radius: 24px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .glass-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.08);
  }

  .stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1C1C1C;
    color: white;
  }

  .chart-container {
    position: relative;
    height: 350px;
    width: 100%;
  }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #E5E5E5; border-radius: 10px; }
  ::-webkit-scrollbar-thumb:hover { background: #D1D1D1; }

  @keyframes slideInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-slide-up { animation: slideInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both; }

  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }
</style>
</head>
<body class="flex min-h-screen overflow-x-hidden">

  <!-- SIDEBAR (PARTIAL) -->
  <%- include('partials/sidebar', { currentPath: '/admin/dashboard' }) %>

  <!-- MAIN CONTENT -->
  <main class="flex-1 flex flex-col min-w-0">
    
    <!-- Top Nav -->
    <header class="h-24 bg-white/80 backdrop-blur-md border-b border-brand-border flex items-center justify-between px-10 sticky top-0 z-50">
      <div class="flex items-center gap-6">
        <h1 class="editorial-title text-3xl italic tracking-tight">Executive <span class="not-italic font-bold text-brand-dark">Overview</span></h1>
      </div>
      
      <div class="flex items-center gap-8">
        <!-- Date Picker Placeholder -->
        <div class="hidden md:flex items-center gap-3 px-5 py-2.5 bg-brand-bg border border-brand-border rounded-full text-[0.7rem] font-bold uppercase tracking-widest text-brand-muted">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          Last 30 Days
        </div>

        <div class="flex items-center gap-4">
          <div class="text-right hidden sm:block">
            <p class="text-xs font-black uppercase tracking-widest">Administrator</p>
            <p class="text-[0.65rem] text-brand-muted">Control Center active</p>
          </div>
          <div class="w-12 h-12 rounded-2xl bg-brand-dark flex items-center justify-center border-4 border-white shadow-sm overflow-hidden">
            <img src="https://ui-avatars.com/api/?name=Admin&background=1c1c1c&color=fff" alt="Admin" class="w-full h-full object-cover">
          </div>
        </div>
      </div>
    </header>

    <div class="p-10 space-y-10">
      
      <!-- Quick Stats -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Revenue -->
        <div class="glass-card p-8 animate-slide-up">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            </div>
            <span class="text-[0.65rem] font-black text-emerald-500 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-tighter">+12.5%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Total Revenue</p>
          <h3 class="text-3xl font-bold tracking-tighter">₹<%= (stats && stats.totalRevenue) ? stats.totalRevenue.toLocaleString() : '1,284,500' %></h3>
        </div>

        <!-- Orders -->
        <div class="glass-card p-8 animate-slide-up delay-1">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            </div>
            <span class="text-[0.65rem] font-black text-emerald-500 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-tighter">+8.2%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Total Orders</p>
          <h3 class="text-3xl font-bold tracking-tighter"><%= (stats && stats.totalOrders) ? stats.totalOrders : '1,420' %></h3>
        </div>

        <!-- Customers -->
        <div class="glass-card p-8 animate-slide-up delay-2">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <span class="text-[0.65rem] font-black text-emerald-500 bg-emerald-50 px-3 py-1 rounded-full uppercase tracking-tighter">+4.1%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Active Users</p>
          <h3 class="text-3xl font-bold tracking-tighter"><%= (stats && stats.totalUsers) ? stats.totalUsers : '856' %></h3>
        </div>

        <!-- Conversion -->
        <div class="glass-card p-8 animate-slide-up delay-3">
          <div class="flex justify-between items-start mb-6">
            <div class="stat-icon shadow-lg shadow-black/10">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
            </div>
            <span class="text-[0.65rem] font-black text-rose-500 bg-rose-50 px-3 py-1 rounded-full uppercase tracking-tighter">-2.4%</span>
          </div>
          <p class="text-[0.65rem] font-bold text-brand-muted uppercase tracking-[0.2em] mb-1">Conversion Rate</p>
          <h3 class="text-3xl font-bold tracking-tighter">3.2%</h3>
        </div>
      </div>

      <!-- Main Visuals -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Sales Chart -->
        <div class="lg:col-span-2 glass-card p-10 animate-slide-up delay-4">
          <div class="flex items-center justify-between mb-10">
            <div>
              <h4 class="text-xl font-bold tracking-tight">Sales Analytics</h4>
              <p class="text-[0.7rem] text-brand-muted uppercase tracking-widest font-medium mt-1">Revenue Performance Overview</p>
            </div>
            <div class="flex gap-2">
              <button class="px-4 py-2 bg-brand-dark text-white text-[0.6rem] font-black uppercase tracking-widest rounded-lg">Weekly</button>
              <button class="px-4 py-2 bg-brand-bg text-brand-dark text-[0.6rem] font-black uppercase tracking-widest rounded-lg border border-brand-border">Monthly</button>
            </div>
          </div>
          <div class="chart-container">
            <canvas id="salesChart"></canvas>
          </div>
        </div>

        <!-- Top Categories -->
        <div class="glass-card p-10 animate-slide-up delay-4">
          <h4 class="text-xl font-bold tracking-tight mb-2">Category Performance</h4>
          <p class="text-[0.7rem] text-brand-muted uppercase tracking-widest font-medium mb-10">Distribution of Sales</p>
          
          <div class="space-y-8">
            <div class="relative pt-1">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-bold uppercase tracking-wider">Men's Apparel</span>
                <span class="text-xs font-bold">45%</span>
              </div>
              <div class="overflow-hidden h-1.5 text-xs flex rounded-full bg-brand-bg">
                <div style="width:45%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-brand-dark"></div>
              </div>
            </div>
            <div class="relative pt-1">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-bold uppercase tracking-wider">Women's Collection</span>
                <span class="text-xs font-bold">32%</span>
              </div>
              <div class="overflow-hidden h-1.5 text-xs flex rounded-full bg-brand-bg">
                <div style="width:32%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-brand-dark opacity-80"></div>
              </div>
            </div>
            <div class="relative pt-1">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-bold uppercase tracking-wider">Accessories</span>
                <span class="text-xs font-bold">15%</span>
              </div>
              <div class="overflow-hidden h-1.5 text-xs flex rounded-full bg-brand-bg">
                <div style="width:15%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-brand-dark opacity-60"></div>
              </div>
            </div>
            <div class="relative pt-1">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs font-bold uppercase tracking-wider">Limited Editions</span>
                <span class="text-xs font-bold">8%</span>
              </div>
              <div class="overflow-hidden h-1.5 text-xs flex rounded-full bg-brand-bg">
                <div style="width:8%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-brand-dark opacity-40"></div>
              </div>
            </div>
          </div>

          <div class="mt-12 pt-8 border-t border-brand-border">
            <h5 class="text-[0.65rem] font-black uppercase tracking-widest text-brand-muted mb-4">Top Product</h5>
            <div class="flex items-center gap-4 p-4 bg-brand-bg rounded-2xl">
              <div class="w-12 h-12 rounded-xl bg-white border border-brand-border overflow-hidden">
                <img src="https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=100&auto=format&fit=crop" class="w-full h-full object-cover">
              </div>
              <div>
                <p class="text-xs font-bold">Linen Heritage Blazer</p>
                <p class="text-[0.6rem] text-brand-muted font-bold">124 Units Sold</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recent Orders & Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-10">
        <div class="lg:col-span-2 glass-card overflow-hidden">
          <div class="p-10 border-b border-brand-border flex items-center justify-between">
            <h4 class="text-xl font-bold tracking-tight">Recent Acquisitions</h4>
            <a href="/admin/orders" class="text-[0.6rem] font-black uppercase tracking-widest text-brand-muted hover:text-brand-dark transition-colors underline underline-offset-4">View All Registry</a>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="bg-brand-bg/50">
                  <th class="px-10 py-5 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Order ID</th>
                  <th class="px-10 py-5 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Client</th>
                  <th class="px-10 py-5 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Valuation</th>
                  <th class="px-10 py-5 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Status</th>
                  <th class="px-10 py-5 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted text-right">Activity</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-border">
                <% if(recentOrders && recentOrders.length > 0) { %>
                  <% recentOrders.forEach(order => { %>
                    <tr class="hover:bg-brand-bg/30 transition-colors">
                      <td class="px-10 py-6 text-[0.7rem] font-bold">#ORD-<%= order._id.toString().slice(-6).toUpperCase() %></td>
                      <td class="px-10 py-6">
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-full bg-brand-bg flex items-center justify-center text-[0.6rem] font-bold">
                            <%= order.address.name.charAt(0) %>
                          </div>
                          <span class="text-[0.7rem] font-bold"><%= order.address.name %></span>
                        </div>
                      </td>
                      <td class="px-10 py-6 text-[0.7rem] font-bold">₹<%= order.totalAmount.toLocaleString() %></td>
                      <td class="px-10 py-6">
                        <span class="px-3 py-1 rounded-full text-[0.55rem] font-black uppercase tracking-widest bg-brand-bg border border-brand-border"><%= order.status %></span>
                      </td>
                      <td class="px-10 py-6 text-right">
                        <a href="/admin/orders/<%= order._id %>" class="inline-flex items-center justify-center w-8 h-8 rounded-lg border border-brand-border hover:bg-brand-dark hover:text-white transition-all">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <!-- Static Placeholder Rows for UI Demo -->
                  <tr class="hover:bg-brand-bg/30 transition-colors">
                    <td class="px-10 py-6 text-[0.7rem] font-bold">#ORD-942851</td>
                    <td class="px-10 py-6">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-brand-bg flex items-center justify-center text-[0.6rem] font-bold">JW</div>
                        <span class="text-[0.7rem] font-bold">Julianne White</span>
                      </div>
                    </td>
                    <td class="px-10 py-6 text-[0.7rem] font-bold">₹12,450</td>
                    <td class="px-10 py-6">
                      <span class="px-3 py-1 rounded-full text-[0.55rem] font-black uppercase tracking-widest bg-emerald-50 text-emerald-600 border border-emerald-100">Delivered</span>
                    </td>
                    <td class="px-10 py-6 text-right">
                      <button class="inline-flex items-center justify-center w-8 h-8 rounded-lg border border-brand-border hover:bg-brand-dark hover:text-white transition-all">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                      </button>
                    </td>
                  </tr>
                  <tr class="hover:bg-brand-bg/30 transition-colors">
                    <td class="px-10 py-6 text-[0.7rem] font-bold">#ORD-831924</td>
                    <td class="px-10 py-6">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-brand-bg flex items-center justify-center text-[0.6rem] font-bold">AM</div>
                        <span class="text-[0.7rem] font-bold">Arthur Morgan</span>
                      </div>
                    </td>
                    <td class="px-10 py-6 text-[0.7rem] font-bold">₹8,900</td>
                    <td class="px-10 py-6">
                      <span class="px-3 py-1 rounded-full text-[0.55rem] font-black uppercase tracking-widest bg-amber-50 text-amber-600 border border-amber-100">Shipped</span>
                    </td>
                    <td class="px-10 py-6 text-right">
                      <button class="inline-flex items-center justify-center w-8 h-8 rounded-lg border border-brand-border hover:bg-brand-dark hover:text-white transition-all">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                      </button>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="glass-card p-10 overflow-hidden flex flex-col">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-3 h-3 rounded-full bg-indigo-500 shadow-[0_0_12px_rgba(99,102,241,0.5)]"></div>
            <h4 class="text-xl font-bold tracking-tight">Most Popular Products</h4>
          </div>
          
          <div class="flex-1 overflow-y-auto pr-2 custom-scrollbar">
            <table class="w-full text-left">
              <thead>
                <tr class="border-b border-brand-border">
                  <th class="pb-4 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted">Product Name</th>
                  <th class="pb-4 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted text-center">Qty Sold</th>
                  <th class="pb-4 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted text-center">Status</th>
                  <th class="pb-4 text-[0.6rem] font-black uppercase tracking-widest text-brand-muted text-right">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-brand-border/50">
                <% if(typeof popularProducts !== 'undefined' && popularProducts.length > 0) { %>
                  <% popularProducts.forEach(prod => { %>
                    <tr class="group hover:bg-brand-bg/30 transition-colors">
                      <td class="py-4">
                        <div class="flex items-center gap-4">
                          <div class="w-12 h-12 rounded-xl bg-brand-bg border border-brand-border overflow-hidden flex-shrink-0">
                            <img src="<%= prod.image || 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?q=80&w=100' %>" class="w-full h-full object-cover">
                          </div>
                          <span class="text-[0.7rem] font-bold truncate max-w-[120px]"><%= prod.name %></span>
                        </div>
                      </td>
                      <td class="py-4 text-center text-[0.7rem] font-bold"><%= prod.totalSold %></td>
                      <td class="py-4 text-center">
                        <span class="px-3 py-1 rounded-full text-[0.55rem] font-black uppercase tracking-widest bg-emerald-50 text-emerald-600 border border-emerald-100">Popular</span>
                      </td>
                      <td class="py-4 text-right">
                        <button class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-indigo-50 text-indigo-600 hover:bg-indigo-100 transition-all text-[0.55rem] font-black uppercase tracking-widest">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                          View
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <!-- Static Placeholder Rows for UI Demo -->
                  <tr class="group hover:bg-brand-bg/30 transition-colors">
                    <td class="py-4">
                      <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl bg-brand-bg border border-brand-border overflow-hidden flex-shrink-0">
                          <img src="https://images.unsplash.com/photo-1583522676223-9a74404a20e1?q=80&w=100" class="w-full h-full object-cover">
                        </div>
                        <span class="text-[0.7rem] font-bold truncate max-w-[120px]">Super Glow Vitamin Serum</span>
                      </div>
                    </td>
                    <td class="py-4 text-center text-[0.7rem] font-bold">124</td>
                    <td class="py-4 text-center">
                      <span class="px-3 py-1 rounded-full text-[0.55rem] font-black uppercase tracking-widest bg-emerald-50 text-emerald-600 border border-emerald-100">Popular</span>
                    </td>
                    <td class="py-4 text-right">
                      <button class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-indigo-50 text-indigo-600 hover:bg-indigo-100 transition-all text-[0.55rem] font-black uppercase tracking-widest">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        View
                      </button>
                    </td>
                  </tr>
                  <tr class="group hover:bg-brand-bg/30 transition-colors">
                    <td class="py-4">
                      <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl bg-brand-bg border border-brand-border overflow-hidden flex-shrink-0">
                          <img src="https://images.unsplash.com/photo-1556228720-195a672e8a03?q=80&w=100" class="w-full h-full object-cover">
                        </div>
                        <span class="text-[0.7rem] font-bold truncate max-w-[120px]">Hydra F5 Moisturizer</span>
                      </div>
                    </td>
                    <td class="py-4 text-center text-[0.7rem] font-bold">98</td>
                    <td class="py-4 text-center">
                      <span class="px-3 py-1 rounded-full text-[0.55rem] font-black uppercase tracking-widest bg-emerald-50 text-emerald-600 border border-emerald-100">Popular</span>
                    </td>
                    <td class="py-4 text-right">
                      <button class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-indigo-50 text-indigo-600 hover:bg-indigo-100 transition-all text-[0.55rem] font-black uppercase tracking-widest">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        View
                      </button>
                    </td>
                  </tr>
                  <tr class="group hover:bg-brand-bg/30 transition-colors">
                    <td class="py-4">
                      <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-xl bg-brand-bg border border-brand-border overflow-hidden flex-shrink-0">
                          <img src="https://images.unsplash.com/photo-1620916566398-39f1143ab7be?q=80&w=100" class="w-full h-full object-cover">
                        </div>
                        <span class="text-[0.7rem] font-bold truncate max-w-[120px]">BIFF SP5 Face Wash</span>
                      </div>
                    </td>
                    <td class="py-4 text-center text-[0.7rem] font-bold">86</td>
                    <td class="py-4 text-center">
                      <span class="px-3 py-1 rounded-full text-[0.55rem] font-black uppercase tracking-widest bg-emerald-50 text-emerald-600 border border-emerald-100">Popular</span>
                    </td>
                    <td class="py-4 text-right">
                      <button class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-indigo-50 text-indigo-600 hover:bg-indigo-100 transition-all text-[0.55rem] font-black uppercase tracking-widest">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        View
                      </button>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </main>

  <script>
    // Chart.js Configuration
    const ctx = document.getElementById('salesChart').getContext('2d');
    
    // Custom gradient for the chart
    const gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(28, 28, 28, 0.08)');
    gradient.addColorStop(1, 'rgba(28, 28, 28, 0)');

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['01 May', '05 May', '10 May', '15 May', '20 May', '25 May', '30 May'],
        datasets: [{
          label: 'Revenue',
          data: [65000, 82000, 78000, 95000, 110000, 105000, 128000],
          borderColor: '#1C1C1C',
          borderWidth: 3,
          pointBackgroundColor: '#FFFFFF',
          pointBorderColor: '#1C1C1C',
          pointBorderWidth: 2,
          pointRadius: 4,
          pointHoverRadius: 6,
          fill: true,
          backgroundColor: gradient,
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            grid: { display: true, color: 'rgba(0,0,0,0.03)' },
            border: { display: false },
            ticks: {
              color: '#888888',
              font: { family: 'Outfit', size: 10, weight: 600 },
              callback: function(value) { return '₹' + value/1000 + 'k'; }
            }
          },
          x: {
            grid: { display: false },
            border: { display: false },
            ticks: {
              color: '#888888',
              font: { family: 'Outfit', size: 10, weight: 600 }
            }
          }
        },
        interaction: {
          intersect: false,
          mode: 'index',
        },
      }
    });
  </script>
</body>
</html>
