<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Variant Management — AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- TAILWIND -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Plus Jakarta Sans', 'sans-serif']
        },
        colors: {
          'luxury-bg': '#F4F2EE',
          'luxury-accent': '#C1272D',
          'luxury-text': '#1C1C1C',
          'luxury-muted': '#8E8E8E'
        }
      }
    }
  }
</script>

<style>
  body { background-color: theme('colors.luxury-bg'); color: theme('colors.luxury-text'); font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }
  
  /* Sidebar styles */
  .sidebar-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 0px; transition: all 0.2s ease; position: relative; color: theme('colors.luxury-muted'); font-size: 14px; font-weight: 500; }
  .sidebar-item:hover { color: theme('colors.luxury-text'); }
  .sidebar-item.active { background-color: #fff; color: theme('colors.luxury-text'); }
  .sidebar-item.active::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background-color: theme('colors.luxury-accent'); }

  /* Table styles */
  .table-card { background: white; border-radius: 0px; overflow: hidden; border: 1px solid #E5E7EB; }
  
  .status-pill { padding: 4px 12px; border-radius: 100px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .status-active { background: #F3F4F6; color: #1C1C1C; border: 1px solid #E5E7EB; }
  .status-inactive { background: #FEF2F2; color: #DC2626; border: 1px solid #FEE2E2; }
  
  .stock-pill { padding: 4px 10px; border-radius: 100px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.02em; display: inline-flex; align-items: center; gap: 4px; }
  .stock-in { background: #ECFDF5; color: #059669; }
  .stock-low { background: #FFF7ED; color: #EA580C; }
  .stock-out { background: #FEF2F2; color: #DC2626; }

  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 5px; height: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #D1D1D1; border-radius: 10px; }
  
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }

  /* Radio dot */
  .radio-dot { width: 14px; height: 14px; border: 1px solid #D1D5DB; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
  .radio-dot.selected { border-color: #C1272D; }
  .radio-dot.selected::after { content: ''; width: 8px; height: 8px; background-color: #C1272D; border-radius: 50%; }

  .variant-image-box { aspect-ratio: 1/1.2; width: 44px; background: #F3F2EE; overflow: hidden; flex-shrink: 0; }
</style>
</head>
<body class="flex min-h-screen">

  <!-- SIDEBAR -->
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-50 w-60 bg-white border-r border-stone-200 transition-transform lg:translate-x-0 lg:static lg:inset-0 -translate-x-full">
    <div class="h-full flex flex-col pt-8 pb-6">
      <!-- Logo -->
      <div class="px-8 mb-12">
        <h1 class="text-2xl font-serif font-bold tracking-tighter uppercase">AJAX</h1>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 px-4 space-y-1">
        <p class="text-[10px] font-bold text-stone-400 tracking-[0.2em] mb-4 px-4 uppercase">Management</p>
        
        <a href="/admin/dashboard" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          Dashboard
        </a>
        <a href="/admin/orders" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Orders
        </a>
        <a href="/admin/products" class="sidebar-item active">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
          Products
        </a>
        <a href="/admin/categories" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Categories
        </a>
        <a href="/admin/coupons" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/><path d="M12 7v5l3 3"/></svg>
          Coupons
        </a>
        <a href="/admin/offers" class="sidebar-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Offers
        </a>
        <a href="/admin/users" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Customers
        </a>
        <a href="/admin/reviews" class="sidebar-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Reviews
        </a>
      </nav>

      <!-- Profile Section -->
      <div class="px-8 mt-auto pt-6 border-t border-stone-100 flex items-center gap-3">
        <div class="w-9 h-9 rounded-full bg-stone-100 flex items-center justify-center overflow-hidden border border-stone-200">
            <img src="https://ui-avatars.com/api/?name=Oulian+Vane&background=F3F2EE&color=1C1C1C" alt="Admin" class="w-full h-full object-cover">
        </div>
        <div class="flex-1 overflow-hidden">
          <p class="text-xs font-bold truncate">oulian Vane</p>
          <p class="text-[10px] text-stone-400 truncate tracking-tight">julian@noco.com</p>
        </div>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="flex-1 min-w-0 flex flex-col p-6 lg:p-10 relative">
    
    <!-- Header -->
    <header class="flex items-center justify-between mb-2">
        <div>
            <h2 class="text-4xl font-serif font-medium leading-tight">Variant Management</h2>
            <p class="text-stone-400 text-sm mt-1">Configure and manage product SKU variations</p>
        </div>
        
        <button class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm border border-stone-200 lg:absolute lg:right-10 lg:bottom-10">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        </button>
    </header>

    <!-- PRODUCT INFO CARD -->
    <section class="mt-8 bg-white p-6 shadow-[0_4px_20px_rgba(0,0,0,0.02)] border border-stone-100 rounded-sm animate-fade-in">
        <div class="flex flex-col md:flex-row md:items-center gap-6">
            <div class="flex items-center gap-6 flex-1">
                <div class="w-20 h-24 bg-stone-100 overflow-hidden border border-stone-200">
                    <img src="<%= variants.length && variants[0].images.length ? variants[0].images[0] : '/images/no-image.png' %>" alt="Silk Evening Gown" class="w-full h-full object-cover">
                </div>
                <div>
                    <h3 class="text-2xl font-serif font-medium leading-none"> <%= product.name %></h3>
                    <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest mt-2">  <%= product.category?.name || 'Category' %> / <%= product.subcategory?.name || 'SubCategory' %></p>
                </div>
            </div>
            
            <div class="flex gap-12 text-center border-t md:border-t-0 md:border-l border-stone-100 pt-6 md:pt-0 md:pl-12">
                <div>
                    <p class="text-[10px] text-stone-400 font-bold uppercase tracking-widest mb-2">Total Variants</p>
                    <p class="text-4xl font-serif"><%= variants.length %></p>
                </div>
                <div>
                    <p class="text-[10px] text-stone-400 font-bold uppercase tracking-widest mb-2">Active</p>
                    <p class="text-4xl font-serif"><%= variants.filter(v => v.isActive).length %></p>
                </div>
            </div>
        </div>
    </section>

    <!-- ACTIONS BAR -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="relative w-full sm:w-96">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-stone-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Search SKU or attribute..." class="w-full pl-11 pr-4 py-3 bg-white border border-stone-200 text-sm focus:outline-none focus:border-stone-900 transition-all font-medium placeholder:text-stone-300">
        </div>
        
        <div class="flex items-center gap-3 w-full sm:w-auto">
            <button class="flex items-center justify-center gap-2 px-6 py-3 bg-white border border-stone-200 text-[13px] font-semibold hover:bg-stone-50 transition-all min-w-[120px]">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="2" y1="14" x2="6" y2="14"/><line x1="10" y1="8" x2="14" y2="8"/><line x1="18" y1="16" x2="22" y2="16"/></svg>
                Filter
            </button>
            <a href="/admin/products/<%= product._id %>/variants/add"
                   class="flex items-center justify-center gap-2 px-8 py-3 bg-stone-900 text-white text-[13px] font-semibold hover:bg-stone-800 transition-all shadow-md">
             Add Variant
            </a>
        </div>
    </div>

    <!-- TABLE -->
    <div class="mt-8 table-card animate-fade-in overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="text-[10px] uppercase font-bold text-stone-400 tracking-widest border-b border-stone-100">
                        <th class="px-6 py-5">Default</th>
                        <th class="px-6 py-5">Variants</th>
                        <th class="px-6 py-5">SKU</th>
                        <th class="px-6 py-5">Price</th>
                        <th class="px-6 py-5">Status</th>
                        <th class="px-6 py-5">Stock</th>
                        <th class="px-6 py-5">Stock Status</th>
                        <th class="px-6 py-5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-stone-50">
               <% if (!variants || variants.length === 0) { %>

               <tr> 
               <td colspan="8" class="text-center py-10 text-stone-400">
                No variants found for this product
                 </td>
               </tr>

           <% } else { %>

            <% variants.forEach((variant, index) => { %>

  <tr class="group hover:bg-stone-50/50 transition-colors">

      <!-- DEFAULT RADIO -->
      <td class="px-6 py-6">
          <div class="radio-dot <%= index === 0 ? 'selected' : '' %>"></div>
      </td>

      <!-- VARIANT INFO -->
      <td class="px-6 py-6 min-w-[280px]">
          <div class="flex items-center gap-4">

              <div class="variant-image-box border border-stone-200">
                  <img src="<%= variant.images[0] || '/images/no-image.png' %>" 
                       class="w-full h-full object-cover">
              </div>

              <div>
                  <div class="flex items-center gap-2">
                      <p class="text-sm font-bold text-stone-900">
                          <%= variant.color %>
                      </p>

                      <% if(index === 0){ %>
                      <span class="text-[9px] font-bold px-1.5 py-0.5 bg-stone-100 text-stone-400 border border-stone-200 rounded-sm">
                          DEFAULT
                      </span>
                      <% } %>
                  </div>

                  <p class="text-[10px] text-stone-400 font-medium mt-1">
                      <%= variant.color %> • <%= variant.size || 'N/A' %>
                  </p>
              </div>

          </div>
      </td>

      <!-- SKU -->
      <td class="px-6 py-6 text-[11px] font-bold text-stone-400 uppercase tracking-tight">
          <%= variant.sku %>
      </td>

      <!-- PRICE -->
      <td class="px-6 py-6 text-sm font-bold">
          ₹<%= variant.price %>
      </td>

      <!-- STATUS -->
      <td class="px-6 py-6">
          <span class="status-pill <%= variant.isActive ? 'status-active' : 'status-inactive' %>">
              <%= variant.isActive ? 'Active' : 'Inactive' %>
          </span>
      </td>

      <!-- STOCK -->
      <td class="px-6 py-6 text-sm font-bold">
          <%= variant.stock %>
      </td>

      <!-- STOCK STATUS -->
      <td class="px-6 py-6">
          <% if(variant.stock === 0){ %>
              <span class="stock-pill stock-out">OUT</span>
          <% } else if(variant.stock < 5){ %>
              <span class="stock-pill stock-low">LOW</span>
          <% } else { %>
              <span class="stock-pill stock-in">IN STOCK</span>
          <% } %>
      </td>

      <!-- ACTION -->
      <td class="px-6 py-6 text-right">
          <button class="p-2 text-stone-400 hover:text-stone-900 transition-colors">
              ✏️
          </button>
      </td>

  </tr>

  <% }) %>
   <% } %>
</tbody>
            </table>
        </div>

        <!-- Footer / Summary -->
        <div class="p-6 border-t border-stone-100 flex items-center justify-between gap-4">
            <p class="text-xs text-stone-400 font-medium tracking-tight">
                Showing <span class="text-stone-700 font-bold"><%= variants.length %></span> variant<%= variants.length !== 1 ? 's' : '' %> for this product
            </p>
          
    </div>
  </main>

  <script>
    // Sidebar toggle for mobile (if screen size < 1024px)
    const sidebar = document.getElementById('sidebar');
    // Implement mobile menu toggle logic here if requested
  </script>
</body>
</html>
