<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Categories — AJAX Admin</title>

<!-- FONTS -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700&family=DM+Sans:wght@200;300;400;500;600&display=swap" rel="stylesheet">

<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/utils/swal-helper.js"></script>

<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['DM Sans', 'sans-serif']
        }
      }
    }
  }
</script>

<style>
  :root {
    --admin-bg: #F8F7F4;
    --admin-sidebar: #FFFFFF;
    --admin-border: rgba(0,0,0,0.06);
    --admin-accent: #1C1C1C;
    --admin-muted: #888888;
  }

  body { background: var(--admin-bg); color: var(--admin-accent); font-family: 'DM Sans', sans-serif; min-height: 100vh; }
  
  /* Sidebar */
  .sidebar-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 0px; transition: all 0.2s ease; position: relative; color: theme('colors.luxury-muted'); font-size: 14px; font-weight: 500; }
  .sidebar-item:hover { color: theme('colors.luxury-text'); }
  .sidebar-item.active { background-color: #EBEAE4; color: theme('colors.luxury-text'); }
  .sidebar-item.active::after { content: ''; position: absolute; right: 0; top: 0; bottom: 0; width: 3px; background-color: theme('colors.luxury-accent'); }

  /* Table */
  .table-card { background: #fff; border: 1px solid var(--admin-border); border-radius: 12px; overflow: hidden; }
  .tr-row { transition: background .2s; }
  .tr-row:hover { background: #FAF9F8; }

  /* Stats */
  .stat-bubble { background: #fff; border: 1px solid var(--admin-border); border-radius: 16px; padding: 1.5rem; transition: transform .3s; }
  .stat-bubble:hover { transform: translateY(-3px); }

  /* Status Pills */
  .status-pill { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; padding: .35rem .8rem; border-radius: 20px; }
  .status-active { background: #E8F5E9; color: #2E7D32; }
  .status-inactive { background: #F5F5F5; color: #757575; }

  /* Toggle */
  .switch { position: relative; display: inline-block; width: 42px; height: 22px; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .slider { position: absolute; cursor: pointer; inset: 0; background-color: #E2E2E2; border-radius: 34px; transition: .4s; }
  .slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background-color: white; border-radius: 50%; transition: .4s; }
  input:checked + .slider { background-color: var(--admin-accent); }
  input:checked + .slider:before { transform: translateX(20px); }

  /* Animations */
  @keyframes slideUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .animate-up { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both; }

  #sidebar { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  @media(max-width:1024px) {
    #sidebar { position: fixed; left: 0; top: 0; bottom: 0; transform: translateX(-100%); z-index: 1001; width: 280px; }
    #sidebar.open { transform: translateX(0); }
  }
</style>
</head>
<body class="flex">

  <!-- ── SIDEBAR (PARTIAL) ── -->
  <%- include('partials/sidebar', { currentPath: '/admin/categories' }) %>

  <!-- ── MAIN CONTENT ── -->
  <main class="flex-1 flex flex-col min-w-0">
    
    <header class="h-20 bg-white border-b border-[var(--admin-border)] flex items-center justify-between px-8 sticky top-0 z-50">
      <div class="flex items-center gap-4">
        <button id="sidebarToggle" class="lg:hidden p-2 hover:bg-stone-100 rounded-lg">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <h1 class="text-xl font-serif font-bold">Categories</h1>
      </div>
      <button onclick="openModal()" class="bg-black text-white px-6 py-2.5 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-stone-800 transition-all shadow-lg flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Category
      </button>
    </header>

    <div class="p-8 animate-up">
      
      <!-- Stats Row -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="stat-bubble">
          <p class="text-[0.6rem] uppercase tracking-widest font-bold text-stone-400 mb-2">Total Collections</p>
          <div class="flex items-baseline gap-2">
            <h3 class="text-3xl font-serif font-bold"><%= totalCategories %></h3>
          </div>
        </div>
        <div class="stat-bubble">
          <p class="text-[0.6rem] uppercase tracking-widest font-bold text-stone-400 mb-2">Sub Groups</p>
          <h3 class="text-3xl font-serif font-bold"><%= totalSubCategories %></h3>
        </div>
        <div class="stat-bubble">
          <p class="text-[0.6rem] uppercase tracking-widest font-bold text-stone-400 mb-2">Active</p>
          <h3 class="text-3xl font-serif font-bold text-emerald-600"><%= activeCount %></h3>
        </div>
        <div class="stat-bubble">
          <p class="text-[0.6rem] uppercase tracking-widest font-bold text-stone-400 mb-2">Inactive</p>
          <h3 class="text-3xl font-serif font-bold text-stone-400"><%= inactiveCount %></h3>
        </div>
      </div>

      <!-- Content -->
      <div class="table-card">
        <div class="p-6 border-b border-[var(--admin-border)] flex flex-col md:flex-row justify-between items-center gap-4">
          <h3 class="font-serif font-bold text-lg">Category Registry</h3>
          <form method="GET" action="/admin/categories" class="relative w-full md:w-72">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-stone-400" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" name="search" value="<%= search %>" placeholder="Search catalogs..." class="w-full pl-10 pr-10 py-2.5 bg-stone-50 border border-[var(--admin-border)] rounded-lg text-sm outline-none focus:bg-white focus:border-black transition-all">
            <% if(search) { %>
              <button type="button" onclick="window.location.href='/admin/categories'" class="absolute right-3 top-1/2 -translate-y-1/2 text-stone-400 hover:text-black">✕</button>
            <% } %>
          </form>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-stone-50 border-b border-[var(--admin-border)]">
                <th class="px-8 py-4 text-[0.6rem] uppercase tracking-widest font-bold text-stone-400">Index</th>
                <th class="px-8 py-4 text-[0.6rem] uppercase tracking-widest font-bold text-stone-400">Identity</th>
                <th class="px-8 py-4 text-[0.6rem] uppercase tracking-widest font-bold text-stone-400">Sub-Tier</th>
                <th class="px-8 py-4 text-[0.6rem] uppercase tracking-widest font-bold text-stone-400">Visibility</th>
                <th class="px-8 py-4 text-[0.6rem] uppercase tracking-widest font-bold text-stone-400 text-center">Settings</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-[var(--admin-border)]">
              <% categories.forEach((cat, index) => { %>
                <tr class="tr-row">
                  <td class="px-8 py-5 text-xs text-stone-400"><%= (currentPage - 1) * 5 + index + 1 %></td>
                  <td class="px-8 py-5">
                    <p class="text-sm font-bold"><%= cat.name %></p>
                    <p class="text-[0.6rem] text-stone-400 uppercase tracking-tighter">Collection ID: <%= cat._id.toString().slice(-6) %></p>
                  </td>
                  <td class="px-8 py-5 text-xs font-medium"><%= cat.subCount %> Nodes</td>
                  <td class="px-8 py-5">
                    <span class="status-pill <%= cat.isActive ? 'status-active' : 'status-inactive' %>">
                      <%= cat.isActive ? 'VISIBLE' : 'HIDDEN' %>
                    </span>
                  </td>
                  <td class="px-8 py-5">
                    <div class="flex items-center justify-center gap-4">
                      <button  type="button"onclick="handleEdit(this)" data-id="<%= cat._id %>" data-name="<%= cat.name %>" data-status="<%= cat.isActive %>"class="p-2 hover:bg-stone-100 rounded-lg text-stone-400 hover:text-black transition-all"
>
  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
  </svg>
                      </button>
                      <button onclick="deleteCategory('<%= cat._id %>')" class="p-2 hover:bg-red-50 rounded-lg text-stone-400 hover:text-red-600 transition-all">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                      </button>
                      <label class="switch ml-2">
                        <input type="checkbox" <%= cat.isActive ? 'checked' : '' %> onchange="toggleCategory('<%= cat._id %>', this)">
                        <span class="slider"></span>
                      </label>
                    </div>
                  </td>
                </tr>
              <% }) %>
              <% if(categories.length === 0) { %>
                <tr><td colspan="5" class="py-20 text-center text-sm text-stone-400 font-medium italic">No collections match your criteria.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <div class="px-8 py-6 bg-stone-50 border-t border-[var(--admin-border)] flex flex-col sm:flex-row justify-between items-center gap-4">
          <p class="text-[0.7rem] text-stone-400 font-medium">Page <%= currentPage %> of <%= totalPages %></p>
          <div class="flex gap-1.5">
            <% if(currentPage > 1) { %>
              <a href="?page=<%= currentPage - 1 %>&search=<%= search %>" class="w-8 h-8 flex items-center justify-center border border-[var(--admin-border)] rounded hover:bg-white transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
              </a>
            <% } %>
            <% for(let i=1; i<=totalPages; i++) { %>
              <a href="?page=<%= i %>&search=<%= search %>" class="w-8 h-8 flex items-center justify-center border border-[var(--admin-border)] rounded text-[0.65rem] font-black tracking-tighter transition-all <%= i === currentPage ? 'bg-black text-white border-black' : 'hover:bg-white' %>"><%= i %></a>
            <% } %>
            <% if(currentPage < totalPages) { %>
              <a href="?page=<%= currentPage + 1 %>&search=<%= search %>" class="w-8 h-8 flex items-center justify-center border border-[var(--admin-border)] rounded hover:bg-white transition-all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- MODAL -->
  <div id="categoryModal" class="fixed inset-0 z-[2000] bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4">
    <div id="modalContent" class="bg-white w-full max-w-md rounded-2xl p-8 relative shadow-2xl scale-95 opacity-0 transition-all duration-300">
      <button onclick="closeModal()" class="absolute top-6 right-6 text-stone-400 hover:text-black transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>

      <h2 id="modalTitle" class="text-3xl font-serif font-bold mb-6">New Category</h2>
      <input type="hidden" id="categoryId">

      <div class="space-y-6">
        <div class="space-y-2">
          <label class="text-[0.6rem] uppercase tracking-widest font-bold text-stone-400">Identity Name</label>
          <input id="categoryName" class="w-full bg-stone-50 border border-stone-100 rounded-xl px-4 py-3 outline-none focus:bg-white focus:border-black transition-all font-medium" placeholder="Collection title..." maxlength="50">
        </div>

        <div class="flex items-center justify-between p-4 bg-stone-50 rounded-xl border border-stone-100">
          <div>
            <p class="text-sm font-bold">Public Visibility</p>
            <p class="text-[0.65rem] text-stone-400">Available across the storefront</p>
          </div>
          <label class="switch">
            <input type="checkbox" id="categoryStatus" checked>
            <span class="slider"></span>
          </label>
        </div>

        <div class="pt-4 flex gap-3">
          <button onclick="closeModal()" class="flex-1 px-6 py-3 border border-stone-200 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-stone-50 transition-all">Cancel</button>
          <button id="saveBtn" onclick="saveCategory()" class="flex-2 px-8 py-3 bg-black text-white rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-stone-800 transition-all shadow-md">Create Entry</button>
        </div>
      </div>
    </div>
  </div>

  <div id="sidebarOverlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[1000] hidden"></div>

  <script src="/js/admin/category.js"></script>
</body>
</html>
